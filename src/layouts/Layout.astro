---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "BUSCA - Censo y Búsqueda de Emergencia", 
  description = "Plataforma de censo de víctimas, refugios y reporte de personas desaparecidas." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    
    <!-- PWA Meta Tags -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#000000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

  </head>
  <body class="bg-canvas text-ink min-h-screen flex flex-col antialiased font-sans">
    <slot />

    <!-- Registro de Service Worker para PWA -->
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js")
            .then((reg) => {
              console.log("Service Worker registrado con éxito:", reg.scope);
            })
            .catch((err) => {
              console.error("Fallo al registrar Service Worker:", err);
            });
        });
      }
    </script>
  </body>
</html>
