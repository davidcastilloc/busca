---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import UpdateToast from "../components/UpdateToast.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
}

const { 
  title = "dondeestan.org - Censo y Búsqueda de Emergencia", 
  description = "Plataforma de censo de víctimas, refugios y reporte de personas desaparecidas.",
  ogImage = Astro.url ? new URL("/icons/icon-512.png", Astro.url).href : "https://dondeestan.org/icons/icon-512.png",
  ogUrl = Astro.url ? Astro.url.href : "https://dondeestan.org",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://api.qrserver.com" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />

    <!-- Telegram WebApp SDK -->
    <script is:inline src="https://telegram.org/js/telegram-web-app.js"></script>
    
    <!-- Leaflet y MarkerCluster (Carga única global para evitar colisiones) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script is:inline src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js" crossorigin=""></script>

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    
    <!-- PWA Meta Tags -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#000000" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="600" />}
    {ogImage && <meta property="og:image:height" content="800" />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

  </head>
  <body class="bg-canvas text-ink min-h-screen flex flex-col antialiased font-sans">
    
    <!-- Global Loader Overlay -->
    <div id="global-loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-canvas/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="animate-spin rounded-full h-12 w-12 border-4 border-ink border-t-transparent"></div>
    </div>

    <script>
      import "../scripts/form-reporte-alpine";

      document.addEventListener('astro:before-preparation', () => {
        const loader = document.getElementById('global-loader');
        if (loader) {
          loader.classList.remove('opacity-0', 'pointer-events-none');
          loader.classList.add('opacity-100');
        }
      });
      document.addEventListener('astro:page-load', () => {
        const loader = document.getElementById('global-loader');
        if (loader) {
          loader.classList.remove('opacity-100');
          loader.classList.add('opacity-0', 'pointer-events-none');
        }
      });
    </script>

    <slot />

    <!-- Toast de actualización del Service Worker -->
    <UpdateToast />

    <!-- Toast de Modo Offline -->
    <div id="offline-toast" class="fixed top-20 left-1/2 -translate-x-1/2 z-[99999] hidden animate-slide-down w-[calc(100%-2rem)] max-w-sm pointer-events-none">
      <div class="bg-amber-500 text-ink rounded-2xl px-4 py-3 shadow-2xl flex items-center gap-3 border border-amber-600/20">
        <span class="text-lg flex-shrink-0">⚠️</span>
        <div class="flex-grow min-w-0">
          <p class="font-uber-text uber-body-sm-strong leading-tight">Sin conexión a Internet</p>
          <p class="font-uber-text text-[11px] text-ink/70 leading-tight">Estás navegando en modo offline.</p>
        </div>
      </div>
    </div>

    <script>
      function checkConnection() {
        const toast = document.getElementById('offline-toast');
        if (!toast) return;
        if (navigator.onLine) {
          toast.classList.add('hidden');
        } else {
          toast.classList.remove('hidden');
        }
      }
      
      window.addEventListener('online', checkConnection);
      window.addEventListener('offline', checkConnection);
      
      document.addEventListener('astro:page-load', checkConnection);
      if (typeof navigator !== 'undefined') checkConnection();
    </script>

    <!-- Registro de Service Worker para PWA -->
    <script>
      if ("serviceWorker" in navigator && !import.meta.env.DEV) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js")
            .then((reg) => {
              console.log("Service Worker registrado con éxito:", reg.scope);
              
              // Verificar actualizaciones cada 60 segundos
              setInterval(() => {
                reg.update();
              }, 60000);
            })
            .catch((err) => {
              console.error("Fallo al registrar Service Worker:", err);
            });
        });

        // Escuchar mensajes de progreso del Background Sync
        navigator.serviceWorker.addEventListener("message", (event) => {
          const data = event.data;
          if (data?.type === "sync-complete" && data.sincronizados > 0) {
            console.log(`Background Sync: ${data.sincronizados}/${data.total} registros sincronizados`);
          }
        });
      }
    </script>

    <!-- Script de Telegram Mini App para Auto-Login -->
    <script>
      function initTelegramMiniApp() {
        const tg = (window as any).Telegram?.WebApp;
        if (!tg) return;

        // Limpiar estado y listeners para evitar fugas entre páginas de Astro
        try {
          tg.MainButton.hide();
          tg.MainButton.offClick();
          if (tg.isVersionAtLeast && tg.isVersionAtLeast('6.1')) {
            tg.BackButton.hide();
            tg.BackButton.offClick();
          }
        } catch (e) {
          console.error("Error al resetear botones de Telegram:", e);
        }

        // Avisar a Telegram que la app está lista
        tg.ready();
        
        // Expandir la aplicación
        tg.expand();

        // Aplicar theming dinámico basado en Telegram
        document.documentElement.style.setProperty('--tg-theme-bg-color', tg.backgroundColor || '#000000');
        document.documentElement.style.setProperty('--tg-theme-text-color', tg.textColor || '#ffffff');
        if (tg.isVersionAtLeast && tg.isVersionAtLeast('6.1')) {
          tg.setHeaderColor(tg.themeParams.bg_color || tg.backgroundColor || '#000000');
          tg.setBackgroundColor(tg.themeParams.secondary_bg_color || tg.backgroundColor || '#000000');
        }

        // Control del BackButton de Telegram
        if (tg.isVersionAtLeast && tg.isVersionAtLeast('6.1')) {
          if (window.location.pathname !== '/') {
            tg.BackButton.show();
            tg.BackButton.onClick(() => {
              window.history.back();
            });
          } else {
            tg.BackButton.hide();
          }
        }

        // Ruteo dinámico según start_param de Telegram
        const startParam = tg.initDataUnsafe?.start_param;
        if (startParam && !sessionStorage.getItem('tg_routed')) {
          sessionStorage.setItem('tg_routed', 'true');
          if (startParam === 'buscar' && window.location.pathname !== '/buscar') {
            window.location.href = '/buscar';
            return;
          } else if (startParam === 'reportar' && window.location.pathname !== '/reportar') {
            window.location.href = '/reportar';
            return;
          }
        }

        // Auto-login con initData
        const initData = tg.initData;
        if (initData && !sessionStorage.getItem('tg_auth_attempted')) {
          console.log("Telegram MiniApp detectada. Intentando autenticación automática...");
          sessionStorage.setItem('tg_auth_attempted', 'true');
          
          fetch('/api/auth/telegram-miniapp', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ initData })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              console.log(`Autenticado automáticamente como voluntario: ${data.nombre}`);
              window.location.reload();
            } else {
              console.warn("No se pudo autenticar automáticamente como voluntario:", data.error);
            }
          })
          .catch(err => {
            console.error("Error en login automático de Telegram:", err);
          });
        }
      }

      // Ejecutar en cada navegación de Astro
      document.addEventListener('astro:page-load', initTelegramMiniApp);
    </script>
  </body>
</html>

