---

<!-- Banner de suscripción a notificaciones Push -->
<div id="push-banner" class="hidden">
  <button
    id="push-subscribe-btn"
    class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-uber-text font-medium transition-all duration-300 bg-canvas-soft text-ink border border-canvas-soft hover:bg-surface-pressed cursor-pointer"
    title="Activar alertas de emergencia en tu dispositivo"
  >
    <span>🔔</span>
    <span id="push-text">Alertas</span>
  </button>
</div>

<script>
  const banner = document.getElementById("push-banner");
  const subscribeBtn = document.getElementById("push-subscribe-btn");
  const pushText = document.getElementById("push-text");

  const PUSH_DISMISSED_KEY = "push-banner-dismissed";
  const PUSH_SUBSCRIBED_KEY = "push-subscribed";

  async function initPushBanner() {
    if (!banner || !subscribeBtn || !pushText) return;

    // No mostrar si: no soporta Push, ya suscrito, o ya descartado
    if (!("PushManager" in window) || !("serviceWorker" in navigator)) return;
    if (localStorage.getItem(PUSH_SUBSCRIBED_KEY) === "true") {
      // Ya suscrito — mostrar estado activo
      banner.classList.remove("hidden");
      pushText.textContent = "Alertas ✓";
      subscribeBtn.classList.add("bg-green-500/10", "border-green-500/30");
      subscribeBtn.classList.remove("bg-canvas-soft", "border-canvas-soft");
      subscribeBtn.disabled = true;
      return;
    }
    if (localStorage.getItem(PUSH_DISMISSED_KEY) === "true") return;

    // Verificar permiso actual
    const permiso = Notification.permission;
    if (permiso === "denied") return; // El usuario bloqueó notificaciones
    
    // Mostrar banner
    banner.classList.remove("hidden");

    subscribeBtn.addEventListener("click", suscribirse);
  }

  async function suscribirse() {
    if (!subscribeBtn || !pushText) return;

    try {
      subscribeBtn.disabled = true;
      pushText.textContent = "Activando...";

      // 1. Pedir permiso
      const permiso = await Notification.requestPermission();
      if (permiso !== "granted") {
        pushText.textContent = "Denegado";
        localStorage.setItem(PUSH_DISMISSED_KEY, "true");
        setTimeout(() => {
          if (banner) banner.classList.add("hidden");
        }, 2000);
        return;
      }

      // 2. Obtener VAPID public key del servidor
      const vapidResp = await fetch("/api/push-vapid-key");
      if (!vapidResp.ok) throw new Error("No se pudo obtener la clave VAPID");
      const { publicKey } = await vapidResp.json();

      // 3. Suscribir al Push Manager
      const registration = await navigator.serviceWorker.ready;
      const subscription = await registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(publicKey),
      });

      // 4. Enviar suscripción al servidor
      const subJson = subscription.toJSON();
      const resp = await fetch("/api/push-subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          endpoint: subJson.endpoint,
          keys: {
            p256dh: subJson.keys?.p256dh || "",
            auth: subJson.keys?.auth || "",
          },
          rol: "voluntario",
        }),
      });

      if (!resp.ok) throw new Error("Error al guardar suscripción");

      // 5. Éxito
      localStorage.setItem(PUSH_SUBSCRIBED_KEY, "true");
      pushText.textContent = "Alertas ✓";
      subscribeBtn.classList.add("bg-green-500/10", "border-green-500/30");
      subscribeBtn.classList.remove("bg-canvas-soft", "border-canvas-soft");

      // Vibrar como confirmación
      if ("vibrate" in navigator) navigator.vibrate([100, 50, 100]);

    } catch (err) {
      console.error("Error al suscribirse a push:", err);
      pushText.textContent = "Error";
      subscribeBtn.disabled = false;
      setTimeout(() => {
        if (pushText) pushText.textContent = "Alertas";
      }, 3000);
    }
  }

  function urlBase64ToUint8Array(base64String: string): Uint8Array {
    const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
    const base64 = (base64String + padding)
      .replace(/-/g, "+")
      .replace(/_/g, "/");
    const rawData = atob(base64);
    const outputArray = new Uint8Array(rawData.length);
    for (let i = 0; i < rawData.length; i++) {
      outputArray[i] = rawData.charCodeAt(i);
    }
    return outputArray;
  }

  // Inicializar cuando el DOM esté listo
  // Ejecutar al cargar o transicionar de página
  document.addEventListener("astro:page-load", initPushBanner);
</script>
