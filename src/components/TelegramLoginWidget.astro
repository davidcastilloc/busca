---
export interface Props {
  botName: string;
  authUrl: string;
  size?: "large" | "medium" | "small";
  radius?: number;
  requestAccess?: "write";
}

const { 
  botName, 
  authUrl, 
  size = "large", 
  radius = 12, 
  requestAccess 
} = Astro.props;
---

<div class="telegram-login-wrapper flex justify-center w-full my-4">
  <script 
    is:inline
    async 
    src="https://telegram.org/js/telegram-widget.js?22"
    data-telegram-login={botName}
    data-size={size}
    data-radius={radius}
    data-auth-url={authUrl}
    data-request-access={requestAccess || ""}
  ></script>
</div>
