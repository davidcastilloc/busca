---
---

<div class="bg-canvas border border-canvas-soft p-4 rounded-xl shadow-sm">
  <label class="block font-uber-text uber-body-sm-strong text-body mb-2">📸 Foto Evidencia (Opcional)</label>
  
  <div class="flex flex-col items-center gap-3">
    <!-- Vista previa de imagen -->
    <div id="foto-preview-container" class="hidden w-32 h-32 rounded-lg border-2 border-dashed border-canvas-soft overflow-hidden relative group">
      <img id="foto-preview" class="w-full h-full object-cover" src="" alt="Vista previa" />
      <button 
        type="button" 
        id="btn-quitar-foto" 
        class="btn btn-circle bg-primary text-white w-8 h-8 min-h-0 absolute top-1 right-1 opacity-0 group-hover:opacity-100 active:opacity-100 transition-opacity"
      >
        ✕
      </button>
    </div>

    <!-- Input file -->
    <input 
      type="file" 
      id="foto-file" 
      accept="image/*" 
      capture="environment"
      class="file-input w-full min-h-[48px] bg-canvas-soft border-none font-uber-text" 
    />
    
    <!-- Hidden input con la clave de R2 o el base64 de la foto -->
    <input type="hidden" name="foto_key" id="foto_key" />
    
    <p id="upload-status" class="text-xs text-body text-center font-uber-text"></p>
  </div>
</div>

<script>
  const fileInput = document.getElementById("foto-file") as HTMLInputElement;
  const hiddenInput = document.getElementById("foto_key") as HTMLInputElement;
  const previewContainer = document.getElementById("foto-preview-container");
  const previewImg = document.getElementById("foto-preview") as HTMLImageElement;
  const removeBtn = document.getElementById("btn-quitar-foto");
  const statusText = document.getElementById("upload-status");

  // Comprimir imagen client-side para red 3G
  async function comprimirImagen(file: File, maxAncho = 1200, calidad = 0.7): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => {
        let w = img.width;
        let h = img.height;

        // Redimensionar si excede maxAncho
        if (w > maxAncho) {
          h = Math.round((h * maxAncho) / w);
          w = maxAncho;
        }

        const canvas = document.createElement("canvas");
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext("2d");
        if (!ctx) { reject(new Error("No canvas context")); return; }

        ctx.drawImage(img, 0, 0, w, h);
        canvas.toBlob(
          (blob) => {
            if (blob) resolve(blob);
            else reject(new Error("No se pudo comprimir"));
          },
          "image/jpeg",
          calidad
        );
      };
      img.onerror = () => reject(new Error("Error leyendo imagen"));
      img.src = URL.createObjectURL(file);
    });
  }

  function formatearTamaño(bytes: number): string {
    if (bytes < 1024) return bytes + " B";
    if (bytes < 1048576) return (bytes / 1024).toFixed(0) + " KB";
    return (bytes / 1048576).toFixed(1) + " MB";
  }

  if (fileInput && hiddenInput && previewContainer && previewImg && removeBtn && statusText) {
    fileInput.addEventListener("change", async () => {
      const files = fileInput.files;
      if (!files || files.length === 0) return;

      const file = files[0];
      const tamañoOriginal = file.size;

      statusText.textContent = "Comprimiendo imagen...";
      statusText.className = "text-xs text-body font-uber-text text-center";

      try {
        // Comprimir imagen
        const blobComprimido = await comprimirImagen(file);
        const tamañoFinal = blobComprimido.size;

        // Mostrar vista previa del blob comprimido
        const previewUrl = URL.createObjectURL(blobComprimido);
        previewImg.src = previewUrl;
        previewContainer.classList.remove("hidden");

        const ahorro = Math.round((1 - tamañoFinal / tamañoOriginal) * 100);
        statusText.textContent = `Comprimida: ${formatearTamaño(tamañoOriginal)} → ${formatearTamaño(tamañoFinal)} (${ahorro}% menos)`;

        // Si hay conexión, subir inmediatamente a R2
        if (navigator.onLine) {
          statusText.textContent += " | Subiendo...";

          try {
            const formData = new FormData();
            formData.append("foto", blobComprimido, "foto.jpg");

            const response = await fetch("/api/upload", {
              method: "POST",
              body: formData
            });

            if (response.ok) {
              const data = await response.json();
              hiddenInput.value = data.key;
              statusText.textContent = `✓ Subida OK (${formatearTamaño(tamañoFinal)})`;
              statusText.className = "text-xs text-body font-uber-text text-center font-medium";
            } else {
              throw new Error("Fallo al subir");
            }
          } catch (err) {
            console.error(err);
            statusText.textContent = `⚠ Sin conexión. Guardada localmente (${formatearTamaño(tamañoFinal)})`;
            statusText.className = "text-xs text-body font-uber-text text-center";
            guardarBase64Comprimido(blobComprimido);
          }
        } else {
          statusText.textContent = `⚠ Offline. Encolada (${formatearTamaño(tamañoFinal)})`;
          statusText.className = "text-xs text-body font-uber-text text-center";
          guardarBase64Comprimido(blobComprimido);
        }
      } catch (err) {
        console.error("Error comprimiendo:", err);
        // Fallback: usar archivo original
        statusText.textContent = "Usando imagen original (sin comprimir)";

        const reader = new FileReader();
        reader.onload = (e) => {
          if (e.target?.result) {
            previewImg.src = e.target.result as string;
            previewContainer.classList.remove("hidden");
          }
        };
        reader.readAsDataURL(file);

        if (navigator.onLine) {
          try {
            const formData = new FormData();
            formData.append("foto", file);
            const response = await fetch("/api/upload", { method: "POST", body: formData });
            if (response.ok) {
              const data = await response.json();
              hiddenInput.value = data.key;
              statusText.textContent = "✓ Subida OK (original)";
            }
          } catch (e) {
            guardarBase64(file);
          }
        } else {
          guardarBase64(file);
        }
      }
    });

    removeBtn.addEventListener("click", () => {
      fileInput.value = "";
      hiddenInput.value = "";
      previewImg.src = "";
      previewContainer.classList.add("hidden");
      statusText.textContent = "";
    });

    function guardarBase64Comprimido(blob: Blob) {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (e.target?.result) {
          hiddenInput.value = e.target.result as string;
        }
      };
      reader.readAsDataURL(blob);
    }

    function guardarBase64(file: File) {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (e.target?.result) {
          hiddenInput.value = e.target.result as string;
        }
      };
      reader.readAsDataURL(file);
    }
  }
</script>
