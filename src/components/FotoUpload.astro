---
---

<div class="bg-canvas border border-canvas-soft rounded-xl shadow-sm overflow-hidden">
  <div class="px-4 pt-4 pb-2">
    <label class="block font-uber-text uber-body-sm-strong text-body mb-3">📸 Foto</label>

    <!-- Vista previa GRANDE (mobile-first) -->
    <div id="foto-preview-container" class="hidden mb-3">
      <div class="relative rounded-xl overflow-hidden bg-canvas-soft aspect-video w-full shadow-inner">
        <img id="foto-preview" class="w-full h-full object-cover" src="" alt="Vista previa" />
        <!-- Botón quitar -->
        <button
          type="button"
          id="btn-quitar-foto"
          class="absolute top-2 right-2 w-9 h-9 rounded-full bg-black/60 text-white flex items-center justify-center text-lg leading-none backdrop-blur-sm hover:bg-black/80 active:scale-95 transition-all"
          aria-label="Quitar foto"
        >
          ✕
        </button>
      </div>
      <!-- Estado de compresión -->
      <p id="upload-status" class="text-xs text-body text-center font-uber-text mt-2"></p>
    </div>

    <!-- Zona de selección: dos botones grandes cuando NO hay foto -->
    <div id="foto-selector" class="grid grid-cols-2 gap-2">
      <!-- Botón Cámara -->
      <label
        id="btn-camara-label"
        for="foto-file-camara"
        class="flex flex-col items-center justify-center gap-2 h-24 rounded-xl border-2 border-dashed border-canvas-soft bg-canvas-soft hover:border-primary/50 hover:bg-primary/5 active:scale-95 cursor-pointer transition-all select-none"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="text-xs font-uber-text font-bold text-ink">Cámara</span>
        <!-- accept sin capture → deja elegir al sistema en desktop; capture fuerza cámara en móvil -->
        <input type="file" id="foto-file-camara" accept="image/*" capture="environment" class="sr-only" />
      </label>

      <!-- Botón Galería -->
      <label
        id="btn-galeria-label"
        for="foto-file-galeria"
        class="flex flex-col items-center justify-center gap-2 h-24 rounded-xl border-2 border-dashed border-canvas-soft bg-canvas-soft hover:border-primary/50 hover:bg-primary/5 active:scale-95 cursor-pointer transition-all select-none"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-xs font-uber-text font-bold text-ink">Galería</span>
        <!-- Sin capture → siempre abre el selector de archivos/galería -->
        <input type="file" id="foto-file-galeria" accept="image/*" class="sr-only" />
      </label>
    </div>

    <!-- Input oculto estándar (fallback, referenciado por el script del form) -->
    <input type="file" id="foto-file" accept="image/*" class="sr-only" aria-hidden="true" tabindex="-1" />
  </div>

  <!-- Hidden input con la key de R2 (lo lee el formulario padre) -->
  <input type="hidden" name="foto_key" id="foto_key" />
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const inputCamara  = document.getElementById("foto-file-camara")  as HTMLInputElement;
    const inputGaleria = document.getElementById("foto-file-galeria") as HTMLInputElement;
    const fileInput    = document.getElementById("foto-file")          as HTMLInputElement; // compat
    const hiddenInput  = document.getElementById("foto_key")           as HTMLInputElement;
    const previewContainer = document.getElementById("foto-preview-container");
    const fotoSelector     = document.getElementById("foto-selector");
    const previewImg   = document.getElementById("foto-preview")       as HTMLImageElement;
    const removeBtn    = document.getElementById("btn-quitar-foto");
    const statusText   = document.getElementById("upload-status");

    if (!hiddenInput) return;

    function updateKey(val: string) {
      hiddenInput.value = val;
      hiddenInput.dispatchEvent(new Event("input", { bubbles: true }));
    }

    // Compresión adaptativa: objetivo <400KB
    async function comprimirImagen(
      file: File,
      maxAncho = 1200,
      calidadInicial = 0.75,
      maxBytes = 400 * 1024
    ): Promise<Blob> {
      const intentar = (ancho: number, calidad: number): Promise<Blob> =>
        new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => {
            let w = img.width;
            let h = img.height;
            if (w > ancho) { h = Math.round((h * ancho) / w); w = ancho; }
            const canvas = document.createElement("canvas");
            canvas.width = w; canvas.height = h;
            const ctx = canvas.getContext("2d");
            if (!ctx) { reject(new Error("No canvas context")); return; }
            ctx.drawImage(img, 0, 0, w, h);
            canvas.toBlob(
              (blob) => { blob ? resolve(blob) : reject(new Error("No blob")); },
              "image/jpeg", calidad
            );
          };
          img.onerror = () => reject(new Error("Error leyendo imagen"));
          img.src = URL.createObjectURL(file);
        });

      let blob = await intentar(maxAncho, calidadInicial);
      if (blob.size > maxBytes) blob = await intentar(maxAncho, 0.55);
      if (blob.size > maxBytes) blob = await intentar(800, 0.5);
      return blob;
    }

    function fmt(bytes: number): string {
      if (bytes < 1024) return bytes + " B";
      if (bytes < 1048576) return (bytes / 1024).toFixed(0) + " KB";
      return (bytes / 1048576).toFixed(1) + " MB";
    }

    async function procesarArchivo(file: File) {
      if (!statusText || !previewContainer || !previewImg || !fotoSelector) return;

      statusText.textContent = "Comprimiendo...";
      previewContainer.classList.remove("hidden");
      fotoSelector.classList.add("hidden");

      try {
        const orig = file.size;
        const blob = await comprimirImagen(file);
        const fin  = blob.size;

        // Vista previa
        previewImg.src = URL.createObjectURL(blob);

        const ahorro = Math.round((1 - fin / orig) * 100);
        statusText.textContent = `${fmt(orig)} → ${fmt(fin)} (${ahorro}% menos) | Subiendo...`;
        statusText.className = "text-xs text-body text-center font-uber-text mt-2";

        if (navigator.onLine) {
          const fd = new FormData();
          fd.append("foto", blob, "foto.jpg");
          try {
            const res = await fetch("/api/upload", { method: "POST", body: fd });
            if (res.ok) {
              const data = await res.json();
              updateKey(data.key);
              statusText.textContent = `✓ Lista (${fmt(fin)})`;
              statusText.className = "text-xs text-green-600 text-center font-uber-text font-bold mt-2";
            } else { throw new Error("Fallo upload"); }
          } catch {
            statusText.textContent = `⚠ Sin conexión — guardada local`;
            guardarBase64(blob);
          }
        } else {
          statusText.textContent = "⚠ Offline — encolada";
          guardarBase64(blob);
        }
      } catch (err) {
        console.error("Error comprimiendo:", err);
        // Fallback sin comprimir
        const fd = new FormData();
        fd.append("foto", file);
        previewImg.src = URL.createObjectURL(file);
        if (navigator.onLine) {
          try {
            const res = await fetch("/api/upload", { method: "POST", body: fd });
            if (res.ok) {
              const data = await res.json();
              updateKey(data.key);
              if (statusText) { statusText.textContent = "✓ Lista (sin comprimir)"; }
            }
          } catch { guardarBase64(file); }
        } else { guardarBase64(file); }
      }
    }

    function guardarBase64(blob: Blob | File) {
      const reader = new FileReader();
      reader.onload = (e) => { if (e.target?.result) updateKey(e.target.result as string); };
      reader.readAsDataURL(blob);
    }

    // Escuchar ambos inputs de archivo
    [inputCamara, inputGaleria].forEach(input => {
      if (!input) return;
      const newInput = input.cloneNode(true) as HTMLInputElement;
      input.parentNode?.replaceChild(newInput, input);
      newInput.addEventListener("change", () => {
        const files = newInput.files;
        if (!files || files.length === 0) return;
        // Sincronizar con el input genérico (compat con validaciones del formulario padre)
        const dt = new DataTransfer();
        dt.items.add(files[0]);
        if (fileInput) fileInput.files = dt.files;
        procesarArchivo(files[0]);
      });
    });

    // Botón quitar foto
    if (removeBtn) {
      const newRemoveBtn = removeBtn.cloneNode(true);
      removeBtn.parentNode?.replaceChild(newRemoveBtn, removeBtn);
      newRemoveBtn.addEventListener("click", () => {
        updateKey("");
        previewImg.src = "";
        const ic = document.getElementById("foto-file-camara") as HTMLInputElement;
        const ig = document.getElementById("foto-file-galeria") as HTMLInputElement;
        if (ic) ic.value = "";
        if (ig) ig.value = "";
        if (fileInput) fileInput.value = "";
        previewContainer?.classList.add("hidden");
        fotoSelector?.classList.remove("hidden");
        if (statusText) statusText.textContent = "";
      });
    }
  });
</script>
