---
---

<div class="card bg-base-100 border border-neutral-content p-4 shadow-sm">
  <label class="label font-bold text-sm text-base-content/80 mb-2">📸 Foto Evidencia (Opcional)</label>
  
  <div class="flex flex-col items-center gap-3">
    <!-- Vista previa de imagen -->
    <div id="foto-preview-container" class="hidden w-32 h-32 rounded-lg border-2 border-dashed border-base-300 overflow-hidden relative group">
      <img id="foto-preview" class="w-full h-full object-cover" src="" alt="Vista previa" />
      <button 
        type="button" 
        id="btn-quitar-foto" 
        class="btn btn-circle btn-error btn-xs absolute top-1 right-1 opacity-0 group-hover:opacity-100 transition-opacity"
      >
        ✕
      </button>
    </div>

    <!-- Input file -->
    <input 
      type="file" 
      id="foto-file" 
      accept="image/*" 
      class="file-input file-input-bordered file-input-error file-input-sm w-full" 
    />
    
    <!-- Hidden input con la clave de R2 o el base64 de la foto -->
    <input type="hidden" name="foto_key" id="foto_key" />
    
    <p id="upload-status" class="text-xs text-base-content/60 text-center"></p>
  </div>
</div>

<script>
  const fileInput = document.getElementById("foto-file") as HTMLInputElement;
  const hiddenInput = document.getElementById("foto_key") as HTMLInputElement;
  const previewContainer = document.getElementById("foto-preview-container");
  const previewImg = document.getElementById("foto-preview") as HTMLImageElement;
  const removeBtn = document.getElementById("btn-quitar-foto");
  const statusText = document.getElementById("upload-status");

  if (fileInput && hiddenInput && previewContainer && previewImg && removeBtn && statusText) {
    fileInput.addEventListener("change", async () => {
      const files = fileInput.files;
      if (!files || files.length === 0) return;

      const file = files[0];
      
      // Mostrar vista previa local
      const reader = new FileReader();
      reader.onload = (e) => {
        if (e.target?.result) {
          previewImg.src = e.target.result as string;
          previewContainer.classList.remove("hidden");
        }
      };
      reader.readAsDataURL(file);

      // Si hay conexión, subir inmediatamente a R2
      if (navigator.onLine) {
        statusText.textContent = "Subiendo imagen al servidor...";
        statusText.className = "text-xs text-info font-medium";

        try {
          const formData = new FormData();
          formData.append("foto", file);

          const response = await fetch("/api/upload", {
            method: "POST",
            body: formData
          });

          if (response.ok) {
            const data = await response.json();
            hiddenInput.value = data.key;
            statusText.textContent = "Imagen subida exitosamente.";
            statusText.className = "text-xs text-success font-medium";
          } else {
            throw new Error("Fallo al subir archivo");
          }
        } catch (err) {
          console.error(err);
          statusText.textContent = "Error al subir imagen. Se guardará localmente.";
          statusText.className = "text-xs text-warning font-medium";
          
          // Fallback offline: Guardar base64 en hidden input
          guardarBase64(file);
        }
      } else {
        // Guardar base64 directamente para cola offline
        statusText.textContent = "Sin conexión. Imagen encolada localmente.";
        statusText.className = "text-xs text-warning font-medium";
        guardarBase64(file);
      }
    });

    removeBtn.addEventListener("click", () => {
      fileInput.value = "";
      hiddenInput.value = "";
      previewImg.src = "";
      previewContainer.classList.add("hidden");
      statusText.textContent = "";
    });

    // Helper para convertir archivo a base64
    function guardarBase64(file: File) {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (e.target?.result) {
          hiddenInput.value = e.target.result as string; // Contiene "data:image/jpeg;base64,..."
        }
      };
      reader.readAsDataURL(file);
    }
  }
</script>
