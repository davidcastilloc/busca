---
import MapaUbicacion from "./MapaUbicacion.astro";
import FotoUpload from "./FotoUpload.astro";
---

<div class="max-w-2xl mx-auto px-4 py-4 sm:py-6">
  <form id="form-persona" class="space-y-8">
    <!-- Bloque 1: Datos Identificación -->
    <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
      <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">1. Identificación de la Persona</legend>
      
      <div class="grid grid-cols-1 gap-4">
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Cédula / Documento</label>
          <input type="text" name="cedula" class="input w-full font-uber-text uber-body-md" placeholder="Opcional (ej. V-1234567)" />
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Nombres *</label>
          <input type="text" name="nombre" required class="input w-full font-uber-text uber-body-md" placeholder="Nombres completos" />
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Apellidos</label>
          <input type="text" name="apellido" class="input w-full font-uber-text uber-body-md" placeholder="Apellidos completos" />
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Edad</label>
          <input type="number" name="edad" min="0" max="120" class="input w-full font-uber-text uber-body-md" placeholder="Años" />
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Sexo *</label>
          <select name="sexo" class="select w-full font-uber-text uber-body-md">
            <option value="X">No especifica / Otro</option>
            <option value="M">Masculino</option>
            <option value="F">Femenino</option>
          </select>
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Estado Actual *</label>
          <select name="estado" class="select w-full font-uber-text uber-body-md-strong">
            <option value="vivo">Vivo / A salvo</option>
            <option value="herido">Herido</option>
            <option value="fallecido">Fallecido</option>
            <option value="desconocido">Desconocido</option>
          </select>
        </div>
      </div>
    </fieldset>

    <!-- Bloque 2: Ubicación -->
    <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
      <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">2. Ubicación y Contacto</legend>
      
      <div class="space-y-4">
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Lugar / Sector del Censo</label>
          <input type="text" name="ubicacion_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Nombre de calle, sector, plaza o punto de referencia" />
        </div>
        
        <MapaUbicacion />
        
        <div class="grid grid-cols-1 gap-4">
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Refugio / Albergue</label>
            <input type="text" name="refugio" class="input w-full font-uber-text uber-body-md" placeholder="Nombre del refugio actual (si aplica)" />
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Contacto de la Persona</label>
            <input type="text" name="contacto" class="input w-full font-uber-text uber-body-md" placeholder="Teléfono o contacto cercano" />
          </div>
        </div>
      </div>
    </fieldset>

    <!-- Bloque 3: Evidencia y Detalles -->
    <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
      <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">3. Detalles y Evidencia</legend>
      
      <div class="space-y-4">
        <FotoUpload />
        
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Notas adicionales / Observaciones</label>
          <textarea name="notas" class="textarea w-full h-24 font-uber-text uber-body-md" placeholder="Cualquier información relevante: estado médico, vestimenta, necesidades..."></textarea>
        </div>
      </div>
    </fieldset>

    <!-- Notificación emergente (Toast estilo ex-toast de Uber) -->
    <div id="toast-container" class="toast-mobile hidden">
      <div id="toast-message" class="bg-canvas border border-canvas-soft text-ink rounded-xl p-4 shadow-md font-uber-text uber-body-sm flex items-center gap-2">
        <span>Guardando...</span>
      </div>
    </div>

    <button type="submit" class="btn bg-primary text-white hover:bg-black-elevated w-full font-uber-text uber-button-large py-4">
      Registrar en censo
    </button>
  </form>
</div>

<script>
  import { encolarRegistro } from "../lib/offline-queue";

  const form = document.getElementById("form-persona") as HTMLFormElement;
  const toastContainer = document.getElementById("toast-container");
  const toastMessage = document.getElementById("toast-message");

  if (form && toastContainer && toastMessage) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      // Parsear tipos
      const payload = {
        cedula: data.cedula ? String(data.cedula).trim() : null,
        nombre: String(data.nombre).trim(),
        apellido: data.apellido ? String(data.apellido).trim() : null,
        edad: data.edad ? parseInt(String(data.edad), 10) : null,
        sexo: data.sexo || "X",
        estado: data.estado || "desconocido",
        ubicacion_nombre: data.ubicacion_nombre ? String(data.ubicacion_nombre).trim() : null,
        latitud: data.latitud ? parseFloat(String(data.latitud)) : null,
        longitud: data.longitud ? parseFloat(String(data.longitud)) : null,
        refugio: data.refugio ? String(data.refugio).trim() : null,
        contacto: data.contacto ? String(data.contacto).trim() : null,
        notas: data.notas ? String(data.notas).trim() : null,
        foto_key: data.foto_key ? String(data.foto_key).trim() : null,
        fuente: "web"
      };

      mostrarToast("Procesando registro...", "border-blue-500/30");

      if (navigator.onLine) {
        try {
          const response = await fetch("/api/personas", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          if (response.ok) {
            mostrarToast("✓ Registro enviado con éxito.", "border-green-500/30");
            form.reset();
            document.getElementById("btn-quitar-foto")?.click();
          } else {
            const errData = await response.json();
            throw new Error(errData.error || "Error de validación del servidor");
          }
        } catch (err: any) {
          console.error(err);
          await guardarOffline(payload);
        }
      } else {
        await guardarOffline(payload);
      }
    });

    async function guardarOffline(payload: any) {
      try {
        await encolarRegistro("persona", payload);
        mostrarToast("⚠️ Guardado localmente sin red. Se sincronizará automáticamente.", "border-yellow-500/30");
        form.reset();
        document.getElementById("btn-quitar-foto")?.click();

        // Disparar evento personalizado
        const event = new CustomEvent("offline-record-added");
        window.dispatchEvent(event);
      } catch (e: any) {
        mostrarToast("❌ Error al guardar localmente: " + e.message, "border-red-500/30");
      }
    }

    function mostrarToast(text: string, borderClass: string) {
      if (!toastContainer || !toastMessage) return;
      
      toastMessage.className = `bg-canvas border ${borderClass} text-ink rounded-xl p-4 shadow-md font-uber-text uber-body-sm flex items-center gap-2`;
      toastMessage.innerHTML = `<span>${text}</span>`;
      toastContainer.classList.remove("hidden");

      setTimeout(() => {
        toastContainer.classList.add("hidden");
      }, 5000);
    }
  }
</script>
