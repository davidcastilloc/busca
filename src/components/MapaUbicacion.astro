---
---

<div class="card bg-base-100 border border-neutral-content p-4 shadow-sm">
  <label class="label font-bold text-sm text-base-content/80 mb-2">📍 Coordenadas Geográficas (GPS)</label>
  
  <div class="flex gap-2 mb-2">
    <div class="flex-1">
      <input 
        type="number" 
        step="any" 
        name="latitud" 
        id="latitud" 
        class="input input-bordered w-full input-sm" 
        placeholder="Latitud (ej. 10.4806)" 
      />
    </div>
    <div class="flex-1">
      <input 
        type="number" 
        step="any" 
        name="longitud" 
        id="longitud" 
        class="input input-bordered w-full input-sm" 
        placeholder="Longitud (ej. -66.9036)" 
      />
    </div>
    
    <button 
      type="button" 
      id="btn-obtener-gps" 
      class="btn btn-secondary btn-sm btn-square" 
      title="Obtener ubicación GPS"
    >
      🎯
    </button>
  </div>
  
  <p id="gps-status" class="text-xs text-base-content/60 italic"></p>
</div>

<script>
  const btn = document.getElementById("btn-obtener-gps");
  const latInput = document.getElementById("latitud") as HTMLInputElement;
  const lonInput = document.getElementById("longitud") as HTMLInputElement;
  const statusText = document.getElementById("gps-status");

  if (btn && latInput && lonInput && statusText) {
    btn.addEventListener("click", () => {
      if (!("geolocation" in navigator)) {
        statusText.textContent = "Geolocalización no soportada por el navegador.";
        return;
      }

      statusText.textContent = "Obteniendo coordenadas GPS precisas...";
      btn.classList.add("loading");

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lon = position.coords.longitude;
          const accuracy = position.coords.accuracy;

          latInput.value = lat.toFixed(6);
          lonInput.value = lon.toFixed(6);

          statusText.textContent = `Ubicación obtenida. Precisión: ±${Math.round(accuracy)} metros.`;
          btn.classList.remove("loading");
        },
        (error) => {
          btn.classList.remove("loading");
          switch (error.code) {
            case 1:
              statusText.textContent = "Permiso GPS denegado. Ingrese coordenadas manualmente.";
              break;
            case 2:
              statusText.textContent = "La ubicación no está disponible actualmente.";
              break;
            case 3:
              statusText.textContent = "Tiempo de espera agotado al obtener el GPS.";
              break;
            default:
              statusText.textContent = "Error al obtener GPS: " + error.message;
          }
        },
        {
          enableHighAccuracy: true,
          timeout: 10000,
          maximumAge: 0
        }
      );
    });
  }
</script>
