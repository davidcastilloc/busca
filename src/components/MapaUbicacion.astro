---
---

<div class="bg-canvas-soft border border-canvas-soft p-4 rounded-xl space-y-3">
  <label class="block font-uber-text uber-body-sm-strong text-body">📍 Coordenadas Geográficas (GPS)</label>
  
  <div class="flex gap-2">
    <div class="flex-1">
      <input 
        type="number" 
        step="any" 
        name="latitud" 
        id="latitud" 
        class="input w-full font-uber-text text-sm" 
        placeholder="Latitud (ej. 10.4806)" 
      />
    </div>
    <div class="flex-1">
      <input 
        type="number" 
        step="any" 
        name="longitud" 
        id="longitud" 
        class="input w-full font-uber-text text-sm" 
        placeholder="Longitud (ej. -66.9036)" 
      />
    </div>
    
    <button 
      type="button" 
      id="btn-obtener-gps" 
      class="btn bg-primary text-white px-3 font-uber-text text-sm cursor-pointer flex-shrink-0"
      title="Obtener ubicación GPS"
    >
      🎯 GPS
    </button>
  </div>
  
  <p id="gps-status" class="text-xs text-mute font-uber-text italic"></p>

  <!-- Mini-mapa preview con Leaflet -->
  <div id="gps-preview-map" class="w-full h-40 rounded-xl overflow-hidden border border-canvas-soft bg-canvas hidden"></div>
</div>

<!-- Leaflet CSS + JS (solo si no están cargados) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline>
  (function() {
    const btn = document.getElementById("btn-obtener-gps");
    const latInput = document.getElementById("latitud");
    const lonInput = document.getElementById("longitud");
    const statusText = document.getElementById("gps-status");
    const mapContainer = document.getElementById("gps-preview-map");

    if (!btn || !latInput || !lonInput || !statusText) return;

    let miniMap = null;
    let marker = null;

    function initMiniMap(lat, lon) {
      if (typeof L === "undefined" || !mapContainer) return;

      mapContainer.classList.remove("hidden");

      if (!miniMap) {
        miniMap = L.map("gps-preview-map", {
          zoomControl: false,
          attributionControl: false,
          dragging: true,
          scrollWheelZoom: false,
        }).setView([lat, lon], 15);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
        }).addTo(miniMap);

        // Permitir mover el marcador para ajustar posición
        miniMap.on("click", function(e) {
          var latlng = e.latlng;
          latInput.value = latlng.lat.toFixed(6);
          lonInput.value = latlng.lng.toFixed(6);
          actualizarMarcador(latlng.lat, latlng.lng);
          statusText.textContent = "Ubicación ajustada manualmente en el mapa.";
          statusText.className = "text-xs text-blue-600 font-uber-text italic font-medium";
        });
      }

      actualizarMarcador(lat, lon);
      miniMap.setView([lat, lon], 15);

      // Fix: invalidar tamaño tras hacerse visible
      setTimeout(function() {
        if (miniMap) miniMap.invalidateSize();
      }, 100);
    }

    function actualizarMarcador(lat, lon) {
      if (!miniMap) return;
      if (marker) {
        marker.setLatLng([lat, lon]);
      } else {
        marker = L.marker([lat, lon]).addTo(miniMap);
      }
    }

    btn.addEventListener("click", function() {
      if (!("geolocation" in navigator)) {
        statusText.textContent = "Geolocalización no soportada por el navegador.";
        return;
      }

      statusText.textContent = "Obteniendo coordenadas GPS precisas...";
      statusText.className = "text-xs text-yellow-600 font-uber-text italic font-medium";
      btn.classList.add("opacity-50");
      btn.disabled = true;

      navigator.geolocation.getCurrentPosition(
        function(position) {
          var lat = position.coords.latitude;
          var lon = position.coords.longitude;
          var accuracy = position.coords.accuracy;

          latInput.value = lat.toFixed(6);
          lonInput.value = lon.toFixed(6);

          statusText.textContent = "Ubicación obtenida. Precisión: ±" + Math.round(accuracy) + " metros.";
          statusText.className = "text-xs text-success font-uber-text italic font-semibold";
          btn.classList.remove("opacity-50");
          btn.disabled = false;

          // Mostrar mini-mapa con la ubicación
          initMiniMap(lat, lon);
        },
        function(error) {
          btn.classList.remove("opacity-50");
          btn.disabled = false;
          var msg = "Error al obtener GPS";
          if (error.code === 1) msg = "Permiso GPS denegado. Ingrese coordenadas manualmente.";
          else if (error.code === 2) msg = "La ubicación no está disponible actualmente.";
          else if (error.code === 3) msg = "Tiempo de espera agotado al obtener el GPS.";
          statusText.textContent = msg;
          statusText.className = "text-xs text-red-500 font-uber-text italic";
        },
        {
          enableHighAccuracy: true,
          timeout: 10000,
          maximumAge: 0
        }
      );
    });

    // Si ya hay coordenadas pre-llenadas, mostrar mapa
    function checkExistingCoords() {
      var lat = parseFloat(latInput.value);
      var lon = parseFloat(lonInput.value);
      if (!isNaN(lat) && !isNaN(lon) && lat !== 0 && lon !== 0) {
        initMiniMap(lat, lon);
      }
    }

    // Actualizar mapa cuando el usuario escribe coordenadas manualmente
    latInput.addEventListener("change", checkExistingCoords);
    lonInput.addEventListener("change", checkExistingCoords);
  })();
</script>
