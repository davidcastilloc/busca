---
---

<div class="bg-canvas-soft border border-canvas-soft p-4 rounded-xl space-y-4 font-uber-text">
  <!-- Buscador de dirección y GPS -->
  <div class="relative space-y-2">
    <label class="block font-uber-text uber-body-sm-strong text-body">📍 Buscar y Ubicar en el Mapa</label>
    <div class="flex gap-2 items-center">
      <div class="relative flex-grow">
        <input 
          type="text" 
          id="map-search-input" 
          class="input w-full pr-10 text-sm font-uber-text bg-canvas border border-canvas-soft rounded-lg focus:border-primary focus:outline-none h-11" 
          placeholder="Buscar sector, calle o punto de referencia..." 
          autocomplete="off"
        />
        <div id="map-search-spinner" class="absolute right-3 top-1/2 -translate-y-1/2 hidden">
          <span class="loading loading-spinner loading-xs text-primary"></span>
        </div>
      </div>
      <button 
        type="button" 
        id="btn-map-search" 
        class="w-11 h-11 flex items-center justify-center bg-primary hover:bg-black-elevated text-white rounded-lg shrink-0 transition-all cursor-pointer active:scale-95 border border-transparent shadow-sm"
        title="Buscar dirección"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.602 10.602z" />
        </svg>
      </button>
      <button 
        type="button" 
        id="btn-obtener-gps" 
        class="w-11 h-11 flex items-center justify-center bg-canvas border border-canvas-soft text-red-500 hover:bg-canvas-soft rounded-lg shrink-0 transition-all cursor-pointer active:scale-95 shadow-sm"
        title="Usar mi ubicación GPS actual"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
      </button>
    </div>
    
    <!-- Sugerencias de búsqueda -->
    <div 
      id="map-search-suggestions" 
      class="hidden absolute left-0 right-0 z-[1001] mt-1 max-h-60 overflow-y-auto bg-canvas border border-canvas-soft rounded-lg shadow-lg divide-y divide-canvas-soft"
    ></div>
  </div>

  <!-- Vista del mapa -->
  <div class="relative">
    <div 
      id="gps-preview-map" 
      class="w-full h-64 sm:h-72 rounded-xl overflow-hidden border border-canvas-soft bg-canvas"
    ></div>
    <!-- Tip overlay -->
    <div class="absolute bottom-2 left-2 z-[1000] bg-black/75 text-white text-[10px] px-2.5 py-1 rounded-full pointer-events-none font-medium">
      📍 Haz clic en el mapa o arrastra el pin para ajustar
    </div>
  </div>

  <p id="gps-status" class="text-xs text-mute font-uber-text italic"></p>

  <!-- Coordenadas colapsables para usuarios avanzados -->
  <details class="group border border-canvas-soft rounded-lg bg-canvas/30">
    <summary class="flex justify-between items-center p-3 cursor-pointer select-none font-uber-text text-xs text-body font-semibold">
      <span>Coordenadas Geográficas (Opcional)</span>
      <span class="transition-transform group-open:rotate-180 text-[10px]">▼</span>
    </summary>
    <div class="p-3 border-t border-canvas-soft grid grid-cols-2 gap-2 bg-canvas/50">
      <div>
        <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text">Latitud</label>
        <input 
          type="number" 
          step="any" 
          name="latitud" 
          id="latitud" 
          class="input w-full font-uber-text text-xs bg-canvas border border-canvas-soft p-2 rounded" 
          placeholder="Ej: 10.4806" 
        />
      </div>
      <div>
        <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text">Longitud</label>
        <input 
          type="number" 
          step="any" 
          name="longitud" 
          id="longitud" 
          class="input w-full font-uber-text text-xs bg-canvas border border-canvas-soft p-2 rounded" 
          placeholder="Ej: -66.9036" 
        />
      </div>
    </div>
  </details>
</div>

<!-- Leaflet CSS + JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline>
  (function() {
    let miniMap = null;
    let marker = null;
    let reverseGeocodingTimeout = null;

    // Coordenadas iniciales por defecto (Caracas)
    const DEFAULT_LAT = 10.4806;
    const DEFAULT_LON = -66.9036;

    function initMapaUbicacion() {
      const btnGps = document.getElementById("btn-obtener-gps");
      const latInput = document.getElementById("latitud");
      const lonInput = document.getElementById("longitud");
      const statusText = document.getElementById("gps-status");
      const mapContainer = document.getElementById("gps-preview-map");
      const searchInput = document.getElementById("map-search-input");
      const btnSearch = document.getElementById("btn-map-search");
      const searchSpinner = document.getElementById("map-search-spinner");
      const suggestionsContainer = document.getElementById("map-search-suggestions");
      const addressInput = document.querySelector('input[name="ubicacion_nombre"]');

      if (!mapContainer || !latInput || !lonInput) return;

      // Limpiar instancia previa de Leaflet si existe
      if (window.mapaReporteInstance) {
        try {
          window.mapaReporteInstance.remove();
        } catch(e) {
          console.error("Error destruyendo mapa previo:", e);
        }
        window.mapaReporteInstance = null;
        marker = null;
      }

      // Obtener lat/lon iniciales
      let initLat = parseFloat(latInput.value);
      let initLon = parseFloat(lonInput.value);
      const hasCoords = !isNaN(initLat) && !isNaN(initLon) && initLat !== 0 && initLon !== 0;

      if (!hasCoords) {
        initLat = DEFAULT_LAT;
        initLon = DEFAULT_LON;
      }

      // Inicializar mapa
      miniMap = L.map("gps-preview-map", {
        zoomControl: true,
        attributionControl: false,
        dragging: true,
        scrollWheelZoom: false,
      }).setView([initLat, initLon], hasCoords ? 16 : 12);

      window.mapaReporteInstance = miniMap;

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
      }).addTo(miniMap);

      // Crear marcador
      marker = L.marker([initLat, initLon], {
        draggable: true
      }).addTo(miniMap);

      // Evento: Clic en el mapa para mover marcador
      miniMap.on("click", function(e) {
        const latlng = e.latlng;
        actualizarCoordenadas(latlng.lat, latlng.lng, true);
      });

      // Evento: Arrastre de marcador finalizado
      marker.on("dragend", function(e) {
        const position = marker.getLatLng();
        actualizarCoordenadas(position.lat, position.lng, true);
      });

      // Sincronizar inputs manuales
      function syncManualInput() {
        const lat = parseFloat(latInput.value);
        const lon = parseFloat(lonInput.value);
        if (!isNaN(lat) && !isNaN(lon)) {
          marker.setLatLng([lat, lon]);
          miniMap.setView([lat, lon]);
        }
      }
      latInput.addEventListener("change", syncManualInput);
      lonInput.addEventListener("change", syncManualInput);

      // Actualizar coordenadas e inputs
      function actualizarCoordenadas(lat, lon, triggerReverseGeocode = false) {
        const fixedLat = parseFloat(lat.toFixed(6));
        const fixedLon = parseFloat(lon.toFixed(6));
        
        latInput.value = fixedLat;
        lonInput.value = fixedLon;
        latInput.dispatchEvent(new Event("input", { bubbles: true }));
        lonInput.dispatchEvent(new Event("input", { bubbles: true }));
        
        if (marker) {
          marker.setLatLng([lat, lon]);
        }

        if (triggerReverseGeocode) {
          obtenerDireccionInversa(fixedLat, fixedLon);
        }
      }

      // Reverse Geocoding usando Nominatim
      async function obtenerDireccionInversa(lat, lon) {
        if (statusText) {
          statusText.textContent = "Obteniendo dirección del punto marcado...";
          statusText.className = "text-xs text-blue-600 font-uber-text italic font-medium";
        }

        // Debounce para evitar spam
        clearTimeout(reverseGeocodingTimeout);
        reverseGeocodingTimeout = setTimeout(async () => {
          try {
            const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`);
            if (!res.ok) throw new Error("Error en geocodificación");
            const data = await res.json();
            
            if (data && data.display_name) {
              // Limpiar un poco el nombre largo para que no sea excesivo
              const parts = data.display_name.split(",");
              const shortAddress = parts.slice(0, 3).join(",").trim();
              
              if (addressInput) {
                addressInput.value = data.display_name; // Guardar completo
                // Disparar evento change para validaciones del formulario
                addressInput.dispatchEvent(new Event("change"));
                addressInput.dispatchEvent(new Event("input", { bubbles: true }));
              }
              if (searchInput) {
                searchInput.value = shortAddress;
              }
              if (statusText) {
                statusText.textContent = "Ubicación seleccionada con éxito.";
                statusText.className = "text-xs text-green-600 font-uber-text italic font-semibold";
              }
            }
          } catch (err) {
            console.error("Error en reverse geocoding:", err);
            if (statusText) {
              statusText.textContent = "Coordenadas marcadas (no se pudo resolver la dirección física).";
              statusText.className = "text-xs text-mute font-uber-text italic";
            }
          }
        }, 800);
      }

      // Geolocalización del dispositivo (GPS)
      if (btnGps) {
        btnGps.addEventListener("click", function() {
          if (!("geolocation" in navigator)) {
            if (statusText) statusText.textContent = "Geolocalización no soportada por el navegador.";
            return;
          }

          if (statusText) {
            statusText.textContent = "Obteniendo ubicación GPS del dispositivo...";
            statusText.className = "text-xs text-yellow-600 font-uber-text italic font-medium";
          }
          btnGps.classList.add("opacity-50");
          btnGps.disabled = true;

          navigator.geolocation.getCurrentPosition(
            function(position) {
              const lat = position.coords.latitude;
              const lon = position.coords.longitude;
              const accuracy = position.coords.accuracy;

              actualizarCoordenadas(lat, lon, true);
              miniMap.setView([lat, lon], 17);

              btnGps.classList.remove("opacity-50");
              btnGps.disabled = false;
            },
            function(error) {
              btnGps.classList.remove("opacity-50");
              btnGps.disabled = false;
              let msg = "Error al obtener ubicación GPS";
              if (error.code === 1) msg = "Permiso GPS denegado por el usuario.";
              else if (error.code === 2) msg = "Posición GPS no disponible.";
              else if (error.code === 3) msg = "Tiempo de espera agotado al obtener el GPS.";
              
              if (statusText) {
                statusText.textContent = msg;
                statusText.className = "text-xs text-red-500 font-uber-text italic";
              }
            },
            {
              enableHighAccuracy: true,
              timeout: 8000,
              maximumAge: 0
            }
          );
        });
      }

      // Búsqueda de dirección con Nominatim (Geocoding)
      async function buscarDireccion() {
        const query = searchInput.value.trim();
        if (!query) return;

        if (searchSpinner) searchSpinner.classList.remove("hidden");
        if (statusText) {
          statusText.textContent = "Buscando dirección...";
          statusText.className = "text-xs text-blue-600 font-uber-text italic font-medium";
        }

        try {
          // Filtrado por Venezuela (countrycodes=ve) para mejor exactitud local
          const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5&countrycodes=ve`);
          if (!res.ok) throw new Error("Error en búsqueda");
          const results = await res.json();

          if (searchSpinner) searchSpinner.classList.add("hidden");

          if (!results || results.length === 0) {
            if (statusText) {
              statusText.textContent = "No se encontraron resultados en el mapa.";
              statusText.className = "text-xs text-red-500 font-uber-text italic";
            }
            if (suggestionsContainer) suggestionsContainer.classList.add("hidden");
            return;
          }

          // Mostrar sugerencias
          if (suggestionsContainer) {
            suggestionsContainer.innerHTML = "";
            suggestionsContainer.classList.remove("hidden");

            results.forEach(item => {
              const div = document.createElement("div");
              div.className = "p-3 hover:bg-canvas-soft cursor-pointer text-xs font-uber-text text-ink transition-colors";
              div.textContent = item.display_name;
              div.addEventListener("click", () => {
                const lat = parseFloat(item.lat);
                const lon = parseFloat(item.lon);
                
                actualizarCoordenadas(lat, lon, false);
                miniMap.setView([lat, lon], 16);
                
                if (addressInput) {
                  addressInput.value = item.display_name;
                  addressInput.dispatchEvent(new Event("change"));
                  addressInput.dispatchEvent(new Event("input", { bubbles: true }));
                }
                searchInput.value = item.display_name.split(",").slice(0, 3).join(",").trim();
                
                suggestionsContainer.classList.add("hidden");
                if (statusText) {
                  statusText.textContent = "Ubicación actualizada en el mapa.";
                  statusText.className = "text-xs text-green-600 font-uber-text italic font-semibold";
                }
              });
              suggestionsContainer.appendChild(div);
            });
          }
        } catch (err) {
          console.error("Error al buscar dirección:", err);
          if (searchSpinner) searchSpinner.classList.add("hidden");
          if (statusText) {
            statusText.textContent = "Error al conectar con el servidor de mapas.";
            statusText.className = "text-xs text-red-500 font-uber-text italic";
          }
        }
      }

      if (btnSearch) {
        btnSearch.addEventListener("click", buscarDireccion);
      }

      if (searchInput) {
        searchInput.addEventListener("keydown", function(e) {
          if (e.key === "Enter") {
            e.preventDefault();
            buscarDireccion();
          }
        });

        // Ocultar sugerencias al hacer clic fuera
        document.addEventListener("click", function(e) {
          if (suggestionsContainer && !suggestionsContainer.contains(e.target) && e.target !== searchInput && e.target !== btnSearch) {
            suggestionsContainer.classList.add("hidden");
          }
        });
      }

      // Si tiene coordenadas iniciales, cargarlas y centrar
      if (hasCoords) {
        actualizarCoordenadas(initLat, initLon, false);
      }
    }

    // Esperar a que Leaflet esté disponible en window antes de inicializar
    function checkAndInit() {
      if (typeof L !== "undefined") {
        initMapaUbicacion();
      } else {
        setTimeout(checkAndInit, 100);
      }
    }

    // Registrar en astro:page-load para soportar ClientRouter
    document.addEventListener("astro:page-load", checkAndInit);
  })();
</script>

