<div id="offline-badge" class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-uber-text font-medium transition-all duration-300 bg-canvas-soft text-ink border border-canvas-soft">
  <span id="offline-dot" class="w-2 h-2 rounded-full bg-green-500"></span>
  <span id="offline-text">Conectado</span>
</div>

<script>
  import { contarPendientes, obtenerPendientes, eliminarRegistro } from "../lib/offline-queue";

  const badge = document.getElementById("offline-badge");
  const dot = document.getElementById("offline-dot");
  const text = document.getElementById("offline-text");
  let sincronizando = false;

  async function actualizarUI() {
    if (!badge || !text || !dot) return;
    const online = navigator.onLine;
    const pendientes = await contarPendientes();

    if (online) {
      if (pendientes > 0) {
        badge.className = "flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-uber-text font-medium transition-all duration-300 bg-primary text-white cursor-pointer animate-pulse";
        dot.className = "w-2 h-2 rounded-full bg-yellow-500";
        text.textContent = `Pendiente (${pendientes})`;
        if (!sincronizando) {
          sincronizarCola();
        }
      } else {
        badge.className = "flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-uber-text font-medium transition-all duration-300 bg-canvas-soft text-ink border border-canvas-soft";
        dot.className = "w-2 h-2 rounded-full bg-green-500";
        text.textContent = "Conectado";
      }
    } else {
      badge.className = "flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-uber-text font-medium transition-all duration-300 bg-primary text-white";
      dot.className = "w-2 h-2 rounded-full bg-red-500";
      text.textContent = `Sin red (${pendientes})`;
    }
  }

  function dataURLtoBlob(dataurl: string): Blob {
    const arr = dataurl.split(",");
    const match = arr[0].match(/:(.*?);/);
    const mime = match ? match[1] : "image/jpeg";
    const bstr = atob(arr[1]);
    let n = bstr.length;
    const u8arr = new Uint8Array(n);
    while (n--) {
      u8arr[n] = bstr.charCodeAt(n);
    }
    return new Blob([u8arr], { type: mime });
  }

  async function sincronizarCola() {
    if (sincronizando) return;
    sincronizando = true;
    
    const pendientes = await obtenerPendientes();
    if (pendientes.length === 0) {
      sincronizando = false;
      return;
    }

    try {
      // Subir fotos en base64 primero a R2
      for (const item of pendientes) {
        if (item.data && item.data.foto_key && item.data.foto_key.startsWith("data:image/")) {
          try {
            const blob = dataURLtoBlob(item.data.foto_key);
            const formData = new FormData();
            formData.append("foto", blob, "offline-photo.jpg");

            const imgResp = await fetch("/api/upload", {
              method: "POST",
              body: formData
            });

            if (imgResp.ok) {
              const imgData = await imgResp.json();
              item.data.foto_key = imgData.key; // Reemplazar base64 con la key R2 real
            }
          } catch (imgErr) {
            console.error("No se pudo subir foto offline para item:", item, imgErr);
            // Limpiar foto_key fallido para permitir que el registro de censo se sincronice igual
            item.data.foto_key = null;
          }
        }
      }

      const resp = await fetch("/api/sync", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(pendientes)
      });

      if (resp.ok) {
        const data = await resp.json();
        if (data.success) {
          // Eliminar los registros sincronizados de IndexedDB
          for (const item of pendientes) {
            if (item.id !== undefined) {
              await eliminarRegistro(item.id);
            }
          }
          console.log(`Sincronizados ${data.count} registros desde cola local.`);
        }
      }
    } catch (err) {
      console.error("Fallo de sincronización automática:", err);
    } finally {
      sincronizando = false;
      actualizarUI();
    }
  }

  window.addEventListener("online", () => {
    console.log("Conexión restablecida. Iniciando sincronización.");
    actualizarUI();
  });
  window.addEventListener("offline", actualizarUI);

  // Escuchar evento personalizado de inserción en IndexedDB
  window.addEventListener("offline-record-added", actualizarUI);

  // Intervalo de seguridad por si cambia el estado sin eventos
  setInterval(actualizarUI, 5000);

  // Ejecución inicial
  actualizarUI();
</script>
