    document.getElementById("btn-reportar-vi")?.addEventListener("click", (e) => {
      e.stopPropagation();
      abrirReporteRapido();
    });

    document.getElementById("btn-compartir-cartel")?.addEventListener("click", (e) => {
      e.stopPropagation();
      generarCartel();
    });

    document.getElementById("btn-marcar-encontrado")?.addEventListener("click", (e) => {
      e.stopPropagation();
      cerrarModal();
      abrirReporteRapido();
    });

    document.getElementById("modal-btn-marcar-vivo")?.addEventListener("click", (e) => {
      e.stopPropagation();
      cerrarModal();
      abrirReporteRapido();
    });

    // Mostrar modal
    modalDetalle!.classList.remove("hidden");
    document.body.style.overflow = "hidden";
