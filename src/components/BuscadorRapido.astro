    actionsHtml += `<button id="btn-reportar-vi" class="btn bg-canvas-soft text-ink flex-1 min-w-[120px] font-uber-text uber-body-md-strong">📢 Lo vi</button>`;

    actionsHtml += `<button id="btn-compartir-cartel" class="btn bg-primary text-white flex-1 min-w-[120px] font-uber-text uber-body-md-strong">📷 Compartir</button>`;

    if (tipo === "reporte" && data.estado_reporte !== "resuelto") {
      actionsHtml += `<button id="btn-marcar-encontrado" class="btn bg-canvas-soft text-ink flex-1 min-w-[120px] font-uber-text uber-body-md-strong">✅ Encontrado</button>`;
    }

    if (tipo === "persona" && data.estado === "desconocido") {
      actionsHtml += `<button id="modal-btn-marcar-vivo" class="btn bg-success text-white flex-1 min-w-[120px] font-uber-text uber-body-md-strong">✅ A salvo</button>`;
