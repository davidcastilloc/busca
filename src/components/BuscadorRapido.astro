    let mapaHtml = "";
    if (lat && lon) {
      const z = 15;
      const tileX = Math.floor((lon + 180) / 360 * Math.pow(2, z));
      const tileY = Math.floor((1 - Math.log(Math.tan(lat * Math.PI / 180) + 1 / Math.cos(lat * Math.PI / 180)) / Math.PI) / 2 * Math.pow(2, z));
      mapaHtml = `
