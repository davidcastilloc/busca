      }
    }

    if (telValido) {
      actionsHtml += `<a href="tel:${tel}" class="btn bg-canvas-soft text-ink flex-1 min-w-[120px] font-uber-text uber-body-md-strong text-center justify-center items-center flex">📞 Llamar</a>`;
