<div class="w-full max-w-3xl mx-auto p-4">
  <!-- Filtros rápidos -->
  <div class="flex flex-wrap gap-2 justify-center mb-4">
    <button id="filtro-todos" class="btn btn-error text-white font-black btn-sm">Todos</button>
    <button id="filtro-missing" class="btn btn-outline border-base-300 font-bold btn-sm">Por Localizar</button>
    <button id="filtro-found" class="btn btn-outline border-base-300 font-bold btn-sm">Localizadas</button>
  </div>

  <!-- Buscador -->
  <div class="card bg-base-100 border border-base-300 p-6 shadow-sm">
    <form id="form-search" class="space-y-4">
      <div class="flex flex-col sm:flex-row gap-2">
        <input 
          type="text" 
          id="query-input" 
          required
          class="input input-bordered flex-1 text-lg" 
          placeholder="Buscar por nombre, cédula, ubicación..." 
          autofocus
        />
        <button type="submit" class="btn btn-error text-white font-bold text-lg px-8">
          🔍 Buscar
        </button>
      </div>
      <p class="text-xs text-base-content/50 text-center">
        Búsqueda aproximada con tolerancia a errores ortográficos
      </p>
    </form>
  </div>

  <!-- Resultados -->
  <div id="results-loader" class="hidden flex justify-center py-10">
    <span class="loading loading-spinner loading-lg text-error"></span>
  </div>

  <div id="results-header" class="hidden font-bold text-sm text-base-content/70 mt-6 mb-2"></div>
  <div id="results-container" class="space-y-4"></div>

  <!-- Paginación -->
  <div id="pagination" class="hidden flex justify-center gap-2 mt-6">
    <button id="btn-prev" class="btn btn-outline btn-sm">&larr; Anterior</button>
    <span id="page-info" class="btn btn-ghost btn-sm"></span>
    <button id="btn-next" class="btn btn-outline btn-sm">Siguiente &rarr;</button>
  </div>
</div>

<script>
  const API = "http://localhost:3001";
  let currentPage = 1;
  let currentQuery = "";
  let currentFilter = "";
  let totalResults = 0;
  const PER_PAGE = 20;

  const form = document.getElementById("form-search");
  const input = document.getElementById("query-input");
  const loader = document.getElementById("results-loader");
  const header = document.getElementById("results-header");
  const container = document.getElementById("results-container");
  const pagination = document.getElementById("pagination");
  const btnPrev = document.getElementById("btn-prev");
  const btnNext = document.getElementById("btn-next");
  const pageInfo = document.getElementById("page-info");

  // Filtros
  document.getElementById("filtro-todos").addEventListener("click", () => setFilter(""));
  document.getElementById("filtro-missing").addEventListener("click", () => setFilter("missing"));
  document.getElementById("filtro-found").addEventListener("click", () => setFilter("found"));

  function setFilter(f) {
    currentFilter = f;
    currentPage = 1;
    doSearch();
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    currentQuery = input.value.trim();
    currentPage = 1;
    doSearch();
  });

  btnPrev.addEventListener("click", () => { if (currentPage > 1) { currentPage--; doSearch(); } });
  btnNext.addEventListener("click", () => { if (currentPage * PER_PAGE < totalResults) { currentPage++; doSearch(); } });

  async function doSearch() {
    if (!currentQuery && !currentFilter) {
      showHeader("Escribe algo para buscar", false);
      container.innerHTML = "";
      pagination.classList.add("hidden");
      return;
    }

    showLoader(true);
    try {
      let url = `${API}/api/search?limit=${PER_PAGE}&page=${currentPage}`;
      if (currentQuery) url += `&q=${encodeURIComponent(currentQuery)}`;
      if (currentFilter) url += `&status=${currentFilter}`;

      const resp = await fetch(url);
      if (!resp.ok) throw new Error("Error en búsqueda");
      const data = await resp.json();
      totalResults = data.total;
      renderResults(data.hits);
    } catch (err) {
      console.error(err);
      showHeader("❌ Error de conexión al motor de búsqueda", true);
      container.innerHTML = "";
      pagination.classList.add("hidden");
    } finally {
      showLoader(false);
    }
  }

  function renderResults(hits) {
    container.innerHTML = "";
    if (!hits || hits.length === 0) {
      showHeader(currentQuery
        ? `Sin resultados para "${currentQuery}"`
        : "Sin resultados con ese filtro", false);
      pagination.classList.add("hidden");
      return;
    }

    const from = (currentPage - 1) * PER_PAGE + 1;
    const to = Math.min(currentPage * PER_PAGE, totalResults);
    showHeader(`Resultados ${from}-${to} de ${totalResults.toLocaleString("es")}`, false);

    for (const p of hits) {
      const card = document.createElement("div");
      card.className = "card card-side bg-base-100 shadow-md border-l-4 border-error/30 flex-col sm:flex-row overflow-hidden transition-all duration-200 hover:scale-[1.01]";

      const imgHtml = p.tiene_foto
        ? `<figure class="w-full sm:w-44 h-44 sm:h-auto shrink-0 bg-base-300 relative">
             <img src="${API}/api/persons/${p.id}/photo" alt="Foto" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />
           </figure>`
        : `<div class="w-full sm:w-44 h-44 shrink-0 bg-base-300 flex items-center justify-center text-4xl select-none">👤</div>`;

      const statusBadge = p.status === "found"
        ? `<div class="badge badge-success text-white font-black text-xs">Localizada</div>`
        : `<div class="badge badge-error text-white font-black text-xs">Por Localizar</div>`;

      const hlName = p._formatted?.nombre_completo || p.nombre_completo;
      const hlLoc = p._formatted?.ultima_ubicacion || p.ultima_ubicacion;
      const hlDesc = p._formatted?.descripcion || p.descripcion;

      card.innerHTML = `
        ${imgHtml}
        <div class="card-body p-5 flex flex-col justify-between">
          <div>
            <div class="flex flex-wrap items-center justify-between gap-2 mb-1.5">
              <h2 class="card-title text-xl font-bold tracking-tight">${hlName}</h2>
              ${statusBadge}
            </div>
            <div class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-sm mb-3">
              ${p.cedula ? `<div><span class="text-base-content/50 font-semibold">Cédula:</span> <span class="font-bold">${p._formatted?.cedula || p.cedula}</span></div>` : ""}
              ${p.edad ? `<div><span class="text-base-content/50 font-semibold">Edad:</span> <span class="font-bold">${p.edad} años</span></div>` : ""}
              ${p.genero ? `<div><span class="text-base-content/50 font-semibold">Género:</span> <span class="font-bold">${p.genero}</span></div>` : ""}
              ${hlLoc ? `<div class="col-span-2"><span class="text-base-content/50 font-semibold">📍 Ubicación:</span> <span class="font-bold">${hlLoc}</span></div>` : ""}
            </div>
            ${hlDesc ? `<div class="bg-base-200 p-2.5 rounded-lg text-sm border-l-2 border-base-300 italic mb-2.5 text-base-content/90">"${hlDesc}"</div>` : ""}
          </div>
          <div class="flex flex-wrap items-center justify-between text-xs text-base-content/50 border-t border-base-200 pt-2.5 mt-auto">
            <div>Reportante: <span class="font-bold">${p.reportante || "Anónimo"}</span></div>
            <div>${p.created_at ? new Date(p.created_at).toLocaleDateString("es-VE") : ""}</div>
          </div>
        </div>
      `;
      container.appendChild(card);
    }

    const totalPages = Math.ceil(totalResults / PER_PAGE);
    if (totalPages > 1) {
      pagination.classList.remove("hidden");
      pageInfo.textContent = `Pág. ${currentPage} de ${totalPages}`;
      btnPrev.disabled = currentPage <= 1;
      btnNext.disabled = currentPage >= totalPages;
    } else {
      pagination.classList.add("hidden");
    }
  }

  function showLoader(s) { loader.classList.toggle("hidden", !s); }
  function showHeader(msg, err) {
    header.textContent = msg;
    header.classList.remove("hidden");
    header.className = err
      ? "font-bold text-sm text-error mt-6 mb-2"
      : "font-bold text-sm text-base-content/75 mt-6 mb-2";
  }
</script>
