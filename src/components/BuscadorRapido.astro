---
---

<div class="w-full max-w-3xl mx-auto px-4 py-4 sm:py-6">
  <!-- Tabs de búsqueda (button-tab-translucent) -->
  <div class="flex gap-2 sm:gap-3 justify-center mb-6 sm:mb-8">
    <button id="btn-tab-exact" class="flex-1 sm:flex-none px-4 sm:px-5 py-3 rounded-[36px] bg-primary text-white font-uber-text uber-body-md-strong transition-colors cursor-pointer text-center">
      Censo de Personas
    </button>
    <button id="btn-tab-semantic" class="flex-1 sm:flex-none px-4 sm:px-5 py-3 rounded-[36px] bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text uber-body-md-strong transition-colors cursor-pointer text-center">
      Búsqueda IA
    </button>
  </div>

  <!-- Formulario 1: Búsqueda Exacta (card-elevated) -->
  <div id="panel-exact" class="bg-canvas border border-canvas-soft p-4 sm:p-8 rounded-xl shadow-sm">
    <form id="form-search-exact" class="space-y-3">
      <div class="flex flex-col gap-3">
        <input 
          type="text" 
          id="query-exact" 
          required
          class="input w-full font-uber-text uber-body-md" 
          placeholder="Nombre, Cédula, Ubicación o Refugio..." 
        />
        <button type="submit" class="btn bg-primary text-white hover:bg-black-elevated w-full sm:w-auto font-uber-text uber-body-md-strong">
          Buscar
        </button>
      </div>
      <p class="text-xs text-body font-uber-text">
        Búsqueda exacta en el censo oficial de albergues y rescatistas.
      </p>
    </form>
  </div>

  <!-- Formulario 2: Búsqueda Semántica (IA) (card-elevated) -->
  <div id="panel-semantic" class="bg-canvas border border-canvas-soft p-4 sm:p-8 rounded-xl shadow-sm hidden">
    <form id="form-search-semantic" class="space-y-3">
      <div class="space-y-2">
        <label class="block font-uber-text uber-body-md-strong text-ink">Descripción del Reporte</label>
        <textarea 
          id="query-semantic" 
          required
          minlength="5"
          rows="4"
          class="textarea w-full font-uber-text uber-body-md" 
          placeholder="Ej: Niño de unos 8 años, jean azul, gorra roja, visto por última vez en la plaza Bolívar..."
        ></textarea>
      </div>
      <button type="submit" id="btn-submit-semantic" class="btn bg-primary text-white hover:bg-black-elevated w-full font-uber-text uber-body-md-strong">
        Buscar por Similitud IA
      </button>
      <p class="text-xs text-body font-uber-text">
        La IA procesará la descripción y buscará reportes con características físicas similares.
      </p>
    </form>
  </div>

  <!-- Resultados de búsqueda -->
  <div id="results-loader" class="hidden flex justify-center py-10">
    <span class="loading loading-spinner loading-lg text-primary"></span>
  </div>

  <div id="results-header" class="hidden font-uber-text uber-body-md-strong text-body mt-8 mb-4"></div>
  <div id="results-container" class="space-y-6"></div>
</div>

<script>
  const btnTabExact = document.getElementById("btn-tab-exact");
  const btnTabSemantic = document.getElementById("btn-tab-semantic");
  const panelExact = document.getElementById("panel-exact");
  const panelSemantic = document.getElementById("panel-semantic");

  const formSearchExact = document.getElementById("form-search-exact") as HTMLFormElement;
  const formSearchSemantic = document.getElementById("form-search-semantic") as HTMLFormElement;
  
  const queryExact = document.getElementById("query-exact") as HTMLInputElement;
  const querySemantic = document.getElementById("query-semantic") as HTMLTextAreaElement;
  const btnSubmitSemantic = document.getElementById("btn-submit-semantic");
  
  const loader = document.getElementById("results-loader");
  const resultsHeader = document.getElementById("results-header");
  const resultsContainer = document.getElementById("results-container");

  // Control de pestañas
  if (btnTabExact && btnTabSemantic && panelExact && panelSemantic) {
    btnTabExact.addEventListener("click", () => {
      btnTabExact.className = "px-5 py-2.5 rounded-[36px] bg-primary text-white font-uber-text uber-body-md-strong transition-colors cursor-pointer";
      btnTabSemantic.className = "px-5 py-2.5 rounded-[36px] bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text uber-body-md-strong transition-colors cursor-pointer";
      panelExact.classList.remove("hidden");
      panelSemantic.classList.add("hidden");
    });

    btnTabSemantic.addEventListener("click", () => {
      btnTabExact.className = "px-5 py-2.5 rounded-[36px] bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text uber-body-md-strong transition-colors cursor-pointer";
      btnTabSemantic.className = "px-5 py-2.5 rounded-[36px] bg-primary text-white font-uber-text uber-body-md-strong transition-colors cursor-pointer";
      panelExact.classList.add("hidden");
      panelSemantic.classList.remove("hidden");
    });
  }

  // Enviar búsqueda exacta
  if (formSearchExact) {
    formSearchExact.addEventListener("submit", async (e) => {
      e.preventDefault();
      const q = queryExact.value.trim();
      if (!q) return;

      mostrarLoader(true);
      try {
        const resp = await fetch(`/api/buscar?q=${encodeURIComponent(q)}`);
        if (resp.ok) {
          const resultados = await resp.json();
          renderizarPersonas(resultados, q);
        } else {
          throw new Error("Error en respuesta");
        }
      } catch (err) {
        console.error(err);
        mostrarMensajeHeader("❌ Hubo un error de conexión al buscar.", true);
      } finally {
        mostrarLoader(false);
      }
    });
  }

  // Enviar búsqueda semántica
  if (formSearchSemantic && btnSubmitSemantic) {
    formSearchSemantic.addEventListener("submit", async (e) => {
      e.preventDefault();
      const desc = querySemantic.value.trim();
      if (desc.length < 5) return;

      if (!navigator.onLine) {
        mostrarMensajeHeader("❌ La búsqueda semántica requiere conexión a internet.", true);
        return;
      }

      mostrarLoader(true);
      btnSubmitSemantic.classList.add("opacity-50");

      try {
        const resp = await fetch("/api/buscar-similar", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ descripcion: desc })
        });

        if (resp.ok) {
          const resultados = await resp.json();
          renderizarReportes(resultados);
        } else {
          throw new Error("Error en búsqueda semántica");
        }
      } catch (err) {
        console.error(err);
        mostrarMensajeHeader("❌ Error al procesar búsqueda inteligente.", true);
      } finally {
        mostrarLoader(false);
        btnSubmitSemantic.classList.remove("opacity-50");
      }
    });
  }

  function mostrarLoader(show: boolean) {
    if (loader) {
      if (show) loader.classList.remove("hidden");
      else loader.classList.add("hidden");
    }
  }

  function mostrarMensajeHeader(msg: string, isError = false) {
    if (resultsHeader && resultsContainer) {
      resultsHeader.textContent = msg;
      resultsHeader.classList.remove("hidden");
      if (isError) {
        resultsHeader.className = "font-uber-text uber-body-md-strong text-primary mt-8 mb-4";
        resultsContainer.innerHTML = "";
      } else {
        resultsHeader.className = "font-uber-text uber-body-md-strong text-body mt-8 mb-4";
      }
    }
  }

  // Render para censo (Personas)
  function renderizarPersonas(personas: any[], q: string) {
    if (!resultsContainer) return;
    resultsContainer.innerHTML = "";

    if (personas.length === 0) {
      mostrarMensajeHeader(`Sin resultados exactos para "${q}". Intenta con búsqueda semántica si tienes una descripción.`);
      return;
    }

    mostrarMensajeHeader(`Se encontraron ${personas.length} registros exactos:`);

    personas.forEach(p => {
      const card = document.createElement("div");
      
      const configEstado: Record<string, { badge: string, dot: string, text: string }> = {
        vivo: { badge: "border border-green-500/30 text-ink bg-canvas", dot: "bg-green-500", text: "Vivo / A salvo" },
        herido: { badge: "border border-yellow-500/30 text-ink bg-canvas", dot: "bg-yellow-500", text: "Herido" },
        fallecido: { badge: "border border-red-500/30 text-ink bg-canvas", dot: "bg-red-500", text: "Fallecido" },
        desconocido: { badge: "border border-canvas-soft text-ink bg-canvas", dot: "bg-mute", text: "Desconocido" }
      };
      
      const config = configEstado[p.estado] || configEstado.desconocido;
      const imgHtml = p.foto_key 
        ? `<figure class="w-full sm:w-44 h-44 sm:h-auto shrink-0 bg-canvas-soft relative">
             <img src="/api/upload?key=${encodeURIComponent(p.foto_key)}" alt="Foto" class="w-full h-full object-cover" loading="lazy" />
           </figure>`
        : `<div class="w-full sm:w-44 h-44 shrink-0 bg-canvas-soft flex items-center justify-center text-4xl select-none text-mute">👤</div>`;

      const fecha = formatFechaLocal(p.updated_at);

      card.className = "bg-canvas border border-canvas-soft rounded-xl shadow-sm flex flex-col sm:flex-row overflow-hidden transition-all duration-200 hover:scale-[1.01]";
      card.innerHTML = `
        ${imgHtml}
        <div class="p-6 flex flex-col justify-between flex-grow">
          <div>
            <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
              <h2 class="font-uber-display text-xl text-ink leading-snug">${p.nombre} ${p.apellido || ""}</h2>
              <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-uber-text font-medium ${config.badge}">
                <span class="w-1.5 h-1.5 rounded-full ${config.dot}"></span>
                <span>${config.text}</span>
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm text-body mb-4 font-uber-text">
              ${p.cedula ? `<div>Documento: <span class="font-semibold text-ink">${p.cedula}</span></div>` : ""}
              ${p.edad !== null && p.edad !== undefined ? `<div>Edad: <span class="font-semibold text-ink">${p.edad} años</span></div>` : ""}
              ${p.sexo ? `<div>Sexo: <span class="font-semibold text-ink">${p.sexo}</span></div>` : ""}
              ${p.refugio ? `<div class="sm:col-span-2">📍 Refugio: <span class="font-semibold text-ink bg-canvas-soft px-2 py-0.5 rounded">${p.refugio}</span></div>` : ""}
              ${p.ubicacion_nombre ? `<div class="sm:col-span-2">📍 Zona: <span class="font-semibold text-ink">${p.ubicacion_nombre}</span></div>` : ""}
            </div>
            
            ${p.notas ? `<div class="bg-canvas-soft p-3 rounded-lg text-sm border-l-2 border-primary italic mb-4 text-ink font-uber-text">"${p.notas}"</div>` : ""}
          </div>
          
          <div class="flex flex-wrap items-center justify-between text-xs text-mute border-t border-canvas-soft pt-3 mt-auto font-uber-text">
            <div>Fuente: <span class="font-semibold capitalize text-body">${p.fuente || "web"}</span></div>
            <div>Actualizado: <span class="font-semibold text-body">${fecha}</span></div>
          </div>
        </div>
      `;
      resultsContainer.appendChild(card);
    });
  }

  // Render para reportes (Semantic matching)
  function renderizarReportes(reportes: any[]) {
    if (!resultsContainer) return;
    resultsContainer.innerHTML = "";

    if (reportes.length === 0) {
      mostrarMensajeHeader("Sin coincidencia de reportes por similitud semántica.");
      return;
    }

    mostrarMensajeHeader(`Coincidencias inteligentes encontradas (${reportes.length} reportes similares):`);

    reportes.forEach(r => {
      const card = document.createElement("div");
      
      const configTipo: Record<string, { badge: string, dot: string, text: string }> = {
        desaparecido: { badge: "border border-red-500/30 text-ink bg-canvas", dot: "bg-red-500", text: "Desaparecido" },
        encontrado: { badge: "border border-green-500/30 text-ink bg-canvas", dot: "bg-green-500", text: "Encontrado" },
        refugio: { badge: "border border-blue-500/30 text-ink bg-canvas", dot: "bg-blue-500", text: "Refugio" },
        necesidad: { badge: "border border-yellow-500/30 text-ink bg-canvas", dot: "bg-yellow-500", text: "Necesidad" }
      };
      
      const config = configTipo[r.tipo] || { badge: "border border-canvas-soft text-ink bg-canvas", dot: "bg-mute", text: "Reporte" };
      const similarityScore = r.score ? Math.round(r.score * 100) : null;
      
      const imgHtml = r.foto_key 
        ? `<figure class="w-full sm:w-44 h-44 sm:h-auto shrink-0 bg-canvas-soft relative">
             <img src="/api/upload?key=${encodeURIComponent(r.foto_key)}" alt="Foto" class="w-full h-full object-cover" loading="lazy" />
           </figure>`
        : `<div class="w-full sm:w-44 h-44 shrink-0 bg-canvas-soft flex items-center justify-center text-4xl select-none text-mute">📢</div>`;

      const fecha = formatFechaLocal(r.updated_at);

      card.className = "bg-canvas border border-canvas-soft rounded-xl shadow-sm flex flex-col sm:flex-row overflow-hidden transition-all duration-200 hover:scale-[1.01]";
      card.innerHTML = `
        ${imgHtml}
        <div class="p-6 flex flex-col justify-between flex-grow">
          <div>
            <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
              <h2 class="font-uber-display text-xl text-ink leading-snug">
                ${r.nombre_buscado || "Persona no identificada"}
              </h2>
              <div class="flex items-center gap-2">
                ${similarityScore !== null ? `<div class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary text-white text-xs font-uber-text font-medium">🎯 Coincidencia: ${similarityScore}%</div>` : ""}
                <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-uber-text font-medium ${config.badge}">
                  <span class="w-1.5 h-1.5 rounded-full ${config.dot}"></span>
                  <span>${config.text}</span>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm text-body mb-4 font-uber-text">
              ${r.cedula_buscado ? `<div>Documento: <span class="font-semibold text-ink">${r.cedula_buscado}</span></div>` : ""}
              ${r.ubicacion_nombre ? `<div class="sm:col-span-2">Último avistamiento: <span class="font-semibold text-ink">${r.ubicacion_nombre}</span></div>` : ""}
              ${r.reportante_nombre ? `<div>Reportado por: <span class="font-semibold text-ink">${r.reportante_nombre}</span></div>` : ""}
              ${r.reportante_contacto ? `<div>Contacto: <span class="font-semibold text-ink">${r.reportante_contacto}</span></div>` : ""}
            </div>
            
            <div class="bg-canvas-soft border-l-2 border-primary p-3 rounded-lg text-sm italic mb-4 text-ink font-uber-text">
              <strong>Descripción:</strong> "${r.descripcion}"
            </div>
          </div>
          
          <div class="flex flex-wrap items-center justify-between text-xs text-mute border-t border-canvas-soft pt-3 mt-auto font-uber-text">
            <div>Estado Reporte: <span class="font-semibold uppercase text-primary">${r.estado_reporte || "abierto"}</span></div>
            <div>Fecha: <span class="font-semibold text-body">${fecha}</span></div>
          </div>
        </div>
      `;
      resultsContainer.appendChild(card);
    });
  }

  function formatFechaLocal(fechaStr: string) {
    try {
      const d = new Date(fechaStr + " UTC");
      return d.toLocaleString("es-ES", { timeZone: "America/Caracas" });
    } catch (e) {
      return fechaStr;
    }
  }
</script>
