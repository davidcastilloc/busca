---
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";
import OfflineIndicator from "./OfflineIndicator.astro";
import PushBanner from "./PushBanner.astro";
import ShareButton from "./ShareButton.astro";
const sessionToken = Astro.cookies.get("session_token")?.value;
let isVolunteer = false;

try {
  const { DB } = env;
  if (DB && sessionToken) {
    const vol = await obtenerVoluntarioSesion(DB, sessionToken);
    isVolunteer = !!vol;
  }
} catch (e) {
  console.error("Error al obtener sesión en Navbar:", e);
}
---

<div id="web-navbar" class="w-full bg-canvas border-b border-canvas-soft sticky top-0 z-50 py-4 px-4 sm:px-8">
  <script is:inline>
    // Ocultar Navbar en Telegram MiniApp para usar el Header nativo
    if (window.Telegram?.WebApp?.initData) {
      document.getElementById('web-navbar').style.display = 'none';
    }
  </script>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <div class="flex-shrink-0 min-w-0">
      <a href="/" class="flex items-center gap-2 sm:gap-3 font-uber-display text-xl sm:text-2xl tracking-tight text-ink">
        <img src="/icons/icon-192.png" alt="dondeestan.org" class="w-7 h-7 sm:w-8 sm:h-8 rounded-md object-cover grayscale flex-shrink-0" />
        <span class="flex items-center gap-1 truncate">dondeestan<span class="text-body font-normal">.org</span></span>
      </a>
    </div>
    
    <!-- Menú de Navegación -->
    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
      <nav class="hidden md:flex items-center gap-1">
        <a href="/buscar" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Buscar
        </a>
        {isVolunteer && (
          <a href="/registrar" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
            Censo
          </a>
        )}
        <a href="/reportar" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Reportar
        </a>
        <a href="/#refugios-seccion" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Refugios
        </a>
        <a href="/ayudar" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Voluntarios
        </a>
      </nav>

      <ShareButton class="md:hidden mr-2" />
      
      <!-- Menú móvil (Icon Button Circular) -->
      <div class="dropdown dropdown-end md:hidden">
        <div tabindex="0" role="button" class="w-10 h-10 rounded-full bg-canvas-soft flex items-center justify-center text-ink hover:bg-surface-pressed transition-colors active:bg-surface-pressed">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content mt-3 z-50 p-2 bg-canvas border border-canvas-soft rounded-xl shadow-lg w-64 divide-y divide-canvas-soft">
          <li>
            <a href="/buscar" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Buscar
            </a>
          </li>
          {isVolunteer && (
            <li>
              <a href="/registrar" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
                Censo
              </a>
            </li>
          )}
          <li>
            <a href="/reportar" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Reportar
            </a>
          </li>
          <li>
            <a href="/#refugios-seccion" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Refugios
            </a>
          </li>
          <li>
            <a href="/ayudar" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Voluntarios
            </a>
          </li>
          <li>
            <div class="px-4 py-3" id="push-menu-mobile">
              <PushBanner />
            </div>
          </li>
        </ul>
      </div>

      <!-- Push + Offline: solo visible en desktop -->
      <div class="hidden md:flex items-center gap-2">
        <ShareButton />
        <div class="h-6 w-px bg-canvas-soft"></div>
        <PushBanner />
        <OfflineIndicator />
      </div>
    </div>
  </div>
</div>

