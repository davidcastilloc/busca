---
import OfflineIndicator from "./OfflineIndicator.astro";
---

<div class="w-full bg-canvas border-b border-canvas-soft sticky top-0 z-50 py-4 px-4 sm:px-8">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <div class="flex-shrink-0">
      <a href="/" class="flex items-center gap-3 font-uber-display text-2xl tracking-tight text-ink">
        <img src="/icons/icon-192.png" alt="BUSCA" class="w-8 h-8 rounded-md object-cover grayscale" />
        <span>BUSCA</span>
      </a>
    </div>
    
    <!-- Menú de Navegación -->
    <div class="flex items-center gap-4 sm:gap-6">
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Buscar
        </a>
        <a href="/registrar" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Censo
        </a>
        <a href="/reportar" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Reportar
        </a>
        <a href="/flyer/crear" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Crear Cartel
        </a>
        <a href="/admin/dashboard" class="px-4 py-2 rounded-full hover:bg-canvas-soft text-ink font-uber-text uber-body-md-strong transition-colors">
          Panel
        </a>
      </nav>

      <!-- Menú móvil (Icon Button Circular) -->
      <div class="dropdown dropdown-end md:hidden">
        <div tabindex="0" role="button" class="w-10 h-10 rounded-full bg-canvas-soft flex items-center justify-center text-ink hover:bg-surface-pressed transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
          </svg>
        </div>
        <ul tabindex="0" class="dropdown-content mt-3 z-50 p-2 bg-canvas border border-canvas-soft rounded-xl shadow-lg w-52 divide-y divide-canvas-soft">
          <li>
            <a href="/" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Buscar
            </a>
          </li>
          <li>
            <a href="/registrar" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Censo
            </a>
          </li>
          <li>
            <a href="/reportar" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Reportar
            </a>
          </li>
          <li>
            <a href="/flyer/crear" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Crear Cartel
            </a>
          </li>
          <li>
            <a href="/admin/dashboard" class="block px-4 py-3 text-ink font-uber-text uber-body-md-strong hover:bg-canvas-soft transition-colors">
              Panel
            </a>
          </li>
        </ul>
      </div>

      <div class="h-6 w-px bg-canvas-soft hidden sm:block"></div>
      
      <OfflineIndicator />
    </div>
  </div>
</div>
