---
// ShareButton.astro
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---
<button
  class={`btn-share w-10 h-10 rounded-full bg-canvas-soft flex items-center justify-center text-ink hover:bg-surface-pressed transition-colors active:bg-surface-pressed flex-shrink-0 ${className}`}
  title="Compartir"
  aria-label="Compartir página"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">

    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
  </svg>
</button>

<script>
  function initShare() {
    const buttons = document.querySelectorAll('.btn-share');
    buttons.forEach(btn => {
      // Remove previous event listeners to avoid duplicates on view transitions
      const newBtn = btn.cloneNode(true);
      if (btn.parentNode) {
        btn.parentNode.replaceChild(newBtn, btn);
      }
      
      newBtn.addEventListener('click', async () => {
        const shareData = {
          title: document.title,
          text: 'dondeestan.org - Censo y Búsqueda de Emergencia. Ayuda a encontrar a las víctimas y colabora con refugios.',
          url: window.location.href,
        };

        if (navigator.share) {
          try {
            await navigator.share(shareData);
          } catch (err) {
            if (err.name !== 'AbortError') {
              console.log('Error al compartir', err);
            }
          }
        } else {
          try {
            await navigator.clipboard.writeText(shareData.url);
            alert('Enlace copiado al portapapeles. ¡Compártelo en Whatsapp y otras redes!');
          } catch (err) {
            console.error('Error copiando al portapapeles', err);
          }
        }
      });
    });
  }
  
  // Initialize on page load and after view transitions
  document.addEventListener('astro:page-load', initShare);
</script>
