---
import { CATEGORIAS_INVENTARIO } from "../lib/items";
---
<div 
  id="modal-edit-refugio" 
  class="fixed inset-0 z-50 bg-black/60 flex items-end sm:items-center justify-center animate-fade-in" 
  style="backdrop-filter:blur(4px); display: none;"
  x-data="{ open: false, tipo: 'refugio', tab: 'gps', error: '', warning: false, gpi: false }"
  x-show="open"
  @open-edit-modal.window="
    open = true;
    tipo = $event.detail.tipo || 'refugio';
  "
  @close-edit-modal.window="open = false"
  @show-gpi.window="gpi = true"
  @hide-gpi.window="gpi = false"
  @show-warning.window="warning = true"
  @hide-warning.window="warning = false"
>
      <div class="bg-canvas w-full sm:max-w-lg sm:rounded-2xl rounded-t-2xl p-6 space-y-4 max-h-[95vh] overflow-y-auto border border-canvas-soft shadow-xl" @click.stop>
        <div class="flex justify-between items-center">
          <h3 class="font-uber-display text-lg text-ink font-semibold" id="edit-refugio-titulo">Actualizar Centro</h3>
          <button id="btn-close-edit" @click="open = false" class="w-8 h-8 rounded-full bg-canvas-soft flex items-center justify-center text-ink text-sm hover:bg-surface-pressed cursor-pointer">✕</button>
        </div>

        <form id="form-edit-refugio" class="space-y-4">
          <input type="hidden" id="edit-refugio-id" />
          
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-tipo">Tipo de Centro *</label>
            <select id="edit-tipo" required x-model="tipo" class="select w-full font-uber-text uber-body-md">
              <option value="refugio">Refugio / Albergue</option>
              <option value="centro_acopio">Centro de Acopio</option>
              <option value="hospital">Hospital / Puesto de Salud</option>
            </select>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-encargado">Encargado *</label>
            <input 
              type="text" 
              id="edit-encargado" 
              required
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>

          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-direccion">Dirección / Sector *</label>
            <div class="flex gap-2 mb-3">
              <input 
                type="text" 
                id="edit-direccion" 
                required 
                class="input flex-grow font-uber-text uber-body-md" 
                placeholder="Ej: Sector La Lucha, Caracas"
              />
              <button type="button" id="btn-edit-buscar-direccion" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed border border-canvas-soft font-uber-text font-semibold px-3 py-2 rounded-xl text-xs shrink-0 cursor-pointer">
                📍 Ubicar
              </button>
            </div>

            <!-- Bloque de ubicación integrado para edicion -->
            <div class="p-3.5 bg-canvas-soft rounded-xl flex flex-col gap-3 border border-canvas-soft">
              <span class="text-[10px] font-bold text-mute uppercase tracking-wider font-uber-text">📍 Método de Ubicación GPS *</span>
              
              <!-- Tabs de selección de método -->
              <div class="flex gap-1 bg-canvas p-1 rounded-lg border border-canvas-soft">
                <button type="button" @click="tab = 'gps'" :class="tab === 'gps' ? 'bg-primary text-white border-none' : 'bg-transparent text-ink border-none'" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md cursor-pointer transition-colors">
                  GPS Móvil
                </button>
                <button type="button" @click="tab = 'gmaps'" :class="tab === 'gmaps' ? 'bg-primary text-white border-none' : 'bg-transparent text-ink border-none'" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md cursor-pointer transition-colors">
                  Pegar Enlace
                </button>
                <button type="button" @click="tab = 'map'" :class="tab === 'map' ? 'bg-primary text-white border-none' : 'bg-transparent text-ink border-none'" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md cursor-pointer transition-colors">
                  Mapa Manual
                </button>
              </div>

              <!-- Inputs ocultos para lat/lng -->
              <input type="hidden" id="edit-latitud" />
              <input type="hidden" id="edit-longitud" />

              <!-- Panel 1: GPS Móvil -->
              <div id="panel-edit-gps" x-show="tab === 'gps'" class="flex items-center justify-between gap-2">
                <span class="text-[10px] text-body font-uber-text">Obtén la ubicación actual del dispositivo.</span>
                <button id="btn-edit-ref-gps" type="button" class="btn btn-xs bg-primary text-white font-uber-text px-3 py-1.5 rounded-lg text-[10px] cursor-pointer shrink-0">
                  Detectar GPS
                </button>
              </div>

              <!-- Panel 2: Pegar Enlace -->
              <div id="panel-edit-gmaps" x-show="tab === 'gmaps'" class="space-y-2">
                <div class="flex gap-2">
                  <input 
                    type="url" 
                    id="edit-gmaps-link" 
                    class="input flex-grow font-uber-text text-xs p-2.5 min-h-[36px]" 
                    placeholder="Pegar enlace de Google Maps..."
                  />
                  <button type="button" id="btn-edit-resolver-gmaps" class="btn bg-primary text-white font-uber-text font-semibold px-3 py-1.5 rounded-lg text-[10px] shrink-0 cursor-pointer">
                    Extraer
                  </button>
                </div>
              </div>

              <!-- Panel 3: Mapa Manual -->
              <div id="panel-edit-map" x-show="tab === 'map'" class="text-[10px] text-mute font-uber-text italic">
                Toca el mapa abajo para ajustar el marcador manualmente.
              </div>

              <!-- Contenedor del mapa (común) -->
              <div id="edit-gps-map" class="w-full h-40 rounded-lg overflow-hidden border border-canvas-soft bg-canvas"></div>
              
              <!-- Tarjeta de Info de Google Places en Modal (oculta por defecto) -->
              <div id="edit-google-place-info" x-show="gpi" class="mt-2 p-3 rounded-xl border border-blue-200 bg-gradient-to-br from-blue-50/80 to-indigo-50/60 space-y-2">
                <div class="flex items-center gap-1.5 text-[11px] font-uber-text font-bold text-blue-700 uppercase tracking-wider">
                  <span>📍</span> Datos del lugar (Google)
                </div>
                <div id="edit-gpi-content" class="grid gap-1.5 text-[11px] font-uber-text text-body">
                </div>
              </div>

              <!-- Estatus de Ubicación -->
              <div id="edit-gps-status" class="text-[11px] text-mute font-uber-text italic">Ubicación cargada.</div>
            </div>
          </div>

          <div id="edit-capacity-section" x-show="tipo === 'refugio'" class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-capacidad">Capacidad Máxima *</label>
              <input 
                type="number" 
                id="edit-capacidad" 
                required 
                min="1"
                class="input w-full font-uber-text uber-body-md" 
              />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-ocupacion">Población Total *</label>
              <input 
                type="number" 
                id="edit-ocupacion" 
                required 
                min="0"
                class="input w-full font-uber-text uber-body-md" 
              />
            </div>
          </div>

          <div id="edit-demographics-section" x-show="tipo === 'refugio'" class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-2">
            <span class="text-xs font-semibold text-ink font-uber-text block">👥 Desglose de Población</span>
            <div class="grid grid-cols-3 gap-2">
              <div>
                <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-ninos">Niños</label>
                <input type="number" id="edit-ninos" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
              </div>
              <div>
                <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-bebes">Bebés</label>
                <input type="number" id="edit-bebes" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
              </div>
              <div>
                <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-mayores">Adultos M.</label>
                <input type="number" id="edit-mayores" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
              </div>
              <div>
                <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-prof">Prof. Salud</label>
                <input type="number" id="edit-prof" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
              </div>
              <div>
                <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-vols">Voluntarios</label>
                <input type="number" id="edit-vols" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
              </div>
            </div>
            <div id="edit-demografia-warning" x-show="warning" class="text-[10px] text-red-500 font-uber-text font-medium bg-red-500/5 p-2 rounded">
              ⚠️ La Población Total debe ser mayor o igual a la suma de los subgrupos.
            </div>
          </div>

          <div id="edit-inventory-section" x-show="tipo === 'refugio' || tipo === 'centro_acopio'" class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-3">
            <span class="text-xs font-semibold text-ink font-uber-text block">📋 Estado del Inventario (43 Ítems)</span>
            
            <div class="flex gap-1 overflow-x-auto pb-1.5 border-b border-canvas-soft scrollbar-none" id="edit-tabs-container">
              {CATEGORIAS_INVENTARIO.map((cat, idx) => (
                <button 
                  type="button" 
                  class={`edit-tab-btn font-uber-text text-[11px] whitespace-nowrap px-2.5 py-1 rounded-lg border ${idx === 0 ? 'bg-primary text-white border-primary' : 'bg-canvas-soft text-ink border-transparent'} cursor-pointer`}
                  data-target={`edit-tab-${idx}`}
                >
                  {cat.nombre}
                </button>
              ))}
            </div>

            <div class="edit-tab-contents max-h-48 overflow-y-auto">
              {CATEGORIAS_INVENTARIO.map((cat, idx) => (
                <div id={`edit-tab-${idx}`} class={`edit-tab-pane space-y-2 ${idx === 0 ? '' : 'hidden'}`}>
                  {cat.items.map((item) => (
                    <div class="flex flex-col gap-1 py-1 border-b border-canvas-soft last:border-b-0">
                      <span class="text-[11px] font-uber-text text-ink font-medium">{item.nombre}</span>
                      <div class="flex gap-0.5 bg-canvas-soft p-0.5 rounded-lg w-full overflow-x-auto">
                        {["Crítico", "Alerta", "Estable", "Excedente"].map((est) => {
                          let activeClass = "";
                          if (est === "Crítico") activeClass = "has-[:checked]:bg-red-500 has-[:checked]:text-white";
                          else if (est === "Alerta") activeClass = "has-[:checked]:bg-amber-500 has-[:checked]:text-white";
                          else if (est === "Estable") activeClass = "has-[:checked]:bg-green-600 has-[:checked]:text-white";
                          else if (est === "Excedente") activeClass = "has-[:checked]:bg-blue-600 has-[:checked]:text-white";

                          return (
                            <label class={`flex-grow text-center py-1 text-[9px] rounded-md cursor-pointer transition-all font-semibold font-uber-text select-none border border-transparent hover:bg-surface-pressed ${activeClass}`}>
                              <input 
                                type="radio" 
                                name={`edit-inv-${item.id}`} 
                                value={est} 
                                class="hidden" 
                              />
                              {est}
                            </label>
                          );
                        })}
                      </div>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-necesidades">Notas Adicionales de Necesidades (Texto Libre)</label>
            <textarea 
              id="edit-necesidades" 
              rows="2"
              class="textarea w-full font-uber-text uber-body-md" 
              placeholder="Ej: Agua mineral, mantas, leche de fórmula..."
            ></textarea>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-contacto">Teléfono o Datos de Contacto</label>
            <input 
              type="text" 
              id="edit-contacto" 
              class="input w-full font-uber-text uber-body-md" 
              placeholder="Ej: 0412-1234567"
            />
          </div>

          <div class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-3">
            <span class="text-xs font-semibold text-ink font-uber-text block">📸 Fotos del Centro</span>
            
            <!-- Fotos Existentes -->
            <div id="edit-preview-existentes" class="grid grid-cols-3 gap-2 empty:hidden">
              <!-- Cargadas por JS -->
            </div>
            
            <!-- Subir nuevas -->
            <div class="flex flex-col gap-2 border-t border-canvas-soft pt-2">
              <span class="text-[10px] font-bold text-mute uppercase font-uber-text">Subir nuevas fotos (Máx 3 en total)</span>
              <input 
                type="file" 
                id="edit-fotos-nuevas" 
                multiple 
                accept="image/*" 
                class="block w-full text-xs text-mute font-uber-text file:mr-4 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary file:text-white hover:file:bg-primary-hover cursor-pointer"
              />
              <div id="edit-preview-nuevas" class="grid grid-cols-3 gap-2 mt-2">
                <!-- Nuevas previsualizaciones -->
              </div>
            </div>
          </div>

          <div id="edit-refugio-error" x-show="error" x-text="error" class="text-xs text-red-500 font-uber-text bg-red-500/5 border border-red-500/20 p-3 rounded-lg"></div>

          <button type="submit" class="btn bg-primary text-white w-full font-uber-text font-semibold py-2.5 rounded-xl">
            Guardar Cambios
          </button>
        </form>
      </div>
    </div>

<script>
  let editMap: any = null;
  let editMarker: any = null;
  let lastEditedCardId = "";

  const ITEM_MAP: Record<string, string> = {
    agua_potable: "Agua potable embotellada",
    botellones_agua: "Botellones (Para cocina o hidratación masiva)",
    pastillas_potabilizadoras: "Pastillas Potabilizadoras",
    cloro_potabilizacion: "Cloro Líquido / Pastillas de Cloro (Para desinfección)",
    tanques_envases: "Tanques / Envases Vacíos",
    alimentos_enlatados: "Alimentos enlatados (atún, sardina, granos)",
    arroz_harina: "Carbohidratos Secos (arroz, pasta, harina de maíz)",
    pasta_granos: "Granos y Legumbres (caraotas, lentejas, arvejas)",
    leche_polvo: "Proteína en Polvo / Larga Duración (Leche en polvo, embutidos)",
    comida_lista: "Comida Lista para Consumo (Galletas, barras, frutos secos)",
    aceite_comestible: "Aceite comestible",
    azucar_sal: "Azúcar / Sal",
    papillas_adultos_mayores: "Papillas y comida líquida para adultos mayores",
    jabon_champu: "Jabón de baño / Champú",
    crema_cepillo: "Crema dental / Cepillo de dientes",
    papel_higienico: "Papel higiénico",
    toallas_sanitarias: "Toallas sanitarias / Tampón",
    desodorante: "Desodorante (unisex)",
    toallitas_humedas: "Toallitas húmedas",
    detergente_jabon: "Detergente para ropa / Jabón de platos",
    cloro_desinfectante: "Desinfectante / Limpiador de pisos",
    bolsas_basura: "Bolsas para basura de alta resistencia",
    alcohol_oxigenada: "Alcohol / Agua oxigenada",
    gasas_vendas: "Gasas / Vendas / Adhesivos médicos",
    analgesicos: "Analgésicos (Paracetamol, Ibuprofeno)",
    antialergicos: "Antialérgicos (Loratadina)",
    medicos_cronicos: "Medicamentos crónicos (Presión, Diabetes)",
    antibioticos: "Antibióticos de amplio espectro",
    suero_hidratacion: "Suero de hidratación oral",
    tapabocas_guantes: "Tapabocas / Guantes desechables",
    termometros: "Termómetros",
    agujas_inyectadoras: "Agujas / Inyectadoras",
    panales_bebe: "Pañales desechables para bebés",
    leche_formula: "Leche de fórmula infantil",
    biberones: "Teteros / Biberones limpios",
    papillas_compotas: "Papillas / Compotas",
    ropa_bebe: "Ropa de bebé",
    champu_jabon_bebe: "Champú y jabón especial para bebé",
    pomadas_antipanalitis: "Pomadas antipañalitis",
    corrales_cunas: "Cunas de viaje / Corrales plegables",
    colchonetas_esterillas: "Colchonetas / Esterillas",
    mantas_cobijas: "Mantas / Cobijas / Sábanas",
    linternas_velas: "Linternas con pilas / Velas",
    baterias_powerbanks: "Baterías portátiles (Powerbanks)",
    repelente_mosquitos: "Repelente de mosquitos",
    herramientas_basicas: "Kit de herramientas básicas",
    fosforos_encendedores: "Fósforos / Encendedores",
    toldos_carpas: "Toldos / Carpas / Lonas plásticas",
    ropa_abrigo: "Ropa abrigada / Impermeables",
    brazaletes_identificadores: "Brazaletes identificadores",
    pulseras_gps: "Pulseras GPS",
    papeleria: "Papelería (bolígrafos, cuadernos, marcadores)",
    silbatos_pitos: "Silbatos y pitos",
    comida_mascotas: "Comida para mascotas (Perros/Gatos)",
    medicinas_mascotas: "Medicinas / Insumos veterinarios básicos",
    entretenimiento_infantil: "Entretenimiento infantil",
    actividades_culturales: "Actividades culturales",
    baile_musica: "Baile y música",
    veterinario: "Atención Veterinaria"
  };

  document.addEventListener('astro:page-load', () => {
    // Limpieza de mapa de edición
    if (editMap) {
      try { editMap.remove(); } catch (e) {}
      editMap = null;
    }
    editMarker = null;

    const modal = document.getElementById("modal-edit-refugio");
    const closeBtn = document.getElementById("btn-close-edit");
    const form = document.getElementById("form-edit-refugio") as HTMLFormElement;
    const errorDiv = document.getElementById("edit-refugio-error");

    const inputId = document.getElementById("edit-refugio-id") as HTMLInputElement;
    const selectTipo = document.getElementById("edit-tipo") as HTMLSelectElement;
    const inputEncargado = document.getElementById("edit-encargado") as HTMLInputElement;
    const inputDireccion = document.getElementById("edit-direccion") as HTMLInputElement;
    const btnEditBuscarDireccion = document.getElementById("btn-edit-buscar-direccion");
    const inputOcupacion = document.getElementById("edit-ocupacion") as HTMLInputElement;
    const inputCapacidad = document.getElementById("edit-capacidad") as HTMLInputElement;
    const inputNecesidades = document.getElementById("edit-necesidades") as HTMLTextAreaElement;
    const inputContacto = document.getElementById("edit-contacto") as HTMLInputElement;
    const editTitulo = document.getElementById("edit-refugio-titulo");

    const inputNinos = document.getElementById("edit-ninos") as HTMLInputElement;
    const inputBebes = document.getElementById("edit-bebes") as HTMLInputElement;
    const inputMayores = document.getElementById("edit-mayores") as HTMLInputElement;
    const inputProf = document.getElementById("edit-prof") as HTMLInputElement;
    const inputVols = document.getElementById("edit-vols") as HTMLInputElement;

    const latEditInput = document.getElementById("edit-latitud") as HTMLInputElement;
    const lonEditInput = document.getElementById("edit-longitud") as HTMLInputElement;
    const gpsEditStatus = document.getElementById("edit-gps-status");
    const btnEditGps = document.getElementById("btn-edit-ref-gps");

    const previewExistentes = document.getElementById("edit-preview-existentes");
    const inputFotosNuevas = document.getElementById("edit-fotos-nuevas") as HTMLInputElement;
    const previewNuevas = document.getElementById("edit-preview-nuevas");
    
    let existingFotos: string[] = [];
    let newFilesToUpload: File[] = [];

    function renderEditPreviews() {
      if (previewExistentes) {
        previewExistentes.innerHTML = "";
        existingFotos.forEach((fotoKey, index) => {
          const div = document.createElement("div");
          div.className = "relative aspect-square rounded-lg overflow-hidden border border-canvas-soft bg-surface-pressed";
          
          const img = document.createElement("img");
          img.src = `/api/upload?key=${fotoKey}`;
          img.className = "w-full h-full object-cover";
          
          const removeBtn = document.createElement("button");
          removeBtn.type = "button";
          removeBtn.innerHTML = "✕";
          removeBtn.className = "absolute top-1 right-1 bg-black/60 hover:bg-black text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center border-none cursor-pointer";
          removeBtn.addEventListener("click", () => {
            existingFotos.splice(index, 1);
            renderEditPreviews();
          });
          
          div.appendChild(img);
          div.appendChild(removeBtn);
          previewExistentes.appendChild(div);
        });
      }
      
      if (previewNuevas) {
        previewNuevas.innerHTML = "";
        newFilesToUpload.forEach((file, index) => {
          const url = URL.createObjectURL(file);
          const div = document.createElement("div");
          div.className = "relative aspect-square rounded-lg overflow-hidden border border-canvas-soft bg-surface-pressed";
          
          const img = document.createElement("img");
          img.src = url;
          img.className = "w-full h-full object-cover";
          
          const removeBtn = document.createElement("button");
          removeBtn.type = "button";
          removeBtn.innerHTML = "✕";
          removeBtn.className = "absolute top-1 right-1 bg-black/60 hover:bg-black text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center border-none cursor-pointer";
          removeBtn.addEventListener("click", () => {
            newFilesToUpload.splice(index, 1);
            URL.revokeObjectURL(url);
            renderEditPreviews();
          });
          
          div.appendChild(img);
          div.appendChild(removeBtn);
          previewNuevas.appendChild(div);
        });
      }
    }

    inputFotosNuevas?.addEventListener("change", () => {
      if (!inputFotosNuevas.files) return;
      const newFiles = Array.from(inputFotosNuevas.files);
      for (const file of newFiles) {
        if (existingFotos.length + newFilesToUpload.length < 3) {
          newFilesToUpload.push(file);
        }
      }
      inputFotosNuevas.value = "";
      renderEditPreviews();
    });

    function mostrarInfoGoogleModal(data: any) {
      const container = document.getElementById("edit-google-place-info");
      const content = document.getElementById("edit-gpi-content");
      if (!container || !content) return;

      const items: string[] = [];

      if (data.name) {
        items.push(`<div class="flex items-center gap-1"><span class="font-semibold text-ink">🏛️ ${data.name}</span></div>`);
      }

      if (data.estado_operativo || data.estado_label) {
        const label = data.estado_label || data.estado || data.estado_operativo;
        const isOpen = data.estado_operativo === "OPERATIONAL";
        const isClosed = data.estado_operativo?.includes("CLOSED");
        const color = isOpen ? "text-green-700 bg-green-100" : isClosed ? "text-red-700 bg-red-100" : "text-gray-700 bg-gray-100";
        items.push(`<div><span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold ${color}">${isOpen ? "🟢" : isClosed ? "🔴" : "⚪"} ${label}</span></div>`);
      }

      if (data.abierto_ahora !== undefined) {
        const badge = data.abierto_ahora 
          ? '<span class="text-green-700 font-semibold">✅ Abierto ahora</span>'
          : '<span class="text-orange-600 font-semibold">🚫 Cerrado ahora</span>';
        items.push(`<div>${badge}</div>`);
      }

      if (data.accesible !== undefined) {
        items.push(`<div>${data.accesible ? "♿ Acceso para silla de ruedas" : "⚠️ Sin acceso confirmado para silla de ruedas"}</div>`);
      }

      if (data.horario && data.horario.length > 0) {
        const horarioHtml = data.horario.map((h: string) => `<div class="pl-3 text-[10px]">${h}</div>`).join("");
        items.push(`<details class="cursor-pointer"><summary class="font-semibold text-ink">🕐 Horario</summary><div class="mt-1 space-y-0.5">${horarioHtml}</div></details>`);
      }

      if (data.phone_international || data.phone) {
        const tel = data.phone_international || data.phone;
        items.push(`<div>📞 <a href="tel:${tel.replace(/\s/g, '')}" class="text-blue-600 underline font-semibold">${tel}</a></div>`);
      }

      if (data.website) {
        const domain = data.website.replace(/^https?:\/\//, "").replace(/\/$/, "").substring(0, 40);
        items.push(`<div>🌐 <a href="${data.website}" target="_blank" rel="noopener" class="text-blue-600 underline">${domain}</a></div>`);
      }

      if (data.google_maps_url) {
        items.push(`<div>🗺️ <a href="${data.google_maps_url}" target="_blank" rel="noopener" class="text-blue-600 underline">Ver en Google Maps</a></div>`);
      }

      if (data.estado || data.municipio) {
        const parts = [data.municipio, data.estado].filter(Boolean);
        items.push(`<div>📌 ${parts.join(", ")}</div>`);
      }

      if (items.length > 0) {
        content.innerHTML = items.join("");
        window.dispatchEvent(new CustomEvent('show-gpi'));
      } else {
        window.dispatchEvent(new CustomEvent('hide-gpi'));
      }
    }

    function initEditMap(lat: number, lon: number, zoom = 15) {
      if (typeof (window as any).L === "undefined") return;
      const L = (window as any).L;

      if (!editMap) {
        editMap = L.map("edit-gps-map", {
          zoomControl: true,
          attributionControl: false
        }).setView([lat, lon], zoom);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
        }).addTo(editMap);

        editMap.on("click", (e: any) => {
          const clat = e.latlng.lat;
          const clon = e.latlng.lng;
          latEditInput.value = clat.toFixed(6);
          lonEditInput.value = clon.toFixed(6);
          
          if (editMarker) {
            editMarker.setLatLng(e.latlng);
          } else {
            editMarker = L.marker(e.latlng).addTo(editMap);
          }

          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Ubicación modificada: ${clat.toFixed(5)}, ${clon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-blue-600 font-uber-text italic font-medium";
          }
        });
      }

      if (editMarker) {
        editMarker.setLatLng([lat, lon]);
      } else {
        editMarker = L.marker([lat, lon]).addTo(editMap);
      }
      editMap.setView([lat, lon], zoom);
      
      setTimeout(() => {
        if (editMap) editMap.invalidateSize();
      }, 200);
    }

    const editTabBtns = document.querySelectorAll(".edit-tab-btn");
    editTabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        editTabBtns.forEach((b) => {
          b.classList.remove("bg-primary", "text-white", "border-primary");
          b.classList.add("bg-canvas-soft", "text-ink", "border-transparent");
        });
        btn.classList.add("bg-primary", "text-white", "border-primary");
        btn.classList.remove("bg-canvas-soft", "text-ink", "border-transparent");

        document.querySelectorAll(".edit-tab-pane").forEach((pane) => pane.classList.add("hidden"));
        const targetId = btn.getAttribute("data-target");
        if (targetId) {
          document.getElementById(targetId)?.classList.remove("hidden");
        }
      });
    });

    const tabEditGps = document.getElementById("tab-edit-gps");
    const tabEditGmaps = document.getElementById("tab-edit-gmaps");
    const tabEditMap = document.getElementById("tab-edit-map");

    const panelEditGps = document.getElementById("panel-edit-gps");
    const panelEditGmaps = document.getElementById("panel-edit-gmaps");
    const panelEditMap = document.getElementById("panel-edit-map");

    function deseleccionarEditTabs() {
      [tabEditGps, tabEditGmaps, tabEditMap].forEach(tab => {
        tab?.classList.remove("bg-primary", "text-white");
        tab?.classList.add("bg-transparent", "text-ink");
      });
      [panelEditGps, panelEditGmaps, panelEditMap].forEach(panel => panel?.classList.add("hidden"));
    }

    tabEditGps?.addEventListener("click", () => {
      deseleccionarEditTabs();
      tabEditGps.classList.add("bg-primary", "text-white");
      tabEditGps.classList.remove("bg-transparent", "text-ink");
      panelEditGps?.classList.remove("hidden");
    });

    tabEditGmaps?.addEventListener("click", () => {
      deseleccionarEditTabs();
      tabEditGmaps.classList.add("bg-primary", "text-white");
      tabEditGmaps.classList.remove("bg-transparent", "text-ink");
      panelEditGmaps?.classList.remove("hidden");
    });

    tabEditMap?.addEventListener("click", () => {
      deseleccionarEditTabs();
      tabEditMap.classList.add("bg-primary", "text-white");
      tabEditMap.classList.remove("bg-transparent", "text-ink");
      panelEditMap?.classList.remove("hidden");
    });

    btnEditGps?.addEventListener("click", () => {
      if (!navigator.geolocation) {
        alert("Geolocalización no soportada.");
        return;
      }
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Detectando GPS...";
        gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lon = position.coords.longitude;
          latEditInput.value = lat.toFixed(6);
          lonEditInput.value = lon.toFixed(6);
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Ubicación GPS: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          initEditMap(lat, lon, 15);
        },
        () => {
          if (gpsEditStatus) {
            gpsEditStatus.textContent = "No se pudo obtener ubicación.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      );
    });

    btnEditBuscarDireccion?.addEventListener("click", async () => {
      const dir = inputDireccion.value.trim();
      if (!dir) {
        alert("Introduce una dirección.");
        return;
      }
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Buscando coordenadas...";
        gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
      }

      try {
        const resp = await fetch(`/api/maps/geocode?address=${encodeURIComponent(dir)}`);
        if (resp.ok) {
          const data = await resp.json();
          const lat = data.lat;
          const lon = data.lng;
          latEditInput.value = lat.toFixed(6);
          lonEditInput.value = lon.toFixed(6);
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Encontrado: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          
          if (data.formatted_address) {
            inputDireccion.value = data.formatted_address;
          }
          if (data.phone && !inputContacto.value) {
            inputContacto.value = data.phone;
          }
          if (data.tipo && selectTipo.value === "refugio") {
            selectTipo.value = data.tipo;
          }

          mostrarInfoGoogleModal(data);
          initEditMap(lat, lon, 15);
        } else {
          if (gpsEditStatus) {
            gpsEditStatus.textContent = "No encontrado. Intenta con más detalles.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      } catch {
        if (gpsEditStatus) {
          gpsEditStatus.textContent = "Error al buscar dirección.";
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    });

    const btnEditResolverGmaps = document.getElementById("btn-edit-resolver-gmaps");
    const inputEditGmaps = document.getElementById("edit-gmaps-link") as HTMLInputElement;

    btnEditResolverGmaps?.addEventListener("click", async () => {
      const url = inputEditGmaps.value.trim();
      if (!url) {
        alert("Pega un enlace de Google Maps.");
        return;
      }
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Resolviendo enlace...";
        gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
      }

      try {
        const resp = await fetch("/api/maps/resolve", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url })
        });
        if (resp.ok) {
          const data = await resp.json();
          latEditInput.value = data.lat.toFixed(6);
          lonEditInput.value = data.lng.toFixed(6);

          if (data.formatted_address) {
            inputDireccion.value = data.formatted_address;
          }
          if (data.phone && !inputContacto.value) {
            inputContacto.value = data.phone;
          }
          if (data.tipo && selectTipo.value === "refugio") {
            selectTipo.value = data.tipo;
          }

          mostrarInfoGoogleModal(data);

          if (data.aproximado) {
            if (gpsEditStatus) {
              gpsEditStatus.textContent = `⚠️ Ubicación aproximada: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)} — Ajusta el pin tocando el mapa.`;
              gpsEditStatus.className = "text-[11px] text-amber-600 font-uber-text italic font-semibold";
            }
            initEditMap(data.lat, data.lng, 16);
          } else {
            if (gpsEditStatus) {
              gpsEditStatus.textContent = `Resuelto: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
              gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
            }
            initEditMap(data.lat, data.lng, 17);
          }
        } else {
          const err = await resp.json();
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Error: ${err.error}`;
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      } catch {
        if (gpsEditStatus) {
          gpsEditStatus.textContent = "Error de conexión.";
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    });

    document.querySelectorAll(".btn-edit-refugio").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el = btn as HTMLElement;
        const card = el.closest(".refugio-card");
        lastEditedCardId = card ? card.id : "";
        const tipo = el.dataset.tipo || "refugio";
        
        if (inputId) inputId.value = el.dataset.id || "";
        if (selectTipo) selectTipo.value = tipo;
        if (inputEncargado) inputEncargado.value = el.dataset.encargado || "";
        if (inputDireccion) inputDireccion.value = el.dataset.direccion || "";

        const editCapacitySec = document.getElementById("edit-capacity-section");
        const editDemographicsSec = document.getElementById("edit-demographics-section");
        const editInventorySec = document.getElementById("edit-inventory-section");

        if (tipo === "refugio") {
          editCapacitySec?.classList.remove("hidden");
          editDemographicsSec?.classList.remove("hidden");
          editInventorySec?.classList.remove("hidden");
          
          if (inputOcupacion) {
            inputOcupacion.setAttribute("required", "true");
            inputOcupacion.value = el.dataset.ocupacion || "0";
          }
          if (inputCapacidad) {
            inputCapacidad.setAttribute("required", "true");
            inputCapacidad.value = el.dataset.capacidad || "100";
          }
        } else if (tipo === "centro_acopio") {
          editCapacitySec?.classList.add("hidden");
          editDemographicsSec?.classList.add("hidden");
          editInventorySec?.classList.remove("hidden");
          
          inputOcupacion?.removeAttribute("required");
          inputCapacidad?.removeAttribute("required");
        } else {
          // hospital
          editCapacitySec?.classList.add("hidden");
          editDemographicsSec?.classList.add("hidden");
          editInventorySec?.classList.add("hidden");
          
          inputOcupacion?.removeAttribute("required");
          inputCapacidad?.removeAttribute("required");
        }

        existingFotos = [];
        try {
          if (el.dataset.fotos) {
            existingFotos = JSON.parse(el.dataset.fotos);
          }
        } catch (err) {
          console.error("Error al parsear fotos:", err);
        }
        newFilesToUpload = [];
        if (inputFotosNuevas) inputFotosNuevas.value = "";
        renderEditPreviews();
        if (inputNecesidades) inputNecesidades.value = el.dataset.necesidades || "";
        if (inputContacto) inputContacto.value = el.dataset.contacto || "";
        if (editTitulo) editTitulo.textContent = `Actualizar: ${el.dataset.nombre}`;
        
        // Reset the submit button just in case
        const form = document.getElementById("form-edit-refugio") as HTMLFormElement;
        if (form) {
          const btnSubmit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
          if (btnSubmit) {
            btnSubmit.disabled = false;
            btnSubmit.textContent = "Guardar Cambios";
          }
        }
        
        const gpiCard = document.getElementById("edit-google-place-info");
        window.dispatchEvent(new CustomEvent('hide-gpi'));

        if (inputNinos) inputNinos.value = el.dataset.ninos || "0";
        if (inputBebes) inputBebes.value = el.dataset.bebes || "0";
        if (inputMayores) inputMayores.value = el.dataset.mayores || "0";
        if (inputProf) inputProf.value = el.dataset.prof || "0";
        if (inputVols) inputVols.value = el.dataset.vols || "0";

        const latRaw = el.dataset.lat || "";
        const lngRaw = el.dataset.lng || "";
        latEditInput.value = latRaw;
        lonEditInput.value = lngRaw;

        if (gpsEditStatus) {
          if (latRaw && lngRaw) {
            gpsEditStatus.textContent = `Coordenadas cargadas: ${parseFloat(latRaw).toFixed(5)}, ${parseFloat(lngRaw).toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-mute font-uber-text italic";
          } else {
            gpsEditStatus.textContent = "Ubicación no establecida.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }

        deseleccionarEditTabs();
        tabEditGps?.classList.add("bg-primary", "text-white");
        panelEditGps?.classList.remove("hidden");
        if (inputEditGmaps) inputEditGmaps.value = "";

        const lat = latRaw ? parseFloat(latRaw) : 10.4806;
        const lon = lngRaw ? parseFloat(lngRaw) : -66.9036;
        const zoom = latRaw && lngRaw ? 15 : 12;
        initEditMap(lat, lon, zoom);

        let inventarioObj: Record<string, string> = {};
        try {
          if (el.dataset.inventario) {
            inventarioObj = JSON.parse(el.dataset.inventario);
          }
        } catch (err) {
          console.error("Error al parsear dataset de inventario:", err);
        }

        const radios = form.querySelectorAll('input[type="radio"]');
        radios.forEach((r: any) => {
          r.checked = false;
          if (r.name.startsWith("edit-inv-")) {
            const itemId = r.name.replace("edit-inv-", "");
            const valorEsperado = inventarioObj[itemId] || "Estable";
            if (r.value === valorEsperado) {
              r.checked = true;
            }
          }
        });

        if (errorDiv) {
          errorDiv.textContent = "";
          errorDiv.classList.add("hidden");
        }

        window.dispatchEvent(new CustomEvent('open-edit-modal', { detail: { tipo } }));
        document.body.style.overflow = "hidden";
      });
    });

    function cerrarModal() {
      window.dispatchEvent(new CustomEvent('close-edit-modal'));
      document.body.style.overflow = "";
    }

    closeBtn?.addEventListener("click", cerrarModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) cerrarModal();
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = inputId.value;
      const tipo = selectTipo.value || "refugio";
      const encargado = inputEncargado.value.trim();
      const direccion = inputDireccion.value.trim();
      const ocupacion = tipo === "refugio" ? (parseInt(inputOcupacion.value, 10) || 0) : 0;
      const capacidad = tipo === "refugio" ? (parseInt(inputCapacidad.value, 10) || 100) : 0;
      const necesidades = inputNecesidades.value.trim();
      const contacto = inputContacto.value.trim();
      const lat = latEditInput.value;
      const lon = lonEditInput.value;

      const ninos = tipo === "refugio" ? (parseInt(inputNinos.value) || 0) : 0;
      const bebes = tipo === "refugio" ? (parseInt(inputBebes.value) || 0) : 0;
      const mayores = tipo === "refugio" ? (parseInt(inputMayores.value) || 0) : 0;
      const prof = tipo === "refugio" ? (parseInt(inputProf.value) || 0) : 0;
      const vols = tipo === "refugio" ? (parseInt(inputVols.value) || 0) : 0;

      const sumaSubgrupos = ninos + bebes + mayores + prof + vols;

      if (tipo === "refugio") {
        if (ocupacion < sumaSubgrupos) {
          window.dispatchEvent(new CustomEvent('show-warning'));
          if (errorDiv) {
            errorDiv.textContent = "Error: La Población Total no puede ser menor a la suma de niños, bebés, adultos mayores, profesionales y voluntarios.";
            errorDiv.classList.remove("hidden");
          }
          return;
        } else {
          window.dispatchEvent(new CustomEvent('hide-warning'));
        }

        if (isNaN(ocupacion) || ocupacion < 0) {
          alert("Ocupación inválida");
          return;
        }
        if (isNaN(capacidad) || capacidad <= 0) {
          alert("Capacidad inválida");
          return;
        }
      }

      if (errorDiv) errorDiv.classList.add("hidden");

      const btnSubmit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (btnSubmit) {
        btnSubmit.disabled = true;
        btnSubmit.textContent = "Subiendo imágenes...";
      }

      const fotosKeys = [...existingFotos];
      if (newFilesToUpload.length > 0) {
        for (const file of newFilesToUpload) {
          const formData = new FormData();
          formData.append("foto", file);
          try {
            const uploadResp = await fetch("/api/upload", {
              method: "POST",
              body: formData,
            });
            if (uploadResp.ok) {
              const data = await uploadResp.json();
              if (data.key) {
                fotosKeys.push(data.key);
              }
            }
          } catch (uploadErr) {
            console.error("Error al subir imagen nueva:", uploadErr);
          }
        }
      }

      if (btnSubmit) {
        btnSubmit.textContent = "Guardando cambios...";
      }

      const inventario: Record<string, string> = {};
      const radios = form.querySelectorAll('input[type="radio"]:checked');
      radios.forEach((radio: any) => {
        if (radio.name.startsWith("edit-inv-")) {
          const itemId = radio.name.replace("edit-inv-", "");
          inventario[itemId] = radio.value;
        }
      });

      const payload = {
        ocupacion_actual: ocupacion,
        capacidad_maxima: capacidad,
        necesidades,
        contacto,
        tipo,
        encargado,
        direccion,
        latitud: lat,
        longitud: lon,
        ninos,
        bebes_lactantes: bebes,
        adultos_mayores: mayores,
        personal_profesional: prof,
        voluntarios: vols,
        inventario,
        fotos: fotosKeys
      };

      try {
        const resp = await fetch(`/api/refugios/${id}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        if (resp.ok) {
          const json = await resp.json();
          const r = json.refugio;
          cerrarModal();
          
          const itemsCriticos: string[] = [];
          const itemsAlerta: string[] = [];
          const invData = typeof r.inventario === 'string' ? JSON.parse(r.inventario) : (r.inventario || {});
          for (const [itemId, estado] of Object.entries(invData)) {
            const itemName = ITEM_MAP[itemId];
            if (itemName) {
              if (estado === "Crítico") itemsCriticos.push(itemName);
              else if (estado === "Alerta") itemsAlerta.push(itemName);
            }
          }

          let fechaActualizada = new Date().toLocaleString('es-VE', { 
            dateStyle: 'short', 
            timeStyle: 'short' 
          }).replace(/\//g, "-");
          if (r.updated_at) {
            const d = new Date(r.updated_at);
            if (!isNaN(d.getTime())) {
              fechaActualizada = d.toLocaleString('es-VE', { dateStyle: 'short', timeStyle: 'short' }).replace(/\//g, "-");
            }
          }

          let fotosParsed = [];
          try { fotosParsed = typeof r.fotos === 'string' ? JSON.parse(r.fotos) : (r.fotos || []); } catch {}

          const cardEl = document.getElementById(`refugio-${id}`);
          if (cardEl) {
            cardEl.dispatchEvent(new CustomEvent('update-refugio', {
              detail: {
                ...r,
                fotos: fotosParsed,
                inventario: invData,
                itemsCriticos,
                itemsAlerta,
                fechaActualizada
              }
            }));
          }

          const toast = document.getElementById('index-success-toast');
          if (toast) {
            toast.classList.remove('hidden');
            setTimeout(() => {
              toast.classList.add('hidden');
            }, 3000);
          }
        } else {
          const err = await resp.json();
          if (errorDiv) {
            errorDiv.textContent = `Error: ${err.error || "no se pudo actualizar"}`;
            errorDiv.classList.remove("hidden");
          }
        }
      } catch {
        if (errorDiv) {
          errorDiv.textContent = "Error de conexión con el servidor.";
          errorDiv.classList.remove("hidden");
        }
      } finally {
        if (btnSubmit) {
          btnSubmit.disabled = false;
          btnSubmit.textContent = "Guardar Cambios";
        }
      }
    });
  });
</script>
