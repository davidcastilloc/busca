---
interface Props {
  persona: {
    id: number;
    cedula?: string | null;
    nombre: string;
    apellido?: string | null;
    edad?: number | null;
    sexo?: string | null;
    estado: 'vivo' | 'herido' | 'fallecido' | 'desconocido';
    ubicacion_nombre?: string | null;
    latitud?: number | null;
    longitud?: number | null;
    refugio?: string | null;
    contacto?: string | null;
    notas?: string | null;
    foto_key?: string | null;
    fuente?: string | null;
    updated_at: string;
    score?: number; // Para búsquedas semánticas
    verificacion?: string | null;
  };
}

const { persona } = Astro.props;

// Clases de color para estados
const estadoConfig = {
  vivo: { badge: "badge-success text-white", border: "border-success/30", text: "Vivo / A salvo" },
  herido: { badge: "badge-warning text-black", border: "border-warning/30", text: "Herido" },
  fallecido: { badge: "badge-error text-white", border: "border-error/30", text: "Fallecido" },
  desconocido: { badge: "badge-neutral text-white", border: "border-neutral/30", text: "Desconocido" }
};

let config = estadoConfig[persona.estado] || estadoConfig.desconocido;

if (persona.verificacion === "pendiente") {
  config = { badge: "badge-warning text-black", border: "border-warning/30", text: "A salvo (Sin confirmar)" };
}

const formatFecha = (fechaStr: string) => {
  try {
    const d = new Date(fechaStr + " UTC");
    return d.toLocaleString("es-ES", { timeZone: "America/Caracas" });
  } catch (e) {
    return fechaStr;
  }
};
---

<div class={`card card-side bg-base-100 shadow-md border-l-4 ${config.border} flex-col sm:flex-row overflow-hidden transition-transform duration-200 hover:scale-[1.01]`}>
  <!-- Foto de R2 -->
  {persona.foto_key ? (
    <figure class="w-full aspect-[4/3] sm:aspect-auto sm:w-44 sm:self-stretch shrink-0 bg-base-300 relative flex items-center justify-center overflow-hidden">
      <img 
        src={`/api/upload?key=${encodeURIComponent(persona.foto_key)}`} 
        alt={`Foto de ${persona.nombre}`} 
        class="w-full h-full object-contain"
        loading="lazy"
      />
    </figure>
  ) : (
    <div class="w-full aspect-[4/3] sm:aspect-auto sm:w-44 sm:self-stretch shrink-0 bg-base-300 flex items-center justify-center text-4xl select-none">
      👤
    </div>
  )}

  <div class="card-body p-5 flex flex-col justify-between">
    <div>
      <div class="flex flex-wrap items-center justify-between gap-2 mb-1.5">
        <h2 class="card-title text-xl font-bold tracking-tight">
          {persona.nombre} {persona.apellido || ""}
        </h2>
        
        <div class="flex items-center gap-1.5">
          {persona.score !== undefined && (
            <div class="badge badge-info font-black gap-1 text-white text-xs">
              🎯 Similitud: {Math.round(persona.score * 100)}%
            </div>
          )}
          <div class={`badge font-black text-xs ${config.badge}`}>
            {config.text}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-sm mb-3">
        {persona.cedula && (
          <div>
            <span class="text-base-content/50 font-semibold">Documento:</span> 
            <span class="font-bold">{persona.cedula}</span>
          </div>
        )}
        {(persona.edad !== undefined && persona.edad !== null) && (
          <div>
            <span class="text-base-content/50 font-semibold">Edad:</span> 
            <span class="font-bold">{persona.edad} años</span>
          </div>
        )}
        {persona.sexo && (
          <div>
            <span class="text-base-content/50 font-semibold">Sexo:</span> 
            <span class="font-bold">{persona.sexo}</span>
          </div>
        )}
        {persona.refugio && (
          <div class="col-span-2">
            <span class="text-base-content/50 font-semibold">📍 Refugio:</span> 
            <span class="font-bold text-success-content bg-success/10 px-1.5 py-0.5 rounded">{persona.refugio}</span>
          </div>
        )}
        {persona.ubicacion_nombre && (
          <div class="col-span-2">
            <span class="text-base-content/50 font-semibold">📍 Zona:</span> 
            <span class="font-bold">{persona.ubicacion_nombre}</span>
          </div>
        )}
        {(persona.latitud && persona.longitud) && (
          <div class="col-span-2 text-xs text-base-content/60 font-mono">
            GPS: {persona.latitud.toFixed(5)}, {persona.longitud.toFixed(5)}
          </div>
        )}
      </div>

      {persona.notas && (
        <div class="bg-base-200 p-2.5 rounded-lg text-sm border-l-2 border-base-300 italic mb-2.5 text-base-content/90">
          "{persona.notas}"
        </div>
      )}
    </div>

    <div class="flex flex-wrap items-center justify-between text-xs text-base-content/50 border-t border-base-200 pt-2.5 mt-auto">
      <div>Fuente: <span class="font-bold capitalize">{persona.fuente || "web"}</span></div>
      <div>Actualizado: <span class="font-semibold">{formatFecha(persona.updated_at)}</span></div>
    </div>
  </div>
</div>
