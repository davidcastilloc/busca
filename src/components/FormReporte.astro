---
import MapaUbicacion from "./MapaUbicacion.astro";
import FotoUpload from "./FotoUpload.astro";

interface Props {
  isVolunteer?: boolean;
  volunteerName?: string;
  volunteerPhone?: string;
}

const { isVolunteer = false, volunteerName = "", volunteerPhone = "" } = Astro.props;

import { env } from "cloudflare:workers";
let refugios: any[] = [];
try {
  const { DB } = env;
  if (DB) {
    const res = await DB.prepare(`
      SELECT id, nombre, latitud, longitud, 'refugio' as tipo FROM refugios
      UNION ALL
      SELECT id, nombre, latitud, longitud, 'hospital' as tipo FROM hospitales
      UNION ALL
      SELECT id, nombre, latitud, longitud, 'centro_acopio' as tipo FROM centros_acopio
      ORDER BY nombre ASC
    `).all();
    refugios = res.results || [];
  }
} catch (e) {
  console.error("Error al cargar refugios en FormReporte:", e);
}
---

<div class="max-w-2xl mx-auto px-4 py-4 sm:py-6">
  <!-- Cabecera de Progreso -->
  <div class="mb-8 flex justify-between items-center px-2">
    <div class="flex items-center space-x-2">
      <div id="step-ind-1" class="w-8 h-8 rounded-full flex items-center justify-center bg-primary text-white font-uber-display text-sm transition-colors">1</div>
      <span id="step-txt-1" class="text-xs font-uber-text font-bold text-ink transition-colors">Tipo</span>
    </div>
    <div class="flex-grow h-0.5 bg-canvas-soft mx-2"></div>
    <div class="flex items-center space-x-2">
      <div id="step-ind-2" class="w-8 h-8 rounded-full flex items-center justify-center bg-canvas-soft text-mute font-uber-display text-sm transition-colors">2</div>
      <span id="step-txt-2" class="text-xs font-uber-text text-body transition-colors">Detalles</span>
    </div>
    <div class="flex-grow h-0.5 bg-canvas-soft mx-2"></div>
    <div class="flex items-center space-x-2">
      <div id="step-ind-3" class="w-8 h-8 rounded-full flex items-center justify-center bg-canvas-soft text-mute font-uber-display text-sm transition-colors">3</div>
      <span id="step-txt-3" class="text-xs font-uber-text text-body transition-colors">Confirmar</span>
    </div>
  </div>

  <!-- Info badge for authenticated volunteers -->
  {isVolunteer && (
    <div class="max-w-2xl mx-auto mb-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-800 text-xs px-4 py-2.5 rounded-xl font-uber-text flex items-center gap-2">
      <span>🛡️</span>
      <span>Voluntario Activo: Tu reporte se registrará bajo tu credencial.</span>
    </div>
  )}

  <form id="form-reporte" class="space-y-6">
    <!-- PASO 1: TIPO DE REPORTE -->
    <div id="pane-step-1" class="step-pane space-y-6">
      <div class="text-center mb-6">
        <h2 class="font-uber-display text-xl text-ink">¿Qué tipo de reporte deseas emitir?</h2>
        <p class="text-xs text-body font-uber-text mt-1">Selecciona la opción que mejor describa la situación.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <button type="button" class="type-card text-left p-5 border border-canvas-soft bg-canvas rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" data-type="desaparecido">
          <div>
            <span class="text-3xl block mb-2">🔍</span>
            <h3 class="font-uber-display text-base text-ink">Persona Desaparecida</h3>
            <p class="text-xs text-body font-uber-text mt-1">Busca a un familiar o conocido con quien has perdido contacto.</p>
          </div>
        </button>
        {isVolunteer && (
          <button type="button" class="type-card text-left p-5 border border-canvas-soft bg-canvas rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" data-type="encontrado">
            <div>
              <span class="text-3xl block mb-2">🤝</span>
              <h3 class="font-uber-display text-base text-ink">Persona Encontrada</h3>
              <p class="text-xs text-body font-uber-text mt-1">Reporta a alguien localizado pero que aún no está identificado.</p>
            </div>
          </button>
          <button type="button" class="type-card text-left p-5 border border-canvas-soft bg-canvas rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" data-type="refugio">
            <div>
              <span class="text-3xl block mb-2">🏠</span>
              <h3 class="font-uber-display text-base text-ink">Reportar Refugio</h3>
              <p class="text-xs text-body font-uber-text mt-1">Registra información sobre la capacidad o estado de un refugio.</p>
            </div>
          </button>
        )}
        <button type="button" class="type-card text-left p-5 border border-canvas-soft bg-canvas rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" data-type="necesidad">
          <div>
            <span class="text-3xl block mb-2">🚨</span>
            <h3 class="font-uber-display text-base text-ink">Necesidad Crítica</h3>
            <p class="text-xs text-body font-uber-text mt-1">Petición urgente de agua, comida, medicina o rescate.</p>
          </div>
        </button>
      </div>
      <input type="hidden" name="tipo" id="input-tipo" />

      <div class="flex justify-end pt-4">
        <button type="button" id="btn-next-1" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text px-8" disabled>
          Siguiente
        </button>
      </div>
    </div>

    <!-- PASO 2: DETALLES -->
    <div id="pane-step-2" class="step-pane hidden space-y-6">
      <!-- 2.1 Detalles del Reporte -->
      <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
        <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">1. Detalles del Reporte</legend>
        
        <!-- BLOQUE PERSONA (Desaparecido / Encontrado) -->
        <div id="campos-tipo-persona" class="space-y-4">
          <div>
            <label id="label-nombre-buscado" class="block font-uber-text uber-body-sm-strong text-body mb-1">Nombre de Persona Involucrada *</label>
            <input type="text" name="nombre_buscado" class="input w-full font-uber-text uber-body-md" placeholder="Nombres y apellidos completos" />
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Cédula de Persona Involucrada</label>
            <input type="text" name="cedula_buscado" class="input w-full font-uber-text uber-body-md" placeholder="Opcional (si se conoce)" />
          </div>

          <!-- Campos adicionales específicos para desaparecido -->
          <div id="campos-desaparecido" class="hidden space-y-4 border-t border-canvas-soft pt-4 mt-2">
            <p class="font-uber-display text-sm text-ink font-semibold">Datos adicionales de la persona desaparecida:</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Estado (Última ubicación) *</label>
                <input type="text" name="extra_estado" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Distrito Capital" />
              </div>
              <div>
                <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Ciudad *</label>
                <input type="text" name="extra_ciudad" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Caracas" />
              </div>
              <div>
                <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Sector / Zona *</label>
                <input type="text" name="extra_sector" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Los Palos Grandes" />
              </div>
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Fecha y Hora de Último Contacto *</label>
              <input type="datetime-local" name="extra_ultimo_contacto" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Señas Particulares y Vestimenta *</label>
              <textarea name="extra_senas" class="textarea w-full h-20 font-uber-text uber-body-md" placeholder="Ej: Cicatriz en la ceja izquierda, vestía camisa azul y jean oscuro..."></textarea>
            </div>
          </div>
        </div>

        <!-- BLOQUE NECESIDAD CRÍTICA -->
        <div id="campos-tipo-necesidad" class="hidden space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tipo de Necesidad *</label>
              <select name="necesidad_categoria" id="necesidad_categoria_select" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
                <option value="Agua potable">Agua potable</option>
                <option value="Alimentos / Comida">Alimentos / Comida</option>
                <option value="Atención médica / Medicinas">Atención médica / Medicinas</option>
                <option value="Rescate / Evacuación">Rescate / Evacuación</option>
                <option value="Ropa / Cobijo">Ropa / Cobijo</option>
                <option value="Energía / Telecomunicaciones">Energía / Telecomunicaciones</option>
                <option value="Otro">Otro / Varios</option>
              </select>
              <div id="wrapper-necesidad-otro" class="hidden mt-2">
                <input type="text" name="necesidad_categoria_otro" id="necesidad_categoria_otro" placeholder="Especifica la necesidad (ej: Pañales, linternas...)" class="input w-full font-uber-text uber-body-md" />
              </div>
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Urgencia / Gravedad *</label>
              <select name="necesidad_gravedad" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
                <option value="Alta (Riesgo de vida)">Alta (Riesgo de vida)</option>
                <option value="Media (Urgente)">Media (Urgente)</option>
                <option value="Baja (Soporte)">Baja (Soporte / Prevención)</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Personas Afectadas (Aproximado)</label>
              <input type="number" name="necesidad_afectados" min="1" placeholder="Ej: 15" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">📞 Teléfono para Coordinar Ayuda *</label>
              <input type="tel" name="necesidad_telefono" class="input w-full font-uber-text uber-body-md" placeholder="Ej: 0412-123-4567" />
              <span class="text-xs text-mute mt-1 block font-uber-text">Quién puede recibir la ayuda o coordinar el suministro.</span>
            </div>
          </div>
          {isVolunteer && (
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Asociar a Refugio (Opcional - Solo Voluntarios)</label>
              <select name="refugio_id" id="select_refugio_id" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
                <option value="">Ninguno / Ubicación Manual en Mapa</option>
                {refugios.map((r: any) => (
                  <option value={`${r.tipo}:${r.id}`} data-lat={r.latitud} data-lng={r.longitud} data-nombre={r.nombre}>
                    {r.tipo === 'hospital' ? '🏥 ' : r.tipo === 'centro_acopio' ? '📦 ' : '⛺ '} {r.nombre}
                  </option>
                ))}
              </select>
              <span class="text-xs text-mute mt-1 block font-uber-text">Selecciona un refugio/centro/hospital si los insumos son para uno de ellos.</span>
            </div>
          )}
        </div>

        <!-- BLOQUE REPORTAR REFUGIO -->
        <div id="campos-tipo-refugio" class="hidden space-y-4">
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Nombre del Refugio / Acopio *</label>
            <input type="text" name="refugio_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Albergue Polideportivo Petare" />
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tipo de Centro *</label>
            <select name="refugio_tipo" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
              <option value="Refugio temporal">Refugio / Albergue temporal</option>
              <option value="Centro de acopio">Centro de acopio de insumos</option>
              <option value="Puesto de salud">Puesto de salud / socorro médico</option>
            </select>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Población Alojada (Pers.)</label>
              <input type="number" name="refugio_ocupacion" min="0" placeholder="Ej: 45" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Capacidad Máxima (Pers.)</label>
              <input type="number" name="refugio_capacidad" min="1" placeholder="Ej: 100" class="input w-full font-uber-text uber-body-md" />
            </div>
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">📞 Teléfono del Encargado / Coordinador</label>
            <input type="tel" name="refugio_telefono" class="input w-full font-uber-text uber-body-md" placeholder="Ej: 0414-987-6543" />
            <span class="text-xs text-mute mt-1 block font-uber-text">Para que voluntarios puedan contactar directamente al encargado del refugio.</span>
          </div>
        </div>

        <!-- CAMPO COMÚN: DESCRIPCIÓN DETALLADA -->
        <div class="mt-4 pt-4 border-t border-canvas-soft">
          <div class="flex items-center justify-between mb-1">
            <label id="label-descripcion" class="block font-uber-text uber-body-sm-strong text-body">Descripción Detallada *</label>
            {isVolunteer && (
              <button type="button" id="btn-dictar" class="btn btn-xs btn-outline border-canvas-soft text-mute flex items-center gap-1 cursor-pointer hover:bg-canvas-soft active:scale-95 transition-all" title="Dictar por voz (Micrófono)">
                <span id="mic-icon">🎙️</span>
                <span id="mic-text" class="text-xs font-uber-text">Dictar por voz</span>
              </button>
            )}
          </div>
          <textarea 
            name="descripcion" 
            id="input-descripcion"
            class="textarea w-full h-24 font-uber-text uber-body-md" 
            placeholder="Ej: Detalles de la desaparición o situación..."
          ></textarea>
          <span id="help-descripcion" class="text-xs text-mute mt-1 block font-uber-text">La IA utilizará esta descripción para cruzar reportes.</span>
        </div>
      </fieldset>

      <!-- 2.2 Ubicación -->
      <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
        <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">2. Lugar del Reporte</legend>
        <div class="space-y-4">
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Dirección / Lugar de Avistamiento</label>
            <input type="text" name="ubicacion_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Sector, calle o punto de referencia" />
          </div>
          <MapaUbicacion />
        </div>
      </fieldset>

      <!-- 2.3 Reportante y Evidencia -->
      <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
        <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">3. Reportante y Evidencia</legend>
        <div class="space-y-4">
          <FotoUpload />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tu Nombre (Reportante)</label>
              <input type="text" name="reportante_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Opcional" value={volunteerName} />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tu Contacto (Teléfono/Email)</label>
              <input type="text" name="reportante_contacto" class="input w-full font-uber-text uber-body-md" placeholder="Para coordinar rescate" value={volunteerPhone} />
            </div>
          </div>
        </div>
      </fieldset>

      <div class="flex justify-between pt-4">
        <button type="button" id="btn-back-2" class="btn btn-secondary font-uber-text px-8">
          Atrás
        </button>
        <button type="button" id="btn-next-2" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text px-8">
          Siguiente
        </button>
      </div>
    </div>

    <!-- PASO 3: CONFIRMACIÓN Y OPCIONES -->
    <div id="pane-step-3" class="step-pane hidden space-y-6">
      <div class="text-center mb-6">
        <h2 class="font-uber-display text-xl text-ink">Confirmación de Reporte</h2>
        <p class="text-xs text-body font-uber-text mt-1">Por favor, revisa las opciones finales antes de enviar.</p>
      </div>

      <!-- Resumen del reporte para revisión visual -->
      <div class="border border-canvas-soft bg-canvas-soft p-5 rounded-xl space-y-3 font-uber-text uber-body-sm">
        <p><strong class="text-ink">Tipo de Reporte:</strong> <span id="summary-tipo">-</span></p>
        <p id="summary-row-nombre"><strong class="text-ink">Involucrado:</strong> <span id="summary-nombre">-</span></p>
        <p><strong class="text-ink">Descripción:</strong> <span id="summary-descripcion">-</span></p>
        <p><strong class="text-ink">Ubicación:</strong> <span id="summary-ubicacion">-</span></p>
        <p><strong class="text-ink">Foto adjunta:</strong> <span id="summary-foto">No</span></p>
      </div>

      <!-- Opción de Flyer de Emergencia (sólo para desaparecido con foto) -->
      <div id="flyer-opt-in" class="hidden border border-canvas-soft bg-canvas p-5 rounded-xl shadow-sm">
        <label class="cursor-pointer flex items-start gap-4 select-none">
          <input 
            type="checkbox" 
            name="generar_flyer" 
            id="generar-flyer-chk" 
            checked 
            class="w-5 h-5 rounded-md border-2 border-primary bg-canvas text-primary focus:ring-0 focus:ring-offset-0 mt-0.5 accent-black" 
          />
          <div class="flex-grow">
            <span class="font-uber-display text-sm text-ink block">
              ✨ Generar cartel (flyer) de emergencia descargable
            </span>
            <span class="text-xs text-body mt-1 block">
              Crearemos automáticamente una imagen optimizada para compartir en redes sociales y WhatsApp con los datos provistos.
            </span>
          </div>
        </label>
      </div>

      <!-- Tip de flyer si tipo desaparecido pero sin foto -->
      <div id="flyer-no-photo-tip" class="hidden border border-amber-500/20 bg-amber-500/5 p-4 rounded-xl font-uber-text text-xs text-body">
        💡 <strong>Tip:</strong> Si deseas generar un cartel de búsqueda descargable para WhatsApp y redes, puedes regresar al paso anterior y subir una foto de la persona desaparecida.
      </div>

      <div class="flex justify-between pt-4">
        <button type="button" id="btn-back-3" class="btn btn-secondary font-uber-text px-8">
          Atrás
        </button>
        <button type="submit" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text px-8">
          Enviar reporte de emergencia
        </button>
      </div>
    </div>

    <!-- Toast de estado estilo ex-toast -->
    <div id="toast-container-rep" class="toast-mobile hidden">
      <div id="toast-message-rep" class="bg-canvas border border-canvas-soft text-ink rounded-xl p-4 shadow-md font-uber-text uber-body-sm flex items-center gap-2">
        <span>Guardando...</span>
      </div>
    </div>
  </form>
</div>

<script>
  import { encolarRegistro } from "../lib/offline-queue";

  function initFormReporte() {
    const form = document.getElementById("form-reporte") as HTMLFormElement;
    const toastContainer = document.getElementById("toast-container-rep");
    const toastMessage = document.getElementById("toast-message-rep");

    if (form && toastContainer && toastMessage) {
    const inputTipo = document.getElementById("input-tipo") as HTMLInputElement;
    const typeCards = document.querySelectorAll(".type-card");
    const btnNext1 = document.getElementById("btn-next-1") as HTMLButtonElement;
    const btnNext2 = document.getElementById("btn-next-2") as HTMLButtonElement;
    const btnBack2 = document.getElementById("btn-back-2") as HTMLButtonElement;
    const btnBack3 = document.getElementById("btn-back-3") as HTMLButtonElement;

    // Inputs para validación
    const inputNombre = document.querySelector('input[name="nombre_buscado"]') as HTMLInputElement;
    const inputDescripcion = document.querySelector('textarea[name="descripcion"]') as HTMLTextAreaElement;
    const inputEstado = document.querySelector('input[name="extra_estado"]') as HTMLInputElement;
    const inputCiudad = document.querySelector('input[name="extra_ciudad"]') as HTMLInputElement;
    const inputSector = document.querySelector('input[name="extra_sector"]') as HTMLInputElement;
    const inputUltimoContacto = document.querySelector('input[name="extra_ultimo_contacto"]') as HTMLInputElement;
    const inputSenas = document.querySelector('textarea[name="extra_senas"]') as HTMLTextAreaElement;
    const inputFotoKey = document.getElementById("foto_key") as HTMLInputElement;

    // Elementos del resumen paso 3
    const summaryTipo = document.getElementById("summary-tipo");
    const summaryNombre = document.getElementById("summary-nombre");
    const summaryDescripcion = document.getElementById("summary-descripcion");
    const summaryUbicacion = document.getElementById("summary-ubicacion");
    const summaryFoto = document.getElementById("summary-foto");
    const rowNombre = document.getElementById("summary-row-nombre");
    const flyerOptIn = document.getElementById("flyer-opt-in");
    const flyerNoPhotoTip = document.getElementById("flyer-no-photo-tip");

    let currentStep = 1;

    function toggleCamposEspecificos(tipo: string) {
      const camposPersona = document.getElementById("campos-tipo-persona");
      const camposNecesidad = document.getElementById("campos-tipo-necesidad");
      const camposRefugio = document.getElementById("campos-tipo-refugio");
      const camposDesaparecido = document.getElementById("campos-desaparecido");
      const labelNombreBuscado = document.getElementById("label-nombre-buscado");
      const labelDescripcion = document.getElementById("label-descripcion");
      const labelFoto = Array.from(document.querySelectorAll("#form-reporte label")).find(el => el.textContent?.includes("Foto Evidencia"));
      const helpDescripcion = document.getElementById("help-descripcion");

      if (!camposPersona || !camposNecesidad || !camposRefugio || !camposDesaparecido) return;

      // Ocultar todos
      camposPersona.classList.add("hidden");
      camposNecesidad.classList.add("hidden");
      camposRefugio.classList.add("hidden");
      camposDesaparecido.classList.add("hidden");

      if (tipo === "desaparecido") {
        camposPersona.classList.remove("hidden");
        camposDesaparecido.classList.remove("hidden");
        if (labelNombreBuscado) labelNombreBuscado.innerHTML = 'Nombre de Persona Involucrada *';
        inputNombre.placeholder = "Nombres y apellidos completos";
        inputDescripcion.placeholder = "Ej: Detalles de la desaparición, vestimenta, última vez que se le vio...";
        if (labelDescripcion) labelDescripcion.innerHTML = 'Detalles adicionales y contexto *';
        if (labelFoto) labelFoto.innerHTML = '📸 Foto de la Persona (Requerida) *';
        if (helpDescripcion) helpDescripcion.textContent = "La IA utilizará esta descripción para cruzar reportes.";
      } else if (tipo === "encontrado") {
        camposPersona.classList.remove("hidden");
        if (labelNombreBuscado) labelNombreBuscado.innerHTML = 'Nombre de Persona Encontrada';
        inputNombre.placeholder = "Opcional (si se conoce)";
        inputDescripcion.placeholder = "Ej: Rasgos físicos, estado de salud actual, señas particulares...";
        if (labelDescripcion) labelDescripcion.innerHTML = 'Descripción del Hallazgo *';
        if (labelFoto) labelFoto.innerHTML = '📸 Foto Evidencia (Opcional)';
        if (helpDescripcion) helpDescripcion.textContent = "La IA utilizará esta descripción para cruzar reportes.";
      } else if (tipo === "necesidad") {
        camposNecesidad.classList.remove("hidden");
        inputDescripcion.placeholder = "Ej: Describa qué insumos específicos hacen falta, el nivel de urgencia y la cantidad de familias afectadas...";
        if (labelDescripcion) labelDescripcion.innerHTML = 'Descripción de la Necesidad *';
        if (labelFoto) labelFoto.innerHTML = '📸 Foto del Lugar/Situación (Opcional)';
        if (helpDescripcion) helpDescripcion.textContent = "La información será visible para voluntarios y coordinadores de ayuda.";
      } else if (tipo === "refugio") {
        camposRefugio.classList.remove("hidden");
        inputDescripcion.placeholder = "Ej: Estado general del refugio, insumos críticos faltantes, datos sobre el encargado o reglas de acceso...";
        if (labelDescripcion) labelDescripcion.innerHTML = 'Descripción del Refugio / Necesidades *';
        if (labelFoto) labelFoto.innerHTML = '📸 Foto del Centro (Opcional)';
        if (helpDescripcion) helpDescripcion.textContent = "Detalle el estado del refugio, insumos requeridos y contactos.";
      }
    }

    function mostrarError(input: HTMLElement, mensaje: string) {
      input.classList.add("border-red-500", "focus:border-red-500", "ring-1", "ring-red-500");
      
      let errorSpan = input.parentNode?.querySelector(".input-error-msg");
      if (!errorSpan) {
        errorSpan = document.createElement("span");
        errorSpan.className = "input-error-msg text-xs text-red-500 mt-1 block font-uber-text font-semibold";
        input.parentNode?.appendChild(errorSpan);
      }
      errorSpan.textContent = mensaje;
    }

    function limpiarErrores() {
      const inputs = form.querySelectorAll("input, textarea");
      inputs.forEach(input => {
        input.classList.remove("border-red-500", "focus:border-red-500", "ring-1", "ring-red-500");
        const errorSpan = input.parentNode?.querySelector(".input-error-msg");
        if (errorSpan) {
          errorSpan.remove();
        }
      });
    }

    function validarPaso2(): boolean {
      limpiarErrores();
      let esValido = true;
      const tipo = inputTipo.value;
      const descripcionVal = inputDescripcion.value.trim();

      // Inputs específicos
      const inputRefugioNombre = form.querySelector('[name="refugio_nombre"]') as HTMLInputElement;

      if (tipo === "desaparecido") {
        if (!inputNombre.value.trim()) {
          mostrarError(inputNombre, "El nombre de la persona desaparecida es requerido.");
          esValido = false;
        }
        if (!inputEstado.value.trim()) {
          mostrarError(inputEstado, "El estado de la última ubicación es requerido.");
          esValido = false;
        }
        if (!inputCiudad.value.trim()) {
          mostrarError(inputCiudad, "La ciudad de la última ubicación es requerida.");
          esValido = false;
        }
        if (!inputSector.value.trim()) {
          mostrarError(inputSector, "El sector o zona de la última ubicación es requerido.");
          esValido = false;
        }
        if (!inputUltimoContacto.value.trim()) {
          mostrarError(inputUltimoContacto, "La fecha y hora del último contacto son requeridas.");
          esValido = false;
        }
        if (!inputSenas.value.trim()) {
          mostrarError(inputSenas, "Señas particulares o descripción de vestimenta es requerida.");
          esValido = false;
        }
        if (!inputFotoKey.value.trim()) {
          const fileInputEl = document.getElementById("foto-file");
          if (fileInputEl) {
            mostrarError(fileInputEl, "La foto de la persona desaparecida es requerida.");
          } else {
            mostrarToast("❌ La foto de la persona desaparecida es requerida.", "border-red-500/30");
          }
          esValido = false;
        }
      } else if (tipo === "refugio") {
        if (!inputRefugioNombre.value.trim()) {
          mostrarError(inputRefugioNombre, "El nombre del refugio o centro de acopio es requerido.");
          esValido = false;
        }
      } else if (tipo === "necesidad") {
        const selectCat = document.getElementById("necesidad_categoria_select") as HTMLSelectElement;
        const inputOtro = document.getElementById("necesidad_categoria_otro") as HTMLInputElement;
        if (selectCat && selectCat.value === "Otro" && inputOtro && !inputOtro.value.trim()) {
          mostrarError(inputOtro, "Especifica qué tipo de necesidad es.");
          esValido = false;
        }
      }

      if (descripcionVal.length < 10) {
        mostrarError(inputDescripcion, "La descripción del reporte debe tener al menos 10 caracteres.");
        esValido = false;
      }

      if (!esValido) {
        // Hacer scroll al primer error
        const primerError = form.querySelector(".border-red-500");
        if (primerError) {
          primerError.scrollIntoView({ behavior: "smooth", block: "center" });
          (primerError as HTMLElement).focus();
        }
        mostrarToast("❌ Hay campos con errores en el formulario.", "border-red-500/30");
      }

      return esValido;
    }

    function actualizarResumen() {
      if (!summaryTipo || !summaryNombre || !summaryDescripcion || !summaryUbicacion || !summaryFoto || !rowNombre || !flyerOptIn || !flyerNoPhotoTip) return;

      const tipo = inputTipo.value;
      const nombre = (tipo === "refugio" 
        ? (form.querySelector('[name="refugio_nombre"]') as HTMLInputElement).value 
        : inputNombre.value).trim();
      const desc = inputDescripcion.value.trim();
      const ubicacion = (document.querySelector('input[name="ubicacion_nombre"]') as HTMLInputElement).value.trim();
      const tieneFoto = !!inputFotoKey.value.trim();

      let tipoText = tipo;
      if (tipo === "desaparecido") tipoText = "Persona Desaparecida (Búsqueda)";
      else if (tipo === "encontrado") tipoText = "Persona Encontrada (No Identificada)";
      else if (tipo === "refugio") tipoText = "Reporte de Refugio / Centro de Acopio";
      else if (tipo === "necesidad") tipoText = "Necesidad Crítica";

      summaryTipo.textContent = tipoText;
      
      if (nombre) {
        rowNombre.classList.remove("hidden");
        summaryNombre.textContent = nombre;
      } else {
        rowNombre.classList.add("hidden");
      }

      summaryDescripcion.textContent = desc.substring(0, 100) + (desc.length > 100 ? "..." : "");
      summaryUbicacion.textContent = ubicacion || "No especificada (ubicación por mapa/GPS si se marcó)";
      summaryFoto.textContent = tieneFoto ? "✓ Sí, adjunta" : "No";

      if (tipo === "desaparecido") {
        if (tieneFoto) {
          flyerOptIn.classList.remove("hidden");
          flyerNoPhotoTip.classList.add("hidden");
        } else {
          flyerOptIn.classList.add("hidden");
          flyerNoPhotoTip.classList.remove("hidden");
        }
      } else {
        // Para necesidades, refugios o encontrados, la foto es opcional, mostramos opt-in siempre
        flyerOptIn.classList.remove("hidden");
        flyerNoPhotoTip.classList.add("hidden");
      }
    }

    function goToStep(step: number) {
      if (step > currentStep) {
        if (currentStep === 1 && !inputTipo.value) {
          mostrarToast("❌ Selecciona un tipo de reporte.", "border-red-500/30");
          return;
        }
        if (currentStep === 2 && !validarPaso2()) {
          return;
        }
      }

      document.getElementById(`pane-step-${currentStep}`)?.classList.add("hidden");
      document.getElementById(`pane-step-${step}`)?.classList.remove("hidden");

      if (step === 2 && (window as any).mapaReporteInstance) {
        setTimeout(() => {
          try {
            (window as any).mapaReporteInstance.invalidateSize();
          } catch (e) {
            console.error("Error al redimensionar mapa:", e);
          }
        }, 150);
      }

      for (let i = 1; i <= 3; i++) {
        const ind = document.getElementById(`step-ind-${i}`);
        const txt = document.getElementById(`step-txt-${i}`);
        if (ind && txt) {
          if (i < step) {
            ind.className = "w-8 h-8 rounded-full flex items-center justify-center bg-green-500 text-white font-uber-display text-sm transition-colors";
            ind.innerHTML = "✓";
            txt.className = "text-xs font-uber-text font-bold text-ink transition-colors";
          } else if (i === step) {
            ind.className = "w-8 h-8 rounded-full flex items-center justify-center bg-primary text-white font-uber-display text-sm transition-colors";
            ind.innerHTML = String(i);
            txt.className = "text-xs font-uber-text font-bold text-ink transition-colors";
          } else {
            ind.className = "w-8 h-8 rounded-full flex items-center justify-center bg-canvas-soft text-mute font-uber-display text-sm transition-colors";
            ind.innerHTML = String(i);
            txt.className = "text-xs font-uber-text text-body transition-colors";
          }
        }
      }

      if (step === 3) {
        actualizarResumen();
      }

      currentStep = step;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Eventos de selección de cartas Paso 1
    typeCards.forEach(card => {
      card.addEventListener("click", () => {
        typeCards.forEach(c => {
          c.classList.remove("border-primary", "bg-canvas-softer", "scale-98");
          c.classList.add("border-canvas-soft", "bg-canvas");
        });

        card.classList.remove("border-canvas-soft", "bg-canvas");
        card.classList.add("border-primary", "bg-canvas-softer", "scale-98");

        const selectedType = card.getAttribute("data-type") || "";
        inputTipo.value = selectedType;
        btnNext1.disabled = false;

        toggleCamposEspecificos(selectedType);

        setTimeout(() => {
          goToStep(2);
        }, 350);
      });
    });

    btnNext1.addEventListener("click", () => goToStep(2));
    btnNext2.addEventListener("click", () => goToStep(3));
    btnBack2.addEventListener("click", () => goToStep(1));
    btnBack3.addEventListener("click", () => goToStep(2));

    const selectCategoria = document.getElementById("necesidad_categoria_select") as HTMLSelectElement;
    const wrapperOtro = document.getElementById("wrapper-necesidad-otro");
    if (selectCategoria && wrapperOtro) {
      selectCategoria.addEventListener("change", function() {
        if (this.value === "Otro") {
          wrapperOtro.classList.remove("hidden");
          const inputOtro = document.getElementById("necesidad_categoria_otro") as HTMLInputElement;
          if (inputOtro) {
            inputOtro.focus();
          }
        } else {
          wrapperOtro.classList.add("hidden");
        }
      });
    }

    form.addEventListener("reset", () => {
      if (wrapperOtro) {
        wrapperOtro.classList.add("hidden");
      }
    });

    const selectRefugio = document.getElementById("select_refugio_id") as HTMLSelectElement;
    if (selectRefugio) {
      selectRefugio.addEventListener("change", function() {
        const option = this.options[this.selectedIndex];
        const latStr = option.getAttribute("data-lat");
        const lngStr = option.getAttribute("data-lng");
        const nombre = option.getAttribute("data-nombre");

        if (latStr && lngStr && latStr !== "null" && lngStr !== "null") {
          const lat = parseFloat(latStr);
          const lng = parseFloat(lngStr);
          
          if (!isNaN(lat) && !isNaN(lng)) {
            const latInput = document.getElementById("latitud") as HTMLInputElement;
            const lonInput = document.getElementById("longitud") as HTMLInputElement;
            const mapSearchInput = document.getElementById("map-search-input") as HTMLInputElement;
            const addressInput = document.querySelector('input[name="ubicacion_nombre"]') as HTMLInputElement;
            
            if (latInput && lonInput) {
              latInput.value = lat.toString();
              lonInput.value = lng.toString();
              latInput.dispatchEvent(new Event("change"));
              
              if (mapSearchInput) mapSearchInput.value = nombre || "";
              if (addressInput) addressInput.value = "Refugio: " + (nombre || "");
              
              mostrarToast("📍 Ubicación actualizada al refugio", "border-blue-500/30");
            }
          }
        }
      });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Validar datos antes de submit
      limpiarErrores();
      if (!inputTipo.value) {
        mostrarToast("❌ Selecciona un tipo de reporte.", "border-red-500/30");
        goToStep(1);
        return;
      }
      if (!validarPaso2()) {
        goToStep(2);
        return;
      }

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      let descConcatenada = String(data.descripcion).trim();
      let payload: any = {};
      let endpointUrl = "/api/reportes";
      
      let refugio_id = null;
      let hospital_id = null;
      let centro_acopio_id = null;
      if (data.refugio_id) {
        const [tipo, idStr] = String(data.refugio_id).split(":");
        const id = parseInt(idStr, 10);
        if (tipo === "hospital") {
          hospital_id = id;
        } else if (tipo === "centro_acopio") {
          centro_acopio_id = id;
        } else if (tipo === "refugio") {
          refugio_id = id;
        }
      }

      if (data.tipo === "desaparecido") {
        const fechaContacto = String(data.extra_ultimo_contacto).replace("T", " ");
        const ubicacion = `${String(data.extra_estado).trim()}, ${String(data.extra_ciudad).trim()}, Sector ${String(data.extra_sector).trim()}`;
        const senas = String(data.extra_senas).trim();
        
        descConcatenada = `[FECHA ÚLTIMO CONTACTO: ${fechaContacto}]\n[UBICACIÓN: ${ubicacion}]\n[SEÑAS: ${senas}]\n\n${descConcatenada}`;
        payload = {
          tipo: "desaparecido",
          nombre_buscado: data.nombre_buscado ? String(data.nombre_buscado).trim() : null,
          cedula_buscado: data.cedula_buscado ? String(data.cedula_buscado).trim() : null,
          descripcion: descConcatenada,
          reportante_nombre: data.reportante_nombre ? String(data.reportante_nombre).trim() : null,
          reportante_contacto: data.reportante_contacto ? String(data.reportante_contacto).trim() : null,
          ubicacion_nombre: data.ubicacion_nombre ? String(data.ubicacion_nombre).trim() : null,
          latitud: data.latitud ? parseFloat(String(data.latitud)) : null,
          longitud: data.longitud ? parseFloat(String(data.longitud)) : null,
          foto_key: data.foto_key ? String(data.foto_key).trim() : null,
          refugio_id,
          hospital_id,
          centro_acopio_id
        };
      } else if (data.tipo === "encontrado") {
        payload = {
          tipo: "encontrado",
          nombre_buscado: data.nombre_buscado ? String(data.nombre_buscado).trim() : null,
          cedula_buscado: data.cedula_buscado ? String(data.cedula_buscado).trim() : null,
          descripcion: descConcatenada,
          reportante_nombre: data.reportante_nombre ? String(data.reportante_nombre).trim() : null,
          reportante_contacto: data.reportante_contacto ? String(data.reportante_contacto).trim() : null,
          ubicacion_nombre: data.ubicacion_nombre ? String(data.ubicacion_nombre).trim() : null,
          latitud: data.latitud ? parseFloat(String(data.latitud)) : null,
          longitud: data.longitud ? parseFloat(String(data.longitud)) : null,
          foto_key: data.foto_key ? String(data.foto_key).trim() : null,
          refugio_id,
          hospital_id,
          centro_acopio_id
        };
      } else if (data.tipo === "necesidad") {
        endpointUrl = "/api/necesidades";
        
        let categoriaFinal = String(data.necesidad_categoria);
        if (categoriaFinal === "Otro") {
          categoriaFinal = String(data.necesidad_categoria_otro || "").trim() || "Otro";
        }

        payload = {
          categoria: categoriaFinal,
          gravedad: String(data.necesidad_gravedad),
          afectados: data.necesidad_afectados ? parseInt(String(data.necesidad_afectados), 10) : null,
          descripcion: descConcatenada,
          ubicacion_nombre: data.ubicacion_nombre ? String(data.ubicacion_nombre).trim() : null,
          latitud: data.latitud ? parseFloat(String(data.latitud)) : null,
          longitud: data.longitud ? parseFloat(String(data.longitud)) : null,
          telefono: data.necesidad_telefono ? String(data.necesidad_telefono).trim() : null,
          foto_key: data.foto_key ? String(data.foto_key).trim() : null,
          refugio_id,
          hospital_id,
          centro_acopio_id,
          reportante_nombre: data.reportante_nombre ? String(data.reportante_nombre).trim() : null,
          reportante_contacto: data.reportante_contacto ? String(data.reportante_contacto).trim() : null
        };
      } else if (data.tipo === "refugio") {
        const centroTipo = String(data.refugio_tipo);
        const ocupacion = data.refugio_ocupacion ? `${data.refugio_ocupacion} pers.` : "0 pers.";
        const capacidad = data.refugio_capacidad ? `${data.refugio_capacidad} pers.` : "100 pers.";
        
        descConcatenada = `[TIPO CENTRO: ${centroTipo}]\n[OCUPACIÓN: ${ocupacion} / ${capacidad}]\n\n${descConcatenada}`;
        payload = {
          tipo: "refugio",
          nombre_buscado: data.refugio_nombre ? String(data.refugio_nombre).trim() : "Refugio sin nombre",
          cedula_buscado: null,
          descripcion: descConcatenada,
          reportante_nombre: data.reportante_nombre ? String(data.reportante_nombre).trim() : null,
          reportante_contacto: data.reportante_contacto ? String(data.reportante_contacto).trim() : null,
          ubicacion_nombre: data.ubicacion_nombre ? String(data.ubicacion_nombre).trim() : null,
          latitud: data.latitud ? parseFloat(String(data.latitud)) : null,
          longitud: data.longitud ? parseFloat(String(data.longitud)) : null,
          foto_key: data.foto_key ? String(data.foto_key).trim() : null,
          refugio_id,
          hospital_id,
          centro_acopio_id
        };
      }

      mostrarToast("Procesando reporte...", "border-blue-500/30");

      if (navigator.onLine) {
        try {
          const response = await fetch(endpointUrl, {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          if (response.ok) {
            const generarFlyerChk = document.getElementById("generar-flyer-chk") as HTMLInputElement;
            const quiereFlyer = generarFlyerChk && generarFlyerChk.checked;

            if (quiereFlyer) {
              mostrarToast("Reporte creado. Generando cartel de emergencia...", "border-blue-500/30");
              try {
                let flyerTitle = `Emergencia Activa`;
                if (payload.tipo === "desaparecido") {
                  flyerTitle = `SE BUSCA: ${payload.nombre_buscado || "Persona Desaparecida"}`;
                } else if (payload.tipo === "encontrado") {
                  flyerTitle = `PERSONA ENCONTRADA: ${payload.nombre_buscado || "No identificada"}`;
                } else if (payload.tipo === "necesidad") {
                  const catMatch = payload.descripcion.match(/\[TIPO NECESIDAD: (.*?)\]/);
                  const categoria = catMatch ? catMatch[1] : "Necesidad Urgente";
                  flyerTitle = `EMERGENCIA: ${categoria.toUpperCase()}`;
                } else if (payload.tipo === "refugio") {
                  flyerTitle = `REFUGIO ACTIVO: ${payload.nombre_buscado}`;
                }

                // Concatenar la ubicación al principio de la descripción del flyer si existe
                let flyerDescription = payload.descripcion;
                if (payload.ubicacion_nombre) {
                  flyerDescription = `[UBICACIÓN: ${payload.ubicacion_nombre}]\n${flyerDescription}`;
                }

                const flyerPayload = {
                  title: flyerTitle,
                  description: flyerDescription,
                  foto_key: payload.foto_key || "",
                  tipo: payload.tipo,
                  phones: (() => {
                    const phones: string[] = [];
                    // Teléfono específico por tipo tiene prioridad
                    const tipoTel = payload.tipo === "necesidad"
                      ? (data.necesidad_telefono ? String(data.necesidad_telefono).trim() : "")
                      : payload.tipo === "refugio"
                        ? (data.refugio_telefono ? String(data.refugio_telefono).trim() : "")
                        : "";
                    if (tipoTel) phones.push(tipoTel);
                    // Teléfono del reportante como secundario/fallback
                    const repTel = payload.reportante_contacto || "";
                    if (repTel && repTel !== tipoTel) phones.push(repTel);
                    return phones;
                  })(),
                  socials: [],
                  registrarEnBusca: false
                };

                const flyerResponse = await fetch("/api/flyers", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(flyerPayload)
                });

                if (flyerResponse.ok) {
                  const flyerData = await flyerResponse.json();
                  mostrarToast("✓ Cartel generado. Redirigiendo...", "border-green-500/30");
                  setTimeout(() => {
                    window.location.href = `/flyer/${flyerData.id}?creado=true`;
                  }, 1200);
                  return;
                }
              } catch (flyerErr) {
                console.error("Error al generar flyer:", flyerErr);
              }
            }

            mostrarToast("✓ Reporte emitido con éxito.", "border-green-500/30");
            form.reset();
            document.getElementById("btn-quitar-foto")?.click();
            
            // Volver al paso 1 reseteando la selección
            typeCards.forEach(c => {
              c.classList.remove("border-primary", "bg-canvas-softer", "scale-98");
              c.classList.add("border-canvas-soft", "bg-canvas");
            });
            inputTipo.value = "";
            btnNext1.disabled = true;
            goToStep(1);

          } else {
            const errData = await response.json();
            const rawError = errData.error || "";

            // Tratar de parsear como un error de validación de Zod
            try {
              const zodErrors = JSON.parse(rawError);
              if (Array.isArray(zodErrors)) {
                zodErrors.forEach(err => {
                  const fieldName = err.path[0];
                  // Si es descripción concatenada, mapear a textarea descripción
                  let input = form.querySelector(`[name="${fieldName}"]`) as HTMLElement;
                  if (fieldName === "descripcion") {
                    input = inputDescripcion;
                  }
                  if (input) {
                    mostrarError(input, err.message);
                  }
                });

                const primerError = form.querySelector(".border-red-500");
                if (primerError) {
                  primerError.scrollIntoView({ behavior: "smooth", block: "center" });
                  (primerError as HTMLElement).focus();
                }

                mostrarToast("❌ Error de validación en el servidor.", "border-red-500/30");
                goToStep(2);
                return;
              }
            } catch (jsonErr) {
              // No era un ZodError parseable, usar fallback
            }

            throw new Error(rawError || "Error al procesar en servidor");
          }
        } catch (err: any) {
          console.error("Fallo de red o servidor:", err);
          // Solo guardar offline si es realmente un problema de conexion o red
          if (!navigator.onLine) {
            await guardarOffline(payload);
          } else {
            mostrarToast("❌ " + err.message, "border-red-500/30");
          }
        }
      } else {
        await guardarOffline(payload);
      }
    });

    async function guardarOffline(payload: any) {
      try {
        const queueType = data.tipo === "necesidad" ? "necesidad" : "reporte";
        await encolarRegistro(queueType, payload);
        mostrarToast("⚠️ Guardado localmente sin red. Se sincronizará automáticamente.", "border-yellow-500/30");
        form.reset();
        document.getElementById("btn-quitar-foto")?.click();
        
        // Volver al paso 1 reseteando la selección
        typeCards.forEach(c => {
          c.classList.remove("border-primary", "bg-canvas-softer", "scale-98");
          c.classList.add("border-canvas-soft", "bg-canvas");
        });
        inputTipo.value = "";
        btnNext1.disabled = true;
        goToStep(1);

        const event = new CustomEvent("offline-record-added");
        window.dispatchEvent(event);
      } catch (e: any) {
        mostrarToast("❌ Error al guardar localmente: " + e.message, "border-red-500/30");
      }
    }

    function mostrarToast(text: string, borderClass: string) {
      if (!toastContainer || !toastMessage) return;

      toastMessage.className = `bg-canvas border ${borderClass} text-ink rounded-xl p-4 shadow-md font-uber-text uber-body-sm flex items-center gap-2`;
      toastMessage.innerHTML = `<span>${text}</span>`;
      toastContainer.classList.remove("hidden");

      setTimeout(() => {
        toastContainer.classList.add("hidden");
      }, 5000);
    }

    // Lógica de dictado por voz (Whisper)
    const btnDictar = document.getElementById("btn-dictar") as HTMLButtonElement;
    const micIcon = document.getElementById("mic-icon");
    const micText = document.getElementById("mic-text");
    let mediaRecorder: MediaRecorder | null = null;
    let audioChunks: Blob[] = [];
    let isRecording = false;

    if (btnDictar && micIcon && micText && inputDescripcion) {
      btnDictar.addEventListener("click", async () => {
        if (!isRecording) {
          try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            audioChunks = [];
            
            // Intentar usar formatos compatibles con Whisper
            let options = {};
            if (MediaRecorder.isTypeSupported("audio/webm")) {
              options = { mimeType: "audio/webm" };
            } else if (MediaRecorder.isTypeSupported("audio/ogg")) {
              options = { mimeType: "audio/ogg" };
            }
            
            mediaRecorder = new MediaRecorder(stream, options);
            mediaRecorder.addEventListener("dataavailable", (event) => {
              if (event.data.size > 0) {
                audioChunks.push(event.data);
              }
            });

            mediaRecorder.addEventListener("stop", async () => {
              const audioBlob = new Blob(audioChunks, { type: mediaRecorder?.mimeType || "audio/webm" });
              
              // Cambiar botón a cargando/transcribiendo
              btnDictar.disabled = true;
              micIcon.textContent = "⏳";
              micText.textContent = "Transcribiendo...";

              try {
                const response = await fetch("/api/transcribir", {
                  method: "POST",
                  headers: { "Content-Type": "application/octet-stream" },
                  body: audioBlob
                });

                if (response.ok) {
                  const result = await response.json();
                  if (result.text && result.text.trim()) {
                    const text = result.text.trim();
                    const currentVal = inputDescripcion.value.trim();
                    inputDescripcion.value = currentVal ? `${currentVal} ${text}` : text;
                    inputDescripcion.dispatchEvent(new Event("input"));
                    mostrarToast("✓ Audio transcrito con éxito.", "border-green-500/30");
                  } else {
                    mostrarToast("⚠️ No se detectó voz clara en el audio.", "border-yellow-500/30");
                  }
                } else {
                  throw new Error("Fallo en transcripción");
                }
              } catch (err) {
                console.error(err);
                mostrarToast("❌ Error al transcribir el audio.", "border-red-500/30");
              } finally {
                btnDictar.disabled = false;
                micIcon.textContent = "🎙️";
                micText.textContent = "Dictar por voz";
                
                // Detener todas las pistas de audio para liberar el micrófono
                stream.getTracks().forEach(track => track.stop());
              }
            });

            mediaRecorder.start();
            isRecording = true;
            btnDictar.classList.add("border-red-500", "text-red-500", "animate-pulse");
            micIcon.textContent = "🛑";
            micText.textContent = "Detener grabación";

            // Detener automáticamente a los 15 segundos para no procesar audios gigantescos
            setTimeout(() => {
              if (isRecording && mediaRecorder && mediaRecorder.state !== "inactive") {
                mediaRecorder.stop();
                isRecording = false;
                btnDictar.classList.remove("border-red-500", "text-red-500", "animate-pulse");
              }
            }, 15000);

          } catch (err) {
            console.error("Error al acceder al micrófono:", err);
            mostrarToast("❌ Permiso de micrófono denegado o no disponible.", "border-red-500/30");
          }
        } else {
          if (mediaRecorder && mediaRecorder.state !== "inactive") {
            mediaRecorder.stop();
          }
          isRecording = false;
          btnDictar.classList.remove("border-red-500", "text-red-500", "animate-pulse");
        }
      });
    }
  }
  }

  // Ejecutar inicialización al cargar la página y en navegaciones de ClientRouter
  document.addEventListener("astro:page-load", initFormReporte);
</script>
