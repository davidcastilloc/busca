---
import MapaUbicacion from "./MapaUbicacion.astro";
import FotoUpload from "./FotoUpload.astro";

interface Props {
  isVolunteer?: boolean;
  volunteerName?: string;
  volunteerPhone?: string;
}

const { isVolunteer = false, volunteerName = "", volunteerPhone = "" } = Astro.props;

import { env } from "cloudflare:workers";
let refugios: any[] = [];
try {
  const { DB } = env;
  if (DB) {
    const res = await DB.prepare(`
      SELECT id, nombre, latitud, longitud, 'refugio' as tipo FROM refugios
      UNION ALL
      SELECT id, nombre, latitud, longitud, 'hospital' as tipo FROM hospitales
      UNION ALL
      SELECT id, nombre, latitud, longitud, 'centro_acopio' as tipo FROM centros_acopio
      ORDER BY nombre ASC
    `).all();
    refugios = res.results || [];
  }
} catch (e) {
  console.error("Error al cargar refugios en FormReporte:", e);
}
---

<div x-data="formReporteAlpine" id="form-reporte-container" class="max-w-2xl mx-auto px-4 py-4 sm:py-6">
  <!-- Cabecera de Progreso -->
  <div class="mb-8 flex justify-between items-center px-2">
    <div class="flex items-center space-x-2">
      <div id="step-ind-1" class="w-8 h-8 rounded-full flex items-center justify-center bg-primary text-white font-uber-display text-sm transition-colors">1</div>
      <span id="step-txt-1" class="text-xs font-uber-text font-bold text-ink transition-colors">Tipo</span>
    </div>
    <div class="flex-grow h-0.5 bg-canvas-soft mx-2"></div>
    <div class="flex items-center space-x-2">
      <div id="step-ind-2" class="w-8 h-8 rounded-full flex items-center justify-center bg-canvas-soft text-mute font-uber-display text-sm transition-colors">2</div>
      <span id="step-txt-2" class="text-xs font-uber-text text-body transition-colors">Detalles</span>
    </div>
    <div class="flex-grow h-0.5 bg-canvas-soft mx-2"></div>
    <div class="flex items-center space-x-2">
      <div id="step-ind-3" class="w-8 h-8 rounded-full flex items-center justify-center bg-canvas-soft text-mute font-uber-display text-sm transition-colors">3</div>
      <span id="step-txt-3" class="text-xs font-uber-text text-body transition-colors">Confirmar</span>
    </div>
  </div>

  <!-- Info badge for authenticated volunteers -->
  {isVolunteer && (
    <div class="max-w-2xl mx-auto mb-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-800 text-xs px-4 py-2.5 rounded-xl font-uber-text flex items-center gap-2">
      <span>🛡️</span>
      <span>Voluntario Activo: Tu reporte se registrará bajo tu credencial.</span>
    </div>
  )}

  <form id="form-reporte" class="space-y-6" @submit.prevent="submitForm">
    <!-- PASO 1: TIPO DE REPORTE -->
    <div id="pane-step-1" class="step-pane space-y-6" x-show="step === 1" x-transition>
      <div class="text-center mb-6">
        <h2 class="font-uber-display text-xl text-ink">¿Qué tipo de reporte deseas emitir?</h2>
        <p class="text-xs text-body font-uber-text mt-1">Selecciona la opción que mejor describa la situación.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <button type="button" class="type-card text-left p-5 border rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" :class="tipo === \'desaparecido\' ? \'border-primary bg-canvas-softer scale-98\' : \'border-canvas-soft bg-canvas\'" @click="setTipo(\'desaparecido\')">
          <div>
            <span class="text-3xl block mb-2">🔍</span>
            <h3 class="font-uber-display text-base text-ink">Persona Desaparecida</h3>
            <p class="text-xs text-body font-uber-text mt-1">Busca a un familiar o conocido con quien has perdido contacto.</p>
          </div>
        </button>
        {isVolunteer && (
          <button type="button" class="type-card text-left p-5 border rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" :class="tipo === \'encontrado\' ? \'border-primary bg-canvas-softer scale-98\' : \'border-canvas-soft bg-canvas\'" @click="setTipo(\'encontrado\')">
            <div>
              <span class="text-3xl block mb-2">🤝</span>
              <h3 class="font-uber-display text-base text-ink">Persona Encontrada</h3>
              <p class="text-xs text-body font-uber-text mt-1">Reporta a alguien localizado pero que aún no está identificado.</p>
            </div>
          </button>
          <button type="button" class="type-card text-left p-5 border rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" :class="tipo === \'refugio\' ? \'border-primary bg-canvas-softer scale-98\' : \'border-canvas-soft bg-canvas\'" @click="setTipo(\'refugio\')">
            <div>
              <span class="text-3xl block mb-2">🏠</span>
              <h3 class="font-uber-display text-base text-ink">Reportar Refugio</h3>
              <p class="text-xs text-body font-uber-text mt-1">Registra información sobre la capacidad o estado de un refugio.</p>
            </div>
          </button>
        )}
        <button type="button" class="type-card text-left p-5 border rounded-xl cursor-pointer hover:border-primary transition-all active:scale-98 flex flex-col justify-between" :class="tipo === \'necesidad\' ? \'border-primary bg-canvas-softer scale-98\' : \'border-canvas-soft bg-canvas\'" @click="setTipo(\'necesidad\')">
          <div>
            <span class="text-3xl block mb-2">🚨</span>
            <h3 class="font-uber-display text-base text-ink">Necesidad Crítica</h3>
            <p class="text-xs text-body font-uber-text mt-1">Petición urgente de agua, comida, medicina o rescate.</p>
          </div>
        </button>
      </div>
      <input type="hidden" name="tipo" id="input-tipo" :value="tipo" />

      <div class="flex justify-end pt-4">
        <button type="button" id="btn-next-1" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text px-8" :disabled="!tipo" @click="goToStep(2)">
          Siguiente
        </button>
      </div>
    </div>

    <!-- PASO 2: DETALLES -->
    <div id="pane-step-2" class="step-pane space-y-6" x-show="step === 2" x-transition style="display: none;">
      <!-- 2.1 Detalles del Reporte -->
      <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
        <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">1. Detalles del Reporte</legend>
        
        <!-- BLOQUE PERSONA (Desaparecido / Encontrado) -->
        <div id="campos-tipo-persona" class="space-y-4" x-show="tipo === 'desaparecido' || tipo === 'encontrado'">
          <div>
            <label id="label-nombre-buscado" class="block font-uber-text uber-body-sm-strong text-body mb-1" x-text="tipo === 'desaparecido' ? 'Nombre de Persona Involucrada *' : 'Nombre de Persona Encontrada'"></label>
            <input type="text" name="nombre_buscado" class="input w-full font-uber-text uber-body-md" placeholder="Nombres y apellidos completos" />
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Cédula de Persona Involucrada</label>
            <input type="text" name="cedula_buscado" class="input w-full font-uber-text uber-body-md" placeholder="Opcional (si se conoce)" />
          </div>

          <!-- Campos adicionales específicos para desaparecido -->
          <div id="campos-desaparecido" class="space-y-4 border-t border-canvas-soft pt-4 mt-2" x-show="tipo === 'desaparecido'" style="display: none;">
            <p class="font-uber-display text-sm text-ink font-semibold">Datos adicionales de la persona desaparecida:</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Estado (Última ubicación) *</label>
                <input type="text" name="extra_estado" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Distrito Capital" />
              </div>
              <div>
                <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Ciudad *</label>
                <input type="text" name="extra_ciudad" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Caracas" />
              </div>
              <div>
                <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Sector / Zona *</label>
                <input type="text" name="extra_sector" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Los Palos Grandes" />
              </div>
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Fecha y Hora de Último Contacto *</label>
              <input type="datetime-local" name="extra_ultimo_contacto" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Señas Particulares y Vestimenta *</label>
              <textarea name="extra_senas" class="textarea w-full h-20 font-uber-text uber-body-md" placeholder="Ej: Cicatriz en la ceja izquierda, vestía camisa azul y jean oscuro..."></textarea>
            </div>
          </div>
        </div>

        <!-- BLOQUE NECESIDAD CRÍTICA -->
        <div id="campos-tipo-necesidad" class="space-y-4" x-show="tipo === 'necesidad'" style="display: none;">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tipo de Necesidad *</label>
              <select x-model="necesidadCategoria" name="necesidad_categoria" id="necesidad_categoria_select" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
                <option value="Agua potable">Agua potable</option>
                <option value="Alimentos / Comida">Alimentos / Comida</option>
                <option value="Atención médica / Medicinas">Atención médica / Medicinas</option>
                <option value="Rescate / Evacuación">Rescate / Evacuación</option>
                <option value="Ropa / Cobijo">Ropa / Cobijo</option>
                <option value="Energía / Telecomunicaciones">Energía / Telecomunicaciones</option>
                <option value="Otro">Otro / Varios</option>
              </select>
              <div id="wrapper-necesidad-otro" class="mt-2" x-show="necesidadCategoria === 'Otro'" style="display: none;">
                <input type="text" name="necesidad_categoria_otro" id="necesidad_categoria_otro" placeholder="Especifica la necesidad (ej: Pañales, linternas...)" class="input w-full font-uber-text uber-body-md" />
              </div>
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Urgencia / Gravedad *</label>
              <select name="necesidad_gravedad" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
                <option value="Alta (Riesgo de vida)">Alta (Riesgo de vida)</option>
                <option value="Media (Urgente)">Media (Urgente)</option>
                <option value="Baja (Soporte)">Baja (Soporte / Prevención)</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Personas Afectadas (Aproximado)</label>
              <input type="number" name="necesidad_afectados" min="1" placeholder="Ej: 15" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">📞 Teléfono para Coordinar Ayuda *</label>
              <input type="tel" name="necesidad_telefono" class="input w-full font-uber-text uber-body-md" placeholder="Ej: 0412-123-4567" />
              <span class="text-xs text-mute mt-1 block font-uber-text">Quién puede recibir la ayuda o coordinar el suministro.</span>
            </div>
          </div>
          {isVolunteer && (
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Asociar a Refugio (Opcional - Solo Voluntarios)</label>
              <select name="refugio_id" id="select_refugio_id" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
                <option value="">Ninguno / Ubicación Manual en Mapa</option>
                {refugios.map((r: any) => (
                  <option value={`${r.tipo}:${r.id}`} data-lat={r.latitud} data-lng={r.longitud} data-nombre={r.nombre}>
                    {r.tipo === 'hospital' ? '🏥 ' : r.tipo === 'centro_acopio' ? '📦 ' : '⛺ '} {r.nombre}
                  </option>
                ))}
              </select>
              <span class="text-xs text-mute mt-1 block font-uber-text">Selecciona un refugio/centro/hospital si los insumos son para uno de ellos.</span>
            </div>
          )}
        </div>

        <!-- BLOQUE REPORTAR REFUGIO -->
        <div id="campos-tipo-refugio" class="space-y-4" x-show="tipo === 'refugio'" style="display: none;">
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Nombre del Refugio / Acopio *</label>
            <input type="text" name="refugio_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Ej: Albergue Polideportivo Petare" />
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tipo de Centro *</label>
            <select name="refugio_tipo" class="select w-full font-uber-text uber-body-md bg-canvas-soft border-transparent">
              <option value="Refugio temporal">Refugio / Albergue temporal</option>
              <option value="Centro de acopio">Centro de acopio de insumos</option>
              <option value="Puesto de salud">Puesto de salud / socorro médico</option>
            </select>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Población Alojada (Pers.)</label>
              <input type="number" name="refugio_ocupacion" min="0" placeholder="Ej: 45" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Capacidad Máxima (Pers.)</label>
              <input type="number" name="refugio_capacidad" min="1" placeholder="Ej: 100" class="input w-full font-uber-text uber-body-md" />
            </div>
          </div>
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">📞 Teléfono del Encargado / Coordinador</label>
            <input type="tel" name="refugio_telefono" class="input w-full font-uber-text uber-body-md" placeholder="Ej: 0414-987-6543" />
            <span class="text-xs text-mute mt-1 block font-uber-text">Para que voluntarios puedan contactar directamente al encargado del refugio.</span>
          </div>
        </div>

        <!-- CAMPO COMÚN: DESCRIPCIÓN DETALLADA -->
        <div class="mt-4 pt-4 border-t border-canvas-soft">
          <label id="label-descripcion" class="block font-uber-text uber-body-sm-strong text-body mb-1" x-text="labelDescripcion"></label>
          <textarea 
            name="descripcion" 
            id="input-descripcion"
            class="textarea w-full h-24 font-uber-text uber-body-md" 
            placeholder="Ej: Detalles de la desaparición o situación..."
          ></textarea>
          <span id="help-descripcion" class="text-xs text-mute mt-1 block font-uber-text" x-text="helpDescripcion"></span>
        </div>
      </fieldset>

      <!-- 2.2 Ubicación -->
      <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
        <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">2. Lugar del Reporte</legend>
        <div class="space-y-4">
          <div>
            <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Dirección / Lugar de Avistamiento</label>
            <input type="text" name="ubicacion_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Sector, calle o punto de referencia" />
          </div>
          <MapaUbicacion />
        </div>
      </fieldset>

      <!-- 2.3 Reportante y Evidencia -->
      <fieldset class="fieldset bg-canvas border border-canvas-soft p-4 sm:p-6 rounded-xl shadow-sm">
        <legend class="fieldset-legend font-uber-display text-lg text-ink px-2 bg-canvas">3. Reportante y Evidencia</legend>
        <div class="space-y-4">
          <FotoUpload />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tu Nombre (Reportante)</label>
              <input type="text" name="reportante_nombre" class="input w-full font-uber-text uber-body-md" placeholder="Opcional" value={volunteerName} />
            </div>
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tu Contacto (Teléfono/Email)</label>
              <input type="text" name="reportante_contacto" class="input w-full font-uber-text uber-body-md" placeholder="Para coordinar rescate" value={volunteerPhone} />
            </div>
          </div>
        </div>
      </fieldset>

      <div class="flex justify-between pt-4">
        <button type="button" id="btn-back-2" class="btn btn-secondary font-uber-text px-8" @click="goToStep(1)">
          Atrás
        </button>
        <button type="button" id="btn-next-2" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text px-8" @click="goToStep(3)">
          Siguiente
        </button>
      </div>
    </div>

    <!-- PASO 3: CONFIRMACIÓN Y OPCIONES -->
    <div id="pane-step-3" class="step-pane space-y-6" x-show="step === 3" x-transition style="display: none;">
      <div class="text-center mb-6">
        <h2 class="font-uber-display text-xl text-ink">Confirmación de Reporte</h2>
        <p class="text-xs text-body font-uber-text mt-1">Por favor, revisa las opciones finales antes de enviar.</p>
      </div>

      <!-- Resumen del reporte para revisión visual -->
      <div class="border border-canvas-soft bg-canvas-soft p-5 rounded-xl space-y-3 font-uber-text uber-body-sm">
        <p><strong class="text-ink">Tipo de Reporte:</strong> <span id="summary-tipo">-</span></p>
        <p id="summary-row-nombre"><strong class="text-ink">Involucrado:</strong> <span id="summary-nombre">-</span></p>
        <p><strong class="text-ink">Descripción:</strong> <span id="summary-descripcion">-</span></p>
        <p><strong class="text-ink">Ubicación:</strong> <span id="summary-ubicacion">-</span></p>
        <p><strong class="text-ink">Foto adjunta:</strong> <span id="summary-foto">No</span></p>
      </div>

      <!-- Opción de Flyer de Emergencia (sólo para desaparecido con foto) -->
      <div id="flyer-opt-in" class="hidden border border-canvas-soft bg-canvas p-5 rounded-xl shadow-sm">
        <label class="cursor-pointer flex items-start gap-4 select-none">
          <input 
            type="checkbox" 
            name="generar_flyer" 
            id="generar-flyer-chk" 
            checked 
            class="w-5 h-5 rounded-md border-2 border-primary bg-canvas text-primary focus:ring-0 focus:ring-offset-0 mt-0.5 accent-black" 
          />
          <div class="flex-grow">
            <span class="font-uber-display text-sm text-ink block">
              ✨ Generar cartel (flyer) de emergencia descargable
            </span>
            <span class="text-xs text-body mt-1 block">
              Crearemos automáticamente una imagen optimizada para compartir en redes sociales y WhatsApp con los datos provistos.
            </span>
          </div>
        </label>
      </div>

      <!-- Tip de flyer si tipo desaparecido pero sin foto -->
      <div id="flyer-no-photo-tip" class="hidden border border-amber-500/20 bg-amber-500/5 p-4 rounded-xl font-uber-text text-xs text-body">
        💡 <strong>Tip:</strong> Si deseas generar un cartel de búsqueda descargable para WhatsApp y redes, puedes regresar al paso anterior y subir una foto de la persona desaparecida.
      </div>

      <div class="flex justify-between pt-4">
        <button type="button" id="btn-back-3" class="btn btn-secondary font-uber-text px-8" @click="goToStep(2)">
          Atrás
        </button>
        <button type="submit" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text px-8">
          Enviar reporte de emergencia
        </button>
      </div>
    </div>

    <!-- Toast de estado estilo ex-toast -->
    <div id="toast-container-rep" class="toast-mobile" x-show="toast.visible" x-transition style="display: none;">
      <div id="toast-message-rep" class="bg-canvas border text-ink rounded-xl p-4 shadow-md font-uber-text uber-body-sm flex items-center gap-2" :class="toast.borderClass">
        <span x-text="toast.message"></span>
      </div>
    </div>
  </form>
</div>

<script>
  import { encolarRegistro } from "../lib/offline-queue";
  (window as any).encolarRegistro = encolarRegistro;
</script>

