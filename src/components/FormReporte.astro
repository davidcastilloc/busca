---
import MapaUbicacion from "./MapaUbicacion.astro";
import FotoUpload from "./FotoUpload.astro";
---

<div class="max-w-2xl mx-auto p-4">
  <form id="form-reporte" class="space-y-6">
    <!-- Bloque 1: Datos Reporte -->
    <fieldset class="fieldset bg-base-100 border border-base-300 p-6 rounded-box shadow-sm">
      <legend class="fieldset-legend font-black text-lg text-warning px-2">1. Detalles del Reporte</legend>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="label"><span class="label-text font-bold">Tipo de Reporte *</span></label>
          <select name="tipo" class="select select-bordered w-full font-semibold">
            <option value="desaparecido" class="text-error">Persona Desaparecida (Búsqueda)</option>
            <option value="encontrado" class="text-success">Persona Encontrada (No Identificada)</option>
            <option value="refugio" class="text-info">Solicitud / Reporte de Refugio</option>
            <option value="necesidad" class="text-warning">Necesidad Crítica (Médica, Agua, Comida)</option>
          </select>
        </div>
        
        <div>
          <label class="label"><span class="label-text font-bold">Nombre de Persona Involucrada</span></label>
          <input type="text" name="nombre_buscado" class="input input-bordered w-full" placeholder="Opcional (si se conoce)" />
        </div>
        <div>
          <label class="label"><span class="label-text font-bold">Cédula de Persona Involucrada</span></label>
          <input type="text" name="cedula_buscado" class="input input-bordered w-full" placeholder="Opcional (si se conoce)" />
        </div>

        <div class="md:col-span-2">
          <label class="label"><span class="label-text font-bold">Descripción Detallada *</span></label>
          <textarea 
            name="descripcion" 
            required 
            minlength="10"
            class="textarea textarea-bordered w-full h-32" 
            placeholder="Ej: Hombre de unos 60 años, viste camisa de rayas azul, pantalón marrón. Visto por última vez saliendo de la panadería del centro comercial derrumbado..."
          ></textarea>
          <span class="label-text-alt text-base-content/50">Describe características físicas, vestimenta, señas particulares y condiciones. La IA utilizará esta descripción para cruzar reportes.</span>
        </div>
      </div>
    </fieldset>

    <!-- Bloque 2: Ubicación del Reporte -->
    <fieldset class="fieldset bg-base-100 border border-base-300 p-6 rounded-box shadow-sm">
      <legend class="fieldset-legend font-black text-lg text-warning px-2">2. Lugar del Reporte</legend>
      
      <div class="space-y-4">
        <div>
          <label class="label"><span class="label-text font-bold">Dirección / Lugar de Avistamiento</span></label>
          <input type="text" name="ubicacion_nombre" class="input input-bordered w-full" placeholder="Sector, calle o punto de referencia" />
        </div>
        
        <MapaUbicacion />
      </div>
    </fieldset>

    <!-- Bloque 3: Reportante y Evidencia -->
    <fieldset class="fieldset bg-base-100 border border-base-300 p-6 rounded-box shadow-sm">
      <legend class="fieldset-legend font-black text-lg text-warning px-2">3. Reportante y Evidencia</legend>
      
      <div class="space-y-4">
        <FotoUpload />

        <!-- Opción de Flyer de Emergencia (solo se muestra para tipo=desaparecido si se cargó foto) -->
        <div id="flyer-opt-in" class="hidden border border-error/20 bg-error/5 p-4 rounded-xl mt-2">
          <label class="label cursor-pointer flex items-start gap-3">
            <input 
              type="checkbox" 
              name="generar_flyer" 
              id="generar-flyer-chk" 
              checked 
              class="checkbox checkbox-error mt-0.5" 
            />
            <div class="flex-grow">
              <span class="label-text font-extrabold text-error block text-sm">
                🖼️ Generar cartel (flyer) de búsqueda descargable
              </span>
              <span class="text-xs text-base-content/70 mt-1 block">
                Al enviar el reporte, crearemos un cartel de difusión rápido en formato imagen listo para compartir en redes sociales y WhatsApp.
              </span>
            </div>
          </label>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="label"><span class="label-text font-bold">Tu Nombre (Reportante)</span></label>
            <input type="text" name="reportante_nombre" class="input input-bordered w-full" placeholder="Opcional" />
          </div>
          <div>
            <label class="label"><span class="label-text font-bold">Tu Contacto (Teléfono/Email)</span></label>
            <input type="text" name="reportante_contacto" class="input input-bordered w-full" placeholder="Para coordinar rescate" />
          </div>
        </div>
      </div>
    </fieldset>

    <!-- Toast de estado -->
    <div id="toast-container-rep" class="toast toast-end toast-bottom z-50 hidden">
      <div id="toast-message-rep" class="alert alert-info font-semibold">
        <span>Guardando...</span>
      </div>
    </div>

    <button type="submit" class="btn btn-warning btn-block text-black font-bold text-lg shadow-md">
      📢 Emitir Reporte de Emergencia
    </button>
  </form>
</div>

<script>
  import { encolarRegistro } from "../lib/offline-queue";

  const form = document.getElementById("form-reporte") as HTMLFormElement;
  const toastContainer = document.getElementById("toast-container-rep");
  const toastMessage = document.getElementById("toast-message-rep");

  if (form && toastContainer && toastMessage) {
    const tipoSelect = document.querySelector('select[name="tipo"]') as HTMLSelectElement;
    const fotoFileInput = document.getElementById("foto-file") as HTMLInputElement;
    const quitarFotoBtn = document.getElementById("btn-quitar-foto");
    const flyerOptIn = document.getElementById("flyer-opt-in");

    function actualizarVisibilidadFlyer() {
      if (!tipoSelect || !flyerOptIn) return;
      const esDesaparecido = tipoSelect.value === "desaparecido";
      const tieneFoto = fotoFileInput && fotoFileInput.files && fotoFileInput.files.length > 0;

      if (esDesaparecido && tieneFoto) {
        flyerOptIn.classList.remove("hidden");
      } else {
        flyerOptIn.classList.add("hidden");
      }
    }

    if (tipoSelect) {
      tipoSelect.addEventListener("change", actualizarVisibilidadFlyer);
    }
    if (fotoFileInput) {
      fotoFileInput.addEventListener("change", () => {
        setTimeout(actualizarVisibilidadFlyer, 150);
      });
    }
    if (quitarFotoBtn) {
      quitarFotoBtn.addEventListener("click", () => {
        setTimeout(actualizarVisibilidadFlyer, 150);
      });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      if (String(data.descripcion).trim().length < 10) {
        mostrarToast("❌ La descripción debe tener al menos 10 caracteres.", "alert-error");
        return;
      }

      const payload = {
        tipo: data.tipo || "desaparecido",
        nombre_buscado: data.nombre_buscado ? String(data.nombre_buscado).trim() : null,
        cedula_buscado: data.cedula_buscado ? String(data.cedula_buscado).trim() : null,
        descripcion: String(data.descripcion).trim(),
        reportante_nombre: data.reportante_nombre ? String(data.reportante_nombre).trim() : null,
        reportante_contacto: data.reportante_contacto ? String(data.reportante_contacto).trim() : null,
        ubicacion_nombre: data.ubicacion_nombre ? String(data.ubicacion_nombre).trim() : null,
        latitud: data.latitud ? parseFloat(String(data.latitud)) : null,
        longitud: data.longitud ? parseFloat(String(data.longitud)) : null,
        foto_key: data.foto_key ? String(data.foto_key).trim() : null
      };

      mostrarToast("Procesando reporte...", "alert-info");

      if (navigator.onLine) {
        try {
          const response = await fetch("/api/reportes", {
            method: "POST",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify(payload)
          });

          if (response.ok) {
            const generarFlyerChk = document.getElementById("generar-flyer-chk") as HTMLInputElement;
            const quiereFlyer = generarFlyerChk && generarFlyerChk.checked && payload.tipo === "desaparecido";

            if (quiereFlyer && payload.foto_key && !payload.foto_key.startsWith("data:")) {
              mostrarToast("Reporte creado. Generando cartel de búsqueda...", "alert-info");
              try {
                const flyerPayload = {
                  title: `SE BUSCA: ${payload.nombre_buscado || "Persona Desaparecida"}`,
                  description: payload.descripcion,
                  foto_key: payload.foto_key,
                  phones: payload.reportante_contacto ? [payload.reportante_contacto] : [],
                  socials: [],
                  registrarEnBusca: false // Ya se esta registrando ahora mismo
                };

                const flyerResponse = await fetch("/api/flyers", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(flyerPayload)
                });

                if (flyerResponse.ok) {
                  const flyerData = await flyerResponse.json();
                  mostrarToast("✓ Cartel generado. Redirigiendo...", "alert-success");
                  setTimeout(() => {
                    window.location.href = `/flyer/${flyerData.id}?creado=true`;
                  }, 1200);
                  return;
                } else {
                  console.error("Fallo al crear flyer desde reporte");
                }
              } catch (flyerErr) {
                console.error("Error al generar flyer:", flyerErr);
              }
            }

            mostrarToast("✓ Reporte emitido con éxito.", "alert-success");
            form.reset();
            document.getElementById("btn-quitar-foto")?.click();
            actualizarVisibilidadFlyer();
          } else {
            const errData = await response.json();
            throw new Error(errData.error || "Error al procesar en servidor");
          }
        } catch (err: any) {
          console.error(err);
          await guardarOffline(payload);
        }
      } else {
        await guardarOffline(payload);
      }
    });

    async function guardarOffline(payload: any) {
      try {
        await encolarRegistro("reporte", payload);
        mostrarToast("⚠️ Sin red. Reporte guardado localmente. Se sincronizará al recuperar conexión.", "alert-warning");
        form.reset();
        document.getElementById("btn-quitar-foto")?.click();
        actualizarVisibilidadFlyer();

        // Disparar evento
        const event = new CustomEvent("offline-record-added");
        window.dispatchEvent(event);
      } catch (e: any) {
        mostrarToast("❌ Error al guardar localmente: " + e.message, "alert-error");
      }
    }

    function mostrarToast(text: string, typeClass: string) {
      if (!toastContainer || !toastMessage) return;

      toastMessage.className = `alert ${typeClass} font-semibold shadow-lg border`;
      toastMessage.innerHTML = `<span>${text}</span>`;
      toastContainer.classList.remove("hidden");

      setTimeout(() => {
        toastContainer.classList.add("hidden");
      }, 5000);
    }
  }
</script>
