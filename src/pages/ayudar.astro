---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import TelegramLoginWidget from "../components/TelegramLoginWidget.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";

export const prerender = false;

const sessionToken = Astro.cookies.get("session_token")?.value;
const pendingAuthCookie = Astro.cookies.get("tg_pending_auth")?.value;
const isTelegramRegister = Astro.url.searchParams.get("register") === "telegram" && pendingAuthCookie;

let pendingTgUser = null;
if (isTelegramRegister && pendingAuthCookie) {
  try {
    pendingTgUser = JSON.parse(pendingAuthCookie);
  } catch (e) {
    // Ignore parse error
  }
}

let voluntario: any = null;
let errorMsg = "";
let successMsg = "";
let refugios: any[] = [];

try {
  const { DB } = env;
  if (DB) {
    if (sessionToken) {
      voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    }

    // Procesar POST si es un voluntario logueado
    if (voluntario && Astro.request.method === "POST") {
      const formData = await Astro.request.formData();
      const action = formData.get("action");

      if (action === "update_refugio") {
        const refugioId = formData.get("refugio_id");
        const ocupacion = parseInt(formData.get("ocupacion") as string, 10);

        if (isNaN(ocupacion) || ocupacion < 0) {
          errorMsg = "La ocupación debe ser un número válido mayor o igual a 0.";
        } else {
          await DB.prepare(`
            UPDATE refugios 
            SET ocupacion_actual = ?, updated_at = datetime('now') 
            WHERE id = ?
          `).bind(ocupacion, refugioId).run();
          successMsg = "Ocupación del refugio actualizada con éxito.";
        }
      }
    }

    // Cargar refugios si está logueado
    if (voluntario) {
      const query = await DB.prepare("SELECT * FROM refugios ORDER BY nombre ASC").all();
      refugios = query.results || [];
    }
  }
} catch (error: any) {
  console.error("Error en backend de /ayudar:", error);
  errorMsg = error.message || "Error al conectar con la base de datos.";
}

const formatFecha = (fechaStr: string) => {
  try {
    if (!fechaStr) return "";
    const d = new Date(fechaStr.replace("T", " ") + " UTC");
    return d.toLocaleString("es-ES", { timeZone: "UTC" });
  } catch (e) {
    return fechaStr;
  }
};
---

<Layout title="Panel de Voluntarios - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-base-200 min-h-screen">
    <div class="max-w-3xl mx-auto w-full">
      {voluntario ? (
        // Vista de Voluntario Autenticado
        <div class="space-y-8 animate-fade-in">
          <!-- Encabezado y Cerrar Sesión -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-6 border-b border-base-300">
            <div>
              <h1 class="text-3xl font-black text-base-content tracking-tight">¡Hola, {voluntario.nombre}!</h1>
              <p class="text-sm text-base-content/70 mt-1">
                Panel de control de voluntarios. Gestiona refugios e inventarios desde el terreno.
              </p>
            </div>
            <button id="btn-logout" class="btn btn-outline btn-sm hover:btn-error">
              🚪 Cerrar sesión
            </button>
          </div>

          {errorMsg && (
            <div class="alert alert-error shadow-sm text-sm">
              <span>⚠️ {errorMsg}</span>
            </div>
          )}
          {successMsg && (
            <div class="alert alert-success shadow-sm text-sm">
              <span>✅ {successMsg}</span>
            </div>
          )}

          <!-- Tarjetas de herramientas y cuenta -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="card bg-base-100 border border-base-200 p-6 shadow-sm md:col-span-2 flex flex-col justify-between gap-4">
              <div>
                <h3 class="text-xs font-bold text-base-content/50 uppercase tracking-widest mb-2">Acciones Rápidas</h3>
                <p class="text-sm text-base-content/70">Registra nuevos centros de acopio o gestiona inventario detallado (insumos médicos, comida, agua).</p>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
                <a href="/refugios/nuevo" class="btn btn-primary flex-1 btn-md gap-2">
                  ➕ Registrar Centro
                </a>
                <a href="/" class="btn btn-outline flex-1 btn-md gap-2">
                  📋 Ver Inventarios
                </a>
              </div>
            </div>

            <div class="card bg-base-100 border border-base-200 p-6 shadow-sm flex flex-col justify-between gap-4">
              <div>
                <h3 class="text-xs font-bold text-base-content/50 uppercase tracking-widest mb-3">Datos de Cuenta</h3>
                <div class="text-sm text-base-content/80 space-y-2">
                  <div>📞 Teléfono: <strong class="text-base-content">{voluntario.telefono}</strong></div>
                  <div>📅 Especialidad: <strong class="text-base-content capitalize">{voluntario.rol || "General"}</strong></div>
                </div>
              </div>
              <div class="text-[10px] text-base-content/50">
                Registrado: {voluntario.created_at ? new Date(voluntario.created_at.replace("T", " ") + " UTC").toLocaleDateString("es-ES", { timeZone: "UTC" }) : ""}
              </div>
            </div>
          </div>

          <!-- Lista de Refugios para Ocupación Rápida -->
          <div class="space-y-6 pt-4">
            <h2 class="text-2xl font-black text-base-content tracking-tight flex items-center gap-2">
              ⛺ Ocupación de Refugios en Vivo
            </h2>

            {refugios.length === 0 ? (
              <div class="text-center py-12 bg-base-100 border border-base-200 rounded-3xl">
                <p class="text-base-content/60 text-sm font-medium">No hay refugios registrados en la base de datos.</p>
              </div>
            ) : (
              refugios.map((r) => {
                const cap = r.capacidad_maxima || 100;
                const ocu = r.ocupacion_actual || 0;
                const pct = Math.min(100, Math.round((ocu / cap) * 100));

                let pctColor = "progress-success";
                if (pct >= 90) pctColor = "progress-error";
                else if (pct >= 75) pctColor = "progress-warning";

                return (
                  <div class="card bg-base-100 border border-base-200 p-6 shadow-sm hover:shadow transition-shadow overflow-hidden">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
                      <div>
                        <h3 class="text-xl font-bold text-base-content">{r.nombre}</h3>
                        {r.direccion && <p class="text-xs text-base-content/70 mt-1">📍 {r.direccion}</p>}
                      </div>
                      <div class="text-xs text-base-content/50">
                        Modificado: {formatFecha(r.updated_at)}
                      </div>
                    </div>

                    <!-- Progreso -->
                    <div class="mb-4">
                      <div class="flex justify-between text-xs font-semibold text-base-content/70 mb-1.5">
                        <span>Estado de capacidad</span>
                        <span>{ocu} / {cap} personas ({pct}%)</span>
                      </div>
                      <progress class={`progress w-full h-2.5 ${pctColor}`} value={pct} max="100"></progress>
                    </div>

                    <!-- Formulario rápido -->
                    <form method="POST" class="flex flex-wrap items-end gap-4 bg-base-200/50 p-4 rounded-2xl border border-base-300/50">
                      <input type="hidden" name="action" value="update_refugio" />
                      <input type="hidden" name="refugio_id" value={r.id} />

                      <div class="flex-grow min-w-[140px]">
                        <label class="block text-[10px] font-bold text-base-content/50 uppercase tracking-wider mb-1.5">Nº Personas en Sitio</label>
                        <input 
                          type="number" 
                          name="ocupacion" 
                          value={ocu} 
                          min="0"
                          max={cap * 2}
                          class="input input-bordered input-sm w-full font-semibold text-center bg-base-100" 
                          id={`input-${r.id}`}
                          required 
                        />
                      </div>

                      <!-- Botones rápidos -->
                      <div class="flex gap-1.5">
                        <button 
                          type="button" 
                          class="btn btn-sm btn-outline"
                          onclick={`document.getElementById('input-${r.id}').value = Math.round(${cap} * 0.25)`}
                        >
                          25%
                        </button>
                        <button 
                          type="button" 
                          class="btn btn-sm btn-outline"
                          onclick={`document.getElementById('input-${r.id}').value = Math.round(${cap} * 0.75)`}
                        >
                          75%
                        </button>
                        <button 
                          type="button" 
                          class="btn btn-sm btn-outline"
                          onclick={`document.getElementById('input-${r.id}').value = ${cap}`}
                        >
                          100%
                        </button>
                      </div>

                      <button type="submit" class="btn btn-primary btn-sm ml-auto">
                        Actualizar
                      </button>
                    </form>
                  </div>
                );
              })
            )}
          </div>
        </div>
      ) : (
        // Vista de Registro / Ingreso
        <div class="space-y-6 max-w-md mx-auto animate-fade-in" x-data="{ tab: 'login' }">
          <div class="text-center">
            <span class="text-4xl">🤝</span>
            <h1 class="text-3xl font-black text-base-content tracking-tight mt-3">
              Quiero ayudar
            </h1>
            <p class="text-sm text-base-content/70 mt-1">
              Regístrate o inicia sesión como voluntario para reportar y actualizar el estado de los centros.
            </p>
          </div>

          <!-- Selector de Pestañas Registro / Login -->
          {!isTelegramRegister && (
            <div class="tabs tabs-boxed justify-center p-1 bg-base-300">
              <button 
                id="tab-login" 
                @click="tab = 'login'"
                :class="tab === 'login' ? 'tab-active' : ''"
                class="tab flex-1 font-semibold"
              >
                Iniciar Sesión
              </button>
              <button 
                id="tab-register" 
                @click="tab = 'register'"
                :class="tab === 'register' ? 'tab-active' : ''"
                class="tab flex-1 font-semibold"
              >
                Registrarse
              </button>
            </div>
          )}

          {/* Flujo Normal - Login */}
          <form 
            id="form-login" 
            x-show="tab === 'login'" 
            class="space-y-4 card bg-base-100 border border-base-200 p-6 shadow-sm"
            style={isTelegramRegister ? "display: none;" : ""}
          >
            <h3 class="text-sm font-bold text-base-content/50 uppercase tracking-widest mb-2">Ingresar a tu cuenta</h3>
            
            <div class="flex justify-center py-2">
              <TelegramLoginWidget 
                botName="DondeEstanBot" 
                authUrl="/api/auth/telegram-web" 
              />
            </div>
            
            <div class="divider text-xs text-base-content/40">o con teléfono</div>
            
            <div class="form-control">
              <label class="label" for="login-telefono">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Teléfono *</span>
              </label>
              <input 
                type="tel" 
                id="login-telefono" 
                required 
                class="input input-bordered w-full" 
                placeholder="Ej: 04127654321"
              />
            </div>

            <div class="form-control">
              <label class="label" for="login-pin">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">PIN de 4 dígitos *</span>
              </label>
              <input 
                type="password" 
                id="login-pin" 
                required 
                maxlength="4"
                inputmode="numeric"
                pattern="[0-9]*"
                class="input input-bordered w-full" 
                placeholder="••••"
              />
            </div>

            <div id="login-error" class="hidden alert alert-error text-xs p-3 shadow-sm"></div>

            <button type="submit" id="btn-submit-login" class="btn btn-primary w-full mt-4">
              Iniciar Sesión
            </button>
          </form>

          <!-- Formulario Registro Normal -->
          <form 
            id="form-register" 
            x-show="tab === 'register'" 
            class="space-y-4 card bg-base-100 border border-base-200 p-6 shadow-sm"
            style="display: none;"
          >
            <h3 class="text-sm font-bold text-base-content/50 uppercase tracking-widest mb-2">Crear cuenta voluntario</h3>

            <div class="form-control">
              <label class="label" for="reg-nombre">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Nombre y Apellido *</span>
              </label>
              <input 
                type="text" 
                id="reg-nombre" 
                required 
                class="input input-bordered w-full" 
                placeholder="Ej: Pedro Pérez"
              />
            </div>
            
            <div class="form-control">
              <label class="label" for="reg-telefono">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Teléfono de contacto *</span>
              </label>
              <input 
                type="tel" 
                id="reg-telefono" 
                required 
                class="input input-bordered w-full" 
                placeholder="Ej: 04127654321"
              />
            </div>

            <div class="form-control">
              <label class="label" for="reg-pin">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Crear PIN (4 dígitos) *</span>
              </label>
              <input 
                type="password" 
                id="reg-pin" 
                required 
                maxlength="4"
                inputmode="numeric"
                pattern="[0-9]*"
                class="input input-bordered w-full" 
                placeholder="Ej: 1234"
              />
            </div>

            <div class="form-control">
              <label class="label" for="reg-rol">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Especialidad / Rol *</span>
              </label>
              <select id="reg-rol" required class="select select-bordered w-full">
                <option value="general">General (Cualquier ayuda)</option>
                <option value="busqueda">Búsqueda de Personas</option>
                <option value="rescate">Rescate en Terreno</option>
                <option value="logistica">Logística y Refugios</option>
              </select>
            </div>

            <div class="form-control flex flex-row items-start gap-2.5 my-2">
              <input 
                type="checkbox" 
                id="reg-terminos" 
                required 
                class="checkbox checkbox-primary mt-0.5"
              />
              <label class="label-text cursor-pointer select-none text-xs text-base-content/70" for="reg-terminos">
                Acepto los <a href="/terminos" target="_blank" class="link link-primary font-semibold">Términos y Condiciones</a> y la <a href="/privacidad" target="_blank" class="link link-primary font-semibold">Política de Privacidad</a> *
              </label>
            </div>

            <div id="reg-error" class="hidden alert alert-error text-xs p-3 shadow-sm"></div>

            <button type="submit" id="btn-submit-reg" class="btn btn-primary w-full mt-4">
              Registrarse y entrar
            </button>
          </form>

          {/* Flujo Completar Registro Telegram */}
          {isTelegramRegister && (
            <form id="form-tg-register" class="space-y-4 card bg-base-100 border border-base-200 p-6 shadow-sm">
              <h3 class="text-sm font-bold text-base-content/50 uppercase tracking-widest mb-2">Completar Registro con Telegram</h3>
              <p class="text-xs text-base-content/70">
                Hola <b>{pendingTgUser?.first_name}</b>, para finalizar tu registro y vincular tu cuenta de Telegram, necesitamos un número de teléfono. Si ya tienes cuenta, esto la vinculará automáticamente.
              </p>

              <div class="form-control">
                <label class="label" for="tg-telefono">
                  <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Teléfono de contacto *</span>
                </label>
                <input 
                  type="tel" 
                  id="tg-telefono" 
                  required 
                  class="input input-bordered w-full" 
                  placeholder="Ej: 04127654321"
                />
              </div>

              <div class="form-control">
                <label class="label" for="tg-pin">
                  <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">PIN (4 dígitos) *</span>
                </label>
                <input 
                  type="password" 
                  id="tg-pin" 
                  required 
                  maxlength="4"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  class="input input-bordered w-full" 
                  placeholder="Si ya tienes cuenta, ingresa tu PIN."
                />
              </div>

              <div class="form-control">
                <label class="label" for="tg-rol">
                  <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Especialidad / Rol *</span>
                </label>
                <select id="tg-rol" required class="select select-bordered w-full">
                  <option value="general">General (Cualquier ayuda)</option>
                  <option value="busqueda">Búsqueda de Personas</option>
                  <option value="rescate">Rescate en Terreno</option>
                  <option value="logistica">Logística y Refugios</option>
                </select>
              </div>

              <div class="form-control flex flex-row items-start gap-2.5 my-2">
                <input 
                  type="checkbox" 
                  id="tg-terminos" 
                  required 
                  class="checkbox checkbox-primary mt-0.5"
                />
                <label class="label-text cursor-pointer select-none text-xs text-base-content/70" for="tg-terminos">
                  Acepto los <a href="/terminos" target="_blank" class="link link-primary font-semibold">Términos y Condiciones</a> y la <a href="/privacidad" target="_blank" class="link link-primary font-semibold">Política de Privacidad</a> *
                </label>
              </div>

              <div id="tg-error" class="hidden alert alert-error text-xs p-3 shadow-sm"></div>

              <button type="submit" id="btn-submit-tg" class="btn btn-primary w-full mt-4 flex items-center justify-center gap-2">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M21.011 2.94611C21.4647 2.80218 21.8906 3.22815 21.7466 3.68176L16.4862 20.2524C16.3275 20.7523 15.6517 20.8524 15.3414 20.4194L11.5 15.0538M21.011 2.94611L3.92135 9.07166C3.43398 9.2464 3.46822 9.94821 3.9723 10.0742L11.5 11.9566M21.011 2.94611L11.5 11.9566M11.5 11.9566V15.0538M11.5 15.0538L9.04306 18.2917C8.7501 18.6778 8.13111 18.5284 8.05834 18.054L7.54581 14.717L11.5 11.9566Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Finalizar Registro
              </button>
            </form>
          )}
        </div>
      )}
    </div>
  </main>
</Layout>

<script>
  function initAyudar() {
    // Manejo de Logout
    const btnLogout = document.getElementById("btn-logout");
    btnLogout?.addEventListener("click", async () => {
      try {
        const resp = await fetch("/api/auth/logout", { method: "POST" });
        if (resp.ok) {
          window.location.reload();
        }
      } catch (err) {
        console.error("Error al cerrar sesión:", err);
      }
    });

    // Envío Formulario Login
    const formLogin = document.getElementById("form-login");
    const formRegister = document.getElementById("form-register");
    formLogin?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const telefono = (document.getElementById("login-telefono") as HTMLInputElement).value;
      const pin = (document.getElementById("login-pin") as HTMLInputElement).value;
      const errorDiv = document.getElementById("login-error");
      const btnSubmit = document.getElementById("btn-submit-login") as HTMLButtonElement;

      if (errorDiv) errorDiv.classList.add("hidden");
      if (btnSubmit) btnSubmit.disabled = true;

      try {
        const resp = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ telefono, pin })
        });

        if (resp.ok) {
          window.location.reload();
        } else {
          const err = await resp.json();
          if (errorDiv) {
            errorDiv.textContent = `Error: ${err.error || "no se pudo ingresar."}`;
            errorDiv.classList.remove("hidden");
          }
          if (btnSubmit) btnSubmit.disabled = false;
        }
      } catch {
        if (errorDiv) {
          errorDiv.textContent = "Error de conexión con el servidor.";
          errorDiv.classList.remove("hidden");
        }
        if (btnSubmit) btnSubmit.disabled = false;
      }
    });

    // Envío Formulario Registro
    formRegister?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const nombre = (document.getElementById("reg-nombre") as HTMLInputElement).value.trim();
      const telefono = (document.getElementById("reg-telefono") as HTMLInputElement).value;
      const pin = (document.getElementById("reg-pin") as HTMLInputElement).value;
      const rol = (document.getElementById("reg-rol") as HTMLSelectElement).value;
      const aceptarTerminos = (document.getElementById("reg-terminos") as HTMLInputElement).checked;
      const errorDiv = document.getElementById("reg-error");
      const btnSubmit = document.getElementById("btn-submit-reg") as HTMLButtonElement;

      if (!aceptarTerminos) {
        if (errorDiv) {
          errorDiv.textContent = "Error: Debes aceptar los Términos y la Política de Privacidad.";
          errorDiv.classList.remove("hidden");
        }
        return;
      }

      if (errorDiv) errorDiv.classList.add("hidden");
      if (btnSubmit) btnSubmit.disabled = true;

      try {
        const resp = await fetch("/api/auth/register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ nombre, telefono, pin, rol, aceptarTerminos })
        });

        if (resp.ok) {
          window.location.reload();
        } else {
          const err = await resp.json();
          if (errorDiv) {
            errorDiv.textContent = `Error: ${err.error || "no se pudo registrar."}`;
            errorDiv.classList.remove("hidden");
          }
          if (btnSubmit) btnSubmit.disabled = false;
        }
      } catch {
        if (errorDiv) {
          errorDiv.textContent = "Error de conexión con el servidor.";
          errorDiv.classList.remove("hidden");
        }
        if (btnSubmit) btnSubmit.disabled = false;
      }
    });

    // Envío Formulario Registro Telegram
    const formTgRegister = document.getElementById("form-tg-register");
    formTgRegister?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const telefono = (document.getElementById("tg-telefono") as HTMLInputElement).value;
      const pin = (document.getElementById("tg-pin") as HTMLInputElement).value;
      const rol = (document.getElementById("tg-rol") as HTMLSelectElement).value;
      const aceptarTerminos = (document.getElementById("tg-terminos") as HTMLInputElement).checked;
      const errorDiv = document.getElementById("tg-error");
      const btnSubmit = document.getElementById("btn-submit-tg") as HTMLButtonElement;

      if (!aceptarTerminos) {
        if (errorDiv) {
          errorDiv.textContent = "Error: Debes aceptar los Términos y la Política de Privacidad.";
          errorDiv.classList.remove("hidden");
        }
        return;
      }

      if (errorDiv) errorDiv.classList.add("hidden");
      if (btnSubmit) btnSubmit.disabled = true;

      try {
        const resp = await fetch("/api/auth/telegram-register", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ telefono, pin, rol, aceptarTerminos })
        });

        if (resp.ok) {
          // Limpiar query param y recargar
          window.location.href = "/ayudar";
        } else {
          const err = await resp.json();
          if (errorDiv) {
            errorDiv.textContent = `Error: ${err.error || "no se pudo completar registro."}`;
            errorDiv.classList.remove("hidden");
          }
          if (btnSubmit) btnSubmit.disabled = false;
        }
      } catch {
        if (errorDiv) {
          errorDiv.textContent = "Error de conexión con el servidor.";
          errorDiv.classList.remove("hidden");
        }
        if (btnSubmit) btnSubmit.disabled = false;
      }
    });
  }

  // Re-ejecutar en cada navegación de ClientRouter
  document.addEventListener("astro:page-load", initAyudar);
</script>
