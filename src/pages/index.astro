---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BuscadorRapido from "../components/BuscadorRapido.astro";
import ShareButton from "../components/ShareButton.astro";
import ModalEditRefugio from "../components/ModalEditRefugio.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";
import { CATEGORIAS_INVENTARIO } from "../lib/items";

export const prerender = false;

let esVoluntario = false;
let esAdmin = false;

let totalRefugios = 0;
let totalNecesidades = 0;
let necesidadesCriticas: any[] = [];
let refugiosIniciales: any[] = [];
let zonasPeligro: any[] = [];

try {
  const { DB } = env;
  if (DB) {
    const sessionToken = Astro.cookies.get("session_token")?.value;
    const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    esVoluntario = !!voluntario;
    esAdmin = voluntario?.rol === 'admin';

    const resRefugios = await DB.prepare("SELECT COUNT(*) as total FROM (SELECT id FROM refugios UNION ALL SELECT id FROM centros_acopio UNION ALL SELECT id FROM hospitales)").first<{ total: number }>();
    if (resRefugios) totalRefugios = resRefugios.total;

    const resNecesidades = await DB.prepare("SELECT COUNT(*) as total FROM necesidades WHERE estado = 'abierta'").first<{ total: number }>();
    if (resNecesidades) totalNecesidades = resNecesidades.total;

    const resCriticas = await DB.prepare("SELECT * FROM necesidades WHERE estado = 'abierta' AND gravedad LIKE '%alta%' ORDER BY created_at DESC LIMIT 4").all();
    if (resCriticas && resCriticas.results) {
      necesidadesCriticas = resCriticas.results;
    }

    let zonasPeligro: any[] = [];
    const resZonas = await DB.prepare("SELECT * FROM zonas_peligro WHERE activo = 1 ORDER BY created_at DESC LIMIT 5").all();
    if (resZonas && resZonas.results) {
      zonasPeligro = resZonas.results;
    }

    const queryUnified = `
      SELECT id, nombre, direccion, latitud, longitud, contacto, necesidades, 'refugio' as tipo, 
             capacidad_maxima, ocupacion_actual, ninos, bebes_lactantes, adultos_mayores, 
             personal_profesional, voluntarios, inventario, fecha_registro, created_at, updated_at,
             encargado, fotos
      FROM refugios
      UNION ALL
      SELECT id, nombre, direccion, latitud, longitud, contacto, necesidades, 'centro_acopio' as tipo, 
             NULL as capacidad_maxima, NULL as ocupacion_actual, NULL as ninos, NULL as bebes_lactantes, NULL as adultos_mayores,
             NULL as personal_profesional, NULL as voluntarios, inventario, fecha_registro, created_at, updated_at,
             encargado, fotos
      FROM centros_acopio
      UNION ALL
      SELECT id, nombre, direccion, latitud, longitud, contacto, necesidades, 'hospital' as tipo, 
             NULL as capacidad_maxima, NULL as ocupacion_actual, NULL as ninos, NULL as bebes_lactantes, NULL as adultos_mayores,
             NULL as personal_profesional, NULL as voluntarios, NULL as inventario, fecha_registro, created_at, updated_at,
             NULL as encargado, fotos
      FROM hospitales
      ORDER BY nombre ASC
    `;
    const resRefugiosList = await DB.prepare(queryUnified).all();
    refugiosIniciales = resRefugiosList.results || [];
  }
} catch (e) {
  console.error("Error al cargar datos en index:", e);
}
---

<Layout title="Portal de Coordinación de Emergencia - dondeestan.org">
  <Navbar />
  
  {zonasPeligro && zonasPeligro.length > 0 && (
    <div class="bg-red-600 text-white font-uber-text font-bold text-xs py-2 px-4 shadow-md w-full relative z-40 flex overflow-hidden">
      <div class="whitespace-nowrap animate-[marquee_15s_linear_infinite] flex items-center min-w-full">
        {zonasPeligro.map((z: any) => (
          <span class="mx-4 flex items-center gap-1">
            <span class="text-sm">⚠️</span> {z.tipo_peligro.toUpperCase()}: {z.descripcion} 
          </span>
        ))}
        {zonasPeligro.map((z: any) => (
          <span class="mx-4 flex items-center gap-1" aria-hidden="true">
            <span class="text-sm">⚠️</span> {z.tipo_peligro.toUpperCase()}: {z.descripcion} 
          </span>
        ))}
      </div>
    </div>
  )}

    <main class="flex-grow py-8 md:py-12 px-4 bg-base-100">
    <!-- Hero Section DaisyUI -->
    <div class="hero min-h-[40vh] bg-base-200 rounded-3xl overflow-hidden mb-12 shadow-sm px-6 py-12 md:py-16">
      <div class="hero-content text-center max-w-2xl">
        <div class="flex flex-col gap-6 items-center">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-base-content balance">
            Portal de Apoyo y Coordinación
          </h1>
          <p class="text-lg md:text-xl text-base-content/70 leading-relaxed max-w-prose">
            Consulta refugios, centros de acopio, necesidades críticas y reporta incidencias tras la emergencia.
          </p>
          <div class="flex flex-wrap gap-4 justify-center w-full mt-2">
            <a href="/reportar" class="btn btn-primary btn-lg shadow-sm hover:-translate-y-0.5 transition-transform w-full sm:w-auto">
              Reportar emergencia
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- FEED DE NECESIDADES CRÍTICAS -->
    {necesidadesCriticas.length > 0 && (
      <div class="w-full max-w-4xl mx-auto mb-16">
        <div class="flex justify-between items-end mb-6 px-2">
          <h3 class="text-2xl md:text-3xl font-black text-base-content tracking-tight">Urgencias (Gravedad Alta)</h3>
          <a href="/mapa?layer=necesidades" class="text-sm link link-primary font-bold">Ver todas</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {necesidadesCriticas.map((n) => (
            <div 
              class="card bg-error/10 border border-error/20 hover:shadow-md transition-all duration-300 cursor-pointer w-full group"
              x-data={`{ id: ${n.id}, marcando: false, resuelto: false }`}
              x-show="!resuelto"
              x-transition.opacity.duration.300ms
              @click="if (!$event.target.closest('button')) window.location.href = `/mapa?tipo=necesidad&id=${id}`"
            >
              <div class="card-body p-6">
                <div class="flex items-start gap-4">
                  <div class="avatar placeholder">
                    <div class="bg-error text-error-content rounded-full w-12 h-12 shadow-sm text-xl flex items-center justify-center">
                      ⚠️
                    </div>
                  </div>
                  <div class="flex-grow min-w-0">
                    <h4 class="card-title text-error-content/90 font-bold text-lg leading-tight">{n.categoria}</h4>
                    <p class="text-sm text-base-content/80 mt-2 line-clamp-2 leading-relaxed">{n.descripcion}</p>
                    
                    <div class="flex items-center justify-between mt-4 text-xs font-medium text-base-content/70">
                      <span class="flex items-center gap-1.5 truncate max-w-[60%]">
                        <svg class="w-4 h-4 text-error shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                        <span class="truncate">{n.ubicacion_nombre || 'Sin ubicación'}</span>
                      </span>
                      <span class="badge badge-error badge-sm font-semibold shrink-0">
                        Hace {Math.round((new Date().getTime() - new Date(n.created_at).getTime()) / 3600000)}h
                      </span>
                    </div>
                  </div>
                </div>
                
                {esAdmin && (
                  <div class="card-actions justify-end mt-4 pt-4 border-t border-error/20">
                    <button 
                      @click="
                        marcando = true;
                        fetch(`/api/necesidades/${id}`, {
                          method: 'PUT',
                          headers: { 'Content-Type': 'application/json' },
                          body: JSON.stringify({ estado: 'atendida' })
                        }).then(r => r.ok ? (resuelto = true) : (marcando = false))
                      "
                      :disabled="marcando"
                      class="btn btn-sm btn-success text-success-content hover:scale-95 transition-transform"
                    >
                      <span x-show="!marcando">✅ Marcar Resuelto</span>
                      <span x-show="marcando" class="loading loading-spinner loading-xs"></span>
                    </button>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- OTRAS ACCIONES: Voluntarios, Telegram -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 justify-center mb-16 max-w-2xl mx-auto">
      <a href="/ayudar" class="card bg-neutral text-neutral-content hover:-translate-y-1 hover:shadow-lg transition-all cursor-pointer">
        <div class="card-body p-5 flex flex-row items-center gap-4">
          <div class="text-4xl">👷</div>
          <div>
            <h4 class="card-title text-lg mb-1">Ser Voluntario</h4>
            <p class="text-xs text-neutral-content/70">Apoya logística y operaciones</p>
          </div>
        </div>
      </a>
      
      <a href="https://t.me/DondeEstanBot" target="_blank" rel="noopener noreferrer" class="card bg-[#2481cc] text-white hover:-translate-y-1 hover:shadow-lg hover:bg-[#1d6ba8] transition-all cursor-pointer">
        <div class="card-body p-5 flex flex-row items-center gap-4">
          <div class="text-4xl flex items-center justify-center shrink-0">
            <svg class="w-9 h-9 fill-current" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.892-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </div>
          <div>
            <h4 class="card-title text-lg mb-1">Bot de Telegram</h4>
            <p class="text-xs text-white/70">Reporta emergencias rápido</p>
          </div>
        </div>
      </a>
    </div>

    <!-- SECCIÓN DE REFUGIOS Y CENTROS DE ACOPIO -->
    <div id="refugios-seccion" class="max-w-4xl mx-auto mb-16 px-2 animate-fade-in" x-data="{ query: '', filtro: 'todos' }">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <h2 class="text-3xl font-black text-base-content tracking-tight">
            Refugios y Acopio
          </h2>
          <p class="text-sm text-base-content/70 mt-1">
            Directorio en tiempo real de albergues activos y necesidades.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 sm:shrink-0 w-full sm:w-auto">
          <a href="/mapa?layer=refugios" class="btn btn-outline btn-sm rounded-full">
            🗺️ Mapa Completo
          </a>
          {esVoluntario && (
            <a href="/refugios/nuevo" class="btn btn-primary btn-sm rounded-full shadow-sm">
              ➕ Registrar
            </a>
          )}
        </div>
      </div>

      <!-- Mapa Interactivo -->
      <div class="mb-8 relative rounded-2xl overflow-hidden border border-base-200 shadow-sm">
        <div id="mapa-refugios" class="w-full h-[500px] sm:h-[600px] bg-base-200 z-0"></div>
        <button type="button" id="btn-geolocalizar" class="btn btn-circle btn-primary absolute bottom-4 right-4 z-[400] shadow-md shadow-primary/30" title="Encontrar mi ubicación">
          📍
        </button>
      </div>

      <!-- Filtros Rápidos y Buscador -->
      <div class="flex flex-col gap-4 mb-8">
        <label class="input input-bordered flex items-center gap-2 bg-base-100 shadow-sm rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 opacity-70"><path fill-rule="evenodd" d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z" clip-rule="evenodd" /></svg>
          <input 
            type="text" 
            id="search-refugios" 
            x-model="query"
            placeholder="Buscar por nombre, ubicación..." 
            class="grow"
          />
        </label>
        
        <div class="flex flex-wrap gap-2 overflow-x-auto pb-2 scrollbar-none" id="tipo-filtros">
          <button type="button" @click="filtro = 'todos'" :class="filtro === 'todos' ? 'btn-primary' : 'btn-ghost bg-base-200'" class="btn btn-sm rounded-full transition-all">
            Todos
          </button>
          <button type="button" @click="filtro = 'refugio'" :class="filtro === 'refugio' ? 'btn-primary' : 'btn-ghost bg-base-200'" class="btn btn-sm rounded-full transition-all">
            🏠 Refugios
          </button>
          <button type="button" @click="filtro = 'centro_acopio'" :class="filtro === 'centro_acopio' ? 'btn-primary' : 'btn-ghost bg-base-200'" class="btn btn-sm rounded-full transition-all">
            📦 Acopio
          </button>
          <button type="button" @click="filtro = 'hospital'" :class="filtro === 'hospital' ? 'btn-primary' : 'btn-ghost bg-base-200'" class="btn btn-sm rounded-full transition-all">
            🏥 Hospitales
          </button>
        </div>
      </div>

      <!-- Lista de Refugios -->
      <div id="refugios-container" class="grid grid-cols-1 md:grid-cols-2 gap-6 max-h-[650px] overflow-y-auto pr-2">
        {refugiosIniciales.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-16 bg-base-200 rounded-3xl border border-base-300">
            <span class="text-4xl mb-4">📭</span>
            <p class="text-base-content/60 font-medium">No hay centros registrados en este momento.</p>
          </div>
        ) : (
          refugiosIniciales.map((r) => {
            const ocupacion = r.ocupacion_actual || 0;
            const capacidad = r.capacidad_maxima || 100;
            const pct = Math.min(Math.round((ocupacion / capacidad) * 100), 100);
            
            let tipoLabel = "Refugio / Albergue";
            if (r.tipo === "hospital") {
              tipoLabel = "Hospital / Salud";
            } else if (r.tipo === "centro_acopio") {
              tipoLabel = "Centro de Acopio";
            }

            let itemsCriticos: string[] = [];
            let itemsAlerta: string[] = [];
            if (r.inventario) {
              try {
                const inv = typeof r.inventario === 'string' ? JSON.parse(r.inventario) : r.inventario;
                for (const [itemId, estado] of Object.entries(inv)) {
                  const itemObj = CATEGORIAS_INVENTARIO.flatMap(c => c.items).find(i => i.id === itemId);
                  if (itemObj) {
                    if (estado === "Crítico") {
                      itemsCriticos.push(itemObj.nombre);
                    } else if (estado === "Alerta") {
                      itemsAlerta.push(itemObj.nombre);
                    }
                  }
                }
              } catch (e) {
                console.error("Error al parsear inventario:", e);
              }
            }

            const formatFechaStr = (fstr: string) => {
              if (!fstr) return "";
              try {
                return new Date(fstr).toLocaleString('es-VE', {
                  dateStyle: 'short',
                  timeStyle: 'short'
                });
              } catch {
                return fstr;
              }
            };

            let fechaFormateada = formatFechaStr(r.fecha_registro || r.created_at);
            let fechaActualizada = formatFechaStr(r.updated_at);

            let fotosArray: string[] = [];
            if (r.fotos) {
              try {
                fotosArray = typeof r.fotos === 'string' ? JSON.parse(r.fotos) : r.fotos;
              } catch (e) {
                console.error("Error al parsear fotos:", e);
              }
            }

            return (
              <div 
                id={`refugio-${r.id}`}
                data-refugio-inicial={JSON.stringify({
                  ocupacion: ocupacion,
                  capacidad: capacidad,
                  encargado: r.encargado || '',
                  direccion: r.direccion || '',
                  contacto: r.contacto || '',
                  necesidades: r.necesidades || '',
                  ninos: r.ninos || 0,
                  bebes: r.bebes_lactantes || 0,
                  mayores: r.adultos_mayores || 0,
                  prof: r.personal_profesional || 0,
                  vols: r.voluntarios || 0,
                  itemsCriticos: itemsCriticos,
                  itemsAlerta: itemsAlerta,
                  fechaActualizada: fechaActualizada,
                  fotos: fotosArray
                })}
                x-data="refugioCard"
                x-show={`(filtro === 'todos' || filtro === '${r.tipo}') && (!query || query.toLowerCase().split(' ').filter(Boolean).every(word => '${r.nombre.replace(/'/g, "").toLowerCase()} \${direccion.toLowerCase()} \${necesidades.toLowerCase()}'.includes(word)))`}
                class="refugio-card card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow overflow-visible"
                data-id={r.id}
                data-nombre={r.nombre.toLowerCase()}
                data-direccion={(r.direccion || "").toLowerCase()}
                data-necesidades={(r.necesidades || "").toLowerCase()}
                data-tipo={r.tipo || "refugio"}
                data-lat={r.latitud || ""}
                data-lng={r.longitud || ""}
                data-ocupacion={ocupacion}
                data-capacidad={capacidad}
                data-contacto={r.contacto || ""}
                data-encargado={r.encargado || ""}
                data-semaforo={itemsCriticos.length > 0 ? "rojo" : itemsAlerta.length > 0 ? "amarillo" : "verde"}
                data-fotos={typeof r.fotos === 'string' ? r.fotos : JSON.stringify(r.fotos || [])}
              >
                {fotosArray.length > 0 ? (
                  <figure x-show="fotos.length > 0" class="h-48 w-full bg-base-200 rounded-t-[15px] overflow-hidden">
                    <img 
                      src={`/api/upload?key=${fotosArray[0]}`}
                      :src="fotoUrl" 
                      alt={`Foto de ${r.nombre}`} 
                      class="w-full h-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  </figure>
                ) : (
                  <template x-if="fotos && fotos.length > 0">
                    <figure class="h-48 w-full bg-base-200">
                      <img 
                        :src="fotoUrl" 
                        alt={`Foto de ${r.nombre}`} 
                        class="w-full h-full object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    </figure>
                  </template>
                )}
                
                <div class="card-body p-6">
                  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
                    <div>
                      <div class="flex flex-wrap items-center gap-2 mb-2">
                        <div class={`badge badge-sm font-semibold border-0 ${
                          r.tipo === "hospital" ? "bg-error/20 text-error-content" : 
                          r.tipo === "centro_acopio" ? "bg-warning/20 text-warning-content" : "bg-info/20 text-info-content"
                        }`}>
                          {tipoLabel}
                        </div>
                        <h3 class="card-title text-xl font-bold text-base-content leading-tight">{r.nombre}</h3>
                      </div>
                      <p class="text-sm text-base-content/70" x-show="direccion">📍 <span x-text="direccion">{(r.direccion || "")}</span></p>
                    </div>
                    {r.tipo === "refugio" && (
                      <div class="shrink-0">
                        <div class="badge badge-neutral shadow-sm font-semibold" x-text="ocupacion + ' / ' + capacidad + ' pers.'">
                          {ocupacion} / {capacidad} pers.
                        </div>
                      </div>
                    )}
                  </div>

                  <div class="flex flex-col gap-2 mt-4 text-xs">
                    <div x-show="encargado" class="text-base-content/70">
                      👤 Encargado: <strong class="text-base-content" x-text="encargado">{r.encargado || ""}</strong>
                    </div>
                    <div class="flex gap-2">
                      <div class="badge badge-sm badge-ghost gap-1" x-show="fechaActualizada">
                        ⏱️ Actualizado: <span x-text="fechaActualizada">{fechaActualizada || ""}</span>
                      </div>
                      {(!fechaActualizada && fechaFormateada) && (
                        <div class="badge badge-sm badge-ghost gap-1" x-show="!fechaActualizada">
                          📅 Reportado: {fechaFormateada}
                        </div>
                      )}
                    </div>
                  </div>

                  {r.tipo === "refugio" && (
                    <div class="mt-4">
                      <div class="flex justify-between text-xs font-semibold text-base-content/70 mb-1.5">
                        <span>Ocupación</span>
                        <span x-text="Math.min(Math.round((ocupacion / capacidad) * 100), 100) + '%'">{pct}%</span>
                      </div>
                      <progress 
                        class="progress w-full h-2" 
                        :class="Math.round((ocupacion / capacidad) * 100) >= 90 ? 'progress-error' : (Math.round((ocupacion / capacidad) * 100) >= 70 ? 'progress-warning' : 'progress-success')" 
                        :value="Math.min(Math.round((ocupacion / capacidad) * 100), 100)" 
                        max="100"
                      ></progress>
                    </div>
                  )}

                  {r.tipo === "refugio" && (
                    <div class="grid grid-cols-5 gap-2 mt-5 bg-base-200/50 rounded-xl p-3 text-xs text-center border border-base-200">
                      <div class="flex flex-col items-center">
                        <span class="text-base mb-0.5">👶</span>
                        <strong x-text="ninos">{r.ninos || 0}</strong>
                      </div>
                      <div class="flex flex-col items-center">
                        <span class="text-base mb-0.5">🍼</span>
                        <strong x-text="bebes">{r.bebes_lactantes || 0}</strong>
                      </div>
                      <div class="flex flex-col items-center">
                        <span class="text-base mb-0.5">👵</span>
                        <strong x-text="mayores">{r.adultos_mayores || 0}</strong>
                      </div>
                      <div class="flex flex-col items-center">
                        <span class="text-base mb-0.5">🩺</span>
                        <strong x-text="prof">{r.personal_profesional || 0}</strong>
                      </div>
                      <div class="flex flex-col items-center">
                        <span class="text-base mb-0.5">🤝</span>
                        <strong x-text="vols">{r.voluntarios || 0}</strong>
                      </div>
                    </div>
                  )}

                  <div class="mt-4 p-3 bg-base-200 rounded-xl space-y-2" x-show="itemsCriticos.length > 0 || itemsAlerta.length > 0">
                    <div class="flex flex-wrap gap-1.5 items-center" x-show="itemsCriticos.length > 0">
                      <span class="text-[10px] font-bold text-error uppercase tracking-wider mr-1">Crítico:</span>
                      <template x-for="item in itemsCriticos">
                        <span class="badge badge-error badge-sm font-semibold" x-text="item"></span>
                      </template>
                    </div>
