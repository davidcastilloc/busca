---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BuscadorRapido from "../components/BuscadorRapido.astro";
import ShareButton from "../components/ShareButton.astro";
import ModalEditRefugio from "../components/ModalEditRefugio.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";
import { CATEGORIAS_INVENTARIO } from "../lib/items";

export const prerender = false;

let esVoluntario = false;
let totalRefugios = 0;
let totalNecesidades = 0;
let necesidadesCriticas: any[] = [];
let refugiosIniciales: any[] = [];
let zonasPeligro: any[] = [];

try {
  const { DB } = env;
  if (DB) {
    const sessionToken = Astro.cookies.get("session_token")?.value;
    const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    esVoluntario = !!voluntario;

    const resRefugios = await DB.prepare("SELECT COUNT(*) as total FROM (SELECT id FROM refugios UNION ALL SELECT id FROM centros_acopio UNION ALL SELECT id FROM hospitales)").first<{ total: number }>();
    if (resRefugios) totalRefugios = resRefugios.total;

    const resNecesidades = await DB.prepare("SELECT COUNT(*) as total FROM necesidades WHERE estado = 'abierta'").first<{ total: number }>();
    if (resNecesidades) totalNecesidades = resNecesidades.total;

    const resCriticas = await DB.prepare("SELECT * FROM necesidades WHERE estado = 'abierta' AND gravedad LIKE '%alta%' ORDER BY created_at DESC LIMIT 4").all();
    if (resCriticas && resCriticas.results) {
      necesidadesCriticas = resCriticas.results;
    }

    let zonasPeligro: any[] = [];
    const resZonas = await DB.prepare("SELECT * FROM zonas_peligro WHERE activo = 1 ORDER BY created_at DESC LIMIT 5").all();
    if (resZonas && resZonas.results) {
      zonasPeligro = resZonas.results;
    }

    const queryUnified = `
      SELECT id, nombre, direccion, latitud, longitud, contacto, necesidades, 'refugio' as tipo, 
             capacidad_maxima, ocupacion_actual, ninos, bebes_lactantes, adultos_mayores, 
             personal_profesional, voluntarios, inventario, fecha_registro, created_at, updated_at,
             encargado, fotos
      FROM refugios
      UNION ALL
      SELECT id, nombre, direccion, latitud, longitud, contacto, necesidades, 'centro_acopio' as tipo, 
             NULL as capacidad_maxima, NULL as ocupacion_actual, NULL as ninos, NULL as bebes_lactantes, NULL as adultos_mayores,
             NULL as personal_profesional, NULL as voluntarios, inventario, fecha_registro, created_at, updated_at,
             encargado, fotos
      FROM centros_acopio
      UNION ALL
      SELECT id, nombre, direccion, latitud, longitud, contacto, necesidades, 'hospital' as tipo, 
             NULL as capacidad_maxima, NULL as ocupacion_actual, NULL as ninos, NULL as bebes_lactantes, NULL as adultos_mayores,
             NULL as personal_profesional, NULL as voluntarios, NULL as inventario, fecha_registro, created_at, updated_at,
             NULL as encargado, fotos
      FROM hospitales
      ORDER BY nombre ASC
    `;
    const resRefugiosList = await DB.prepare(queryUnified).all();
    refugiosIniciales = resRefugiosList.results || [];
  }
} catch (e) {
  console.error("Error al cargar datos en index:", e);
}
---

<Layout title="Portal de Coordinación de Emergencia - dondeestan.org">
  <Navbar />
  
  {zonasPeligro && zonasPeligro.length > 0 && (
    <div class="bg-red-600 text-white font-uber-text font-bold text-xs py-2 px-4 shadow-md w-full relative z-40 flex overflow-hidden">
      <div class="whitespace-nowrap animate-[marquee_15s_linear_infinite] flex items-center min-w-full">
        {zonasPeligro.map((z: any) => (
          <span class="mx-4 flex items-center gap-1">
            <span class="text-sm">⚠️</span> {z.tipo_peligro.toUpperCase()}: {z.descripcion} 
          </span>
        ))}
        {zonasPeligro.map((z: any) => (
          <span class="mx-4 flex items-center gap-1" aria-hidden="true">
            <span class="text-sm">⚠️</span> {z.tipo_peligro.toUpperCase()}: {z.descripcion} 
          </span>
        ))}
      </div>
    </div>
  )}

  <main class="flex-grow py-4 sm:py-12 px-4 bg-canvas">
    <!-- Hero Section (estilo hero-band-light de Uber) -->
    <div class="text-center max-w-2xl mx-auto mb-6 sm:mb-10 pt-4">
      <h1 class="font-uber-display text-3xl sm:text-4xl md:text-5xl text-ink tracking-tight mb-2">
        Portal de Apoyo y Coordinación
      </h1>
      <p class="text-sm sm:text-base text-body font-uber-text max-w-xl mx-auto mb-6 px-2">
        Consulta refugios, centros de acopio, necesidades críticas y reporta incidencias tras la emergencia.
      </p>

      <div class="flex justify-center mb-3 px-4 max-w-md mx-auto">
        <a href="/reportar" class="w-full btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong px-6 py-3.5 rounded-full flex items-center justify-center gap-2 shadow-sm transition-transform active:scale-[0.98] cursor-pointer">
          Reportar emergencia
        </a>
      </div>

      <!-- FEED DE NECESIDADES CRÍTICAS -->
      {necesidadesCriticas.length > 0 && (
        <div class="px-4 max-w-lg mx-auto mb-8">
          <div class="flex justify-between items-end mb-3">
            <h3 class="font-uber-display text-lg text-ink font-semibold">Urgencias (Gravedad Alta)</h3>
            <a href="/mapa?layer=necesidades" class="text-xs text-primary font-bold hover:underline">Ver todas</a>
          </div>
          <div class="space-y-3">
            {necesidadesCriticas.map((n) => (
              <div class="bg-red-50 border border-red-100 rounded-xl p-4 flex gap-3 shadow-sm">
                <div class="text-red-500 text-xl mt-0.5">⚠️</div>
                <div>
                  <h4 class="font-uber-display text-sm font-bold text-red-800">{n.categoria}</h4>
                  <p class="font-uber-text text-xs text-red-900 mt-1 line-clamp-2">{n.descripcion}</p>
                  <div class="text-[10px] text-red-700/80 mt-2 flex justify-between">
                    <span>📍 {n.ubicacion_nombre || 'Sin ubicación'}</span>
                    <span>Hace {Math.round((new Date().getTime() - new Date(n.created_at).getTime()) / 3600000)}h</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- OTRAS ACCIONES: Voluntarios, Telegram -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 justify-center mb-6 px-4 max-w-lg mx-auto">
        <a href="/ayudar" class="w-full btn bg-black text-white hover:bg-zinc-800 border-none font-uber-text uber-body-md-strong px-4 py-3 rounded-xl flex items-center justify-start gap-3 shadow-sm transition-transform active:scale-[0.98]">
          <div class="text-2xl">👷</div>
          <div class="text-left leading-tight">
            <div class="font-bold text-sm">Ser Voluntario</div>
            <div class="text-[10px] text-zinc-300 font-normal">Apoya la logística</div>
          </div>
        </a>
        <a href="https://t.me/DondeEstanBot" target="_blank" rel="noopener noreferrer" class="w-full btn bg-[#2481cc] text-white hover:bg-[#1d6ba8] border-none font-uber-text uber-body-md-strong px-4 py-3 rounded-xl flex items-center justify-start gap-3 shadow-sm transition-transform active:scale-[0.98]">
          <div class="text-2xl w-6 flex items-center justify-center">
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.892-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </div>
          <div class="text-left leading-tight">
            <div class="font-bold text-sm">Usar Telegram</div>
            <div class="text-[10px] text-blue-100 font-normal">Reporta vía Bot</div>
          </div>
        </a>
      </div>
    </div>

    <!-- SECCIÓN DE REFUGIOS Y CENTROS DE ACOPIO (MIGRADO) -->
    <div id="refugios-seccion" class="max-w-4xl mx-auto mt-10 mb-10 px-2 animate-fade-in">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
          <h2 class="font-uber-display text-2xl sm:text-3xl text-ink tracking-tight">
            Refugios y Centros de Acopio
          </h2>
          <p class="text-xs sm:text-sm text-body font-uber-text mt-1">
            Directorio en tiempo real de albergues activos y sus necesidades críticas.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 sm:shrink-0 w-full sm:w-auto">
          <a href="/mapa?layer=refugios" class="btn !min-h-[38px] !h-auto !py-2 !px-3.5 text-xs sm:text-sm bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text font-semibold rounded-[36px] text-center border border-canvas-soft flex-1 sm:flex-none">
            🗺️ Mapa Completo
          </a>
          {esVoluntario && (
            <a href="/refugios/nuevo" class="btn !min-h-[38px] !h-auto !py-2 !px-3.5 text-xs sm:text-sm bg-primary text-white hover:bg-black-elevated font-uber-text font-semibold rounded-[36px] text-center shadow-sm flex-1 sm:flex-none">
              ➕ Registrar Refugio
            </a>
          )}
        </div>
      </div>

      <!-- Mapa Interactivo -->
      <div class="mb-6 relative">
        <div id="mapa-refugios" class="w-full h-80 sm:h-96 rounded-xl border border-canvas-soft shadow-sm z-0"></div>
        <button type="button" id="btn-geolocalizar" class="absolute bottom-4 right-4 z-[400] w-10 h-10 bg-white border border-canvas-soft rounded-full shadow-md hover:bg-canvas-soft active:scale-95 transition-transform flex items-center justify-center cursor-pointer text-lg" title="Encontrar mi ubicación">
          📍
        </button>
      </div>

      <!-- Filtros Rápidos y Buscador -->
      <div class="space-y-4 mb-6" x-data="{ query: '', filtro: 'todos' }">
        <!-- Filtros por tipo -->
        <div class="flex flex-wrap gap-2 overflow-x-auto pb-1 scrollbar-none" id="tipo-filtros">
          <button type="button" @click="filtro = 'todos'" :class="filtro === 'todos' ? 'bg-primary text-white' : 'bg-canvas text-ink hover:bg-canvas-soft border-canvas-soft'" class="px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border cursor-pointer transition-all">
            Todos
          </button>
          <button type="button" @click="filtro = 'refugio'" :class="filtro === 'refugio' ? 'bg-primary text-white' : 'bg-canvas text-ink hover:bg-canvas-soft border-canvas-soft'" class="px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border cursor-pointer transition-all">
            🏠 Refugios
          </button>
          <button type="button" @click="filtro = 'centro_acopio'" :class="filtro === 'centro_acopio' ? 'bg-primary text-white' : 'bg-canvas text-ink hover:bg-canvas-soft border-canvas-soft'" class="px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border cursor-pointer transition-all">
            📦 Centros de Acopio
          </button>
          <button type="button" @click="filtro = 'hospital'" :class="filtro === 'hospital' ? 'bg-primary text-white' : 'bg-canvas text-ink hover:bg-canvas-soft border-canvas-soft'" class="px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border cursor-pointer transition-all">
            🏥 Hospitales / Salud
          </button>
        </div>

        <!-- Buscador por texto -->
        <input 
          type="text" 
          id="search-refugios" 
          x-model="query"
          placeholder="Buscar refugio por nombre, ubicación o insumos..." 
          class="input w-full font-uber-text uber-body-md border border-canvas-soft bg-canvas px-4 py-3 rounded-xl focus:outline-none focus:ring-1 focus:ring-primary shadow-sm animate-fade-in"
        />
      </div>

      <!-- Lista de Refugios -->
      <div id="refugios-container" class="space-y-4">
        {refugiosIniciales.length === 0 ? (
          <div class="text-center py-12 bg-canvas-soft border border-canvas-soft rounded-xl">
            <p class="text-sm text-mute font-uber-text">No hay centros registrados en este momento.</p>
          </div>
        ) : (
          refugiosIniciales.map((r) => {
            const ocupacion = r.ocupacion_actual || 0;
            const capacidad = r.capacidad_maxima || 100;
            const pct = Math.min(Math.round((ocupacion / capacidad) * 100), 100);
            
            let colorBar = "bg-success"; // Verde
            if (pct >= 90) colorBar = "bg-error"; // Rojo
            else if (pct >= 70) colorBar = "bg-warning"; // Amarillo/Naranja

            let tipoLabel = "Refugio / Albergue";
            let tipoColor = "bg-blue-100 text-blue-800 border-blue-200";
            if (r.tipo === "hospital") {
              tipoLabel = "Hospital / Salud";
              tipoColor = "bg-red-100 text-red-800 border-red-200";
            } else if (r.tipo === "centro_acopio") {
              tipoLabel = "Centro de Acopio";
              tipoColor = "bg-yellow-100 text-yellow-800 border-yellow-200";
            }

            // Parsear inventario para extraer críticos y alertas
            let itemsCriticos: string[] = [];
            let itemsAlerta: string[] = [];
            if (r.inventario) {
              try {
                const inv = typeof r.inventario === 'string' ? JSON.parse(r.inventario) : r.inventario;
                for (const [itemId, estado] of Object.entries(inv)) {
                  const itemObj = CATEGORIAS_INVENTARIO.flatMap(c => c.items).find(i => i.id === itemId);
                  if (itemObj) {
                    if (estado === "Crítico") {
                      itemsCriticos.push(itemObj.nombre);
                    } else if (estado === "Alerta") {
                      itemsAlerta.push(itemObj.nombre);
                    }
                  }
                }
              } catch (e) {
                console.error("Error al parsear inventario:", e);
              }
            }

            // Formatear fechas
            const formatFechaStr = (fstr: string) => {
              if (!fstr) return "";
              try {
                return new Date(fstr).toLocaleString('es-VE', {
                  dateStyle: 'short',
                  timeStyle: 'short'
                });
              } catch {
                return fstr;
              }
            };

            let fechaFormateada = formatFechaStr(r.fecha_registro || r.created_at);
            let fechaActualizada = formatFechaStr(r.updated_at);

            // Parsear fotos
            let fotosArray: string[] = [];
            if (r.fotos) {
              try {
                fotosArray = typeof r.fotos === 'string' ? JSON.parse(r.fotos) : r.fotos;
              } catch (e) {
                console.error("Error al parsear fotos:", e);
              }
            }

            return (
              <div 
                id={`refugio-${r.id}`}
                x-show={`(filtro === 'todos' || filtro === '${r.tipo}') && (!query || '${r.nombre.replace(/'/g, "").toLowerCase()} ${r.direccion?.replace(/'/g, "").toLowerCase() || ""} ${r.necesidades?.replace(/'/g, "").toLowerCase() || ""}'.includes(query.toLowerCase()))`}
                class="refugio-card bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm space-y-4 transition-all hover:shadow-md"
                data-id={r.id}
                data-nombre={r.nombre.toLowerCase()}
                data-direccion={(r.direccion || "").toLowerCase()}
                data-necesidades={(r.necesidades || "").toLowerCase()}
                data-tipo={r.tipo || "refugio"}
                data-lat={r.latitud || ""}
                data-lng={r.longitud || ""}
                data-ocupacion={ocupacion}
                data-capacidad={capacidad}
                data-contacto={r.contacto || ""}
                data-encargado={r.encargado || ""}
                data-semaforo={itemsCriticos.length > 0 ? "rojo" : itemsAlerta.length > 0 ? "amarillo" : "verde"}
                data-fotos={typeof r.fotos === 'string' ? r.fotos : JSON.stringify(r.fotos || [])}
              >
                {fotosArray && fotosArray.length > 0 && (
                  <div class="w-full h-40 sm:h-48 rounded-xl overflow-hidden border border-canvas-soft bg-surface-pressed mb-2">
                    <img 
                      src={`/api/upload?key=${fotosArray[0]}`} 
                      alt={`Foto de ${r.nombre}`} 
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
                  <div>
                    <div class="flex flex-wrap items-center gap-2">
                      <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full border ${tipoColor} font-uber-text`}>
                        {tipoLabel}
                      </span>
                      <h3 class="font-uber-display text-lg text-ink font-semibold">{r.nombre}</h3>
                    </div>
                    {r.direccion && <p class="text-xs text-body font-uber-text mt-1">📍 {r.direccion}</p>}
                  </div>
                  {r.tipo === "refugio" && (
                    <div class="text-right shrink-0">
                      <span class="text-xs font-semibold text-ink font-uber-text bg-canvas-soft px-2.5 py-1 rounded-full border border-canvas-soft">
                        {ocupacion} / {capacidad} personas
                      </span>
                    </div>
                  )}
                </div>

                <!-- Encargado y Fechas -->
                <div class="flex flex-col gap-2 border-t border-canvas-soft pt-3 mt-2">
                  {r.encargado && (
                    <div class="text-xs font-uber-text text-body">
                      👤 Encargado: <strong class="text-ink">{r.encargado}</strong>
                    </div>
                  )}
                  <div class="flex flex-wrap gap-x-4 gap-y-2">
                    {fechaActualizada && (
                      <div class="inline-flex items-center gap-1.5 bg-blue-50 text-blue-800 border border-blue-200 px-2.5 py-1 rounded-md text-xs font-semibold font-uber-text shadow-sm" title="Última actualización de la información">
                        ⏱️ Actualizado: {fechaActualizada}
                      </div>
                    )}
                    {(!fechaActualizada && fechaFormateada) && (
                      <div class="inline-flex items-center gap-1.5 bg-gray-50 text-gray-700 border border-gray-200 px-2.5 py-1 rounded-md text-xs font-semibold font-uber-text shadow-sm" title="Fecha de reporte original">
                        📅 Reportado: {fechaFormateada}
                      </div>
                    )}
                  </div>
                </div>

                <!-- Barra de capacidad -->
                {r.tipo === "refugio" && (
                  <div class="space-y-1">
                    <div class="flex justify-between text-[11px] font-uber-text font-medium text-mute">
                      <span>Capacidad ocupada</span>
                      <span>{pct}%</span>
                    </div>
                    <div class="w-full bg-canvas-soft h-2.5 rounded-full overflow-hidden border border-canvas-soft">
                      <div class={`h-full ${colorBar}`} style={`width: ${pct}%`}></div>
                    </div>
                  </div>
                )}

                <!-- Demografía -->
                {r.tipo === "refugio" && (
                  <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 text-xs font-uber-text bg-canvas-soft p-3 rounded-lg border border-canvas-soft">
                    <div>👶 Niños: <strong class="text-ink">{r.ninos || 0}</strong></div>
                    <div>🍼 Lactantes: <strong class="text-ink">{r.bebes_lactantes || 0}</strong></div>
                    <div>👵 Mayores: <strong class="text-ink">{r.adultos_mayores || 0}</strong></div>
                    <div>🩺 Personal: <strong class="text-ink">{r.personal_profesional || 0}</strong></div>
                    <div>🤝 Vols: <strong class="text-ink">{r.voluntarios || 0}</strong></div>
                  </div>
                )}

                <!-- Inventario Crítico/Alerta -->
                {(itemsCriticos.length > 0 || itemsAlerta.length > 0) && (
                  <div class="space-y-1.5 bg-canvas-soft/50 border border-canvas-soft p-3 rounded-lg">
                    {itemsCriticos.length > 0 && (
                      <div class="flex flex-wrap gap-1 items-center">
                        <span class="text-[9px] font-bold text-red-700 uppercase tracking-wider font-uber-text mr-1">Crítico:</span>
                        {itemsCriticos.map(item => (
                          <span class="text-[9px] bg-red-500/10 text-red-700 font-semibold px-2 py-0.5 rounded-full border border-red-500/20">{item}</span>
                        ))}
                      </div>
                    )}
                    {itemsAlerta.length > 0 && (
                      <div class="flex flex-wrap gap-1 items-center">
                        <span class="text-[9px] font-bold text-amber-700 uppercase tracking-wider font-uber-text mr-1">Alerta:</span>
                        {itemsAlerta.map(item => (
                          <span class="text-[9px] bg-amber-500/10 text-amber-700 font-semibold px-2 py-0.5 rounded-full border border-amber-500/20">{item}</span>
                        ))}
                      </div>
                    )}
                  </div>
                )}

                <!-- Notas Adicionales -->
                {r.necesidades && (
                  <div class="bg-canvas-soft/30 border border-canvas-soft p-3 rounded-lg mt-3">
                    <span class="text-[10px] font-bold text-mute uppercase tracking-wider font-uber-text block mb-1">📝 Notas Adicionales</span>
                    <p class="text-xs text-body font-uber-text whitespace-pre-wrap">{r.necesidades}</p>
                  </div>
                )}

                <!-- Botones de Acción -->
                <div class="flex flex-wrap sm:justify-between items-center gap-2 pt-2 border-t border-canvas-soft">
                  <div class="flex gap-2">
                    <button 
                      class="btn-ver-en-mapa py-1.5 px-4 rounded-full bg-canvas-soft hover:bg-surface-pressed border border-canvas-soft text-xs text-ink font-semibold cursor-pointer"
                      data-lat={r.latitud || ""}
                      data-lng={r.longitud || ""}
                      data-id={r.id}
                    >
                      🗺️ Ver en Mapa
                    </button>
                    {r.contacto && (
                      <a 
                        href={`tel:${r.contacto}`} 
                        class="py-1.5 px-4 rounded-full bg-canvas-soft hover:bg-surface-pressed border border-canvas-soft text-xs text-ink font-semibold flex items-center justify-center"
                      >
                        📞 Llamar
                      </a>
                    )}
                    <ShareButton 
                      buttonText="Compartir Ficha"
                      url={`https://dondeestan.org/r/${r.id}`}
                      text={`📍 Ayuda en ${r.nombre}:`}
                    />
                  </div>
                  {esVoluntario && (
                    <button 
                      class="btn-edit-refugio py-1.5 px-4 rounded-full bg-black text-white hover:bg-zinc-800 text-xs font-semibold cursor-pointer"
                      data-id={r.id}
                      data-nombre={r.nombre}
                      data-direccion={r.direccion || ""}
                      data-necesidades={r.necesidades || ""}
                      data-tipo={r.tipo || "refugio"}
                      data-lat={r.latitud || ""}
