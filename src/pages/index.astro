          <div id="salvo-gps-status" class="text-xs text-mute font-uber-text italic">Iniciando búsqueda...</div>
          <input type="hidden" id="salvo-latitud" />
          <input type="hidden" id="salvo-longitud" />
        </div>

        <!-- Checkbox de confirmación -->
        <div class="flex items-start gap-2 pt-1">
          <input 
            type="checkbox" 
            id="chk-salvo-confirmacion" 
            class="w-4 h-4 rounded border-2 border-primary bg-canvas text-primary focus:ring-0 focus:ring-offset-0 mt-0.5 accent-black cursor-pointer" 
            required 
          />
          <label for="chk-salvo-confirmacion" class="text-xs text-body font-uber-text select-none cursor-pointer">
            Confirmo que estos datos de contacto y ubicación son correctos para mis familiares.
          </label>
        </div>
      </div>

      <div class="flex gap-2 pt-2">
        <button id="btn-salvo-confirmar-enviar" class="btn bg-success text-white flex-1 font-uber-text uber-body-md-strong">Confirmar "A salvo"</button>
        <button id="btn-salvo-confirmar-cancelar" type="button" class="btn bg-canvas-soft text-ink flex-1 font-uber-text uber-body-md-strong">Atrás</button>
      </div>
    </div>

    <!-- Panel de Éxito y Compartir -->
    <div id="salvo-exito-container" class="hidden text-center space-y-4 border-t border-canvas-soft pt-4 animate-fade-in">
      <div class="text-3xl">🎉</div>
      <h4 class="font-uber-display text-lg text-ink font-semibold">¡Estado actualizado!</h4>
      <p class="text-xs text-body font-uber-text">
        Tu registro ha sido marcado como a salvo. Puedes compartir este reporte con familiares y amigos.
      </p>
      
      <div class="space-y-2 pt-2">
        <button id="btn-salvo-compartir" class="btn bg-[#25D366] text-white w-full font-uber-text font-semibold flex items-center justify-center gap-2 cursor-pointer">
          💬 Compartir por WhatsApp
        </button>
        <button id="btn-salvo-compartir-copiar" class="btn bg-primary text-white w-full font-uber-text font-semibold flex items-center justify-center gap-2 cursor-pointer">
          🔗 Copiar enlace de reporte
        </button>
        <button id="btn-salvo-listo" class="btn bg-canvas-soft text-ink w-full font-uber-text font-semibold cursor-pointer">
          Listo / Cerrar
        </button>
      </div>
