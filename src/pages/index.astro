---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BuscadorRapido from "../components/BuscadorRapido.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

let totalReportes = 0;
let totalSinContacto = 0;
let totalLocalizados = 0;

try {
  const { DB, CACHE_KV } = env;

  if (CACHE_KV) {
    const cachedStats = await CACHE_KV.get("index:stats");
    if (cachedStats) {
      const stats = JSON.parse(cachedStats);
      totalReportes = stats.totalReportes;
      totalSinContacto = stats.totalSinContacto;
      totalLocalizados = stats.totalLocalizados;
    } else if (DB) {
      const personasCount = (await DB.prepare("SELECT COUNT(*) as count FROM personas").first<{ count: number }>())?.count || 0;
      const reportesCount = (await DB.prepare("SELECT COUNT(*) as count FROM reportes").first<{ count: number }>())?.count || 0;
      totalReportes = personasCount + reportesCount;

      const personasDesconocido = (await DB.prepare("SELECT COUNT(*) as count FROM personas WHERE estado = 'desconocido'").first<{ count: number }>())?.count || 0;
      const reportesAbierto = (await DB.prepare("SELECT COUNT(*) as count FROM reportes WHERE tipo = 'desaparecido' AND estado_reporte = 'abierto'").first<{ count: number }>())?.count || 0;
      totalSinContacto = personasDesconocido + reportesAbierto;

      const personasLocalizados = (await DB.prepare("SELECT COUNT(*) as count FROM personas WHERE estado IN ('vivo','herido')").first<{ count: number }>())?.count || 0;
      const reportesResuelto = (await DB.prepare("SELECT COUNT(*) as count FROM reportes WHERE estado_reporte = 'resuelto'").first<{ count: number }>())?.count || 0;
      totalLocalizados = personasLocalizados + reportesResuelto;

      await CACHE_KV.put("index:stats", JSON.stringify({
        totalReportes,
        totalSinContacto,
        totalLocalizados
      }), { expirationTtl: 60 });
    }
  } else if (DB) {
    const personasCount = (await DB.prepare("SELECT COUNT(*) as count FROM personas").first<{ count: number }>())?.count || 0;
    const reportesCount = (await DB.prepare("SELECT COUNT(*) as count FROM reportes").first<{ count: number }>())?.count || 0;
    totalReportes = personasCount + reportesCount;

    const personasDesconocido = (await DB.prepare("SELECT COUNT(*) as count FROM personas WHERE estado = 'desconocido'").first<{ count: number }>())?.count || 0;
    const reportesAbierto = (await DB.prepare("SELECT COUNT(*) as count FROM reportes WHERE tipo = 'desaparecido' AND estado_reporte = 'abierto'").first<{ count: number }>())?.count || 0;
    totalSinContacto = personasDesconocido + reportesAbierto;

    const personasLocalizados = (await DB.prepare("SELECT COUNT(*) as count FROM personas WHERE estado IN ('vivo','herido')").first<{ count: number }>())?.count || 0;
    const reportesResuelto = (await DB.prepare("SELECT COUNT(*) as count FROM reportes WHERE estado_reporte = 'resuelto'").first<{ count: number }>())?.count || 0;
    totalLocalizados = personasLocalizados + reportesResuelto;
  }
} catch (error) {
  console.error("Error al obtener estadísticas del censo/reportes:", error);
}
