<!-- Leaflet y MarkerCluster para mini-mapa GPS y mapa interactivo -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js"></script>

<script>
  let map: any = null;
  let editMap: any = null;
  let editMarker: any = null;
  const marcadores = new Map<string, any>();
  let userMarker: any = null;
  let esVoluntario = false;

  document.addEventListener('astro:page-load', () => {
    // Limpieza de mapas e instancias previas
    if (map) {
      try { map.remove(); } catch (e) {}
      map = null;
    }
    if (editMap) {
      try { editMap.remove(); } catch (e) {}
      editMap = null;
    }
    editMarker = null;
    userMarker = null;
    marcadores.clear();

    const btnEdits = document.querySelectorAll(".btn-edit-refugio");
    esVoluntario = btnEdits.length > 0;

    // Elementos UI
    const searchInput = document.getElementById("search-refugios") as HTMLInputElement;
    const filterBtns = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".refugio-card");
    const btnGeolocalizar = document.getElementById("btn-geolocalizar");

    // Inicializar Mapa
    function initMap() {
      const mapDiv = document.getElementById("mapa-refugios");
      if (!mapDiv) return;

      // Centrar en Venezuela por defecto
      // @ts-ignore
      map = L.map("mapa-refugios", {
        zoomControl: false
      }).setView([8.0, -66.0], 6);

      // Añadir control de Zoom abajo a la derecha
      // @ts-ignore
      L.control.zoom({ position: 'bottomleft' }).addTo(map);

      // Capa de mosaicos (Tiles)
      // @ts-ignore
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: '&copy; <a href="https://openstreetmap.org/copyright">OpenStreetMap</a>'
      }).addTo(map);

      // Crear marcadores desde los datos del DOM de las tarjetas
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const id = el.dataset.id || "";
        const latRaw = el.dataset.lat;
        const lngRaw = el.dataset.lng;
        const nombre = el.dataset.nombre || "";
        const direccion = el.dataset.direccion || "";
        const tipo = el.dataset.tipo || "refugio";
        const ocupacion = el.dataset.ocupacion || "0";
        const capacidad = el.dataset.capacidad || "100";
        const contacto = el.dataset.contacto || "";
        const semaforo = el.dataset.semaforo || "verde";
        const fotosRaw = el.dataset.fotos;
        
        let fotos: string[] = [];
        try {
          if (fotosRaw) {
            fotos = JSON.parse(fotosRaw);
          }
        } catch (err) {
          console.error("Error al parsear fotos en marcador:", err);
        }

        if (!latRaw || !lngRaw) return;

        const lat = parseFloat(latRaw);
        const lng = parseFloat(lngRaw);

        if (isNaN(lat) || isNaN(lng)) return;

        // Definir emoji e icono del marcador según tipo y semáforo
        let emoji = "🏠";
        let classTipo = "marker-refugio";
        if (tipo === "hospital") {
          emoji = "🏥";
          classTipo = "marker-hospital";
        } else if (tipo === "centro_acopio") {
          emoji = "📦";
          classTipo = "marker-acopio";
        }

        // Badge indicador de inventario en marcador
        let badgeHTML = "";
        if (semaforo === "rojo") {
          badgeHTML = `<div class="custom-marker-pulse"></div><div class="custom-marker-badge badge-rojo"></div>`;
        } else if (semaforo === "amarillo") {
          badgeHTML = `<div class="custom-marker-badge badge-amarillo"></div>`;
        } else {
          badgeHTML = `<div class="custom-marker-badge badge-verde"></div>`;
        }

        // Crear el DivIcon personalizado
        // @ts-ignore
        const customIcon = L.divIcon({
          html: `<div class="custom-marker ${classTipo}">${emoji}${badgeHTML}</div>`,
          className: "", // Limpiar clase por defecto de Leaflet
          iconSize: [32, 32],
          iconAnchor: [16, 32],
          popupAnchor: [0, -32]
        });

        // Crear popup
        let semaforoText = "🟢 Estable";
        let semaforoColor = "text-green-600";
        if (semaforo === "rojo") {
          semaforoText = "🔴 Insumos Críticos";
          semaforoColor = "text-red-600 font-bold";
        } else if (semaforo === "amarillo") {
          semaforoText = "🟡 Alertas de Insumo";
          semaforoColor = "text-amber-600 font-semibold";
        }

        const popupHTML = `
          <div class="p-3 space-y-2 max-w-[240px] font-uber-text">
            ${fotos.length > 0 ? `
              <div class="w-full h-24 rounded-lg overflow-hidden border border-canvas-soft bg-surface-pressed mb-1">
                <img src="/api/upload?key=${fotos[0]}" class="w-full h-full object-cover" />
              </div>
            ` : ''}
            <div class="flex items-center gap-1.5">
              <span class="text-base">${emoji}</span>
              <h4 class="font-bold text-ink text-sm leading-tight capitalize">${nombre}</h4>
            </div>
            <p class="text-[10px] text-body leading-normal">📍 ${direccion || 'Sin dirección registrada'}</p>
            <div class="flex flex-col gap-1 text-[11px] bg-canvas-soft p-2 rounded-lg border border-canvas-soft">
              <div>👥 Ocupación: <strong class="text-ink">${ocupacion} / ${capacidad} pers.</strong></div>
              <div>📦 Inventario: <span class="font-semibold ${semaforoColor}">${semaforoText}</span></div>
              ${contacto ? `<div>📞 Contacto: <strong class="text-ink">${contacto}</strong></div>` : ''}
            </div>
            <div class="flex flex-col gap-1.5 pt-1">
              <a href="https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}" target="_blank" rel="noopener noreferrer" class="btn btn-xs btn-primary text-primary-content text-center py-2 rounded-lg text-[10px] font-bold flex items-center justify-center gap-1 no-underline">
                🚗 Cómo llegar
              </a>
              <div class="share-dropdown-container inline-block" data-url="https://dondeestan.org/r/${id}" data-text="📍 Ayuda en ${nombre}:">
                <button type="button" class="btn-share-toggle btn btn-xs bg-canvas-soft text-ink hover:bg-surface-pressed border border-canvas-soft text-center py-2 rounded-lg text-[10px] font-bold flex items-center justify-center gap-1 w-full cursor-pointer">
                  📤 Compartir Ficha
                </button>
              </div>
              ${esVoluntario ? `
                <button type="button" class="btn-mapa-edit btn btn-xs btn-outline border-canvas-soft text-center py-2 rounded-lg text-[10px] font-semibold cursor-pointer" data-id="${id}">
                  ✏️ Actualizar Estado
                </button>
              ` : ''}
            </div>
          </div>
        `;

        // @ts-ignore
        const marker = L.marker([lat, lng], { icon: customIcon }).bindPopup(popupHTML);
        marker.addTo(map);
        marcadores.set(id, marker);
      });

      // Si hay marcadores, ajustar el mapa enfocando en la zona más densa
      if (marcadores.size > 0) {
        const haversine = (lat1, lon1, lat2, lon2) => {
          const R = 6371;
          const dLat = (lat2 - lat1) * Math.PI / 180;
          const dLon = (lon2 - lon1) * Math.PI / 180;
          const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon / 2) ** 2;
          return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        };

        const pts = Array.from(marcadores.values()).map(m => m.getLatLng());
        let maxCount = -1;
        let bestCenter = pts[0];
        
        for (let i = 0; i < pts.length; i++) {
          let count = 0;
          for (let j = 0; j < pts.length; j++) {
            if (haversine(pts[i].lat, pts[i].lng, pts[j].lat, pts[j].lng) < 15) count++;
          }
          if (count > maxCount) { maxCount = count; bestCenter = pts[i]; }
        }
        
        const clusterPoints = pts.filter(p => haversine(bestCenter.lat, bestCenter.lng, p.lat, p.lng) < 15);
        const L = window.L;
        const bounds = L.latLngBounds(clusterPoints.map(p => [p.lat, p.lng]));
        
        if (bounds.isValid()) {
          map.fitBounds(bounds, { padding: [30, 30], maxZoom: 14 });
        }
      }

      if (map) {
        map.on('popupopen', () => {
          if (typeof window.initShareDropdowns === 'function') {
            window.initShareDropdowns();
          }
        });
      }

      setTimeout(() => {
        if (map) map.invalidateSize();
      }, 250);
    }

    // Geolocalización
    btnGeolocalizar?.addEventListener("click", () => {
      if (!navigator.geolocation) {
        alert("Tu navegador no soporta geolocalización.");
        return;
      }

      btnGeolocalizar.classList.add("scale-90");
      navigator.geolocation.getCurrentPosition(
        (position) => {
          btnGeolocalizar.classList.remove("scale-90");
          const lat = position.coords.latitude;
          const lng = position.coords.longitude;

          if (map) {
            map.setView([lat, lng], 14);

            if (userMarker) {
              userMarker.setLatLng([lat, lng]);
            } else {
              // @ts-ignore
              const userIcon = L.divIcon({
                html: `<div class="user-location-marker"><div class="user-location-pulse"></div></div>`,
                className: "",
                iconSize: [16, 16],
                iconAnchor: [8, 8]
              });
              // @ts-ignore
              userMarker = L.marker([lat, lng], { icon: userIcon }).addTo(map);
            }
          }
        },
        (error) => {
          btnGeolocalizar.classList.remove("scale-90");
          console.error("Error de geolocalización:", error);
          alert("No se pudo obtener tu ubicación. Verifica los permisos de tu navegador.");
        },
        { enableHighAccuracy: true, timeout: 5000 }
      );
    });

    // Delegar click del botón "Editar" del mapa para abrir el modal nativo
    document.getElementById("mapa-refugios")?.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains("btn-mapa-edit")) {
        const id = target.getAttribute("data-id");
        if (id) {
          const btnLista = document.querySelector(`.btn-edit-refugio[data-id="${id}"]`) as HTMLButtonElement;
          if (btnLista) {
            btnLista.click();
          }
        }
      }
    });

    // Ver en Mapa desde la lista de tarjetas
    document.querySelectorAll(".btn-ver-en-mapa").forEach((btn) => {
      btn.addEventListener("click", () => {
        const el = btn as HTMLElement;
        const lat = parseFloat(el.dataset.lat || "");
        const lng = parseFloat(el.dataset.lng || "");
        const id = el.dataset.id || "";
        if (!isNaN(lat) && !isNaN(lng) && map) {
          map.setView([lat, lng], 15);
          const marker = marcadores.get(id);
          if (marker) {
            marker.openPopup();
          }
          document.getElementById("mapa-refugios")?.scrollIntoView({ behavior: "smooth" });
        }
      });
    });

    // Inicializar Leaflet cuando cargue la página
    if (typeof window !== "undefined") {
      // @ts-ignore
      if (typeof L !== "undefined") {
        initMap();
      } else {
        const interval = setInterval(() => {
          // @ts-ignore
          if (typeof L !== "undefined") {
            initMap();
            clearInterval(interval);
          }
        }, 100);
      }
    }

    // ================= MODAL DE EDICIÓN NATIVO =================
    const modal = document.getElementById("modal-edit-refugio");
    const closeBtn = document.getElementById("btn-close-edit");
    const form = document.getElementById("form-edit-refugio") as HTMLFormElement;
    const errorDiv = document.getElementById("edit-refugio-error");

    const inputId = document.getElementById("edit-refugio-id") as HTMLInputElement;
    const selectTipo = document.getElementById("edit-tipo") as HTMLSelectElement;
    const inputEncargado = document.getElementById("edit-encargado") as HTMLInputElement;
    const inputDireccion = document.getElementById("edit-direccion") as HTMLInputElement;
    const btnEditBuscarDireccion = document.getElementById("btn-edit-buscar-direccion");
    const inputOcupacion = document.getElementById("edit-ocupacion") as HTMLInputElement;
    const inputCapacidad = document.getElementById("edit-capacidad") as HTMLInputElement;
    const inputNecesidades = document.getElementById("edit-necesidades") as HTMLTextAreaElement;
    const inputContacto = document.getElementById("edit-contacto") as HTMLInputElement;
    const editTitulo = document.getElementById("edit-refugio-titulo");

    const inputNinos = document.getElementById("edit-ninos") as HTMLInputElement;
    const inputBebes = document.getElementById("edit-bebes") as HTMLInputElement;
    const inputMayores = document.getElementById("edit-mayores") as HTMLInputElement;
    const inputProf = document.getElementById("edit-prof") as HTMLInputElement;
    const inputVols = document.getElementById("edit-vols") as HTMLInputElement;

    const latEditInput = document.getElementById("edit-latitud") as HTMLInputElement;
    const lonEditInput = document.getElementById("edit-longitud") as HTMLInputElement;
    const gpsEditStatus = document.getElementById("edit-gps-status");
    const btnEditGps = document.getElementById("btn-edit-ref-gps");

    const previewExistentes = document.getElementById("edit-preview-existentes");
    const inputFotosNuevas = document.getElementById("edit-fotos-nuevas") as HTMLInputElement;
    const previewNuevas = document.getElementById("edit-preview-nuevas");
    
    let existingFotos: string[] = [];
    let newFilesToUpload: File[] = [];

    function renderEditPreviews() {
      if (previewExistentes) {
        previewExistentes.innerHTML = "";
        existingFotos.forEach((fotoKey, index) => {
          const div = document.createElement("div");
          div.className = "relative aspect-square rounded-lg overflow-hidden border border-canvas-soft bg-surface-pressed";
          
          const img = document.createElement("img");
          img.src = `/api/upload?key=${fotoKey}`;
          img.className = "w-full h-full object-cover";
          
          const removeBtn = document.createElement("button");
          removeBtn.type = "button";
          removeBtn.innerHTML = "✕";
          removeBtn.className = "absolute top-1 right-1 bg-black/60 hover:bg-black text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center border-none cursor-pointer";
          removeBtn.addEventListener("click", () => {
            existingFotos.splice(index, 1);
            renderEditPreviews();
          });
          
          div.appendChild(img);
          div.appendChild(removeBtn);
          previewExistentes.appendChild(div);
        });
      }
      
      if (previewNuevas) {
        previewNuevas.innerHTML = "";
        newFilesToUpload.forEach((file, index) => {
          const url = URL.createObjectURL(file);
          const div = document.createElement("div");
          div.className = "relative aspect-square rounded-lg overflow-hidden border border-canvas-soft bg-surface-pressed";
          
          const img = document.createElement("img");
          img.src = url;
          img.className = "w-full h-full object-cover";
          
          const removeBtn = document.createElement("button");
          removeBtn.type = "button";
          removeBtn.innerHTML = "✕";
          removeBtn.className = "absolute top-1 right-1 bg-black/60 hover:bg-black text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center border-none cursor-pointer";
          removeBtn.addEventListener("click", () => {
            newFilesToUpload.splice(index, 1);
            URL.revokeObjectURL(url);
            renderEditPreviews();
          });
          
          div.appendChild(img);
          div.appendChild(removeBtn);
          previewNuevas.appendChild(div);
        });
      }
    }

    inputFotosNuevas?.addEventListener("change", () => {
      if (!inputFotosNuevas.files) return;
      const newFiles = Array.from(inputFotosNuevas.files);
      for (const file of newFiles) {
        if (existingFotos.length + newFilesToUpload.length < 3) {
          newFilesToUpload.push(file);
        }
      }
      inputFotosNuevas.value = "";
      renderEditPreviews();
    });

    function mostrarInfoGoogleModal(data: any) {
      const container = document.getElementById("edit-google-place-info");
      const content = document.getElementById("edit-gpi-content");
      if (!container || !content) return;

      const items: string[] = [];

      if (data.name) {
        items.push(`<div class="flex items-center gap-1"><span class="font-semibold text-ink">🏛️ ${data.name}</span></div>`);
      }

      if (data.estado_operativo || data.estado_label) {
        const label = data.estado_label || data.estado || data.estado_operativo;
        const isOpen = data.estado_operativo === "OPERATIONAL";
        const isClosed = data.estado_operativo?.includes("CLOSED");
        const color = isOpen ? "text-green-700 bg-green-100" : isClosed ? "text-red-700 bg-red-100" : "text-gray-700 bg-gray-100";
        items.push(`<div><span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold ${color}">${isOpen ? "🟢" : isClosed ? "🔴" : "⚪"} ${label}</span></div>`);
      }

      if (data.abierto_ahora !== undefined) {
        const badge = data.abierto_ahora 
          ? '<span class="text-green-700 font-semibold">✅ Abierto ahora</span>'
          : '<span class="text-orange-600 font-semibold">🚫 Cerrado ahora</span>';
        items.push(`<div>${badge}</div>`);
      }

      if (data.accesible !== undefined) {
        items.push(`<div>${data.accesible ? "♿ Acceso para silla de ruedas" : "⚠️ Sin acceso confirmado para silla de ruedas"}</div>`);
      }

      if (data.horario && data.horario.length > 0) {
        const horarioHtml = data.horario.map((h: string) => `<div class="pl-3 text-[10px]">${h}</div>`).join("");
        items.push(`<details class="cursor-pointer"><summary class="font-semibold text-ink">🕐 Horario</summary><div class="mt-1 space-y-0.5">${horarioHtml}</div></details>`);
      }

      if (data.phone_international || data.phone) {
        const tel = data.phone_international || data.phone;
        items.push(`<div>📞 <a href="tel:${tel.replace(/\s/g, '')}" class="text-blue-600 underline font-semibold">${tel}</a></div>`);
      }

      if (data.website) {
        const domain = data.website.replace(/^https?:\/\//, "").replace(/\/$/, "").substring(0, 40);
        items.push(`<div>🌐 <a href="${data.website}" target="_blank" rel="noopener" class="text-blue-600 underline">${domain}</a></div>`);
      }

      if (data.google_maps_url) {
        items.push(`<div>🗺️ <a href="${data.google_maps_url}" target="_blank" rel="noopener" class="text-blue-600 underline">Ver en Google Maps</a></div>`);
      }

      if (data.estado || data.municipio) {
        const parts = [data.municipio, data.estado].filter(Boolean);
        items.push(`<div>📌 ${parts.join(", ")}</div>`);
      }

      if (items.length > 0) {
        content.innerHTML = items.join("");
        window.dispatchEvent(new CustomEvent('show-gpi'));
      } else {
        window.dispatchEvent(new CustomEvent('hide-gpi'));
      }
    }

    function initEditMap(lat: number, lon: number, zoom = 15) {
      if (typeof (window as any).L === "undefined") return;
      const L = (window as any).L;

      if (!editMap) {
        editMap = L.map("edit-gps-map", {
          zoomControl: true,
          attributionControl: false
        }).setView([lat, lon], zoom);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
        }).addTo(editMap);

        editMap.on("click", (e: any) => {
          const clat = e.latlng.lat;
          const clon = e.latlng.lng;
          latEditInput.value = clat.toFixed(6);
          lonEditInput.value = clon.toFixed(6);
          
          if (editMarker) {
            editMarker.setLatLng(e.latlng);
          } else {
            editMarker = L.marker(e.latlng).addTo(editMap);
          }

          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Ubicación modificada: ${clat.toFixed(5)}, ${clon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-blue-600 font-uber-text italic font-medium";
          }
        });
      }

      if (editMarker) {
        editMarker.setLatLng([lat, lon]);
      } else {
        editMarker = L.marker([lat, lon]).addTo(editMap);
      }
      editMap.setView([lat, lon], zoom);
      
      setTimeout(() => {
        editMap.invalidateSize();
      }, 200);
    }

    const editTabBtns = document.querySelectorAll(".edit-tab-btn");
    editTabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        editTabBtns.forEach((b) => {
          b.classList.remove("bg-primary", "text-white", "border-primary");
          b.classList.add("bg-canvas-soft", "text-ink", "border-transparent");
        });
        btn.classList.add("bg-primary", "text-white", "border-primary");
        btn.classList.remove("bg-canvas-soft", "text-ink", "border-transparent");

        document.querySelectorAll(".edit-tab-pane").forEach((pane) => pane.classList.add("hidden"));
        const targetId = btn.getAttribute("data-target");
        if (targetId) {
          document.getElementById(targetId)?.classList.remove("hidden");
        }
      });
    });

    const tabEditGps = document.getElementById("tab-edit-gps");
    const tabEditGmaps = document.getElementById("tab-edit-gmaps");
    const tabEditMap = document.getElementById("tab-edit-map");

    const panelEditGps = document.getElementById("panel-edit-gps");
    const panelEditGmaps = document.getElementById("panel-edit-gmaps");
    const panelEditMap = document.getElementById("panel-edit-map");

    function deseleccionarEditTabs() {
      [tabEditGps, tabEditGmaps, tabEditMap].forEach(tab => {
        tab?.classList.remove("bg-primary", "text-white");
        tab?.classList.add("bg-transparent", "text-ink");
      });
      [panelEditGps, panelEditGmaps, panelEditMap].forEach(panel => panel?.classList.add("hidden"));
    }

    tabEditGps?.addEventListener("click", () => {
      deseleccionarEditTabs();
      tabEditGps.classList.add("bg-primary", "text-white");
      tabEditGps.classList.remove("bg-transparent", "text-ink");
      panelEditGps?.classList.remove("hidden");
    });

    tabEditGmaps?.addEventListener("click", () => {
      deseleccionarEditTabs();
      tabEditGmaps.classList.add("bg-primary", "text-white");
      tabEditGmaps.classList.remove("bg-transparent", "text-ink");
      panelEditGmaps?.classList.remove("hidden");
    });

    tabEditMap?.addEventListener("click", () => {
      deseleccionarEditTabs();
      tabEditMap.classList.add("bg-primary", "text-white");
      tabEditMap.classList.remove("bg-transparent", "text-ink");
      panelEditMap?.classList.remove("hidden");
    });

    btnEditGps?.addEventListener("click", () => {
      if (!navigator.geolocation) {
        alert("Geolocalización no soportada.");
        return;
      }
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Detectando GPS...";
        gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lon = position.coords.longitude;
          latEditInput.value = lat.toFixed(6);
          lonEditInput.value = lon.toFixed(6);
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Ubicación GPS: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          initEditMap(lat, lon, 15);
        },
        () => {
          if (gpsEditStatus) {
            gpsEditStatus.textContent = "No se pudo obtener ubicación.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      );
    });

    btnEditBuscarDireccion?.addEventListener("click", async () => {
      const dir = inputDireccion.value.trim();
      if (!dir) {
        alert("Introduce una dirección.");
        return;
      }
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Buscando coordenadas...";
        gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
      }

      try {
        const resp = await fetch(`/api/maps/geocode?address=${encodeURIComponent(dir)}`);
        if (resp.ok) {
          const data = await resp.json();
          const lat = data.lat;
          const lon = data.lng;
          latEditInput.value = lat.toFixed(6);
          lonEditInput.value = lon.toFixed(6);
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Encontrado: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          
          if (data.formatted_address) {
            inputDireccion.value = data.formatted_address;
          }
          if (data.phone && !inputContacto.value) {
            inputContacto.value = data.phone;
          }
          if (data.tipo && selectTipo.value === "refugio") {
            selectTipo.value = data.tipo;
          }

          mostrarInfoGoogleModal(data);
          initEditMap(lat, lon, 15);
        } else {
          if (gpsEditStatus) {
            gpsEditStatus.textContent = "No encontrado. Intenta con más detalles.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      } catch {
        if (gpsEditStatus) {
          gpsEditStatus.textContent = "Error al buscar dirección.";
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    });

    const btnEditResolverGmaps = document.getElementById("btn-edit-resolver-gmaps");
    const inputEditGmaps = document.getElementById("edit-gmaps-link") as HTMLInputElement;

    btnEditResolverGmaps?.addEventListener("click", async () => {
      const url = inputEditGmaps.value.trim();
      if (!url) {
        alert("Pega un enlace de Google Maps.");
        return;
      }
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Resolviendo enlace...";
        gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
      }

      try {
        const resp = await fetch("/api/maps/resolve", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url })
        });
        if (resp.ok) {
          const data = await resp.json();
          latEditInput.value = data.lat.toFixed(6);
          lonEditInput.value = data.lng.toFixed(6);

          if (data.formatted_address) {
            inputDireccion.value = data.formatted_address;
          }
          if (data.phone && !inputContacto.value) {
            inputContacto.value = data.phone;
          }
          if (data.tipo && selectTipo.value === "refugio") {
            selectTipo.value = data.tipo;
          }

          mostrarInfoGoogleModal(data);

          if (data.aproximado) {
            if (gpsEditStatus) {
              gpsEditStatus.textContent = `⚠️ Ubicación aproximada: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)} — Ajusta el pin tocando el mapa.`;
              gpsEditStatus.className = "text-[11px] text-amber-600 font-uber-text italic font-semibold";
            }
            initEditMap(data.lat, data.lng, 16);
          } else {
            if (gpsEditStatus) {
              gpsEditStatus.textContent = `Resuelto: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
              gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
            }
            initEditMap(data.lat, data.lng, 17);
          }
        } else {
          const err = await resp.json();
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Error: ${err.error}`;
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      } catch {
        if (gpsEditStatus) {
          gpsEditStatus.textContent = "Error de conexión.";
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    });

    document.querySelectorAll(".btn-edit-refugio").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const el = btn as HTMLElement;
        const tipo = el.dataset.tipo || "refugio";
        
        if (inputId) inputId.value = el.dataset.id || "";
        if (selectTipo) selectTipo.value = tipo;
        if (inputEncargado) inputEncargado.value = el.dataset.encargado || "";
        if (inputDireccion) inputDireccion.value = el.dataset.direccion || "";

        const editCapacitySec = document.getElementById("edit-capacity-section");
        const editDemographicsSec = document.getElementById("edit-demographics-section");
        const editInventorySec = document.getElementById("edit-inventory-section");

        if (tipo === "refugio") {
          editCapacitySec?.classList.remove("hidden");
          editDemographicsSec?.classList.remove("hidden");
          editInventorySec?.classList.remove("hidden");
          
          if (inputOcupacion) {
            inputOcupacion.setAttribute("required", "true");
            inputOcupacion.value = el.dataset.ocupacion || "0";
          }
          if (inputCapacidad) {
            inputCapacidad.setAttribute("required", "true");
            inputCapacidad.value = el.dataset.capacidad || "100";
          }
        } else if (tipo === "centro_acopio") {
          editCapacitySec?.classList.add("hidden");
          editDemographicsSec?.classList.add("hidden");
          editInventorySec?.classList.remove("hidden");
          
          inputOcupacion?.removeAttribute("required");
          inputCapacidad?.removeAttribute("required");
        } else {
          // hospital
          editCapacitySec?.classList.add("hidden");
          editDemographicsSec?.classList.add("hidden");
          editInventorySec?.classList.add("hidden");
          
          inputOcupacion?.removeAttribute("required");
          inputCapacidad?.removeAttribute("required");
        }

        existingFotos = [];
        try {
          if (el.dataset.fotos) {
            existingFotos = JSON.parse(el.dataset.fotos);
          }
        } catch (err) {
          console.error("Error al parsear fotos:", err);
        }
        newFilesToUpload = [];
        if (inputFotosNuevas) inputFotosNuevas.value = "";
        renderEditPreviews();
        if (inputNecesidades) inputNecesidades.value = el.dataset.necesidades || "";
        if (inputContacto) inputContacto.value = el.dataset.contacto || "";
        if (editTitulo) editTitulo.textContent = `Actualizar: ${el.dataset.nombre}`;
        
        const gpiCard = document.getElementById("edit-google-place-info");
        window.dispatchEvent(new CustomEvent('hide-gpi'));

        if (inputNinos) inputNinos.value = el.dataset.ninos || "0";
        if (inputBebes) inputBebes.value = el.dataset.bebes || "0";
        if (inputMayores) inputMayores.value = el.dataset.mayores || "0";
        if (inputProf) inputProf.value = el.dataset.prof || "0";
        if (inputVols) inputVols.value = el.dataset.vols || "0";

        const latRaw = el.dataset.lat || "";
        const lngRaw = el.dataset.lng || "";
        latEditInput.value = latRaw;
        lonEditInput.value = lngRaw;

        if (gpsEditStatus) {
          if (latRaw && lngRaw) {
            gpsEditStatus.textContent = `Coordenadas cargadas: ${parseFloat(latRaw).toFixed(5)}, ${parseFloat(lngRaw).toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-mute font-uber-text italic";
          } else {
            gpsEditStatus.textContent = "Ubicación no establecida.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }

        deseleccionarEditTabs();
        tabEditGps?.classList.add("bg-primary", "text-white");
        panelEditGps?.classList.remove("hidden");
        if (inputEditGmaps) inputEditGmaps.value = "";

        const lat = latRaw ? parseFloat(latRaw) : 10.4806;
        const lon = lngRaw ? parseFloat(lngRaw) : -66.9036;
        const zoom = latRaw && lngRaw ? 15 : 12;
        initEditMap(lat, lon, zoom);

        let inventarioObj: Record<string, string> = {};
        try {
          if (el.dataset.inventario) {
            inventarioObj = JSON.parse(el.dataset.inventario);
          }
        } catch (err) {
          console.error("Error al parsear dataset de inventario:", err);
        }

        const radios = form.querySelectorAll('input[type="radio"]');
        radios.forEach((r: any) => {
          r.checked = false;
          if (r.name.startsWith("edit-inv-")) {
            const itemId = r.name.replace("edit-inv-", "");
            const valorEsperado = inventarioObj[itemId] || "Estable";
            if (r.value === valorEsperado) {
              r.checked = true;
            }
          }
        });

        if (errorDiv) {
          errorDiv.textContent = "";
          errorDiv.classList.add("hidden");
        }

        window.dispatchEvent(new CustomEvent('open-edit-modal', { detail: { tipo } }));
        document.body.style.overflow = "hidden";
      });
    });

    function cerrarModal() {
      window.dispatchEvent(new CustomEvent('close-edit-modal'));
      document.body.style.overflow = "";
    }

    closeBtn?.addEventListener("click", cerrarModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) cerrarModal();
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = inputId.value;
      const tipo = selectTipo.value || "refugio";
      const encargado = inputEncargado.value.trim();
      const direccion = inputDireccion.value.trim();
      const ocupacion = tipo === "refugio" ? (parseInt(inputOcupacion.value, 10) || 0) : 0;
      const capacidad = tipo === "refugio" ? (parseInt(inputCapacidad.value, 10) || 100) : 0;
      const necesidades = inputNecesidades.value.trim();
      const contacto = inputContacto.value.trim();
      const lat = latEditInput.value;
      const lon = lonEditInput.value;

      const ninos = tipo === "refugio" ? (parseInt(inputNinos.value) || 0) : 0;
      const bebes = tipo === "refugio" ? (parseInt(inputBebes.value) || 0) : 0;
      const mayores = tipo === "refugio" ? (parseInt(inputMayores.value) || 0) : 0;
      const prof = tipo === "refugio" ? (parseInt(inputProf.value) || 0) : 0;
      const vols = tipo === "refugio" ? (parseInt(inputVols.value) || 0) : 0;

      const sumaSubgrupos = ninos + bebes + mayores + prof + vols;
      const demografiaWarning = document.getElementById("edit-demografia-warning");

      if (tipo === "refugio") {
        if (ocupacion < sumaSubgrupos) {
          window.dispatchEvent(new CustomEvent('show-warning'));
          if (errorDiv) {
            errorDiv.textContent = "Error: La Población Total no puede ser menor a la suma de niños, bebés, adultos mayores, profesionales y voluntarios.";
            errorDiv.classList.remove("hidden");
          }
          return;
        } else {
          window.dispatchEvent(new CustomEvent('hide-warning'));
        }

        if (isNaN(ocupacion) || ocupacion < 0) {
          alert("Ocupación inválida");
          return;
        }
        if (isNaN(capacidad) || capacidad <= 0) {
          alert("Capacidad inválida");
          return;
        }
      }

      if (errorDiv) errorDiv.classList.add("hidden");

      const btnSubmit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (btnSubmit) {
        btnSubmit.disabled = true;
        btnSubmit.textContent = "Subiendo imágenes...";
      }

      const fotosKeys = [...existingFotos];
      if (newFilesToUpload.length > 0) {
        for (const file of newFilesToUpload) {
          const formData = new FormData();
          formData.append("foto", file);
          try {
            const uploadResp = await fetch("/api/upload", {
              method: "POST",
              body: formData,
            });
            if (uploadResp.ok) {
              const data = await uploadResp.json();
              if (data.key) {
                fotosKeys.push(data.key);
              }
            }
          } catch (uploadErr) {
            console.error("Error al subir imagen nueva:", uploadErr);
          }
        }
      }

      if (btnSubmit) {
        btnSubmit.textContent = "Guardando cambios...";
      }

      const inventario: Record<string, string> = {};
      const radios = form.querySelectorAll('input[type="radio"]:checked');
      radios.forEach((radio: any) => {
        if (radio.name.startsWith("edit-inv-")) {
          const itemId = radio.name.replace("edit-inv-", "");
          inventario[itemId] = radio.value;
        }
      });

      try {
        const resp = await fetch(`/api/refugios/${id}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            ocupacion_actual: ocupacion,
            capacidad_maxima: capacidad,
            necesidades,
            contacto,
            tipo,
            encargado,
            direccion,
            latitud: lat,
            longitud: lon,
            ninos,
            bebes_lactantes: bebes,
            adultos_mayores: mayores,
            personal_profesional: prof,
            voluntarios: vols,
            inventario,
            fotos: fotosKeys
          })
        });

        if (resp.ok) {
          cerrarModal();
          window.location.reload();
        } else {
          const err = await resp.json();
          if (errorDiv) {
            errorDiv.textContent = `Error: ${err.error || "no se pudo actualizar"}`;
            errorDiv.classList.remove("hidden");
          }
        }
      } catch {
        if (errorDiv) {
          errorDiv.textContent = "Error de conexión con el servidor.";
          errorDiv.classList.remove("hidden");
        }
      }
    });
  });
</script>
