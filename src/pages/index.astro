</div>

<script>
  const btnEstoyASalvo = document.getElementById("btn-estoy-a-salvo");
  const modalSalvo = document.getElementById("modal-salvo");
  const btnCloseSalvo = document.getElementById("btn-close-salvo");
  const formSalvoBuscar = document.getElementById("form-salvo-buscar") as HTMLFormElement;
  const inputSalvoQuery = document.getElementById("input-salvo-query") as HTMLInputElement;
  const salvoLoader = document.getElementById("salvo-results-loader");
  const salvoResults = document.getElementById("salvo-results");
  const salvoNoResults = document.getElementById("salvo-no-results");
  const btnSalvoRegistrar = document.getElementById("btn-salvo-registrar") as HTMLAnchorElement;

  // Confirmar form elements
  const salvoConfirmarContainer = document.getElementById("salvo-confirmar-container");
  const salvoContacto = document.getElementById("salvo-contacto") as HTMLInputElement;
  const salvoRefugio = document.getElementById("salvo-refugio") as HTMLInputElement;
  const salvoEstadoSalud = document.getElementById("salvo-estado-salud") as HTMLSelectElement;
  const salvoNotas = document.getElementById("salvo-notas") as HTMLTextAreaElement;
  const salvoFotoFile = document.getElementById("salvo-foto-file") as HTMLInputElement;
  const salvoFotoKey = document.getElementById("salvo-foto-key") as HTMLInputElement;
  const salvoFotoStatus = document.getElementById("salvo-foto-status");

  const btnSalvoGps = document.getElementById("btn-salvo-gps");
  const salvoGpsStatus = document.getElementById("salvo-gps-status");
  const salvoLatitud = document.getElementById("salvo-latitud") as HTMLInputElement;
  const salvoLongitud = document.getElementById("salvo-longitud") as HTMLInputElement;
  const chkSalvoConfirmacion = document.getElementById("chk-salvo-confirmacion") as HTMLInputElement;
  const btnSalvoConfirmarEnviar = document.getElementById("btn-salvo-confirmar-enviar") as HTMLButtonElement;
  const btnSalvoConfirmarCancelar = document.getElementById("btn-salvo-confirmar-cancelar");

  // Panel de éxito
  const salvoExitoContainer = document.getElementById("salvo-exito-container");
  const btnSalvoCompartir = document.getElementById("btn-salvo-compartir");
  const btnSalvoCompartirCopiar = document.getElementById("btn-salvo-compartir-copiar");
  const btnSalvoListo = document.getElementById("btn-salvo-listo");

  let personaIdConfirmar: number | null = null;
  let reporteIdConfirmar: number | null = null;
  let personaNombreConfirmar: string = "";

  btnEstoyASalvo?.addEventListener("click", () => {
    modalSalvo?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    inputSalvoQuery?.focus();
  });

  function cerrarModalSalvo() {
    modalSalvo?.classList.add("hidden");
    document.body.style.overflow = "";
    if (formSalvoBuscar) {
      formSalvoBuscar.reset();
      formSalvoBuscar.classList.remove("hidden");
    }
    if (salvoResults) {
      salvoResults.innerHTML = "";
      salvoResults.classList.remove("hidden");
    }
    salvoNoResults?.classList.add("hidden");
    salvoConfirmarContainer?.classList.add("hidden");
    salvoExitoContainer?.classList.add("hidden");
    btnCloseSalvo?.classList.remove("hidden");
    personaIdConfirmar = null;
    reporteIdConfirmar = null;
    personaNombreConfirmar = "";
  }

  btnCloseSalvo?.addEventListener("click", cerrarModalSalvo);
  modalSalvo?.addEventListener("click", (e) => {
    if (e.target === modalSalvo) cerrarModalSalvo();
  });

  // Función para comprimir imagen en el cliente antes de la subida
  async function comprimirImagen(file: File): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = (event) => {
        const img = new Image();
        img.src = event.target?.result as string;
        img.onload = () => {
          const canvas = document.createElement("canvas");
          const maxDim = 800;
          let width = img.width;
          let height = img.height;
          
          if (width > height) {
            if (width > maxDim) {
              height = Math.round((height * maxDim) / width);
              width = maxDim;
            }
          } else {
            if (height > maxDim) {
              width = Math.round((width * maxDim) / height);
              height = maxDim;
            }
          }
          
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext("2d");
          ctx?.drawImage(img, 0, 0, width, height);
          canvas.toBlob(
            (blob) => {
              if (blob) resolve(blob);
              else reject(new Error("Error al comprimir blob"));
            },
            "image/jpeg",
            0.75
          );
        };
        img.onerror = (err) => reject(err);
      };
      reader.onerror = (err) => reject(err);
    });
  }

  // Manejo de carga de foto con compresión
  salvoFotoFile?.addEventListener("change", async (ev) => {
    const input = ev.currentTarget as HTMLInputElement;
    if (!input.files || input.files.length === 0) return;

    const file = input.files[0];
    if (salvoFotoStatus) {
      salvoFotoStatus.textContent = "Comprimiendo foto...";
      salvoFotoStatus.className = "text-[10px] text-yellow-600 font-uber-text mt-1 italic font-medium";
      salvoFotoStatus.classList.remove("hidden");
    }

    try {
      const compressedBlob = await comprimirImagen(file);
      const formData = new FormData();
      formData.append("file", compressedBlob, "evidencia.jpg");

      if (salvoFotoStatus) {
        salvoFotoStatus.textContent = "Cargando foto de verificación...";
      }

      const resp = await fetch("/api/upload", {
        method: "POST",
        body: formData
      });

      if (resp.ok) {
        const res = await resp.json();
        if (salvoFotoKey) salvoFotoKey.value = res.key;
        if (salvoFotoStatus) {
          salvoFotoStatus.textContent = "✓ Foto cargada correctamente";
          salvoFotoStatus.className = "text-[10px] text-success font-uber-text mt-1 italic font-semibold";
        }
      } else {
        throw new Error();
      }
    } catch (err) {
      console.error(err);
      if (salvoFotoStatus) {
        salvoFotoStatus.textContent = "❌ Error al comprimir o cargar foto";
        salvoFotoStatus.className = "text-[10px] text-red-500 font-uber-text mt-1 italic";
      }
    }
  });

  async function obtenerUbicacionGps() {
    if (!salvoGpsStatus || !salvoLatitud || !salvoLongitud) return;
    salvoGpsStatus.textContent = "Buscando ubicación GPS...";
    salvoGpsStatus.className = "text-xs text-yellow-600 font-uber-text italic font-medium";
    
    if (!navigator.geolocation) {
      salvoGpsStatus.textContent = "GPS no compatible con tu navegador";
      salvoGpsStatus.className = "text-xs text-red-500 font-uber-text italic";
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        salvoLatitud.value = lat.toString();
        salvoLongitud.value = lon.toString();
        salvoGpsStatus.textContent = `Ubicación GPS obtenida: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
        salvoGpsStatus.className = "text-xs text-success font-uber-text italic font-semibold";
      },
      (error) => {
        let msg = "No se pudo obtener la ubicación GPS";
        if (error.code === error.PERMISSION_DENIED) {
          msg = "Permiso de GPS denegado";
        }
        salvoGpsStatus.textContent = msg;
        salvoGpsStatus.className = "text-xs text-red-500 font-uber-text italic";
      },
      { timeout: 8000, enableHighAccuracy: true }
    );
  }

  btnSalvoGps?.addEventListener("click", obtenerUbicacionGps);

  btnSalvoConfirmarCancelar?.addEventListener("click", () => {
    personaIdConfirmar = null;
    reporteIdConfirmar = null;
    personaNombreConfirmar = "";
    salvoConfirmarContainer?.classList.add("hidden");
    formSalvoBuscar?.classList.remove("hidden");
    if (salvoResults) salvoResults.classList.remove("hidden");
  });

  btnSalvoConfirmarEnviar?.addEventListener("click", async () => {
    if (!personaIdConfirmar && !reporteIdConfirmar) return;

    const contacto = salvoContacto?.value.trim();
    const refugio = salvoRefugio?.value.trim() || null;
    const estadoSalud = salvoEstadoSalud?.value || "vivo";
    const notas = salvoNotas?.value.trim() || null;
    const fotoKey = salvoFotoKey?.value || null;
    const lat = salvoLatitud?.value ? parseFloat(salvoLatitud.value) : null;
    const lon = salvoLongitud?.value ? parseFloat(salvoLongitud.value) : null;
    const confirmado = chkSalvoConfirmacion?.checked;

    if (!contacto) {
      alert("Contacto requerido para familiares.");
      salvoContacto?.focus();
      return;
    }

    if (!fotoKey) {
      alert("La foto de evidencia es obligatoria para confirmar que estás a salvo.");
      return;
    }

    if (!confirmado) {
      alert("Debes confirmar que los datos son correctos.");
      return;
    }

    btnSalvoConfirmarEnviar.disabled = true;
    btnSalvoConfirmarEnviar.textContent = "Guardando...";

    try {
      let patchResp;
      if (personaIdConfirmar) {
        patchResp = await fetch(`/api/personas/${personaIdConfirmar}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            accion: "reportar_a_salvo",
            estado: estadoSalud,
            contacto,
            refugio,
            notas,
            foto_key: fotoKey,
            latitud: lat,
            longitud: lon
          })
        });
      } else {
        patchResp = await fetch(`/api/reportes/${reporteIdConfirmar}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            accion: "reportar_a_salvo",
            estado_reporte: "resuelto",
            contacto,
            refugio,
            notas,
            foto_key: fotoKey,
            latitud: lat,
            longitud: lon
          })
        });
      }

      if (patchResp.ok) {
        btnSalvoConfirmarEnviar.textContent = "✓ Guardado";
        
        // Mostrar panel de éxito
        salvoConfirmarContainer?.classList.add("hidden");
        btnCloseSalvo?.classList.add("hidden"); // Forzar cerrar por botón Listo
        salvoExitoContainer?.classList.remove("hidden");
      } else {
        const err = await patchResp.json();
        alert(`Error: ${err.error || "intente de nuevo"}`);
        btnSalvoConfirmarEnviar.disabled = false;
        btnSalvoConfirmarEnviar.textContent = 'Confirmar "A salvo"';
      }
    } catch {
      alert("Error de conexión");
      btnSalvoConfirmarEnviar.disabled = false;
      btnSalvoConfirmarEnviar.textContent = 'Confirmar "A salvo"';
    }
  });

  // Listeners de panel de éxito
  btnSalvoCompartir?.addEventListener("click", () => {
    const link = `${window.location.origin}/?q=${encodeURIComponent(personaNombreConfirmar)}`;
    const texto = `¡Hola! He confirmado que estoy a salvo en la plataforma dondeestan.org. Puedes ver mis detalles aquí: ${link}`;
    window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(texto)}`, "_blank");
  });

  btnSalvoCompartirCopiar?.addEventListener("click", () => {
    const link = `${window.location.origin}/?q=${encodeURIComponent(personaNombreConfirmar)}`;
    navigator.clipboard.writeText(link);
    if (btnSalvoCompartirCopiar) btnSalvoCompartirCopiar.textContent = "✓ Enlace copiado";
    setTimeout(() => {
      if (btnSalvoCompartirCopiar) btnSalvoCompartirCopiar.textContent = "🔗 Copiar enlace de reporte";
    }, 2000);
  });

  btnSalvoListo?.addEventListener("click", () => {
    cerrarModalSalvo();
    window.location.reload();
  });

  formSalvoBuscar?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const query = inputSalvoQuery.value.trim();
    if (!query) return;

    if (salvoLoader) salvoLoader.classList.remove("hidden");
    if (salvoResults) salvoResults.innerHTML = "";
    salvoNoResults?.classList.add("hidden");

    try {
      const resp = await fetch(`/api/buscar?q=${encodeURIComponent(query)}&tipo=todos`);
      if (resp.ok) {
        const resultados = await resp.json();
        if (salvoLoader) salvoLoader.classList.add("hidden");
        
        if (resultados.length === 0) {
          if (btnSalvoRegistrar) {
            const esCedula = /^\d+$/.test(query.replace(/[^0-9]/g, ""));
            if (esCedula) {
              btnSalvoRegistrar.href = `/registrar?cedula=${encodeURIComponent(query)}`;
            } else {
              btnSalvoRegistrar.href = `/registrar?nombre=${encodeURIComponent(query)}`;
            }
          }
          salvoNoResults?.classList.remove("hidden");
        } else {
          resultados.forEach((item: any) => {
            const isPersona = item._source === "persona";
            const nombre = isPersona ? `${item.nombre} ${item.apellido || ""}` : (item.nombre_buscado || "Persona");
            
            const card = document.createElement("div");
            card.className = "p-3 bg-canvas-soft border border-canvas-soft rounded-lg flex items-center justify-between gap-3 text-sm";
            
            let btnHtml = "";
            if (isPersona && item.estado === "desconocido") {
              btnHtml = `<button class="btn btn-xs bg-success text-white px-2 py-1 rounded btn-salvo-marcar cursor-pointer">
                           ✅ A salvo
                         </button>`;
            } else if (!isPersona && item.estado_reporte === "abierto") {
              btnHtml = `<button class="btn btn-xs bg-success text-white px-2 py-1 rounded btn-salvo-reporte-marcar cursor-pointer">
                           ✅ Encontrado
                         </button>`;
            } else {
              const displayState = isPersona 
                ? (item.estado === "vivo" ? "A salvo" : item.estado)
                : (item.estado_reporte === "resuelto" ? "Resuelto" : item.estado_reporte);
              btnHtml = `<span class="text-xs text-mute font-medium uppercase font-uber-text">${displayState}</span>`;
            }

            card.innerHTML = `
              <div class="min-w-0 flex-grow">
                <div class="font-semibold text-ink truncate">${nombre}</div>
                <div class="text-xs text-body font-uber-text">${isPersona ? "Censo" : "Reporte"} ${item.cedula || item.cedula_buscado ? `· Doc: ${item.cedula || item.cedula_buscado}` : ""}</div>
              </div>
              <div class="shrink-0">${btnHtml}</div>
            `;
            
            // Eventos dinámicos
            card.querySelector(".btn-salvo-marcar")?.addEventListener("click", (ev) => {
              personaIdConfirmar = item.id;
              personaNombreConfirmar = nombre;
              formSalvoBuscar?.classList.add("hidden");
              if (salvoResults) salvoResults.classList.add("hidden");
              salvoNoResults?.classList.add("hidden");
 
              if (salvoContacto) salvoContacto.value = "";
              if (salvoRefugio) salvoRefugio.value = "";
              if (salvoNotas) salvoNotas.value = "";
              if (salvoFotoFile) salvoFotoFile.value = "";
              if (salvoFotoKey) salvoFotoKey.value = "";
              if (salvoFotoStatus) {
                salvoFotoStatus.textContent = "";
                salvoFotoStatus.classList.add("hidden");
              }
              if (chkSalvoConfirmacion) chkSalvoConfirmacion.checked = false;
              if (salvoLatitud) salvoLatitud.value = "";
              if (salvoLongitud) salvoLongitud.value = "";

              salvoConfirmarContainer?.classList.remove("hidden");
              obtenerUbicacionGps();
            });

            card.querySelector(".btn-salvo-reporte-marcar")?.addEventListener("click", (ev) => {
              reporteIdConfirmar = item.id;
              personaNombreConfirmar = nombre;
              formSalvoBuscar?.classList.add("hidden");
              if (salvoResults) salvoResults.classList.add("hidden");
              salvoNoResults?.classList.add("hidden");

              if (salvoContacto) salvoContacto.value = "";
              if (salvoRefugio) salvoRefugio.value = "";
              if (salvoNotas) salvoNotas.value = "";
              if (salvoFotoFile) salvoFotoFile.value = "";
              if (salvoFotoKey) salvoFotoKey.value = "";
              if (salvoFotoStatus) {
                salvoFotoStatus.textContent = "";
                salvoFotoStatus.classList.add("hidden");
              }
              if (chkSalvoConfirmacion) chkSalvoConfirmacion.checked = false;
              if (salvoLatitud) salvoLatitud.value = "";
              if (salvoLongitud) salvoLongitud.value = "";

              salvoConfirmarContainer?.classList.remove("hidden");
              obtenerUbicacionGps();
            });

            salvoResults?.appendChild(card);
          });
        }
      } else {
        throw new Error();
      }
    } catch {
      if (salvoLoader) salvoLoader.classList.add("hidden");
      alert("Error al buscar");
    }
  });
</script>
