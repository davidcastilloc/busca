---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BuscadorRapido from "../components/BuscadorRapido.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

let totalCensados = 0;
let totalDesaparecidos = 0;
let totalEncontrados = 0;

try {
  const { DB } = env;

  if (DB) {
    const censadosQuery = await DB.prepare("SELECT COUNT(*) as count FROM personas").first<{ count: number }>();
    totalCensados = censadosQuery?.count || 0;

    const desaparecidosQuery = await DB.prepare("SELECT COUNT(*) as count FROM reportes WHERE tipo = 'desaparecido' AND estado_reporte = 'abierto'").first<{ count: number }>();
    totalDesaparecidos = desaparecidosQuery?.count || 0;

    const encontradosQuery = await DB.prepare("SELECT COUNT(*) as count FROM reportes WHERE tipo = 'encontrado' AND estado_reporte = 'abierto'").first<{ count: number }>();
    totalEncontrados = encontradosQuery?.count || 0;
  }
} catch (error) {
  console.error("Error al obtener estadísticas del censo:", error);
}
---

<Layout title="BUSCA - Censo y Búsqueda de Emergencia">
  <Navbar />
  
  <main class="flex-grow py-12 px-4 bg-canvas">
    <!-- Hero Section (estilo hero-band-light de Uber) -->
    <div class="text-center max-w-2xl mx-auto mb-10">
      <h1 class="font-uber-display text-4xl md:text-5xl text-ink tracking-tight mb-4">
        Censo y búsqueda de emergencia
      </h1>
      <p class="text-lg text-body font-uber-text max-w-xl mx-auto mb-8">
        Buscador unificado de personas rescatadas, albergues y reportes de desapariciones. Plataforma optimizada para baja conectividad.
      </p>
      
      <!-- Stats (tarjetas minimalistas de Uber) -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto">
        <div class="bg-canvas border border-canvas-soft p-4 rounded-xl shadow-level1 text-center">
          <div class="text-[11px] text-body font-uber-text font-medium uppercase tracking-wider">Total Censados</div>
          <div class="font-uber-display text-2xl text-ink mt-1">{totalCensados}</div>
          <div class="text-[10px] text-mute font-uber-text mt-0.5">En refugios / a salvo</div>
        </div>
        
        <div class="bg-canvas border border-canvas-soft p-4 rounded-xl shadow-level1 text-center">
          <div class="text-[11px] text-body font-uber-text font-medium uppercase tracking-wider">Desaparecidos</div>
          <div class="font-uber-display text-2xl text-ink mt-1">{totalDesaparecidos}</div>
          <div class="text-[10px] text-mute font-uber-text mt-0.5">Búsquedas activas</div>
        </div>
        
        <div class="bg-canvas border border-canvas-soft p-4 rounded-xl shadow-level1 text-center">
          <div class="text-[11px] text-body font-uber-text font-medium uppercase tracking-wider">Sin Identificar</div>
          <div class="font-uber-display text-2xl text-ink mt-1">{totalEncontrados}</div>
          <div class="text-[10px] text-mute font-uber-text mt-0.5">Encontrados sin ID</div>
        </div>
      </div>
    </div>

    <!-- Buscador principal -->
    <BuscadorRapido />
  </main>
</Layout>
