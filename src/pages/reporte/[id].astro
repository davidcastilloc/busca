---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const { id } = Astro.params;
const url = new URL(Astro.request.url);

let reporte: any = null;

try {
  const { DB } = env;
  if (DB && id) {
    reporte = await DB.prepare("SELECT * FROM reportes WHERE id = ?").bind(id).first();
  }
} catch (error) {
  console.error("Error al cargar reporte:", error);
}

const formatFecha = (fechaStr: string) => {
  try {
    if (!fechaStr) return "";
    const d = new Date(fechaStr.replace("T", " ") + " UTC");
    return d.toLocaleDateString("es-ES", {
      timeZone: "UTC",
      year: "numeric",
      month: "long",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    });
  } catch {
    return fechaStr;
  }
};

// Metadatos por tipo para SEO y compartir
const siteUrl = Astro.url ? Astro.url.origin : "https://dondeestan.org";
const reporteUrl = `${siteUrl}/reporte/${id}`;

const tipoConfig: Record<string, { emoji: string; label: string; color: string; urgente: boolean }> = {
  desaparecido: { emoji: "🔴", label: "SE BUSCA", color: "bg-red-600", urgente: true },
  encontrado:   { emoji: "✅", label: "LOCALIZADO",  color: "bg-green-600", urgente: false },
  necesidad:    { emoji: "🆘", label: "NECESIDAD CRÍTICA", color: "bg-orange-600", urgente: true },
  refugio:      { emoji: "🏠", label: "REFUGIO ACTIVO",    color: "bg-blue-600", urgente: false },
};

const tipo = reporte?.tipo || "desaparecido";
const cfg = tipoConfig[tipo] || tipoConfig.desaparecido;

// Descripción limpia para SEO
const descLimpia = (reporte?.descripcion || "")
  .replace(/\[.*?\]/g, "")
  .trim()
  .substring(0, 300);

const titulo = tipo === "desaparecido" || tipo === "encontrado"
  ? reporte?.nombre_buscado || "Persona"
  : reporte?.nombre_buscado || "Emergencia";

const pageTitle = `${cfg.emoji} ${cfg.label}: ${titulo} — dondeestan.org`;
const ogImage = reporte?.foto_key
  ? `${siteUrl}/api/upload?key=${encodeURIComponent(reporte.foto_key)}`
  : `${siteUrl}/icons/icon-512.png`;

// Texto adaptado para compartir en redes
const contacto = reporte?.reportante_contacto || "";
let shareText = "";
if (tipo === "desaparecido") {
  shareText = `🔴 SE BUSCA: ${titulo}${reporte?.ubicacion_nombre ? ` — Último avisto en ${reporte.ubicacion_nombre}` : ""}. ¡Comparte! ${reporteUrl}`;
} else if (tipo === "encontrado") {
  shareText = `✅ LOCALIZADO: ${titulo}. Informa a sus familiares. ${reporteUrl}`;
} else if (tipo === "necesidad") {
  const catMatch = (reporte?.descripcion || "").match(/\[TIPO NECESIDAD: (.*?)\]/);
  const cat = catMatch ? catMatch[1] : "Necesidad Urgente";
  shareText = `🆘 NECESIDAD CRÍTICA: ${cat}${reporte?.ubicacion_nombre ? ` en ${reporte.ubicacion_nombre}` : ""}${contacto ? `. Contactar: ${contacto}` : ""}. ¡Comparte y ayuda! ${reporteUrl}`;
} else if (tipo === "refugio") {
  shareText = `🏠 REFUGIO ACTIVO: ${titulo}${reporte?.ubicacion_nombre ? ` — ${reporte.ubicacion_nombre}` : ""}${contacto ? `. Encargado: ${contacto}` : ""}. ${reporteUrl}`;
} else {
  shareText = `🚨 Reporte de emergencia en dondeestan.org: ${reporteUrl}`;
}

// Extraer campos estructurados de la descripción
const extractBracket = (text: string, key: string) => {
  const m = text.match(new RegExp(`\\[${key}: (.*?)\\]`));
  return m ? m[1] : null;
};
const desc = reporte?.descripcion || "";
const metaNecesidad = extractBracket(desc, "TIPO NECESIDAD");
const metaUrgencia  = extractBracket(desc, "URGENCIA");
const metaAfectados = extractBracket(desc, "AFECTADOS");
const metaCentro    = extractBracket(desc, "TIPO CENTRO");
const metaOcupacion = extractBracket(desc, "OCUPACIÓN");
const metaFecha     = extractBracket(desc, "FECHA ÚLTIMO CONTACTO");
const metaUbicacion = extractBracket(desc, "UBICACIÓN");
const metaSenas     = extractBracket(desc, "SEÑAS");
---

<Layout
  title={pageTitle}
  description={`${cfg.label}: ${titulo}. ${descLimpia}`}
  ogImage={ogImage}
  ogUrl={reporteUrl}
>
  <Navbar />

  <main class="flex-grow py-8 px-4 max-w-2xl mx-auto w-full bg-base-200 min-h-screen">
    {reporte ? (
      <article class="space-y-6">

        <!-- Header de tipo de reporte -->
        <div class={`${cfg.color} text-white rounded-3xl p-6 flex items-center gap-4 shadow-sm`}>
          <span class="text-4xl" aria-hidden="true">{cfg.emoji}</span>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-widest opacity-80">Reporte #{id} • {formatFecha(reporte.created_at)}</div>
            <h1 class="text-3xl font-black leading-tight mt-1">{cfg.label}</h1>
          </div>
        </div>

        <!-- Título principal -->
        <div class="card bg-base-100 border border-base-200 p-6 shadow-sm rounded-3xl space-y-1">
          <p class="text-xs text-base-content/50 font-bold uppercase tracking-wider">
            {tipo === "desaparecido" || tipo === "encontrado" ? "Persona" : "Nombre / Lugar"}
          </p>
          <h2 class="text-3xl font-black text-base-content">{titulo}</h2>
          {reporte.cedula_buscado && (
            <p class="text-sm text-base-content/80 mt-1">Cédula: <strong>{reporte.cedula_buscado}</strong></p>
          )}
        </div>

        <!-- Foto si existe -->
        {reporte.foto_key && (
          <div class="rounded-3xl overflow-hidden shadow-sm border border-base-200 bg-base-100">
            <img
              src={`/api/upload?key=${encodeURIComponent(reporte.foto_key)}`}
              alt={`Foto de ${titulo}`}
              class="w-full max-h-96 object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )}

        <!-- Datos estructurados por tipo -->
        {(metaNecesidad || metaUrgencia || metaAfectados) && (
          <div class="bg-warning/10 border border-warning/20 text-warning-content rounded-3xl p-6 space-y-3 shadow-sm">
            {metaNecesidad && (
              <div class="flex justify-between border-b border-warning/10 pb-2 last:border-0 last:pb-0">
                <span class="text-xs font-bold uppercase tracking-wider opacity-75">Tipo de Necesidad</span>
                <span class="font-bold text-sm">{metaNecesidad}</span>
              </div>
            )}
            {metaUrgencia && (
              <div class="flex justify-between border-b border-warning/10 pb-2 last:border-0 last:pb-0">
                <span class="text-xs font-bold uppercase tracking-wider opacity-75">Urgencia</span>
                <span class="font-bold text-sm">{metaUrgencia}</span>
              </div>
            )}
            {metaAfectados && (
              <div class="flex justify-between border-b border-warning/10 pb-2 last:border-0 last:pb-0">
                <span class="text-xs font-bold uppercase tracking-wider opacity-75">Personas Afectadas</span>
                <span class="font-bold text-sm">{metaAfectados}</span>
              </div>
            )}
          </div>
        )}

        {(metaCentro || metaOcupacion) && (
          <div class="bg-info/10 border border-info/20 text-info-content rounded-3xl p-6 space-y-3 shadow-sm">
            {metaCentro && (
              <div class="flex justify-between border-b border-info/10 pb-2 last:border-0 last:pb-0">
                <span class="text-xs font-bold uppercase tracking-wider opacity-75">Tipo de Centro</span>
                <span class="font-bold text-sm">{metaCentro}</span>
              </div>
            )}
            {metaOcupacion && (
              <div class="flex justify-between border-b border-info/10 pb-2 last:border-0 last:pb-0">
                <span class="text-xs font-bold uppercase tracking-wider opacity-75">Ocupación</span>
                <span class="font-bold text-sm">{metaOcupacion}</span>
              </div>
            )}
          </div>
        )}

        {(metaFecha || metaUbicacion || metaSenas) && (
          <div class="card bg-base-100 border border-base-200 p-6 shadow-sm rounded-3xl space-y-4">
            {metaFecha && (
              <div>
                <span class="text-xs text-base-content/50 font-bold uppercase tracking-wider block mb-0.5">Último Contacto</span>
                <span class="font-bold text-sm text-base-content">{metaFecha}</span>
              </div>
            )}
            {metaUbicacion && (
              <div>
                <span class="text-xs text-base-content/50 font-bold uppercase tracking-wider block mb-0.5">Ubicación</span>
                <span class="font-bold text-sm text-base-content">{metaUbicacion}</span>
              </div>
            )}
            {metaSenas && (
              <div>
                <span class="text-xs text-base-content/50 font-bold uppercase tracking-wider block mb-0.5">Señas Particulares</span>
                <span class="text-sm text-base-content leading-relaxed">{metaSenas}</span>
              </div>
            )}
          </div>
        )}

        <!-- Ubicación geográfica -->
        {reporte.ubicacion_nombre && (
          <div class="card bg-base-100 border border-base-200 p-6 shadow-sm rounded-3xl">
            <span class="text-xs text-base-content/50 font-bold uppercase tracking-wider block mb-1">📍 Ubicación Reportada</span>
            <span class="font-bold text-sm text-base-content">{reporte.ubicacion_nombre}</span>
            {reporte.latitud && reporte.longitud && (
              <a
                href={`https://maps.google.com/?q=${reporte.latitud},${reporte.longitud}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline btn-sm mt-3 w-fit"
              >
                Ver en Google Maps →
              </a>
            )}
          </div>
        )}

        <!-- Descripción -->
        {descLimpia && (
          <div class="card bg-base-100 border border-base-200 p-6 shadow-sm rounded-3xl">
            <p class="text-xs text-base-content/50 font-bold uppercase tracking-wider mb-2">Descripción</p>
            <p class="text-sm text-base-content/90 whitespace-pre-wrap leading-relaxed">{descLimpia}</p>
          </div>
        )}

        <!-- Contacto: botones de acción directa -->
        {reporte.reportante_contacto && (
          <div class="bg-primary/5 border border-primary/20 rounded-3xl p-6 space-y-4 shadow-sm">
            <p class="text-xs text-base-content/60 font-bold uppercase tracking-wider">📞 Contacto para coordinar</p>
            <p class="text-2xl font-black text-base-content">{reporte.reportante_contacto}</p>
            <div class="flex gap-3 flex-wrap">
              <a
                href={`tel:${reporte.reportante_contacto.replace(/\s|-/g, "")}`}
                class="btn btn-primary flex-grow min-w-[140px]"
              >
                📞 Llamar ahora
              </a>
              <a
                href={`https://wa.me/${reporte.reportante_contacto.replace(/\D/g, "")}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn bg-[#25D366] hover:bg-[#20ba5a] text-white flex-grow min-w-[140px] border-none"
              >
                WhatsApp
              </a>
            </div>
          </div>
        )}

        <!-- Reportante -->
        {reporte.reportante_nombre && (
          <div class="text-xs text-base-content/60 px-1 flex justify-between items-center">
            <span>Reportado por: <strong class="text-base-content/80">{reporte.reportante_nombre}</strong></span>
            {reporte.estado_reporte === "resuelto" && (
              <span class="badge badge-success gap-1">✓ RESUELTO</span>
            )}
          </div>
        )}

        <!-- Botones de compartir -->
        <div class="space-y-3 pt-4">
          <p class="text-xs text-base-content/50 text-center font-bold uppercase tracking-wider">Compartir este reporte</p>
          <div class="grid grid-cols-3 gap-3">
            <a
              href={`https://wa.me/?text=${encodeURIComponent(shareText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline border-base-300 hover:bg-[#25D366]/10 hover:border-[#25D366]/40 hover:text-base-content flex flex-col items-center justify-center gap-1.5 py-4 h-auto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#25D366" class="w-6 h-6"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              <span class="text-xs">WhatsApp</span>
            </a>
            <a
              href={`https://t.me/share/url?url=${encodeURIComponent(reporteUrl)}&text=${encodeURIComponent(shareText.replace(reporteUrl, "").trim())}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline border-base-300 hover:bg-[#229ED9]/10 hover:border-[#229ED9]/40 hover:text-base-content flex flex-col items-center justify-center gap-1.5 py-4 h-auto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#229ED9" class="w-6 h-6"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              <span class="text-xs">Telegram</span>
            </a>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline border-base-300 hover:bg-base-content/5 hover:text-base-content flex flex-col items-center justify-center gap-1.5 py-4 h-auto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              <span class="text-xs">Twitter/X</span>
            </a>
          </div>
          <button
            id="btn-copy-reporte"
            class="btn btn-outline w-full rounded-2xl"
          >
            🔗 Copiar enlace de este reporte
          </button>
        </div>

        <!-- Link al flyer si existe -->
        <div class="text-center pt-2">
          <a href="/reportar" class="link link-primary text-xs font-bold block">
            ← Emitir un nuevo reporte de emergencia
          </a>
        </div>

      </article>
    ) : (
      <div class="text-center py-16 space-y-4">
        <div class="text-5xl">⚠️</div>
        <h1 class="text-2xl font-black text-base-content">Reporte no encontrado</h1>
        <p class="text-sm text-base-content/70">
          El reporte #{id} no existe o fue archivado del sistema.
        </p>
        <div class="pt-4">
          <a href="/" class="btn btn-primary">
            Volver al inicio
          </a>
        </div>
      </div>
    )}
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const btnCopy = document.getElementById("btn-copy-reporte");
      if (btnCopy) {
        // Remover listener viejo clonando el botón para evitar duplicados si se navega de un reporte a otro
        const newBtnCopy = btnCopy.cloneNode(true) as HTMLElement;
        btnCopy.parentNode?.replaceChild(newBtnCopy, btnCopy);
        
        newBtnCopy.addEventListener("click", () => {
          navigator.clipboard.writeText(window.location.href);
          const orig = newBtnCopy.textContent;
          newBtnCopy.textContent = "✓ Enlace copiado";
          newBtnCopy.classList.add("opacity-75");
          setTimeout(() => {
            newBtnCopy.textContent = orig;
            newBtnCopy.classList.remove("opacity-75");
          }, 2000);
        });
      }
    });
  </script>
</Layout>
