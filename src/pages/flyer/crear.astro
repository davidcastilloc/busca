---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

export const prerender = false;
---

<Layout title="Generador de Flyers de Emergencia - BUSCA">
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-xl mx-auto w-full">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-black text-base-content text-error flex items-center justify-center gap-2">
        📢 Generar Flyer de Emergencia
      </h1>
      <p class="text-sm text-base-content/70 mt-2">
        Crea un cartel de difusión rápida para personas desaparecidas o alertas críticas. Optimizado para bajas conexiones y descargas directas.
      </p>
    </div>

    <div class="card bg-base-100 border border-base-300 p-6 shadow-sm">
      <form id="form-flyer" class="space-y-4">
        <!-- Título -->
        <div>
          <label class="label"><span class="label-text font-bold">Título del Flyer *</span></label>
          <input 
            type="text" 
            name="title" 
            required 
            maxlength="100"
            class="input input-bordered w-full" 
            placeholder="Ej: SE BUSCA: Juan Pérez o EMERGENCIA: Zona Inundada" 
          />
        </div>

        <!-- Foto -->
        <div>
          <label class="label"><span class="label-text font-bold">Foto *</span></label>
          <input 
            type="file" 
            id="photo-input" 
            accept="image/*" 
            required
            class="file-input file-input-bordered file-input-error file-input-sm w-full" 
          />
          
          <!-- Hidden canvas y input base64 -->
          <canvas id="canvas-resize" class="hidden"></canvas>
          <input type="hidden" name="photo" id="photo-base64" />

          <!-- Vista previa -->
          <div id="preview-container" class="hidden mt-3 flex justify-center">
            <img id="preview-img" class="max-h-48 rounded-lg shadow-sm border object-cover" src="" alt="Vista previa" />
          </div>
        </div>

        <!-- Descripción -->
        <div>
          <label class="label"><span class="label-text font-bold">Información relevante / Descripción *</span></label>
          <textarea 
            name="description" 
            required 
            maxlength="500"
            class="textarea textarea-bordered w-full h-28" 
            placeholder="Describe rasgos físicos, vestimenta, última ubicación vista, estado de salud o necesidades específicas..."
          ></textarea>
        </div>

        <!-- Teléfonos -->
        <div>
          <label class="label"><span class="label-text font-bold">Teléfonos de contacto (Separados por coma)</span></label>
          <input 
            type="text" 
            name="phones" 
            class="input input-bordered w-full input-sm" 
            placeholder="Ej: +58 414 1234567, 0212 9876543" 
          />
        </div>

        <!-- Redes sociales -->
        <div>
          <label class="label"><span class="label-text font-bold">Redes sociales (Separadas por coma)</span></label>
          <input 
            type="text" 
            name="socials" 
            class="input input-bordered w-full input-sm" 
            placeholder="Ej: @UsuarioInstagram, twitter.com/usuario" 
          />
        </div>

        <!-- Gancho de Registro en Base de Datos de Desaparecidos -->
        <div class="form-control border border-error/20 bg-error/5 p-4 rounded-xl mt-4">
          <label class="label cursor-pointer flex items-start gap-3">
            <input 
              type="checkbox" 
              name="registrarEnBusca" 
              id="registrar-busca" 
              checked 
              class="checkbox checkbox-error mt-0.5" 
            />
            <div class="flex-grow">
              <span class="label-text font-extrabold text-error block text-sm">
                💡 Registrar en base de datos inteligente de búsqueda
              </span>
              <span class="text-xs text-base-content/70 mt-1 block">
                Nuestra Inteligencia Artificial cruzará esta información con refugios, reportes de rescate y avistamientos automáticamente.
              </span>
            </div>
          </label>
        </div>

        <div id="error-alert" class="alert alert-error hidden font-semibold text-xs py-2">
          <span>Ocurrió un error.</span>
        </div>

        <button type="submit" id="btn-submit" class="btn btn-error btn-block text-white font-black mt-2">
          Crear Flyer de Emergencia
        </button>
      </form>
    </div>
  </main>

  <script>
    const form = document.getElementById("form-flyer") as HTMLFormElement;
    const photoInput = document.getElementById("photo-input") as HTMLInputElement;
    const photoBase64 = document.getElementById("photo-base64") as HTMLInputElement;
    const canvas = document.getElementById("canvas-resize") as HTMLCanvasElement;
    const previewContainer = document.getElementById("preview-container");
    const previewImg = document.getElementById("preview-img") as HTMLImageElement;
    const btnSubmit = document.getElementById("btn-submit");
    const errorAlert = document.getElementById("error-alert");

    if (photoInput && photoBase64 && canvas && previewContainer && previewImg) {
      photoInput.addEventListener("change", () => {
        const files = photoInput.files;
        if (!files || files.length === 0) return;

        const file = files[0];
        if (!file.type.startsWith("image/")) {
          mostrarError("Por favor, selecciona una imagen válida.");
          return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            const ctx = canvas.getContext("2d");
            if (!ctx) return;

            const MAX_SIZE = 800;
            let width = img.width;
            let height = img.height;

            if (width > height) {
              if (width > MAX_SIZE) {
                height *= MAX_SIZE / width;
                width = MAX_SIZE;
              }
            } else {
              if (height > MAX_SIZE) {
                width *= MAX_SIZE / height;
                height = MAX_SIZE;
              }
            }

            canvas.width = width;
            canvas.height = height;
            ctx.drawImage(img, 0, 0, width, height);

            // Comprimir imagen a JPEG con calidad 0.7 para bajo ancho de banda
            const compressed = canvas.toDataURL("image/jpeg", 0.7);
            photoBase64.value = compressed;
            previewImg.src = compressed;
            previewContainer.classList.remove("hidden");
          };
          img.src = e.target?.result as string;
        };
        reader.readAsDataURL(file);
      });
    }

    if (form && btnSubmit && errorAlert) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (!navigator.onLine) {
          mostrarError("❌ La generación de flyers requiere conexión a internet.");
          return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        if (!data.title || !data.description || !data.photo) {
          mostrarError("Por favor, completa los campos requeridos.");
          return;
        }

        btnSubmit.classList.add("loading");
        errorAlert.classList.add("hidden");

        try {
          const registrarBuscaCheckbox = document.getElementById("registrar-busca") as HTMLInputElement;
          const registrarEnBusca = registrarBuscaCheckbox ? registrarBuscaCheckbox.checked : false;

          const payload = {
            title: String(data.title).trim(),
            description: String(data.description).trim(),
            photo: String(data.photo),
            phones: data.phones ? String(data.phones).split(",").map(p => p.trim()).filter(p => p) : [],
            socials: data.socials ? String(data.socials).split(",").map(s => s.trim()).filter(s => s) : [],
            registrarEnBusca: registrarEnBusca
          };

          const response = await fetch("/api/flyers", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });

          if (response.ok) {
            const result = await response.json();
            window.location.href = `/flyer/${result.id}`;
          } else {
            const errData = await response.json();
            throw new Error(errData.error || "Fallo en generación de flyer");
          }
        } catch (err: any) {
          console.error(err);
          mostrarError(err.message || "Error al procesar la solicitud.");
          btnSubmit.classList.remove("loading");
        }
      });
    }

    function mostrarError(msg: string) {
      if (errorAlert) {
        errorAlert.innerHTML = `<span>${msg}</span>`;
        errorAlert.classList.remove("hidden");
      }
    }
  </script>
</Layout>
