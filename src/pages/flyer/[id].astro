---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const { id } = Astro.params;
const url = new URL(Astro.request.url);
const esCreado = url.searchParams.has("creado") || url.searchParams.has("new");

let flyer: any = null;
let phones: string[] = [];
let socials: string[] = [];

try {
  const { DB } = env;

  if (DB && id) {
    const result = await DB.prepare("SELECT * FROM flyers WHERE id = ?").bind(id).first();
    if (result) {
      flyer = result;
      phones = JSON.parse(result.phones || "[]");
      socials = JSON.parse(result.socials || "[]");
    }
  }
} catch (error) {
  console.error("Error al cargar flyer de base de datos:", error);
}

const formatFecha = (fechaStr: string) => {
  try {
    const d = new Date(fechaStr + " UTC");
    return d.toLocaleDateString("es-ES", { 
      timeZone: "America/Caracas",
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch (e) {
    return fechaStr;
  }
};
---

<Layout title={flyer ? `${flyer.title} - Cartel de Emergencia` : "Cartel no encontrado - dondeestan.org"}>
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-xl mx-auto w-full">
    {flyer ? (
      <div class="space-y-6">
        {esCreado && (
          <div class="bg-canvas-soft border border-canvas-soft rounded-xl p-5 shadow-sm font-uber-text uber-body-sm text-ink">
            <div class="font-bold text-base mb-1">🎉 Reporte registrado con éxito</div>
            <p class="text-body">
              La plataforma dondeestan.org ya está procesando y cruzando los datos. Guarda este enlace o descarga la imagen abajo.
            </p>
          </div>
        )}

        <!-- Banner informativo (estilo card-soft-tinted) -->
        <div class="bg-canvas-soft border border-canvas-soft p-4 rounded-xl text-ink font-uber-text uber-body-sm shadow-sm">
          <strong>ℹ️ IMPORTANTE:</strong> Guarda este enlace para compartir el cartel digital, o descárgalo como imagen para difundirlo por Whatsapp o imprimirlo.
        </div>

        <!-- Botones de Acción Superiores (estilo Uber) -->
        <div class="flex gap-3 justify-center">
          <button id="btn-download" class="btn bg-primary text-white hover:bg-black-elevated flex-1 font-uber-text uber-body-md-strong">
            Descargar Imagen
          </button>
          <button id="btn-copy" class="btn bg-canvas text-ink border border-canvas-soft shadow-lg hover:bg-canvas-soft flex-1 font-uber-text uber-body-md-strong">
            Copiar Enlace
          </button>
        </div>

        <!-- Contenedor del Cartel Imprimible (html2canvas, diseño premium blanco y negro) -->
        <div id="flyer-card" class="bg-white text-black p-6 rounded-none shadow-md border-8 border-primary font-sans flex flex-col justify-between max-w-md mx-auto aspect-[3/4]">
          <div>
            <!-- Cabecera del Cartel -->
            <div class="text-center bg-primary text-white py-3 px-4 -mx-6 -mt-6 mb-5 font-uber-display text-xl tracking-widest uppercase">
              🚨 DONDE ESTAN 🚨
            </div>

            <!-- Título Principal -->
            <h1 class="text-2xl md:text-3xl font-uber-display tracking-tight text-center text-ink uppercase break-words mb-4 leading-tight">
              {flyer.title}
            </h1>

            <!-- Foto -->
            <div class="w-full aspect-[4/3] bg-canvas-soft border border-canvas-soft rounded-lg overflow-hidden flex items-center justify-center mb-4 relative">
              <img 
                src={`/api/upload?key=${encodeURIComponent(flyer.foto_key)}`} 
                alt={flyer.title}
                class="w-full h-full object-contain"
                crossorigin="anonymous"
                fetchpriority="high"
                decoding="sync"
              />
            </div>

            <!-- Descripción (estilo blockquote minimalista) -->
            <div class="bg-canvas-soft border-l-4 border-primary p-3 text-sm md:text-base leading-relaxed break-words font-medium text-ink mb-4 whitespace-pre-wrap font-uber-text">
              {flyer.description}
            </div>
          </div>

          <!-- Contacto e Info de Cierre -->
          <div>
            {(phones.length > 0 || socials.length > 0) && (
              <div class="border-t border-canvas-soft pt-4 mb-4 grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs font-uber-text text-body">
                {phones.length > 0 && (
                  <div>
                    <h3 class="text-ink uppercase tracking-wider mb-1 font-bold text-[10px]">Llamar a:</h3>
                    {phones.map((phone: string) => (
                      <p class="text-sm font-bold text-ink">{phone}</p>
                    ))}
                  </div>
                )}
                
                {socials.length > 0 && (
                  <div>
                    <h3 class="text-ink uppercase tracking-wider mb-1 font-bold text-[10px]">Redes Sociales:</h3>
                    {socials.map((social: string) => (
                      <p class="text-sm font-bold text-ink truncate">{social}</p>
                    ))}
                  </div>
                )}
              </div>
            )}

            <!-- Footer del Cartel con Logo, QR y Dominio -->
            <div class="border-t border-canvas-soft pt-3 mt-4 flex items-center justify-between font-uber-text">
              <div class="flex items-center gap-2">
                <div class="font-uber-display text-xl tracking-tighter font-black text-primary flex items-center gap-1">
                  dondeestan<span class="text-body">.org</span>
                </div>
              </div>
              <div class="flex gap-3 items-center text-right">
                <div class="flex flex-col text-[9px] text-body uppercase tracking-wider">
                  <span>Escanea para</span>
                  <span>más info o</span>
                  <span>compartir</span>
                </div>
                <img src={`https://api.qrserver.com/v1/create-qr-code/?size=60x60&data=${encodeURIComponent(url.href)}`} alt="QR Code" class="w-12 h-12 border border-canvas-soft p-0.5 rounded-sm" crossorigin="anonymous" />
              </div>
            </div>
            <div class="text-[8px] text-body mt-2 flex justify-between font-uber-text">
              <span>Reporte #{id} • Creado el {formatFecha(flyer.created_at)}</span>
            </div>
          </div>
        </div>
        
        <div class="text-center pt-4">
          <a href="/flyer/crear" class="link-blue font-uber-text uber-body-sm-strong">
            ← Crear un nuevo cartel / flyer
          </a>
        </div>
      </div>
    ) : (
      <div class="text-center py-16 space-y-4">
        <div class="text-5xl">⚠️</div>
        <h1 class="font-uber-display text-2xl text-ink">Cartel no encontrado</h1>
        <p class="text-sm text-body font-uber-text">
          El cartel que buscas no existe o fue eliminado de la base de datos de emergencia.
        </p>
        <div class="pt-4">
          <a href="/" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong">
            Volver al inicio
          </a>
        </div>
      </div>
    )}
  </main>

  <!-- DIV OCULTO PARA GENERAR CARTEL (estilos inline, compatible con html2canvas) -->
  {flyer && (
    <div id="cartel-container" style="position:absolute;left:-9999px;top:-9999px;">
      <div id="cartel-se-busca" style="width:600px;font-family:system-ui,-apple-system,sans-serif;background:#fff;color:#000;">
        <!-- Franja superior -->
        <div style="background:#000;color:#fff;padding:16px 24px;text-align:center;">
          <div style="font-size:12px;letter-spacing:4px;font-weight:500;margin-bottom:4px;">dondeestan.org</div>
          <div style="font-size:36px;font-weight:700;letter-spacing:2px;">DONDE ESTAN</div>
        </div>
        <!-- Foto -->
        <div id="cartel-foto-wrap" style="width:100%;height:400px;background:#efefef;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;">
          <img id="cartel-foto" style="position:absolute;" src="" alt="" crossorigin="anonymous" />
        </div>
        <!-- Datos -->
        <div style="padding:20px 24px;">
          <div id="cartel-nombre" style="font-size:28px;font-weight:700;line-height:1.2;margin-bottom:8px;"></div>
          <div id="cartel-datos" style="font-size:14px;color:#5e5e5e;margin-bottom:12px;"></div>
          <div id="cartel-descripcion" style="font-size:15px;line-height:1.5;margin-bottom:16px;border-left:3px solid #000;padding-left:12px;font-style:italic;"></div>
          <div id="cartel-contacto-info" style="font-size:14px;color:#5e5e5e;"></div>
        </div>
        <!-- Franja inferior -->
        <div style="background:#000;color:#fff;padding:14px 24px;display:flex;justify-content:space-between;align-items:center;">
          <div>
            <div id="cartel-contacto" style="font-size:16px;font-weight:700;"></div>
          </div>
          <div style="font-size:11px;opacity:0.7;text-align:right;">
            <div>dondeestan.org</div>
            <div>dondeestan.org</div>
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- Script descarga y copiar -->
  <script>
    const btnDownload = document.getElementById("btn-download");
    const btnCopy = document.getElementById("btn-copy");

    if (btnDownload) {
      btnDownload.addEventListener("click", async () => {
        btnDownload.classList.add("opacity-50");
        const originalText = btnDownload.textContent;
        btnDownload.textContent = "Generando...";

        try {
          // Leer datos del cartel visible para llenar el div oculto
          const flyerCard = document.getElementById("flyer-card");
          if (!flyerCard) throw new Error("No se encontró el cartel");

          const cartelNombre = document.getElementById("cartel-nombre");
          const cartelDatos = document.getElementById("cartel-datos");
          const cartelDescripcion = document.getElementById("cartel-descripcion");
          const cartelContactoInfo = document.getElementById("cartel-contacto-info");
          const cartelContacto = document.getElementById("cartel-contacto");
          const cartelFotoWrap = document.getElementById("cartel-foto-wrap");

          // Extraer datos del DOM visible
          const h1 = flyerCard.querySelector("h1");
          const nombre = h1 ? h1.textContent?.trim() || "PERSONA" : "PERSONA";
          if (cartelNombre) cartelNombre.textContent = nombre;

          // Descripción
          const descDiv = flyerCard.querySelector(".whitespace-pre-wrap");
          if (cartelDescripcion && descDiv) {
            cartelDescripcion.textContent = descDiv.textContent?.trim() || "";
          }

          // Teléfonos y redes
          const phonesEl = flyerCard.querySelectorAll("h3");
          const contactParts: string[] = [];
          phonesEl.forEach((h3) => {
            const container = h3.parentElement;
            if (container) {
              const vals = container.querySelectorAll("p");
              vals.forEach(p => {
                if (p.textContent?.trim()) contactParts.push(p.textContent.trim());
              });
            }
          });
          
          if (cartelContacto) {
            cartelContacto.textContent = contactParts.length > 0 
              ? `CONTACTO: ${contactParts[0]}` 
              : "CONTACTE AUTORIDADES";
          }
          if (cartelDatos && contactParts.length > 1) {
            cartelDatos.textContent = contactParts.slice(1).join(" | ");
          }

          // Cargar foto como blob URL
          const fotoImg = flyerCard.querySelector("img[fetchpriority]") as HTMLImageElement;
          if (fotoImg && fotoImg.src && cartelFotoWrap) {
            const cartelFoto = document.getElementById("cartel-foto") as HTMLImageElement;
            try {
              const fotoResp = await fetch(fotoImg.src);
              if (!fotoResp.ok) throw new Error();
              const fotoBlob = await fotoResp.blob();
              const blobUrl = URL.createObjectURL(fotoBlob);

              await new Promise((resolve, reject) => {
                const tempImg = new Image();
                tempImg.src = blobUrl;
                tempImg.onload = () => {
                  const containerW = 600;
                  const containerH = 400;
                  const imgW = tempImg.naturalWidth;
                  const imgH = tempImg.naturalHeight;
                  const containerAspect = containerW / containerH;
                  const imgAspect = imgW / imgH;

                  cartelFoto.src = blobUrl;
                  if (imgAspect > containerAspect) {
                    const newHeight = containerW / imgAspect;
                    cartelFoto.style.width = `${containerW}px`;
                    cartelFoto.style.height = `${newHeight}px`;
                    cartelFoto.style.left = "0px";
                    cartelFoto.style.top = `${(containerH - newHeight) / 2}px`;
                  } else {
                    const newWidth = containerH * imgAspect;
                    cartelFoto.style.height = `${containerH}px`;
                    cartelFoto.style.width = `${newWidth}px`;
                    cartelFoto.style.top = "0px";
                    cartelFoto.style.left = `${(containerW - newWidth) / 2}px`;
                  }
                  resolve(null);
                };
                tempImg.onerror = () => reject();
              });
            } catch {
              cartelFotoWrap.style.flexDirection = "column";
              cartelFotoWrap.innerHTML = `<div style="font-size:72px;color:#afafaf;">👤</div><div style="font-size:16px;color:#5e5e5e;font-weight:bold;margin-top:8px;">SIN FOTO</div>`;
            }
          } else if (cartelFotoWrap) {
            cartelFotoWrap.style.flexDirection = "column";
            cartelFotoWrap.innerHTML = `<div style="font-size:72px;color:#afafaf;">👤</div><div style="font-size:16px;color:#5e5e5e;font-weight:bold;margin-top:8px;">SIN FOTO DISPONIBLE</div>`;
          }

          // Import dinámico html2canvas
          const { default: html2canvas } = await import("html2canvas");

          const cartelEl = document.getElementById("cartel-se-busca");
          if (!cartelEl) throw new Error("Cartel element not found");

          const canvas = await html2canvas(cartelEl, {
            scale: 2,
            useCORS: true,
            allowTaint: true,
            backgroundColor: "#ffffff",
            onclone: (clonedDoc) => {
              const styles = clonedDoc.querySelectorAll("style, link[rel='stylesheet']");
              styles.forEach(s => s.remove());
            }
          });

          const blob = await new Promise<Blob>((resolve) => {
            canvas.toBlob((b) => resolve(b!), "image/png");
          });

          const nombreArchivo = `SE_BUSCA_${nombre.replace(/\s+/g, "_")}.png`;
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url;
          a.download = nombreArchivo;
          a.click();
          URL.revokeObjectURL(url);

          btnDownload.textContent = "✓ Descargado";
          setTimeout(() => {
            btnDownload.textContent = originalText;
            btnDownload.classList.remove("opacity-50");
          }, 2500);

        } catch (err) {
          console.error("Fallo de descarga de flyer:", err);
          alert("Error al generar imagen del cartel. Toma una captura de pantalla.");
          btnDownload.classList.remove("opacity-50");
          btnDownload.textContent = originalText;
        }
      });
    }

    if (btnCopy) {
      btnCopy.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href);
        const originalText = btnCopy.textContent;
        btnCopy.textContent = "✓ Enlace Copiado";
        btnCopy.classList.add("opacity-85");
        
        setTimeout(() => {
          btnCopy.textContent = originalText;
          btnCopy.classList.remove("opacity-85");
        }, 2000);
      });
    }
  </script>
</Layout>

