---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const { id } = Astro.params;

let flyer: any = null;
let phones: string[] = [];
let socials: string[] = [];

try {
  const { DB } = env;

  if (DB && id) {
    const result = await DB.prepare("SELECT * FROM flyers WHERE id = ?").bind(id).first();
    if (result) {
      flyer = result;
      phones = JSON.parse(result.phones || "[]");
      socials = JSON.parse(result.socials || "[]");
    }
  }
} catch (error) {
  console.error("Error al cargar flyer de base de datos:", error);
}

const formatFecha = (fechaStr: string) => {
  try {
    const d = new Date(fechaStr + " UTC");
    return d.toLocaleDateString("es-ES", { 
      timeZone: "America/Caracas",
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
  } catch (e) {
    return fechaStr;
  }
};
---

<Layout title={flyer ? `${flyer.title} - Flyer de Emergencia` : "Flyer no encontrado - BUSCA"}>
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-xl mx-auto w-full">
    {flyer ? (
      <div class="space-y-6">
        <!-- Banner informativo -->
        <div class="alert alert-warning shadow-sm font-semibold text-xs text-start">
          <div>
            <strong>ℹ️ IMPORTANTE:</strong> Guarda este enlace para compartir el cartel digital, o descárgalo como imagen para difundirlo por Whatsapp o imprimirlo.
          </div>
        </div>

        <!-- Botones de Acción Superiores -->
        <div class="flex gap-2 justify-center">
          <button id="btn-download" class="btn btn-error text-white font-black flex-1">
            📥 Descargar Imagen
          </button>
          <button id="btn-copy" class="btn btn-outline border-base-300 flex-1 font-bold">
            🔗 Copiar Enlace
          </button>
        </div>

        <!-- Contenedor del Flyer Imprimible (html2canvas) -->
        <div id="flyer-card" class="bg-white text-black p-6 rounded-none shadow-xl border-8 border-error font-sans flex flex-col justify-between max-w-md mx-auto aspect-[3/4]">
          <div>
            <!-- Cabecera del Cartel -->
            <div class="text-center bg-error text-white py-3 px-4 -mx-6 -mt-6 mb-5 font-black text-2xl tracking-widest uppercase">
              🚨 ALERTA DE EMERGENCIA 🚨
            </div>

            <!-- Título Principal -->
            <h1 class="text-2xl md:text-3xl font-black tracking-tight text-center text-error uppercase break-words mb-4 leading-tight">
              {flyer.title}
            </h1>

            <!-- Foto -->
            <div class="w-full aspect-[4/3] bg-neutral-200 border-2 border-neutral-300 rounded overflow-hidden flex items-center justify-center mb-4 relative shadow-inner">
              <img 
                src={`/api/upload?key=${encodeURIComponent(flyer.foto_key)}`} 
                alt={flyer.title}
                class="w-full h-full object-cover"
                crossorigin="anonymous"
              />
            </div>

            <!-- Descripción -->
            <div class="bg-neutral-50 border-l-4 border-error p-3 text-sm md:text-base leading-relaxed break-words font-medium text-neutral-800 mb-4 whitespace-pre-wrap">
              {flyer.description}
            </div>
          </div>

          <!-- Contacto e Info de Cierre -->
          <div>
            {(phones.length > 0 || socials.length > 0) && (
              <div class="border-t border-neutral-300 pt-4 mb-4 grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-bold text-neutral-700">
                {phones.length > 0 && (
                  <div>
                    <h3 class="text-error uppercase tracking-wider mb-1 font-black text-[10px]">Llamar a:</h3>
                    {phones.map(phone => (
                      <p class="text-sm font-black text-black">{phone}</p>
                    ))}
                  </div>
                )}
                
                {socials.length > 0 && (
                  <div>
                    <h3 class="text-error uppercase tracking-wider mb-1 font-black text-[10px]">Redes Sociales:</h3>
                    {socials.map(social => (
                      <p class="text-sm font-black text-black truncate">{social}</p>
                    ))}
                  </div>
                )}
              </div>
            )}

            <!-- Footer del Cartel -->
            <div class="text-[9px] text-neutral-500 font-bold border-t border-neutral-200 pt-2 flex justify-between">
              <span>Creado en BUSCA • {formatFecha(flyer.created_at)}</span>
              <span class="text-error tracking-wider uppercase font-black">Reporte #{id}</span>
            </div>
          </div>
        </div>
        
        <div class="text-center pt-2">
          <a href="/flyer/crear" class="link link-error font-bold text-sm">
            ← Crear un nuevo cartel / flyer
          </a>
        </div>
      </div>
    ) : (
      <div class="text-center py-16 space-y-4">
        <div class="text-6xl">⚠️</div>
        <h1 class="text-2xl font-black text-base-content">Flyer no encontrado</h1>
        <p class="text-sm text-base-content/70">
          El cartel que buscas no existe o fue eliminado de la base de datos de emergencia.
        </p>
        <div class="pt-4">
          <a href="/" class="btn btn-error text-white font-bold btn-sm">
            Volver al Inicio
          </a>
        </div>
      </div>
    )}
  </main>

  <!-- Script html2canvas -->
  <script>
    import html2canvas from "html2canvas";

    const btnDownload = document.getElementById("btn-download");
    const btnCopy = document.getElementById("btn-copy");
    const flyerCard = document.getElementById("flyer-card");

    if (btnDownload && flyerCard) {
      btnDownload.addEventListener("click", async () => {
        btnDownload.classList.add("loading");
        btnDownload.textContent = "Generando...";

        try {
          const canvas = await html2canvas(flyerCard, {
            scale: 2, // Calidad alta
            useCORS: true, // Permitir R2 crossorigin
            backgroundColor: "#ffffff"
          });

          const image = canvas.toDataURL("image/jpeg", 0.9);
          const link = document.createElement("a");
          link.href = image;
          link.download = `flyer-${window.location.pathname.split("/").pop()}.jpg`;
          link.click();
        } catch (err) {
          console.error("Fallo de descarga de flyer:", err);
          alert("Error al generar imagen del cartel. Toma una captura de pantalla.");
        } finally {
          btnDownload.classList.remove("loading");
          btnDownload.textContent = "📥 Descargar Imagen";
        }
      });
    }

    if (btnCopy) {
      btnCopy.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href);
        btnCopy.textContent = "✓ Enlace Copiado";
        btnCopy.className = "btn btn-success text-white flex-1 font-bold animate-pulse";
        
        setTimeout(() => {
          btnCopy.textContent = "🔗 Copiar Enlace";
          btnCopy.className = "btn btn-outline border-base-300 flex-1 font-bold";
        }, 2000);
      });
    }
  </script>
</Layout>
