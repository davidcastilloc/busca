---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import FormPersona from "../components/FormPersona.astro";

export const prerender = false;
---

<Layout title="Registrar Persona en Albergue - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 bg-canvas">
    <div class="text-center max-w-xl mx-auto mb-8 px-4">
      <h1 class="font-uber-display text-3xl text-ink tracking-tight">Censo de personas</h1>
      <p class="text-sm text-body font-uber-text mt-2">
        Utiliza este formulario para registrar personas reubicadas en refugios, personas rescatadas o ciudadanos censados en terreno.
      </p>
    </div>

    <FormPersona />
  </main>
</Layout>
