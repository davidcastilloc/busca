---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import FormPersona from "../components/FormPersona.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";

export const prerender = false;

const sessionToken = Astro.cookies.get("session_token")?.value;
const { DB } = env;
const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);

if (!voluntario) {
  return Astro.redirect("/ayudar");
}
---

<Layout title="Registrar Persona en Albergue - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 bg-base-200 min-h-screen">
    <div class="text-center max-w-xl mx-auto mb-8 px-4">
      <h1 class="text-3xl md:text-4xl font-black text-base-content tracking-tight">Censo de personas</h1>
      <p class="text-sm text-base-content/70 mt-2">
        Utiliza este formulario para registrar personas reubicadas en refugios, personas rescatadas o ciudadanos censados en terreno.
      </p>
    </div>

    <FormPersona />
  </main>
</Layout>
