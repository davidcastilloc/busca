---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const { id } = Astro.params;
const url = new URL(Astro.request.url);
const esCreado = url.searchParams.has("creado") || url.searchParams.has("new");

let flyer: any = null;
let phones: string[] = [];
let socials: string[] = [];

try {
  const { DB } = env;

  if (DB && id) {
    const result = await DB.prepare("SELECT * FROM flyers WHERE id = ?").bind(id).first();
    if (result) {
      flyer = result;
      phones = JSON.parse(result.phones || "[]");
      socials = JSON.parse(result.socials || "[]");
    }
  }
} catch (error) {
  console.error("Error al cargar flyer de base de datos:", error);
}

const formatFechaHora = (fechaStr: string) => {
  try {
    if (!fechaStr) return "";
    const d = new Date(fechaStr.replace("T", " ") + " UTC");
    const dateStr = d.toLocaleDateString("es-ES", { 
      timeZone: "UTC",
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
    const timeStr = d.toLocaleTimeString("es-ES", {
      timeZone: "UTC",
      hour: '2-digit',
      minute: '2-digit',
      hour12: true
    });
    return `Reportado el: ${dateStr} a las ${timeStr}`;
  } catch (e) {
    return fechaStr;
  }
};

// Datos para compartir en redes sociales
const siteUrl = "https://dondeestan.org";
const flyerUrl = `${siteUrl}/f/${id}`;
const ogImage = `${siteUrl}/f/${id}.png`;

// Descripción corta para compartir
const rawDesc = flyer?.description || "";
let ubicacion = "";
const ubiMatch = rawDesc.match(/\[(?:UBICACIÓN|LUGAR):\s*(.*?)\]/i);
if (ubiMatch) {
  ubicacion = ubiMatch[1].trim();
}
const phones0 = phones[0] || "";

let shareText = "";
const titleUpper = flyer?.title || "";
const nombreExtraido = titleUpper.replace(/^(SE BUSCA:|ALERTA AMBER:|ALERTA:|URGENTE:|REFUGIO ACTIVO:|PERSONA ENCONTRADA:|EMERGENCIA:)\s*/i, "").trim();

if (flyer?.tipo === "necesidad") {
  const catMatch = rawDesc.match(/\[TIPO NECESIDAD: (.*?)\]/);
  const gravedadMatch = rawDesc.match(/\[URGENCIA: (.*?)\]/);
  const cat = catMatch ? catMatch[1] : "Necesidad Urgente";
  const grav = gravedadMatch ? gravedadMatch[1] : "Alta urgencia";
  shareText = `🇧 NECESIDAD CRÍTICA: ${cat} (${grav})${ubicacion ? ` en ${ubicacion}` : ""}${phones0 ? `. Contactar: ${phones0}` : ""}. ¡Comparte y ayuda! ${flyerUrl}`;
} else if (flyer?.tipo === "refugio") {
  shareText = `🏠 REFUGIO ACTIVO: ${nombreExtraido}${ubicacion ? ` - ${ubicacion}` : ""}${phones0 ? `. Encargado: ${phones0}` : ""}. ${flyerUrl}`;
} else if (flyer?.tipo === "desaparecido") {
  shareText = `🔴 SE BUSCA: ${nombreExtraido}${ubicacion ? ` - Último avistamiento: ${ubicacion}` : ""}. ¡Comparte! ${flyerUrl}`;
} else if (flyer?.tipo === "encontrado") {
  shareText = `✅ PERSONA ENCONTRADA/LOCALIZADO: ${nombreExtraido}. Informar a familiares. ${flyerUrl}`;
} else {
  shareText = `🚨 Reporte de emergencia en dondeestan.org: ${flyerUrl}`;
}

const ogTitle = flyer?.title || "Reporte de Emergencia";
const ogDesc = shareText.replace(flyerUrl, "").trim();
---

<Layout
  title={flyer ? `${flyer.title} - Cartel de Emergencia | dondeestan.org` : "Cartel no encontrado - dondeestan.org"}
  description={ogDesc || "Reporte de emergencia en dondeestan.org"}
  ogImage={ogImage}
  ogUrl={flyerUrl}
>
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-xl mx-auto w-full">
    {flyer ? (
      <div class="space-y-6">
        {esCreado && (
          <div class="bg-canvas-soft border border-canvas-soft rounded-xl p-5 shadow-sm font-uber-text uber-body-sm text-ink">
            <div class="font-bold text-base mb-1">🎉 Reporte registrado con éxito</div>
            <p class="text-body">
              La plataforma dondeestan.org ya está procesando y cruzando los datos. Guarda este enlace o descarga la imagen abajo.
            </p>
          </div>
        )}

        <!-- Banner informativo (estilo card-soft-tinted) -->
        <div class="bg-canvas-soft border border-canvas-soft p-4 rounded-xl text-ink font-uber-text uber-body-sm shadow-sm">
          <strong>ℹ️ IMPORTANTE:</strong> Guarda este enlace para compartir el cartel digital, o descárgalo como imagen para difundirlo por Whatsapp o imprimirlo.
        </div>

        <!-- Botones de Acción Superiores (estilo Uber) -->
        <div class="flex gap-2 justify-center flex-wrap">
          <button id="btn-download" class="btn bg-primary text-white hover:bg-black-elevated flex-1 min-w-[130px] font-uber-text uber-body-md-strong">
            ⬇️ Descargar
          </button>
          <button id="btn-copy" class="btn bg-canvas text-ink border border-canvas-soft shadow-lg hover:bg-canvas-soft flex-1 min-w-[130px] font-uber-text uber-body-md-strong">
            🔗 Copiar enlace
          </button>
        </div>

        <!-- Botones de compartir en redes sociales -->
        <div class="space-y-2">
          <p class="text-xs text-mute font-uber-text text-center uppercase tracking-wider">Compartir en redes</p>
          <div class="grid grid-cols-3 gap-2">
            <a
              id="btn-whatsapp"
              href={`https://wa.me/?text=${encodeURIComponent(shareText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center justify-center gap-1.5 py-3 px-2 rounded-xl border border-canvas-soft bg-[#25D366]/10 hover:bg-[#25D366]/20 transition-colors text-center font-uber-text uber-body-sm-strong text-ink"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#25D366" class="w-6 h-6"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              <span class="text-xs">WhatsApp</span>
            </a>
            <a
              id="btn-telegram"
              href={`https://t.me/share/url?url=${encodeURIComponent(flyerUrl)}&text=${encodeURIComponent(shareText.replace(flyerUrl, "").trim())}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center justify-center gap-1.5 py-3 px-2 rounded-xl border border-canvas-soft bg-[#229ED9]/10 hover:bg-[#229ED9]/20 transition-colors text-center font-uber-text uber-body-sm-strong text-ink"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#229ED9" class="w-6 h-6"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              <span class="text-xs">Telegram</span>
            </a>
            <a
              id="btn-twitter"
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center justify-center gap-1.5 py-3 px-2 rounded-xl border border-canvas-soft bg-[#000]/5 hover:bg-[#000]/10 transition-colors text-center font-uber-text uber-body-sm-strong text-ink"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              <span class="text-xs">Twitter/X</span>
            </a>
          </div>
        </div>

        <!-- Contenedor del Cartel Imprimible (html2canvas, diseño premium blanco y negro) -->
        <div id="flyer-card" class="bg-white text-black p-6 rounded-none shadow-md border-8 border-primary font-sans flex flex-col justify-between max-w-md mx-auto aspect-[3/4]">
          <div>
            <!-- Cabecera del Cartel -->
            <div class="text-center bg-primary text-white py-3 px-4 -mx-6 -mt-6 mb-5 font-uber-display text-xl tracking-widest uppercase">
              🚨 DONDE ESTAN 🚨
            </div>

            <!-- Título Principal -->
            <h1 class="text-2xl md:text-3xl font-uber-display tracking-tight text-center text-ink uppercase break-words mb-4 leading-tight">
              {flyer.title}
            </h1>

            <!-- Foto -->
            <div class="w-full aspect-[4/3] bg-canvas-soft border border-canvas-soft rounded-lg overflow-hidden flex items-center justify-center mb-4 relative">
              {flyer.foto_key ? (
                <img 
                  src={`/api/upload?key=${encodeURIComponent(flyer.foto_key)}`} 
                  alt={flyer.title}
                  class="w-full h-full object-contain"
                  crossorigin="anonymous"
                  fetchpriority="high"
                  decoding="sync"
                />
              ) : (
                <div class="flex flex-col items-center justify-center p-6 text-center text-mute">
                  <span class="text-6xl mb-2">
                    {flyer.title.includes("REFUGIO") ? "🏠" : flyer.title.includes("EMERGENCIA") ? "⚠️" : "📢"}
                  </span>
                  <span class="text-[10px] font-bold uppercase tracking-widest text-mute">Difusión de Emergencia</span>
                </div>
              )}
            </div>

            <!-- Descripción (estilo blockquote minimalista) -->
            <div class="bg-canvas-soft border-l-4 border-primary p-3 text-sm md:text-base leading-relaxed break-words font-medium text-ink mb-4 whitespace-pre-wrap font-uber-text">
              {flyer.description}
            </div>
          </div>

          <!-- Contacto e Info de Cierre -->
          <div>
            {(phones.length > 0 || socials.length > 0) && (
              <div class="border-t border-canvas-soft pt-4 mb-4 grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs font-uber-text text-body">
                {phones.length > 0 && (
                  <div>
                    <h3 class="text-ink uppercase tracking-wider mb-1 font-bold text-[10px]">Llamar a:</h3>
                    {phones.map((phone: string) => (
                      <p class="text-sm font-bold text-ink">{phone}</p>
                    ))}
                  </div>
                )}
                
                {socials.length > 0 && (
                  <div>
                    <h3 class="text-ink uppercase tracking-wider mb-1 font-bold text-[10px]">Redes Sociales:</h3>
                    {socials.map((social: string) => (
                      <p class="text-sm font-bold text-ink truncate">{social}</p>
                    ))}
                  </div>
                )}
              </div>
            )}

            <!-- Footer del Cartel con Logo, QR y Dominio -->
            <div class="border-t border-canvas-soft pt-3 mt-4 flex items-center justify-between font-uber-text">
              <div class="flex items-center gap-2">
                <div class="font-uber-display text-xl tracking-tighter font-black text-primary flex items-center gap-1">
                  dondeestan<span class="text-body">.org</span>
                </div>
              </div>
              <div class="flex gap-3 items-center text-right">
                <div class="flex flex-col text-[9px] text-body uppercase tracking-wider">
                  <span>Escanea para</span>
                  <span>más info o</span>
                  <span>compartir</span>
                </div>
                <img src={`https://api.qrserver.com/v1/create-qr-code/?size=60x60&data=${encodeURIComponent(url.href)}`} alt="QR Code" class="w-12 h-12 border border-canvas-soft p-0.5 rounded-sm" crossorigin="anonymous" />
              </div>
            </div>
            <div class="text-[8px] text-body mt-2 flex justify-between font-uber-text">
              <span>Reporte #{id} • {formatFechaHora(flyer.created_at)}</span>
            </div>
          </div>
        </div>
        
        <div class="text-center pt-4">
          <a href="/reportar" class="link-blue font-uber-text uber-body-sm-strong">
            ← Emitir un nuevo reporte / cartel
          </a>
        </div>
      </div>
    ) : (
      <div class="text-center py-16 space-y-4">
        <div class="text-5xl">⚠️</div>
        <h1 class="font-uber-display text-2xl text-ink">Cartel no encontrado</h1>
        <p class="text-sm text-body font-uber-text">
          El cartel que buscas no existe o fue eliminado de la base de datos de emergencia.
        </p>
        <div class="pt-4">
          <a href="/" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong">
            Volver al inicio
          </a>
        </div>
      </div>
    )}
  </main>

  <!-- DIV OCULTO PARA GENERAR CARTEL (estilos inline, compatible con html2canvas) -->
  {flyer && (
    <div id="cartel-container" style="position:absolute;left:-9999px;top:-9999px;">
      <div id="cartel-se-busca" style="width:600px;font-family:system-ui,-apple-system,sans-serif;background:#fff;color:#000;">
        <!-- Franja superior -->
        <div style="background:#000;color:#fff;padding:16px 24px;text-align:center;">
          <div style="font-size:12px;letter-spacing:4px;font-weight:500;margin-bottom:4px;">dondeestan.org</div>
          <div style="font-size:36px;font-weight:700;letter-spacing:2px;">DONDE ESTAN</div>
        </div>
        <!-- Foto -->
        <div id="cartel-foto-wrap" style="width:100%;height:400px;background:#efefef;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;">
          <img id="cartel-foto" style="position:absolute;" src="" alt="" crossorigin="anonymous" />
        </div>
        <!-- Datos -->
        <div style="padding:20px 24px;">
          <div id="cartel-nombre" style="font-size:28px;font-weight:700;line-height:1.2;margin-bottom:8px;"></div>
          <div id="cartel-datos" style="font-size:14px;color:#5e5e5e;margin-bottom:12px;"></div>
          <div id="cartel-descripcion" style="font-size:15px;line-height:1.5;margin-bottom:16px;border-left:3px solid #000;padding-left:12px;font-style:italic;"></div>
          <div id="cartel-contacto-info" style="font-size:14px;color:#5e5e5e;"></div>
        </div>
        <!-- Franja inferior -->
        <div style="background:#000;color:#fff;padding:14px 24px;display:flex;justify-content:space-between;align-items:center;">
          <div style="display:flex;flex-direction:column;gap:4px;">
            <div id="cartel-contacto" style="font-size:16px;font-weight:700;"></div>
            <div style="font-size:10px;opacity:0.8;">{formatFechaHora(flyer.created_at)}</div>
          </div>
          <div style="font-size:11px;opacity:0.7;text-align:right;">
            <div>dondeestan.org</div>
            <div>dondeestan.org</div>
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- Script descarga y copiar -->
  <script>
    document.addEventListener("astro:page-load", () => {
      const btnDownload = document.getElementById("btn-download");
      const btnCopy = document.getElementById("btn-copy");

      if (btnDownload) {
        const newBtnDownload = btnDownload.cloneNode(true);
        btnDownload.parentNode?.replaceChild(newBtnDownload, btnDownload);
        newBtnDownload.addEventListener("click", async () => {
          const target = newBtnDownload as HTMLButtonElement;
          const originalText = target.textContent;
          target.textContent = "Generando...";
          target.classList.add("opacity-50");

          try {
            const flyerId = window.location.pathname.split("/").pop() || "";
            const a = document.createElement("a");
            a.href = `/f/${flyerId}.png`;
            a.download = `flyer_${flyerId}.png`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);

            target.textContent = "✓ Descargado";
            setTimeout(() => {
              target.textContent = originalText;
              target.classList.remove("opacity-50");
            }, 2000);
          } catch (err) {
            console.error("Fallo de descarga de flyer:", err);
            alert("Error al descargar el cartel. Toma una captura de pantalla.");
            target.classList.remove("opacity-50");
            target.textContent = originalText;
          }
        });
      }

      if (btnCopy) {
        const newBtnCopy = btnCopy.cloneNode(true);
        btnCopy.parentNode?.replaceChild(newBtnCopy, btnCopy);
        newBtnCopy.addEventListener("click", () => {
          const target = newBtnCopy as HTMLButtonElement;
          navigator.clipboard.writeText(window.location.href);
          const originalText = target.textContent;
          target.textContent = "✓ Enlace Copiado";
          target.classList.add("opacity-85");
          
          setTimeout(() => {
            target.textContent = originalText;
            target.classList.remove("opacity-85");
          }, 2000);
        });
      }
    });
  </script>
</Layout>

