---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import FormReporte from "../components/FormReporte.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";

export const prerender = false;

const sessionToken = Astro.cookies.get("session_token")?.value;
const { DB } = env;
const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
const isVolunteer = !!voluntario;
const volunteerName = voluntario ? voluntario.nombre : "";
const volunteerPhone = voluntario ? voluntario.telefono : "";
---

<Layout title="Reportar Persona Desaparecida o Emergencia - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 bg-base-200 min-h-screen">
    <div class="text-center max-w-xl mx-auto mb-8 px-4">
      <h1 class="text-3xl md:text-4xl font-black text-base-content tracking-tight">Reporte de emergencia</h1>
      <p class="text-sm text-base-content/70 mt-2">
        Reporta la desaparición de un familiar, una persona encontrada no identificada o necesidades críticas en terreno.
      </p>
    </div>

    <FormReporte 
      isVolunteer={isVolunteer} 
      volunteerName={volunteerName} 
      volunteerPhone={volunteerPhone} 
    />
  </main>
</Layout>
