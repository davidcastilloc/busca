---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import FormReporte from "../components/FormReporte.astro";

export const prerender = false;
---

<Layout title="Reportar Persona Desaparecida o Emergencia - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 bg-canvas">
    <div class="text-center max-w-xl mx-auto mb-8 px-4">
      <h1 class="font-uber-display text-3xl text-ink tracking-tight">Reporte de emergencia</h1>
      <p class="text-sm text-body font-uber-text mt-2">
        Reporta la desaparición de un familiar, una persona encontrada no identificada o necesidades críticas en terreno.
      </p>
    </div>

    <FormReporte />
  </main>
</Layout>
