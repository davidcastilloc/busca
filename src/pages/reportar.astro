---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import FormReporte from "../components/FormReporte.astro";

export const prerender = false;
---

<Layout title="Reportar Persona Desaparecida o Emergencia - BUSCA">
  <Navbar />
  
  <main class="flex-grow py-6">
    <div class="text-center max-w-xl mx-auto mb-6 px-4">
      <h1 class="text-3xl font-black text-base-content text-warning">Reporte de Emergencia</h1>
      <p class="text-sm text-base-content/70 mt-2">
        Reporta la desaparición de un familiar, una persona encontrada no identificada o necesidades críticas en terreno.
      </p>
    </div>

    <FormReporte />
  </main>
</Layout>
