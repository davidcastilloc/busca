  // --- BOTTOM SHEET INTERACTIVE ---
  function expandSheet(state: "oculto" | "colapsado" | "medio" | "expandido") {
    const sheet = document.getElementById("bottom-sheet");
    if (!sheet) return;
    sheetState = state;
    
    if (state === "oculto") {
      sheet.style.transform = "translateY(100%)";
      return;
    }

    // Dejar que el DOM calcule su altura primero
    setTimeout(() => {
      const sheetHeight = sheet.offsetHeight;
      const vh = window.innerHeight;
      
      switch (state) {
        case "colapsado":
          sheet.style.transform = "translateY(-80px)";
          break;
        case "medio":
          // Medio es 45vh o la altura total del sheet si es más pequeño
          sheet.style.transform = `translateY(-${Math.min(sheetHeight, Math.round(vh * 0.45))}px)`;
          break;
        case "expandido":
          sheet.style.transform = `translateY(-${sheetHeight}px)`;
          break;
      }
    }, 10);
  }

  function renderDefaultList() {
    const listContainer = document.getElementById("default-list");
    const detailView = document.getElementById("detail-view");
    if (!listContainer || !detailView) return;
    
    detailView.classList.add("hidden");
    listContainer.classList.remove("hidden");

    let countRefugios = dataStore.refugios.length;
    let countNecesidades = dataStore.necesidades.length;
    let countPersonas = dataStore.personas.length;
    let countPeligros = dataStore.peligros.length;

    const sheetTitle = document.getElementById("sheet-title")!;
    sheetTitle.textContent = `${countRefugios + countNecesidades + countPersonas + countPeligros} incidentes y recursos`;

    let html = "";

    // Agrupación Geográfica (Estado / Municipio) en el resumen
    const geoSummary: Record<string, { refugios: number; necesidades: number; personas: number }> = {};
    
    // Contamos por estado/municipio según dirección de refugios o ubicaciones
    dataStore.refugios.forEach(r => {
      const key = r.direccion?.split(",").slice(-2)[0]?.trim() || "Venezuela";
      if (!geoSummary[key]) geoSummary[key] = { refugios: 0, necesidades: 0, personas: 0 };
      geoSummary[key].refugios++;
    });

    dataStore.necesidades.forEach(n => {
      const key = "Necesidades Reportadas";
      if (!geoSummary[key]) geoSummary[key] = { refugios: 0, necesidades: 0, personas: 0, peligros: 0 };
      geoSummary[key].necesidades++;
    });

    dataStore.personas.forEach(p => {
      const key = p.refugio || "Zonas de Búsqueda";
      if (!geoSummary[key]) geoSummary[key] = { refugios: 0, necesidades: 0, personas: 0, peligros: 0 };
      geoSummary[key].personas++;
    });

    dataStore.peligros.forEach(p => {
      const key = "Zonas de Peligro (Vías)";
      if (!geoSummary[key]) geoSummary[key] = { refugios: 0, necesidades: 0, personas: 0, peligros: 0 };
      geoSummary[key].peligros++;
    });

    html += `<div class="mb-4 text-xs font-uber-text text-mute uppercase tracking-wider font-bold">Resumen por Sectores</div>`;
    
    Object.entries(geoSummary).forEach(([zona, metrics]) => {
      const peligrosMetric = (metrics as any).peligros || 0;
      html += `
        <div class="flex items-center justify-between p-3 bg-canvas-soft/40 border border-canvas-soft rounded-xl mb-2">
          <div class="min-w-0">
            <h4 class="font-bold text-xs text-ink truncate">${zona}</h4>
          </div>
          <div class="flex gap-2 text-[10px] font-uber-text">
            ${metrics.refugios > 0 ? `<span class="bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full">🏠 ${metrics.refugios}</span>` : ""}
            ${metrics.necesidades > 0 ? `<span class="bg-purple-100 text-purple-800 px-2 py-0.5 rounded-full">📦 ${metrics.necesidades}</span>` : ""}
            ${metrics.personas > 0 ? `<span class="bg-emerald-100 text-emerald-800 px-2 py-0.5 rounded-full">👥 ${metrics.personas}</span>` : ""}
            ${peligrosMetric > 0 ? `<span class="bg-red-100 text-red-800 px-2 py-0.5 rounded-full">⚠️ ${peligrosMetric}</span>` : ""}
          </div>
        </div>
      `;
    });

    listContainer.innerHTML = html;
  }

