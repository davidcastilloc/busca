  // --- BOTTOM SHEET INTERACTIVE ---
  function expandSheet(state: "colapsado" | "medio" | "expandido") {
    const sheet = document.getElementById("bottom-sheet");
    if (!sheet) return;
    sheetState = state;
    const vh = window.innerHeight;
    switch (state) {
      case "colapsado":
        sheet.style.transform = "translateY(-80px)";
        break;
      case "medio":
        sheet.style.transform = `translateY(-${Math.round(vh * 0.45)}px)`;
        break;
      case "expandido":
        sheet.style.transform = `translateY(-${Math.round(vh * 0.85)}px)`;
        break;
    }
  }

