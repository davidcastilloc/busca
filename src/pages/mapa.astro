  // --- EVENTOS DE UI ---
  function setupUIEvents() {
    const L = (window as any).L;

    // Control del Bottom Sheet
    const bottomSheet = document.getElementById("bottom-sheet");
    const sheetHandle = document.getElementById("sheet-handle");
    const btnSheetClose = document.getElementById("btn-sheet-close");
    
    if (!bottomSheet || !sheetHandle || !btnSheetClose) return;

    let touchStartY = 0;

    sheetHandle.addEventListener("touchstart", (e) => {
      touchStartY = e.touches[0].clientY;
      bottomSheet.style.transition = "none";
    });

    sheetHandle.addEventListener("touchmove", (e) => {
      e.preventDefault(); // Previene el pull-to-refresh del navegador (Safari/Chrome)
      const diff = e.touches[0].clientY - touchStartY;
      if (diff > 0) { // Solo permitir arrastrar hacia abajo
        bottomSheet.style.transform = `translateY(calc(-${bottomSheet.offsetHeight}px + ${diff}px))`;
      }
    }, { passive: false });

    sheetHandle.addEventListener("touchend", (e) => {
      bottomSheet.style.transition = "transform 0.3s cubic-bezier(0.16, 1, 0.3, 1)";
      const diff = e.changedTouches[0].clientY - touchStartY;
      
      if (diff > 40) {
        selectedEntity = null;
        renderDefaultList();
        expandSheet("oculto");
      } else {
        expandSheet(sheetState);
      }
    });

    sheetHandle.addEventListener("click", () => {
      selectedEntity = null;
      renderDefaultList();
      expandSheet("oculto");
    });

    btnSheetClose.addEventListener("click", () => {
      selectedEntity = null;
      renderDefaultList();
      expandSheet("oculto");
    });

    // Píldoras de Capas (Layers)
    document.querySelectorAll(".layer-pill").forEach(pill => {
      pill.addEventListener("click", () => {
        document.querySelectorAll(".layer-pill").forEach(p => p.classList.remove("active"));
        pill.classList.add("active");

        const targetLayer = (pill as HTMLElement).dataset.layer || "todos";
        activeLayer = targetLayer;
        applyLayerFilter();

        selectedEntity = null;
        renderDefaultList();
        
        // Volver a mostrar el panel (colapsado) si estaba oculto
        if (sheetState === "oculto") expandSheet("colapsado");
      });
    });

    // FAB: Orientar Norte
    document.getElementById("btn-north")?.addEventListener("click", () => {
      if (map) map.setBearing ? map.setBearing(0) : map.setView(map.getCenter(), map.getZoom());
    });

    // FAB: Geolocalizar
    document.getElementById("btn-geolocate")?.addEventListener("click", () => {
      if (!navigator.geolocation || !map) return;

      navigator.geolocation.getCurrentPosition(
        (pos) => {
          const lat = pos.coords.latitude;
          const lng = pos.coords.longitude;
          userLatLng = [lat, lng];
          map.flyTo([lat, lng], 14, { duration: 1.2 });

          if (userMarker) {
            userMarker.setLatLng([lat, lng]);
          } else {
            const userIcon = L.divIcon({
              html: `<div class="user-location-marker"><div class="user-location-pulse"></div></div>`,
              className: "",
              iconSize: [20, 20],
              iconAnchor: [10, 10]
            });
            userMarker = L.marker([lat, lng], { icon: userIcon, zIndexOffset: 1000 }).addTo(map);
          }
        },
        () => {
          alert("No se pudo obtener ubicación GPS.");
        },
        { enableHighAccuracy: true, timeout: 6000 }
      );
    });

    // Radar Cerca
    document.getElementById("btn-radar")?.addEventListener("click", () => {
      const btn = document.getElementById("btn-radar")!;
      btn.classList.add("radar-active");
      setTimeout(() => btn.classList.remove("radar-active"), 1200);

      function runRadar(lat: number, lng: number) {
        clearRadarHighlights();
        
        // Agregar pulso visual
        const radarPulse = L.divIcon({
          html: `<div class="radar-pulse-ring"></div><div class="radar-pulse-ring" style="animation-delay:0.3s"></div>`,
          className: "",
          iconSize: [0, 0]
        });
        const pulseMarker = L.marker([lat, lng], { icon: radarPulse, interactive: false }).addTo(map);
        setTimeout(() => map.removeLayer(pulseMarker), 2200);

        // Encontrar los 5 elementos más cercanos de cualquier tipo
        const allItems: any[] = [];
        dataStore.refugios.forEach(r => allItems.push({ ...r, _key: `${r.tipo}-${r.id}`, _t: r.tipo, _emoji: r.tipo === "hospital" ? "🏥" : r.tipo === "centro_acopio" ? "📦" : "🏠" }));
        dataStore.necesidades.forEach(n => allItems.push({ ...n, _key: `necesidad-${n.id}`, _t: "necesidad", _emoji: "📦" }));
        dataStore.personas.forEach(p => allItems.push({ ...p, _key: `persona-${p.id}`, _t: "persona", _emoji: "👥" }));
        dataStore.peligros.forEach(p => allItems.push({ ...p, _key: `peligro-${p.id}`, _t: "peligro", _emoji: "⚠️" }));

        const sorted = allItems.map(item => ({
          ...item,
          dist: haversine(lat, lng, item.lat, item.lng)
        })).sort((a, b) => a.dist - b.dist);

        const top5 = sorted.slice(0, 5);
        if (top5.length === 0) return;

        // Trazar línea al más cercano
        radarLine = L.polyline([[lat, lng], [top5[0].lat, top5[0].lng]], {
          color: "#2563eb",
          weight: 3,
          className: "route-line"
        }).addTo(map);

        // Resaltar marcadores
        top5.forEach(item => {
          const marker = markers.get(item._key);
          if (marker) {
            const el = marker.getElement();
            if (el) {
              const markerDiv = el.querySelector(".custom-marker");
              if (markerDiv) markerDiv.classList.add("highlighted");
            }
            radarHighlights.push(marker);
          }
        });

        // Ajustar mapa
        const bounds = L.latLngBounds([[lat, lng], ...top5.map(i => [i.lat, i.lng])]);
        map.fitBounds(bounds.pad(0.2));

        // Renderizar en el bottom sheet
        const listContainer = document.getElementById("default-list");
        const detailView = document.getElementById("detail-view");
        const sheetTitle = document.getElementById("sheet-title");
        if (!listContainer || !detailView || !sheetTitle) return;
        
        listContainer.classList.remove("hidden");
        detailView.classList.add("hidden");

        sheetTitle.textContent = `🎯 Recursos cercanos (${top5.length})`;

        listContainer.innerHTML = top5.map(i => `
          <div onclick="window._showDetails('${i._t}', '${i.id}')" class="sheet-card flex items-center justify-between p-3 bg-canvas-soft/60 border border-canvas-soft rounded-xl cursor-pointer hover:bg-surface-pressed/50">
            <div>
              <h4 class="font-bold text-xs text-ink">${i._emoji} ${i.nombre || i.categoria}</h4>
              <p class="text-[10px] text-mute mt-0.5">A ${i.dist < 1 ? `${Math.round(i.dist * 1000)}m` : `${i.dist.toFixed(1)}km`}</p>
            </div>
            <span class="text-xs">→</span>
          </div>
        `).join("");

        expandSheet("expandido");
      }

      if (userLatLng) {
        runRadar(userLatLng[0], userLatLng[1]);
      } else {
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            userLatLng = [pos.coords.latitude, pos.coords.longitude];
            runRadar(userLatLng[0], userLatLng[1]);
          },
          () => alert("Activa el GPS para usar el radar."),
          { enableHighAccuracy: true, timeout: 6000 }
        );
      }
    });

    // Buscador
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const searchResults = document.getElementById("search-results");
    let searchTimeout: any = null;

    searchInput?.addEventListener("input", () => {
      clearTimeout(searchTimeout);
      if (!searchResults) return;
      searchTimeout = setTimeout(() => {
        const query = searchInput.value.trim().toLowerCase();
        if (!query || query.length < 2) {
          searchResults.classList.add("hidden");
          return;
        }

        const matches: any[] = [];
        
        // Buscar en refugios
        dataStore.refugios.forEach(r => {
          if (r.nombre.toLowerCase().includes(query) || r.direccion.toLowerCase().includes(query)) {
            matches.push({ id: r.id, name: r.nombre, label: r.direccion, tipo: r.tipo, emoji: r.tipo === "hospital" ? "🏥" : r.tipo === "centro_acopio" ? "📦" : "🏠" });
          }
        });

        // Buscar en necesidades
        dataStore.necesidades.forEach(n => {
          if (n.categoria.toLowerCase().includes(query) || n.descripcion.toLowerCase().includes(query)) {
            matches.push({ id: n.id, name: n.categoria, label: n.descripcion, tipo: "necesidad", emoji: "📦" });
          }
        });

        // Buscar en personas
        dataStore.personas.forEach(p => {
          if (p.nombre.toLowerCase().includes(query) || p.notas.toLowerCase().includes(query)) {
            matches.push({ id: p.id, name: p.nombre, label: `Persona (${p.estado})`, tipo: "persona", emoji: "👥" });
          }
        });

        // Buscar en peligros
        dataStore.peligros.forEach(p => {
          const pTipoMap: Record<string, string> = { bloqueo: "Bloqueo", derrumbe: "Derrumbe", inundacion: "Inundación" };
          const pName = pTipoMap[p.tipo] || p.tipo;
          if (p.tipo.toLowerCase().includes(query) || p.descripcion.toLowerCase().includes(query)) {
            matches.push({ id: p.id, name: pName, label: p.descripcion, tipo: "peligro", emoji: "⚠️" });
          }
        });

        const sliced = matches.slice(0, 6);
        if (sliced.length === 0) {
          searchResults.innerHTML = `<div class="p-3 text-xs text-mute font-uber-text">Sin coincidencias</div>`;
        } else {
          searchResults.innerHTML = sliced.map(m => `
            <button onclick="window._goSearch('${m.tipo}', '${m.id}')" class="w-full text-left flex items-center gap-2.5 px-3 py-2 hover:bg-canvas-soft border-b border-canvas-soft last:border-none cursor-pointer">
              <span class="text-base">${m.emoji}</span>
              <div class="min-w-0 flex-1">
                <div class="text-xs font-bold text-ink truncate">${m.name}</div>
                <div class="text-[10px] text-mute truncate">${m.label}</div>
              </div>
            </button>
          `).join("");
        }

        searchResults.classList.remove("hidden");
      }, 250);
    });

    (window as any)._goSearch = (tipo: string, id: string) => {
      searchResults.classList.add("hidden");
      searchInput.value = "";

      const marker = markers.get(`${tipo}-${id}`);
      if (marker) {
        map.flyTo(marker.getLatLng(), 17, { duration: 1.5 });
        setTimeout(() => marker.openPopup(), 1600);
        showEntityDetail(tipo, id);
        expandSheet("medio");
      }
    };

    (window as any)._voyEnCamino = (
      necesidadId: number,
      refugioId: number | null,
      centroAcopioId: number | null = null,
      hospitalId: number | null = null
    ) => {
      window.dispatchEvent(new CustomEvent('open-camino-modal', {
        detail: { necesidadId, refugioId, centroAcopioId, hospitalId }
      }));
    };

    (window as any)._marcarAtendida = (necesidadId: number) => {
      window.dispatchEvent(new CustomEvent('open-atendida-modal', {
        detail: { necesidadId }
      }));
    };

    window.addEventListener('reload-map-data', async (e: any) => {
      const necesidadId = e.detail.necesidadId;
      
      // 1. Actualización de interfaz optimista inmediata (sin recargar ni esperar fetch)
      const n = dataStore.necesidades.find((x: any) => String(x.id) === String(necesidadId));
      if (n) {
        n.en_camino = (n.en_camino || 0) + 1;
        
        // Actualizar el texto del panel lateral directamente si está abierto
        const spanEl = document.getElementById("det-necesidad-en-camino");
        if (spanEl) {
          spanEl.textContent = `👥 ${n.en_camino} en camino`;
        }
        
        // Actualizar el popup del marcador en el mapa
        const markerKey = `necesidad-${necesidadId}`;
        const marker = markers.get(markerKey);
        if (marker) {
          marker.setPopupContent(buildNecesidadPopupHtml(n));
        }
      }

      // 2. Sincronizar en segundo plano con el servidor
      try {
        await fetchUnifiedData();
        // Volver a renderizar detalles con datos confirmados del servidor
        showEntityDetail("necesidad", String(necesidadId));
      } catch (err) {
        console.error("Error al sincronizar datos tras registrar camino:", err);
      }
    });

    window.addEventListener('reload-map-data-atendida', async (e: any) => {
      const necesidadId = e.detail.necesidadId;
      const markerKey = `necesidad-${necesidadId}`;
      const marker = markers.get(markerKey);
      if (marker && map) {
        map.removeLayer(marker);
        markers.delete(markerKey);
      }
      await fetchUnifiedData();
      renderDefaultList();
      const listContainer = document.getElementById("default-list");
      const detailView = document.getElementById("detail-view");
      if (listContainer && detailView) {
        listContainer.classList.remove("hidden");
        detailView.classList.add("hidden");
      }
    });
  }

  function clearRadarHighlights() {
    if (radarLine && map) {
      map.removeLayer(radarLine);
      radarLine = null;
    }
    radarHighlights.forEach(m => {
      const el = m.getElement();
      if (el) {
        const markerDiv = el.querySelector(".custom-marker");
        if (markerDiv) markerDiv.classList.remove("highlighted");
      }
    });
    radarHighlights = [];
  }

  // Rutas y compartición globales
  const L_global = (window as any).L;

  (window as any)._rutaA = (key: string) => {
    const marker = markers.get(key);
    if (!marker) return;

    const destLatLng = marker.getLatLng();

    function drawRoute(uLat: number, uLng: number) {
      if (routeLine && map) map.removeLayer(routeLine);

      routeLine = (window as any).L.polyline([[uLat, uLng], [destLatLng.lat, destLatLng.lng]], {
        color: "#2563eb",
        weight: 4,
        className: "route-line"
      }).addTo(map);

      const bounds = (window as any).L.latLngBounds([[uLat, uLng], [destLatLng.lat, destLatLng.lng]]);
      map.fitBounds(bounds.pad(0.15));

      const dist = haversine(uLat, uLng, destLatLng.lat, destLatLng.lng);
      const minsWalk = Math.round((dist / 5) * 60);

      const routeInfo = document.getElementById("route-info")!;
      const routeDestName = document.getElementById("route-dest-name")!;
      const routeDistance = document.getElementById("route-distance")!;
      const routeTime = document.getElementById("route-time")!;

      routeDestName.textContent = marker.getPopup().getContent().match(new RegExp("<h4[^>]*>([^<]+)</h4>"))?.[1] || "Destino";
      routeDistance.textContent = dist < 1 ? `${Math.round(dist * 1000)} m` : `${dist.toFixed(1)} km`;
      routeTime.textContent = minsWalk < 60 ? `${minsWalk} min` : `${Math.floor(minsWalk / 60)}h ${minsWalk % 60}m`;

      (document.getElementById("route-gmaps") as HTMLAnchorElement).href = `https://www.google.com/maps/dir/?api=1&origin=${uLat},${uLng}&destination=${destLatLng.lat}&travelmode=walking`;
      (document.getElementById("route-waze") as HTMLAnchorElement).href = `https://waze.com/ul?ll=${destLatLng.lat},${destLatLng.lng}&navigate=yes`;

      routeInfo.classList.remove("hidden");
      map.closePopup();
    }

    if (userLatLng) {
      drawRoute(userLatLng[0], userLatLng[1]);
    } else {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          userLatLng = [pos.coords.latitude, pos.coords.longitude];
          drawRoute(userLatLng[0], userLatLng[1]);
        },
        () => {
          window.open(`https://www.google.com/maps/dir/?api=1&destination=${destLatLng.lat},${destLatLng.lng}`, "_blank");
        },
        { enableHighAccuracy: true, timeout: 6000 }
      );
    }
  };

  document.getElementById("btn-route-close")?.addEventListener("click", () => {
    if (routeLine && map) {
      map.removeLayer(routeLine);
      routeLine = null;
    }
    document.getElementById("route-info")!.classList.add("hidden");
  });

  (window as any)._shareEntity = (tipo: string, id: string) => {
    let text = "";
    let url = `${window.location.origin}/mapa?tipo=${tipo}&id=${id}`;

    if (tipo === "refugio" || tipo === "hospital" || tipo === "centro_acopio") {
      const r = dataStore.refugios.find(x => String(x.id) === String(id) && x.tipo === tipo);
      if (!r) return;
      const emoji = r.tipo === "hospital" ? "🏥" : r.tipo === "centro_acopio" ? "📦" : "🏠";
      const label = r.tipo === "hospital" ? "Hospital" : r.tipo === "centro_acopio" ? "Centro de Acopio" : "Refugio";
      text = `${emoji} ${label}: *${r.nombre}*\\n📍 Dirección: ${r.direccion}`;
      if (r.tipo === "refugio") text += `\\n👥 Ocupación: ${r.ocupacion}/${r.capacidad}`;
      text += `\\n🗺️ Ver en mapa: `;
    } else if (tipo === "necesidad") {
      const n = dataStore.necesidades.find(x => String(x.id) === String(id));
      if (!n) return;
      text = `📦 Necesidad: *${n.categoria}*\\n⚠️ Gravedad: ${n.gravedad}\\n📝 Descripción: ${n.descripcion}\\n🗺️ Ver en mapa: `;
    } else if (tipo === "persona") {
      const p = dataStore.personas.find(x => String(x.id) === String(id));
      if (!p) return;
      text = `👥 Persona: *${p.nombre}*\\n🟢 Estado: ${p.estado}\\n📝 Notas: ${p.notas}\\n🗺️ Ver en mapa: `;
    } else if (tipo === "peligro") {
      const p = dataStore.peligros.find(x => String(x.id) === String(id));
      if (!p) return;
      text = `⚠️ Peligro en vía: *${p.tipo}*\\n📝 Detalle: ${p.descripcion}\\n🗺️ Ver en mapa: `;
    }

    if (navigator.share) {
      navigator.share({ title: "dondeestan.org", text, url }).catch(() => {});
    } else {
      window.open(`https://wa.me/?text=${encodeURIComponent(text + " " + url)}`, "_blank");
    }
  };
</script>
