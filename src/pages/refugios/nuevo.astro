---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { CATEGORIAS_INVENTARIO } from "../../lib/items";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../../lib/auth-helpers";

export const prerender = false;

// Proteger ruta
const sessionToken = Astro.cookies.get("session_token")?.value;
const { DB } = env;
const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
if (!voluntario) {
  return Astro.redirect("/ayudar");
}
---

<Layout title="Registrar Refugio / Centro de Acopio - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-canvas max-w-lg mx-auto w-full">
    <div class="space-y-6">
      <div>
        <a href="/refugios" class="text-xs text-primary hover:underline font-semibold font-uber-text">
          ← Volver al listado
        </a>
        <h1 class="font-uber-display text-2xl sm:text-3xl text-ink tracking-tight mt-2">
          Registrar Albergue / Acopio
        </h1>
        <p class="text-xs text-body font-uber-text mt-1">
          Añade un nuevo refugio voluntario o formal para geolocalizarlo e indicar sus necesidades.
        </p>
      </div>

      <form id="form-nuevo-refugio" class="space-y-4 bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm">
        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-tipo">Tipo de Centro *</label>
          <select id="ref-tipo" required class="select w-full font-uber-text uber-body-md">
            <option value="refugio" selected>Refugio / Albergue</option>
            <option value="centro_acopio">Centro de Acopio</option>
            <option value="hospital">Hospital / Puesto de Salud</option>
          </select>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-nombre">Nombre del Centro *</label>
          <input 
            type="text" 
            id="ref-nombre" 
            required 
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: Escuela Bolivariana Petare"
          />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-encargado">Encargado *</label>
          <input 
            type="text" 
            id="ref-encargado" 
            required
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Nombre del encargado"
          />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-direccion">Dirección / Sector *</label>
          <div class="flex gap-2 mb-3">
            <input 
              type="text" 
              id="ref-direccion" 
              required 
              class="input flex-grow font-uber-text uber-body-md" 
              placeholder="Ej: Sector La Lucha, Caracas"
            />
            <button type="button" id="btn-buscar-direccion" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed border border-canvas-soft font-uber-text font-semibold px-3 py-2 rounded-xl text-xs shrink-0 cursor-pointer">
              📍 Ubicar
            </button>
          </div>

          <!-- Bloque de ubicación integrado -->
          <div class="p-4 bg-canvas-soft rounded-xl flex flex-col gap-3 border border-canvas-soft">
            <span class="text-[10px] font-bold text-mute uppercase tracking-wider font-uber-text">📍 Método de Ubicación GPS *</span>
            
            <!-- Tabs de selección de método -->
            <div class="flex gap-1 bg-canvas p-1 rounded-lg border border-canvas-soft">
              <button type="button" id="tab-loc-gps" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md bg-primary text-white border-none cursor-pointer">
                GPS Móvil
              </button>
              <button type="button" id="tab-loc-gmaps" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md bg-transparent text-ink border-none cursor-pointer">
                Pegar Enlace
              </button>
              <button type="button" id="tab-loc-map" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md bg-transparent text-ink border-none cursor-pointer">
                Mapa Manual
              </button>
            </div>

            <!-- Inputs ocultos para lat/lng -->
            <input type="hidden" id="ref-latitud" />
            <input type="hidden" id="ref-longitud" />

            <!-- Panel 1: GPS Móvil -->
            <div id="panel-loc-gps" class="flex items-center justify-between gap-2">
              <span class="text-[10px] text-body font-uber-text">Usa el GPS del celular para geolocalizar de inmediato.</span>
              <button id="btn-ref-gps" type="button" class="btn btn-xs bg-primary text-white font-uber-text px-3 py-1.5 rounded-lg text-[10px] cursor-pointer shrink-0">
                Detectar GPS
              </button>
            </div>

            <!-- Panel 2: Pegar Enlace -->
            <div id="panel-loc-gmaps" class="space-y-2 hidden">
              <div class="flex gap-2">
                <input 
                  type="url" 
                  id="ref-gmaps-link" 
                  class="input flex-grow font-uber-text text-xs p-2.5 min-h-[36px]" 
                  placeholder="Pegar enlace de Google Maps..."
                />
                <button type="button" id="btn-resolver-gmaps" class="btn bg-primary text-white font-uber-text font-semibold px-3 py-1.5 rounded-lg text-[10px] shrink-0 cursor-pointer">
                  Extraer
                </button>
              </div>
            </div>

            <!-- Panel 3: Mapa Manual -->
            <div id="panel-loc-map" class="text-[10px] text-mute font-uber-text italic hidden">
              Toca el mapa abajo para ajustar el marcador manualmente.
            </div>

            <!-- Contenedor del mapa (común) -->
            <div id="ref-gps-map" class="w-full h-44 rounded-lg overflow-hidden border border-canvas-soft bg-canvas"></div>
            
            <!-- Estatus de Ubicación -->
            <div id="ref-gps-status" class="text-[11px] text-mute font-uber-text italic">Obteniendo ubicación actual...</div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-capacidad">Capacidad Máxima *</label>
            <input 
              type="number" 
              id="ref-capacidad" 
              min="1"
              value="100"
              required
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-ocupacion">Población Total *</label>
            <input 
              type="number" 
              id="ref-ocupacion" 
              min="0"
              value="0"
              required
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
        </div>

        <div class="bg-canvas border border-canvas-soft p-4 rounded-xl space-y-3">
          <span class="text-xs font-semibold text-ink font-uber-text block">👥 Desglose de Población</span>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-ninos">Niños</label>
              <input type="number" id="ref-ninos" min="0" value="0" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-bebes-lactantes">Bebés Lactantes</label>
              <input type="number" id="ref-bebes-lactantes" min="0" value="0" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-adultos-mayores">Adultos Mayores</label>
              <input type="number" id="ref-adultos-mayores" min="0" value="0" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-personal-profesional">Personal Prof.</label>
              <input type="number" id="ref-personal-profesional" min="0" value="0" class="input w-full font-uber-text uber-body-md" />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-voluntarios">Voluntarios</label>
              <input type="number" id="ref-voluntarios" min="0" value="0" class="input w-full font-uber-text uber-body-md" />
            </div>
          </div>
          <div id="demografia-warning" class="hidden text-[11px] text-red-500 font-uber-text font-medium bg-red-500/5 p-2 rounded">
            ⚠️ La Población Total debe ser mayor o igual a la suma de los subgrupos.
          </div>
        </div>

        <div class="bg-canvas border border-canvas-soft p-4 rounded-xl space-y-4">
          <span class="text-xs font-semibold text-ink font-uber-text block">📋 Estado del Inventario (43 Ítems)</span>
          
          <div class="flex gap-1 overflow-x-auto pb-2 border-b border-canvas-soft scrollbar-none" id="tabs-container">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <button 
                type="button" 
                class={`tab-btn font-uber-text text-xs whitespace-nowrap px-3 py-1.5 rounded-lg border ${idx === 0 ? 'bg-primary text-white border-primary' : 'bg-canvas-soft text-ink border-transparent'} cursor-pointer`}
                data-target={`tab-${idx}`}
              >
                {cat.nombre}
              </button>
            ))}
          </div>

          <div class="tab-contents">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <div id={`tab-${idx}`} class={`tab-pane space-y-3 ${idx === 0 ? '' : 'hidden'}`}>
                {cat.items.map((item) => (
                  <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 py-2 border-b border-canvas-soft last:border-b-0">
                    <span class="text-xs font-uber-text text-ink font-medium md:max-w-[200px]">{item.nombre}</span>
                    <div class="flex gap-1 bg-canvas-soft p-1 rounded-xl w-full md:w-auto overflow-x-auto">
                      {["Crítico", "Alerta", "Estable", "Excedente"].map((est) => {
                        let activeClass = "";
                        if (est === "Crítico") activeClass = "has-[:checked]:bg-red-500 has-[:checked]:text-white";
                        else if (est === "Alerta") activeClass = "has-[:checked]:bg-amber-500 has-[:checked]:text-white";
                        else if (est === "Estable") activeClass = "has-[:checked]:bg-green-600 has-[:checked]:text-white";
                        else if (est === "Excedente") activeClass = "has-[:checked]:bg-blue-600 has-[:checked]:text-white";

                        return (
                          <label class={`flex-grow text-center py-1.5 px-3 text-[10px] rounded-lg cursor-pointer transition-all font-semibold font-uber-text select-none border border-transparent hover:bg-surface-pressed ${activeClass}`}>
                            <input 
                              type="radio" 
                              name={`inv-${item.id}`} 
                              value={est} 
                              class="hidden" 
                              defaultChecked={est === "Estable"} 
                            />
                            {est}
                          </label>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-necesidades">Necesidades de Insumos (Texto Libre)</label>
          <textarea 
            id="ref-necesidades" 
            rows="3" 
            class="textarea w-full font-uber-text uber-body-md" 
            placeholder="Ej: Colchonetas, agua potable, pañales, analgésicos..."
          ></textarea>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-contacto">Teléfono o Datos de Contacto *</label>
          <input 
            type="text" 
            id="ref-contacto" 
            required
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: 0414-7654321, email..."
          />
        </div>


        <div id="ref-error" class="hidden text-xs text-red-500 font-uber-text bg-red-500/5 border border-red-500/20 p-3 rounded-lg"></div>

        <button type="submit" id="btn-submit-ref" class="btn bg-primary text-white w-full font-uber-text font-semibold py-3 rounded-xl cursor-pointer">
          Registrar Centro
        </button>
      </form>
    </div>
  </main>
</Layout>

<!-- Leaflet para el mapa de coordenadas -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  let map: any = null;
  let marker: any = null;

  const latInput = document.getElementById("ref-latitud") as HTMLInputElement;
  const lonInput = document.getElementById("ref-longitud") as HTMLInputElement;
  const gpsStatus = document.getElementById("ref-gps-status");
  const btnGps = document.getElementById("btn-ref-gps");

  function initMap(lat: number, lon: number, zoom = 15) {
    if (typeof (window as any).L === "undefined") return;
    const L = (window as any).L;

    if (!map) {
      map = L.map("ref-gps-map", {
        zoomControl: true,
        attributionControl: false
      }).setView([lat, lon], zoom);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 18,
      }).addTo(map);

      map.on("click", (e: any) => {
        const clat = e.latlng.lat;
        const clon = e.latlng.lng;
        latInput.value = clat.toFixed(6);
        lonInput.value = clon.toFixed(6);
        
        if (marker) {
          marker.setLatLng(e.latlng);
        } else {
          marker = L.marker(e.latlng).addTo(map);
        }

        if (gpsStatus) {
          gpsStatus.textContent = `Ubicación marcada en mapa: ${clat.toFixed(5)}, ${clon.toFixed(5)}`;
          gpsStatus.className = "text-[11px] text-blue-600 font-uber-text italic font-medium";
        }
      });
    }

    if (marker) {
      marker.setLatLng([lat, lon]);
    } else {
      marker = L.marker([lat, lon]).addTo(map);
    }
    map.setView([lat, lon], zoom);
  }

  // Centrar inicialmente en Caracas
  initMap(10.4806, -66.9036, 12);

  async function obtenerUbicacion() {
    if (!gpsStatus || !latInput || !lonInput) return;
    gpsStatus.textContent = "Detectando ubicación GPS...";
    gpsStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";

    if (!navigator.geolocation) {
      gpsStatus.textContent = "Geolocalización no soportada por el navegador.";
      gpsStatus.className = "text-[11px] text-red-500 font-uber-text italic";
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        latInput.value = lat.toFixed(6);
        lonInput.value = lon.toFixed(6);
        gpsStatus.textContent = `Ubicación GPS obtenida: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
        gpsStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
        initMap(lat, lon, 15);
      },
      (error) => {
        let msg = "No se pudo obtener ubicación GPS.";
        if (error.code === error.PERMISSION_DENIED) {
          msg = "Permiso de geolocalización denegado.";
        }
        gpsStatus.textContent = msg;
        gpsStatus.className = "text-[11px] text-red-500 font-uber-text italic";
      },
      { timeout: 8000, enableHighAccuracy: true }
    );
  }

  btnGps?.addEventListener("click", obtenerUbicacion);

  // Buscar dirección con Nominatim OSM
  const btnBuscarDireccion = document.getElementById("btn-buscar-direccion");
  const direccionInput = document.getElementById("ref-direccion") as HTMLInputElement;

  btnBuscarDireccion?.addEventListener("click", async () => {
    const dir = direccionInput.value.trim();
    if (!dir) {
      alert("Por favor introduce una dirección primero.");
      return;
    }

    if (gpsStatus) {
      gpsStatus.textContent = "Buscando coordenadas de la dirección...";
      gpsStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
    }

    try {
      const queryUrl = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(dir + ", Venezuela")}&limit=1`;
      const resp = await fetch(queryUrl, {
        headers: { "Accept-Language": "es" }
      });
      if (resp.ok) {
        const results = await resp.json();
        if (results && results.length > 0) {
          const lat = parseFloat(results[0].lat);
          const lon = parseFloat(results[0].lon);
          latInput.value = lat.toFixed(6);
          lonInput.value = lon.toFixed(6);

          if (gpsStatus) {
            gpsStatus.textContent = `Dirección encontrada: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }

          initMap(lat, lon, 15);
        } else {
          if (gpsStatus) {
            gpsStatus.textContent = "No se encontraron coordenadas. Intenta ser más específico (ej: Caracas, Petare).";
            gpsStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      }
    } catch (err) {
      console.error(err);
      if (gpsStatus) {
        gpsStatus.textContent = "Error al consultar servicio de mapas.";
        gpsStatus.className = "text-[11px] text-red-500 font-uber-text italic";
      }
    }
  });

  // Lógica de Tabs de Ubicación
  const tabGps = document.getElementById("tab-loc-gps");
  const tabGmaps = document.getElementById("tab-loc-gmaps");
  const tabMap = document.getElementById("tab-loc-map");

  const panelGps = document.getElementById("panel-loc-gps");
  const panelGmaps = document.getElementById("panel-loc-gmaps");
  const panelMap = document.getElementById("panel-loc-map");

  function deseleccionarTabs() {
    [tabGps, tabGmaps, tabMap].forEach(tab => {
      tab?.classList.remove("bg-primary", "text-white");
      tab?.classList.add("bg-transparent", "text-ink");
    });
    [panelGps, panelGmaps, panelMap].forEach(panel => panel?.classList.add("hidden"));
  }

  tabGps?.addEventListener("click", () => {
    deseleccionarTabs();
    tabGps.classList.add("bg-primary", "text-white");
    tabGps.classList.remove("bg-transparent", "text-ink");
    panelGps?.classList.remove("hidden");
  });

  tabGmaps?.addEventListener("click", () => {
    deseleccionarTabs();
    tabGmaps.classList.add("bg-primary", "text-white");
    tabGmaps.classList.remove("bg-transparent", "text-ink");
    panelGmaps?.classList.remove("hidden");
  });

  tabMap?.addEventListener("click", () => {
    deseleccionarTabs();
    tabMap.classList.add("bg-primary", "text-white");
    tabMap.classList.remove("bg-transparent", "text-ink");
    panelMap?.classList.remove("hidden");
  });

  // Resolver link de Google Maps
  const btnResolverGmaps = document.getElementById("btn-resolver-gmaps");
  const inputGmaps = document.getElementById("ref-gmaps-link") as HTMLInputElement;

  btnResolverGmaps?.addEventListener("click", async () => {
    const url = inputGmaps.value.trim();
    if (!url) {
      alert("Por favor pega un enlace de Google Maps.");
      return;
    }

    if (gpsStatus) {
      gpsStatus.textContent = "Resolviendo enlace y extrayendo coordenadas...";
      gpsStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
    }

    try {
      const resp = await fetch("/api/maps/resolve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url })
      });

      if (resp.ok) {
        const data = await resp.json();
        latInput.value = data.lat.toFixed(6);
        lonInput.value = data.lng.toFixed(6);

        if (data.aproximado) {
          if (gpsStatus) {
            gpsStatus.textContent = `⚠️ Ubicación aproximada: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)} — Ajusta el pin tocando el mapa.`;
            gpsStatus.className = "text-[11px] text-amber-600 font-uber-text italic font-semibold";
          }
          initMap(data.lat, data.lng, 16);
        } else {
          if (gpsStatus) {
            gpsStatus.textContent = `Enlace resuelto: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
            gpsStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          initMap(data.lat, data.lng, 17);
        }
      } else {
        const err = await resp.json();
        if (gpsStatus) {
          gpsStatus.textContent = `Error: ${err.error || "No se pudieron extraer coordenadas."}`;
          gpsStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    } catch (err) {
      console.error(err);
      if (gpsStatus) {
        gpsStatus.textContent = "Error al conectar con la API de resolución.";
        gpsStatus.className = "text-[11px] text-red-500 font-uber-text italic";
      }
    }
  });

  // Intentar geolocalizar de inmediato
  obtenerUbicacion();



  // Pestañas de inventario
  const tabBtns = document.querySelectorAll(".tab-btn");
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      tabBtns.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "border-primary");
        b.classList.add("bg-canvas-soft", "text-ink", "border-transparent");
      });
      btn.classList.add("bg-primary", "text-white", "border-primary");
      btn.classList.remove("bg-canvas-soft", "text-ink", "border-transparent");

      document.querySelectorAll(".tab-pane").forEach((pane) => pane.classList.add("hidden"));
      const targetId = btn.getAttribute("data-target");
      if (targetId) {
        document.getElementById(targetId)?.classList.remove("hidden");
      }
    });
  });

  // Form submit
  const form = document.getElementById("form-nuevo-refugio") as HTMLFormElement;
  const errorDiv = document.getElementById("ref-error");
  const btnSubmit = document.getElementById("btn-submit-ref") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const tipo = (document.getElementById("ref-tipo") as HTMLSelectElement).value;
    const nombre = (document.getElementById("ref-nombre") as HTMLInputElement).value.trim();
    const encargado = (document.getElementById("ref-encargado") as HTMLInputElement).value.trim();
    const direccion = (document.getElementById("ref-direccion") as HTMLInputElement).value.trim();
    const capacidad = parseInt((document.getElementById("ref-capacidad") as HTMLInputElement).value) || 0;
    const ocupacion = parseInt((document.getElementById("ref-ocupacion") as HTMLInputElement).value) || 0;
    const necesidades = (document.getElementById("ref-necesidades") as HTMLTextAreaElement).value.trim();
    const contacto = (document.getElementById("ref-contacto") as HTMLInputElement).value.trim();
    const lat = latInput.value;
    const lon = lonInput.value;

    const ninos = parseInt((document.getElementById("ref-ninos") as HTMLInputElement).value) || 0;
    const bebes = parseInt((document.getElementById("ref-bebes-lactantes") as HTMLInputElement).value) || 0;
    const mayores = parseInt((document.getElementById("ref-adultos-mayores") as HTMLInputElement).value) || 0;
    const prof = parseInt((document.getElementById("ref-personal-profesional") as HTMLInputElement).value) || 0;
    const vols = parseInt((document.getElementById("ref-voluntarios") as HTMLInputElement).value) || 0;

    const sumaSubgrupos = ninos + bebes + mayores + prof + vols;
    const demografiaWarning = document.getElementById("demografia-warning");

    if (ocupacion < sumaSubgrupos) {
      if (demografiaWarning) demografiaWarning.classList.remove("hidden");
      if (errorDiv) {
        errorDiv.textContent = "Error: La Población Total no puede ser menor a la suma de niños, bebés, adultos mayores, profesionales y voluntarios.";
        errorDiv.classList.remove("hidden");
      }
      return;
    } else {
      if (demografiaWarning) demografiaWarning.classList.add("hidden");
    }

    if (!lat || !lon) {
      if (errorDiv) {
        errorDiv.textContent = "Debes marcar la ubicación del refugio en el mapa o usar detección GPS.";
        errorDiv.classList.remove("hidden");
      }
      return;
    }

    if (errorDiv) errorDiv.classList.add("hidden");
    
    if (btnSubmit) {
      btnSubmit.disabled = true;
      btnSubmit.textContent = "Registrando...";
    }

    // Recopilar inventario
    const inventario: Record<string, string> = {};
    const radios = form.querySelectorAll('input[type="radio"]:checked');
    radios.forEach((radio: any) => {
      if (radio.name.startsWith("inv-")) {
        const itemId = radio.name.replace("inv-", "");
        inventario[itemId] = radio.value;
      }
    });

    try {
      const resp = await fetch("/api/refugios", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          nombre,
          direccion,
          capacidad_maxima: capacidad,
          ocupacion_actual: ocupacion,
          necesidades,
          contacto,
          latitud: lat,
          longitud: lon,
          tipo,
          encargado,
          ninos,
          bebes_lactantes: bebes,
          adultos_mayores: mayores,
          personal_profesional: prof,
          voluntarios: vols,
          inventario
        })
      });

      if (resp.ok) {
        window.location.href = "/refugios";
      } else {
        const err = await resp.json();
        if (errorDiv) {
          errorDiv.textContent = `Error: ${err.error || "no se pudo registrar el centro."}`;
          errorDiv.classList.remove("hidden");
        }
        if (btnSubmit) {
          btnSubmit.disabled = false;
          btnSubmit.textContent = "Registrar Centro";
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = "Error de conexión con el servidor.";
        errorDiv.classList.remove("hidden");
      }
      if (btnSubmit) {
        btnSubmit.disabled = false;
        btnSubmit.textContent = "Registrar Centro";
      }
    }
  });
</script>
