---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

export const prerender = false;
---

<Layout title="Registrar Refugio / Centro de Acopio - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-canvas max-w-lg mx-auto w-full">
    <div class="space-y-6">
      <div>
        <a href="/refugios" class="text-xs text-primary hover:underline font-semibold font-uber-text">
          ← Volver al listado
        </a>
        <h1 class="font-uber-display text-2xl sm:text-3xl text-ink tracking-tight mt-2">
          Registrar Albergue / Acopio
        </h1>
        <p class="text-xs text-body font-uber-text mt-1">
          Añade un nuevo refugio voluntario o formal para geolocalizarlo e indicar sus necesidades.
        </p>
      </div>

      <form id="form-nuevo-refugio" class="space-y-4 bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm">
        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-nombre">Nombre del Refugio / Acopio *</label>
          <input 
            type="text" 
            id="ref-nombre" 
            required 
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: Escuela Bolivariana Petare"
          />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-direccion">Dirección / Sector *</label>
          <div class="flex gap-2">
            <input 
              type="text" 
              id="ref-direccion" 
              required 
              class="input flex-grow font-uber-text uber-body-md" 
              placeholder="Ej: Sector La Lucha, Caracas"
            />
            <button type="button" id="btn-buscar-direccion" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed border border-canvas-soft font-uber-text font-semibold px-3 py-2 rounded-xl text-xs shrink-0 cursor-pointer">
              📍 Ubicar en mapa
            </button>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-capacidad">Capacidad Máxima</label>
            <input 
              type="number" 
              id="ref-capacidad" 
              min="1"
              value="100"
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-ocupacion">Ocupación Actual</label>
            <input 
              type="number" 
              id="ref-ocupacion" 
              min="0"
              value="0"
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-necesidades">Necesidades de Insumos / Medicamentos</label>
          <textarea 
            id="ref-necesidades" 
            rows="3" 
            class="textarea w-full font-uber-text uber-body-md" 
            placeholder="Ej: Colchonetas, agua potable, pañales, analgésicos..."
          ></textarea>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="ref-contacto">Teléfono o Datos de Contacto</label>
          <input 
            type="text" 
            id="ref-contacto" 
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: 0414-7654321, email..."
          />
        </div>

        <!-- Coordenadas GPS y Mapa -->
        <div class="p-4 bg-canvas-soft rounded-xl flex flex-col gap-2 border border-canvas-soft">
          <div class="flex justify-between items-center">
            <span class="text-xs font-semibold text-ink font-uber-text">📍 Ubicación en Mapa GPS *</span>
            <button id="btn-ref-gps" type="button" class="btn btn-xs bg-primary text-white font-uber-text px-2 py-0.5 rounded text-[11px] cursor-pointer">
              Detectar GPS
            </button>
          </div>
          <div id="ref-gps-status" class="text-xs text-mute font-uber-text italic">Marque una ubicación en el mapa haciendo click, o use la detección GPS automática.</div>
          
          <input type="hidden" id="ref-latitud" />
          <input type="hidden" id="ref-longitud" />
          
          <div id="ref-gps-map" class="w-full h-48 rounded-lg overflow-hidden border border-canvas-soft bg-canvas mt-2"></div>
        </div>

        <div id="ref-error" class="hidden text-xs text-red-500 font-uber-text bg-red-500/5 border border-red-500/20 p-3 rounded-lg"></div>

        <button type="submit" id="btn-submit-ref" class="btn bg-primary text-white w-full font-uber-text font-semibold py-3 rounded-xl cursor-pointer">
          Registrar Refugio
        </button>
      </form>
    </div>
  </main>
</Layout>

<!-- Leaflet para el mapa de coordenadas -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  let map: any = null;
  let marker: any = null;

  const latInput = document.getElementById("ref-latitud") as HTMLInputElement;
  const lonInput = document.getElementById("ref-longitud") as HTMLInputElement;
  const gpsStatus = document.getElementById("ref-gps-status");
  const btnGps = document.getElementById("btn-ref-gps");

  function initMap(lat: number, lon: number, zoom = 15) {
    if (typeof (window as any).L === "undefined") return;
    const L = (window as any).L;

    if (!map) {
      map = L.map("ref-gps-map", {
        zoomControl: true,
        attributionControl: false
      }).setView([lat, lon], zoom);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 18,
      }).addTo(map);

      map.on("click", (e: any) => {
        const clat = e.latlng.lat;
        const clon = e.latlng.lng;
        latInput.value = clat.toFixed(6);
        lonInput.value = clon.toFixed(6);
        
        if (marker) {
          marker.setLatLng(e.latlng);
        } else {
          marker = L.marker(e.latlng).addTo(map);
        }

        if (gpsStatus) {
          gpsStatus.textContent = `Ubicación marcada: ${clat.toFixed(5)}, ${clon.toFixed(5)}`;
          gpsStatus.className = "text-xs text-blue-600 font-uber-text italic font-medium";
        }
      });
    }

    if (marker) {
      marker.setLatLng([lat, lon]);
    } else {
      marker = L.marker([lat, lon]).addTo(map);
    }
    map.setView([lat, lon], zoom);
  }

  // Centrar inicialmente en Caracas
  initMap(10.4806, -66.9036, 12);

  async function obtenerUbicacion() {
    if (!gpsStatus || !latInput || !lonInput) return;
    gpsStatus.textContent = "Detectando ubicación GPS...";
    gpsStatus.className = "text-xs text-yellow-600 font-uber-text italic font-medium";

    if (!navigator.geolocation) {
      gpsStatus.textContent = "Geolocalización no soportada por el navegador.";
      gpsStatus.className = "text-xs text-red-500 font-uber-text italic";
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        latInput.value = lat.toFixed(6);
        lonInput.value = lon.toFixed(6);
        gpsStatus.textContent = `Ubicación obtenida: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
        gpsStatus.className = "text-xs text-success font-uber-text italic font-semibold";
        initMap(lat, lon, 15);
      },
      (error) => {
        let msg = "No se pudo obtener ubicación GPS.";
        if (error.code === error.PERMISSION_DENIED) {
          msg = "Permiso de geolocalización denegado.";
        }
        gpsStatus.textContent = msg;
        gpsStatus.className = "text-xs text-red-500 font-uber-text italic";
      },
      { timeout: 8000, enableHighAccuracy: true }
    );
  }

  btnGps?.addEventListener("click", obtenerUbicacion);

  // Buscar dirección con Nominatim OSM
  const btnBuscarDireccion = document.getElementById("btn-buscar-direccion");
  const direccionInput = document.getElementById("ref-direccion") as HTMLInputElement;

  btnBuscarDireccion?.addEventListener("click", async () => {
    const dir = direccionInput.value.trim();
    if (!dir) {
      alert("Por favor introduce una dirección primero.");
      return;
    }

    if (gpsStatus) {
      gpsStatus.textContent = "Buscando coordenadas de la dirección...";
      gpsStatus.className = "text-xs text-yellow-600 font-uber-text italic font-medium";
    }

    try {
      const queryUrl = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(dir + ", Venezuela")}&limit=1`;
      const resp = await fetch(queryUrl, {
        headers: { "Accept-Language": "es" }
      });
      if (resp.ok) {
        const results = await resp.json();
        if (results && results.length > 0) {
          const lat = parseFloat(results[0].lat);
          const lon = parseFloat(results[0].lon);
          latInput.value = lat.toFixed(6);
          lonInput.value = lon.toFixed(6);

          if (gpsStatus) {
            gpsStatus.textContent = `Ubicación encontrada: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsStatus.className = "text-xs text-success font-uber-text italic font-semibold";
          }

          initMap(lat, lon, 15);
        } else {
          if (gpsStatus) {
            gpsStatus.textContent = "No se encontraron coordenadas. Intenta ser más específico (ej: Caracas, Petare).";
            gpsStatus.className = "text-xs text-red-500 font-uber-text italic";
          }
        }
      }
    } catch (err) {
      console.error(err);
      if (gpsStatus) {
        gpsStatus.textContent = "Error al consultar servicio de mapas.";
        gpsStatus.className = "text-xs text-red-500 font-uber-text italic";
      }
    }
  });

  // Intentar geolocalizar de inmediato
  obtenerUbicacion();

  // Form submit
  const form = document.getElementById("form-nuevo-refugio") as HTMLFormElement;
  const errorDiv = document.getElementById("ref-error");
  const btnSubmit = document.getElementById("btn-submit-ref") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const nombre = (document.getElementById("ref-nombre") as HTMLInputElement).value.trim();
    const direccion = (document.getElementById("ref-direccion") as HTMLInputElement).value.trim();
    const capacidad = parseInt((document.getElementById("ref-capacidad") as HTMLInputElement).value);
    const ocupacion = parseInt((document.getElementById("ref-ocupacion") as HTMLInputElement).value);
    const necesidades = (document.getElementById("ref-necesidades") as HTMLTextAreaElement).value.trim();
    const contacto = (document.getElementById("ref-contacto") as HTMLInputElement).value.trim();
    const lat = latInput.value;
    const lon = lonInput.value;

    if (!lat || !lon) {
      if (errorDiv) {
        errorDiv.textContent = "Debes marcar la ubicación del refugio en el mapa o usar detección GPS.";
        errorDiv.classList.remove("hidden");
      }
      return;
    }

    if (errorDiv) errorDiv.classList.add("hidden");
    
    if (btnSubmit) {
      btnSubmit.disabled = true;
      btnSubmit.textContent = "Registrando...";
    }

    try {
      const resp = await fetch("/api/refugios", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          nombre,
          direccion,
          capacidad_maxima: capacidad,
          ocupacion_actual: ocupacion,
          necesidades,
          contacto,
          latitud: lat,
          longitud: lon
        })
      });

      if (resp.ok) {
        window.location.href = "/refugios";
      } else {
        const err = await resp.json();
        if (errorDiv) {
          errorDiv.textContent = `Error: ${err.error || "no se pudo registrar el refugio."}`;
          errorDiv.classList.remove("hidden");
        }
        if (btnSubmit) {
          btnSubmit.disabled = false;
          btnSubmit.textContent = "Registrar Refugio";
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = "Error de conexión con el servidor.";
        errorDiv.classList.remove("hidden");
      }
      if (btnSubmit) {
        btnSubmit.disabled = false;
        btnSubmit.textContent = "Registrar Refugio";
      }
    }
  });
</script>
