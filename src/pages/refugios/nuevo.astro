---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { CATEGORIAS_INVENTARIO, TOTAL_ITEMS } from "../../lib/items";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../../lib/auth-helpers";

export const prerender = false;

// Proteger ruta
const sessionToken = Astro.cookies.get("session_token")?.value;
const { DB } = env;
const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
if (!voluntario) {
  return Astro.redirect("/ayudar");
}
---

<Layout title="Registrar Refugio / Centro de Acopio - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-base-200 min-h-screen">
    <div class="max-w-lg mx-auto w-full space-y-6">
      <div>
        <a href="/" class="text-xs link link-primary font-semibold">
          ← Volver al listado
        </a>
        <h1 class="text-3xl font-black text-base-content tracking-tight mt-2">
          Registrar Albergue / Acopio
        </h1>
        <p class="text-xs text-base-content/70 mt-1">
          Añade un nuevo refugio voluntario o formal para geolocalizarlo e indicar sus necesidades.
        </p>
      </div>

      <form id="form-nuevo-refugio" class="space-y-4 card bg-base-100 border border-base-200 p-6 shadow-sm">
        <div class="form-control">
          <label class="label" for="ref-tipo">
            <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Tipo de Centro *</span>
          </label>
          <select id="ref-tipo" required class="select select-bordered w-full">
            <option value="refugio" selected>Refugio / Albergue</option>
            <option value="centro_acopio">Centro de Acopio</option>
            <option value="hospital">Hospital / Puesto de Salud</option>
          </select>
        </div>

        <div class="form-control">
          <label class="label" for="ref-nombre">
            <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Nombre del Centro *</span>
          </label>
          <input 
            type="text" 
            id="ref-nombre" 
            required 
            class="input input-bordered w-full" 
            placeholder="Ej: Escuela Bolivariana Petare"
          />
        </div>

        <div class="form-control">
          <label class="label" for="ref-encargado">
            <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Encargado *</span>
          </label>
          <input 
            type="text" 
            id="ref-encargado" 
            required
            class="input input-bordered w-full" 
            placeholder="Nombre del encargado"
          />
        </div>

        <div class="form-control">
          <label class="label" for="ref-direccion">
            <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Dirección / Sector *</span>
          </label>
          <div class="flex gap-2">
            <input 
              type="text" 
              id="ref-direccion" 
              required 
              class="input input-bordered flex-grow" 
              placeholder="Ej: Sector La Lucha, Caracas"
            />
            <button type="button" id="btn-buscar-direccion" class="btn btn-outline">
              📍 Ubicar
            </button>
          </div>
        </div>

        <!-- Bloque de ubicación integrado -->
        <div class="p-4 bg-base-200 rounded-2xl flex flex-col gap-3 border border-base-300">
          <span class="text-[10px] font-bold text-base-content/50 uppercase tracking-wider">📍 Método de Ubicación GPS *</span>
          
          <!-- Tabs de selección de método -->
          <div class="tabs tabs-boxed justify-center p-1 bg-base-300">
            <button type="button" id="tab-loc-gps" class="tab tab-active flex-grow font-semibold text-xs border-none">
              GPS Móvil
            </button>
            <button type="button" id="tab-loc-gmaps" class="tab flex-grow font-semibold text-xs border-none">
              Pegar Enlace
            </button>
            <button type="button" id="tab-loc-map" class="tab flex-grow font-semibold text-xs border-none">
              Mapa Manual
            </button>
          </div>

          <!-- Inputs ocultos para lat/lng -->
          <input type="hidden" id="ref-latitud" />
          <input type="hidden" id="ref-longitud" />

          <!-- Panel 1: GPS Móvil -->
          <div id="panel-loc-gps" class="flex items-center justify-between gap-2">
            <span class="text-[10px] text-base-content/75">Usa el GPS del celular para geolocalizar de inmediato.</span>
            <button id="btn-ref-gps" type="button" class="btn btn-xs btn-primary">
              Detectar GPS
            </button>
          </div>

          <!-- Panel 2: Pegar Enlace -->
          <div id="panel-loc-gmaps" class="space-y-2 hidden">
            <div class="flex gap-2">
              <input 
                type="url" 
                id="ref-gmaps-link" 
                class="input input-bordered input-sm flex-grow" 
                placeholder="Pegar enlace de Google Maps..."
              />
              <button type="button" id="btn-resolver-gmaps" class="btn btn-xs btn-primary">
                Extraer
              </button>
            </div>
          </div>

          <!-- Panel 3: Mapa Manual -->
          <div id="panel-loc-map" class="text-[10px] text-base-content/50 italic hidden">
            Toca el mapa abajo para ajustar el marcador manualmente.
          </div>

          <!-- Contenedor del mapa (común) -->
          <div id="ref-gps-map" class="w-full h-44 rounded-xl overflow-hidden border border-base-300 bg-base-100"></div>
          
          <!-- Tarjeta de Info de Google Places (oculta por defecto) -->
          <div id="google-place-info" class="hidden mt-2 p-3 rounded-xl border border-blue-200 bg-gradient-to-br from-blue-50/80 to-indigo-50/60 space-y-2">
            <div class="flex items-center gap-1.5 text-[11px] font-bold text-blue-700 uppercase tracking-wider">
              <span>📍</span> Datos del lugar (Google)
            </div>
            <div id="gpi-content" class="grid gap-1.5 text-[11px] text-base-content">
              <!-- Se llena dinámicamente -->
            </div>
          </div>

          <!-- Estatus de Ubicación -->
          <div id="ref-gps-status" class="text-[11px] text-base-content/50 italic">Obteniendo ubicación actual...</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="form-control">
            <label class="label" for="ref-capacidad">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Capacidad Máxima *</span>
            </label>
            <input 
              type="number" 
              id="ref-capacidad" 
              min="1"
              value="100"
              required
              class="input input-bordered w-full" 
            />
          </div>
          <div class="form-control">
            <label class="label" for="ref-ocupacion">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Población Total *</span>
            </label>
            <input 
              type="number" 
              id="ref-ocupacion" 
              min="0"
              value="0"
              required
              class="input input-bordered w-full" 
            />
          </div>
        </div>

        <div class="bg-base-200 p-4 rounded-xl border border-base-300 space-y-3">
          <span class="text-xs font-bold text-base-content block">👥 Desglose de Población</span>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <div class="form-control">
              <label class="label" for="ref-ninos">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Niños</span>
              </label>
              <input type="number" id="ref-ninos" min="0" value="0" class="input input-bordered w-full bg-base-100" />
            </div>
            <div class="form-control">
              <label class="label" for="ref-bebes-lactantes">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Bebés Lactantes</span>
              </label>
              <input type="number" id="ref-bebes-lactantes" min="0" value="0" class="input input-bordered w-full bg-base-100" />
            </div>
            <div class="form-control">
              <label class="label" for="ref-adultos-mayores">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Adultos Mayores</span>
              </label>
              <input type="number" id="ref-adultos-mayores" min="0" value="0" class="input input-bordered w-full bg-base-100" />
            </div>
            <div class="form-control">
              <label class="label" for="ref-personal-profesional">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Personal Prof.</span>
              </label>
              <input type="number" id="ref-personal-profesional" min="0" value="0" class="input input-bordered w-full bg-base-100" />
            </div>
            <div class="form-control">
              <label class="label" for="ref-voluntarios">
                <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Voluntarios</span>
              </label>
              <input type="number" id="ref-voluntarios" min="0" value="0" class="input input-bordered w-full bg-base-100" />
            </div>
          </div>
          <div id="demografia-warning" class="hidden alert alert-error text-xs p-2.5 shadow-sm mt-2">
            <span>⚠️ La Población Total debe ser mayor o igual a la suma de los subgrupos.</span>
          </div>
        </div>

        <div class="bg-base-200 p-4 rounded-xl border border-base-300 space-y-4">
          <span class="text-xs font-bold text-base-content block">📋 Estado del Inventario ({TOTAL_ITEMS} Ítems)</span>
          
          <div class="tabs tabs-boxed gap-1 overflow-x-auto pb-2 border-b border-base-300" id="tabs-container">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <button 
                type="button" 
                class={`tab tab-btn tab-sm font-semibold whitespace-nowrap ${idx === 0 ? 'tab-active' : ''}`}
                data-target={`tab-${idx}`}
              >
                {cat.nombre}
              </button>
            ))}
          </div>

          <div class="tab-contents">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <div id={`tab-${idx}`} class={`tab-pane space-y-3 ${idx === 0 ? '' : 'hidden'}`}>
                {cat.items.map((item) => (
                  <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 py-2 border-b border-base-300 last:border-b-0">
                    <span class="text-xs text-base-content font-semibold md:max-w-[200px]">
                      {item.nombre}
                      {item.unidad_medida && <span class="text-[10px] text-base-content/50 ml-1 font-normal">({item.unidad_medida})</span>}
                      {item.es_critico && <span class="text-[10px] text-error font-bold ml-1" title="Insumo Crítico">⚠️</span>}
                    </span>
                    <div class="flex gap-1 bg-base-300 p-1 rounded-xl w-full md:w-auto overflow-x-auto">
                      {["Crítico", "Alerta", "Estable", "Excedente"].map((est) => {
                        let activeClass = "";
                        if (est === "Crítico") activeClass = "has-[:checked]:bg-error has-[:checked]:text-error-content";
                        else if (est === "Alerta") activeClass = "has-[:checked]:bg-warning has-[:checked]:text-warning-content";
                        else if (est === "Estable") activeClass = "has-[:checked]:bg-success has-[:checked]:text-success-content";
                        else if (est === "Excedente") activeClass = "has-[:checked]:bg-info has-[:checked]:text-info-content";

                        return (
                          <label class={`flex-grow text-center py-1.5 px-3 text-[10px] rounded-lg cursor-pointer transition-all font-semibold select-none border border-transparent hover:bg-base-200/50 ${activeClass}`}>
                            <input 
                              type="radio" 
                              name={`inv-${item.id}`} 
                              value={est} 
                              class="hidden" 
                              defaultChecked={est === "Estable"} 
                            />
                            {est}
                          </label>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div class="form-control">
          <label class="label" for="ref-necesidades">
            <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Necesidades de Insumos (Texto Libre)</span>
          </label>
          <textarea 
            id="ref-necesidades" 
            rows="3" 
            class="textarea textarea-bordered w-full" 
            placeholder="Ej: Colchonetas, agua potable, pañales, analgésicos..."
          ></textarea>
        </div>

        <div class="form-control">
          <label class="label" for="ref-contacto">
            <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Teléfono o Datos de Contacto *</span>
          </label>
          <input 
            type="text" 
            id="ref-contacto" 
            required
            class="input input-bordered w-full" 
            placeholder="Ej: 0414-7654321, email..."
          />
        </div>

        <div class="bg-base-200 p-4 rounded-xl border border-base-300 space-y-3">
          <span class="text-xs font-bold text-base-content block">📸 Fotos del Centro (Máximo 3)</span>
          <div class="flex flex-col gap-2">
            <input 
              type="file" 
              id="ref-fotos" 
              multiple 
              accept="image/*" 
              class="file-input file-input-bordered file-input-sm w-full"
            />
            <div id="preview-fotos" class="grid grid-cols-3 gap-2 mt-2">
              <!-- Previsualizaciones de imágenes -->
            </div>
          </div>
        </div>

        <div id="ref-error" class="hidden alert alert-error text-xs p-3 shadow-sm"></div>

        <button type="submit" id="btn-submit-ref" class="btn btn-primary w-full mt-4">
          Registrar Centro
        </button>
      </form>
    </div>
  </main>
</Layout>

<!-- Leaflet para el mapa de coordenadas -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  let map: any = null;
  let marker: any = null;

  document.addEventListener('astro:page-load', () => {
    // Limpieza de mapa previo
    if (map) {
      try { map.remove(); } catch (e) {}
      map = null;
    }
    marker = null;

    const latInput = document.getElementById("ref-latitud") as HTMLInputElement;
    const lonInput = document.getElementById("ref-longitud") as HTMLInputElement;
    const gpsStatus = document.getElementById("ref-gps-status");
    const btnGps = document.getElementById("btn-ref-gps");

  /**
   * Mostrar tarjeta de info de Google Places con todos los datos enriquecidos.
   */
  function mostrarInfoGoogle(data: any) {
    const container = document.getElementById("google-place-info");
    const content = document.getElementById("gpi-content");
    if (!container || !content) return;

    const items: string[] = [];

    if (data.name) {
      items.push(`<div class="flex items-center gap-1"><span class="font-semibold text-base-content">🏛️ ${data.name}</span></div>`);
    }

    // Estado operativo
    if (data.estado_operativo || data.estado_label) {
      const label = data.estado_label || data.estado || data.estado_operativo;
      const isOpen = data.estado_operativo === "OPERATIONAL";
      const isClosed = data.estado_operativo?.includes("CLOSED");
      const color = isOpen ? "text-success bg-success/15" : isClosed ? "text-error bg-error/15" : "text-base-content/70 bg-base-300";
      items.push(`<div><span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold ${color}">${isOpen ? "🟢" : isClosed ? "🔴" : "⚪"} ${label}</span></div>`);
    }

    // Abierto ahora
    if (data.abierto_ahora !== undefined) {
      const badge = data.abierto_ahora 
        ? '<span class="text-success font-semibold">✅ Abierto ahora</span>'
        : '<span class="text-warning font-semibold">🚫 Cerrado ahora</span>';
      items.push(`<div>${badge}</div>`);
    }

    // Accesibilidad
    if (data.accesible !== undefined) {
      items.push(`<div>${data.accesible ? "♿ Acceso para silla de ruedas" : "⚠️ Sin acceso confirmado para silla de ruedas"}</div>`);
    }

    // Horario
    if (data.horario && data.horario.length > 0) {
      const horarioHtml = data.horario.map((h: string) => `<div class="pl-3 text-[10px]">${h}</div>`).join("");
      items.push(`<details class="cursor-pointer"><summary class="font-semibold text-base-content">🕐 Horario</summary><div class="mt-1 space-y-0.5">${horarioHtml}</div></details>`);
    }

    // Teléfono
    if (data.phone_international || data.phone) {
      const tel = data.phone_international || data.phone;
      items.push(`<div>📞 <a href="tel:${tel.replace(/\s/g, '')}" class="text-primary underline font-semibold">${tel}</a></div>`);
    }

    // Website
    if (data.website) {
      const domain = data.website.replace(/^https?:\/\//, "").replace(/\/$/, "").substring(0, 40);
      items.push(`<div>🌐 <a href="${data.website}" target="_blank" rel="noopener" class="text-primary underline">${domain}</a></div>`);
    }

    // Google Maps URL
    if (data.google_maps_url) {
      items.push(`<div>🗺️ <a href="${data.google_maps_url}" target="_blank" rel="noopener" class="text-primary underline">Ver en Google Maps</a></div>`);
    }

    // Estado / Municipio
    if (data.estado || data.municipio) {
      const parts = [data.municipio, data.estado].filter(Boolean);
      items.push(`<div>📌 ${parts.join(", ")}</div>`);
    }

    if (items.length > 0) {
      content.innerHTML = items.join("");
      container.classList.remove("hidden");
    } else {
      container.classList.add("hidden");
    }
  }

  function initMap(lat: number, lon: number, zoom = 15) {
    if (typeof (window as any).L === "undefined") return;
    const L = (window as any).L;

    if (!map) {
      map = L.map("ref-gps-map", {
        zoomControl: true,
        attributionControl: false
      }).setView([lat, lon], zoom);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 18,
      }).addTo(map);

      map.on("click", (e: any) => {
        const clat = e.latlng.lat;
        const clon = e.latlng.lng;
        latInput.value = clat.toFixed(6);
        lonInput.value = clon.toFixed(6);
        
        if (marker) {
          marker.setLatLng(e.latlng);
        } else {
          marker = L.marker(e.latlng).addTo(map);
        }

        if (gpsStatus) {
          gpsStatus.textContent = `Ubicación marcada en mapa: ${clat.toFixed(5)}, ${clon.toFixed(5)}`;
          gpsStatus.className = "text-[11px] text-info font-uber-text italic font-medium";
        }
      });
    }

    if (marker) {
      marker.setLatLng([lat, lon]);
    } else {
      marker = L.marker([lat, lon]).addTo(map);
    }
    map.setView([lat, lon], zoom);

    setTimeout(() => {
      if (map) map.invalidateSize();
    }, 200);
  }

  // Centrar inicialmente en Caracas
  initMap(10.4806, -66.9036, 12);

  async function obtenerUbicacion() {
    if (!gpsStatus || !latInput || !lonInput) return;
    gpsStatus.textContent = "Detectando ubicación GPS...";
    gpsStatus.className = "text-[11px] text-warning font-uber-text italic font-medium";

    if (!navigator.geolocation) {
      gpsStatus.textContent = "Geolocalización no soportada por el navegador.";
      gpsStatus.className = "text-[11px] text-error font-uber-text italic";
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        latInput.value = lat.toFixed(6);
        lonInput.value = lon.toFixed(6);
        gpsStatus.textContent = `Ubicación GPS obtenida: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
        gpsStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
        initMap(lat, lon, 15);
      },
      (error) => {
        let msg = "No se pudo obtener ubicación GPS.";
        if (error.code === error.PERMISSION_DENIED) {
          msg = "Permiso de geolocalización denegado.";
        }
        gpsStatus.textContent = msg;
        gpsStatus.className = "text-[11px] text-error font-uber-text italic";
      },
      { timeout: 8000, enableHighAccuracy: true }
    );
  }

  btnGps?.addEventListener("click", obtenerUbicacion);

  // Buscar dirección con Nominatim OSM
  const btnBuscarDireccion = document.getElementById("btn-buscar-direccion");
  const direccionInput = document.getElementById("ref-direccion") as HTMLInputElement;

  btnBuscarDireccion?.addEventListener("click", async () => {
    const dir = direccionInput.value.trim();
    if (!dir) {
      alert("Por favor introduce una dirección primero.");
      return;
    }

    if (gpsStatus) {
      gpsStatus.textContent = "Buscando coordenadas de la dirección...";
      gpsStatus.className = "text-[11px] text-warning font-uber-text italic font-medium";
    }

    try {
      const queryUrl = `/api/maps/geocode?address=${encodeURIComponent(dir)}`;
      const resp = await fetch(queryUrl);
      if (resp.ok) {
        const data = await resp.json() as any;
        const lat = data.lat;
        const lon = data.lng;
        latInput.value = lat.toFixed(6);
        lonInput.value = lon.toFixed(6);

        if (gpsStatus) {
          gpsStatus.textContent = `Dirección encontrada: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
          gpsStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
        }

        // Autorrellenar datos enriquecidos de Google
        if (data.formatted_address) direccionInput.value = data.formatted_address;
        
        if (data.name) {
          const inputNombre = document.getElementById("ref-nombre") as HTMLInputElement;
          if (inputNombre && !inputNombre.value) inputNombre.value = data.name;
        }
        if (data.phone) {
          const inputContact = document.getElementById("ref-contacto") as HTMLInputElement;
          if (inputContact && !inputContact.value) inputContact.value = data.phone;
        }
        if (data.tipo) {
          const selectTipo = document.getElementById("ref-tipo") as HTMLSelectElement;
          if (selectTipo && selectTipo.value === "refugio") selectTipo.value = data.tipo;
        }

        // Mostrar tarjeta con toda la info de Google Places
        mostrarInfoGoogle(data);

        initMap(lat, lon, 15);
      } else {
        if (gpsStatus) {
          gpsStatus.textContent = "No se encontraron coordenadas. Intenta con un sector más específico.";
          gpsStatus.className = "text-[11px] text-error font-uber-text italic";
        }
      }
    } catch (err) {
      console.error(err);
      if (gpsStatus) {
        gpsStatus.textContent = "Error al consultar servicio de mapas.";
        gpsStatus.className = "text-[11px] text-error font-uber-text italic";
      }
    }
  });

  // Lógica de Tabs de Ubicación
  const tabGps = document.getElementById("tab-loc-gps");
  const tabGmaps = document.getElementById("tab-loc-gmaps");
  const tabMap = document.getElementById("tab-loc-map");

  const panelGps = document.getElementById("panel-loc-gps");
  const panelGmaps = document.getElementById("panel-loc-gmaps");
  const panelMap = document.getElementById("panel-loc-map");

  function deseleccionarTabs() {
    [tabGps, tabGmaps, tabMap].forEach(tab => {
      tab?.classList.remove("tab-active");
    });
    [panelGps, panelGmaps, panelMap].forEach(panel => panel?.classList.add("hidden"));
  }

  tabGps?.addEventListener("click", () => {
    deseleccionarTabs();
    tabGps.classList.add("tab-active");
    panelGps?.classList.remove("hidden");
    setTimeout(() => { if (map) map.invalidateSize(); }, 150);
  });

  tabGmaps?.addEventListener("click", () => {
    deseleccionarTabs();
    tabGmaps.classList.add("tab-active");
    panelGmaps?.classList.remove("hidden");
    setTimeout(() => { if (map) map.invalidateSize(); }, 150);
  });

  tabMap?.addEventListener("click", () => {
    deseleccionarTabs();
    tabMap.classList.add("tab-active");
    panelMap?.classList.remove("hidden");
    setTimeout(() => { if (map) map.invalidateSize(); }, 150);
  });

  // Resolver link de Google Maps
  const btnResolverGmaps = document.getElementById("btn-resolver-gmaps");
  const inputGmaps = document.getElementById("ref-gmaps-link") as HTMLInputElement;

  btnResolverGmaps?.addEventListener("click", async () => {
    const url = inputGmaps.value.trim();
    if (!url) {
      alert("Por favor pega un enlace de Google Maps.");
      return;
    }

    if (gpsStatus) {
      gpsStatus.textContent = "Resolviendo enlace y extrayendo coordenadas...";
      gpsStatus.className = "text-[11px] text-warning font-uber-text italic font-medium";
    }

    try {
      const resp = await fetch("/api/maps/resolve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url })
      });

      if (resp.ok) {
        const data = await resp.json() as any;
        latInput.value = data.lat.toFixed(6);
        lonInput.value = data.lng.toFixed(6);

        // Autorrellenar datos enriquecidos de Google
        if (data.formatted_address) {
          const inputDir = document.getElementById("ref-direccion") as HTMLInputElement;
          if (inputDir) inputDir.value = data.formatted_address;
        }
        if (data.name) {
          const inputNombre = document.getElementById("ref-nombre") as HTMLInputElement;
          if (inputNombre && !inputNombre.value) inputNombre.value = data.name;
        }
        if (data.phone) {
          const inputContact = document.getElementById("ref-contacto") as HTMLInputElement;
          if (inputContact && !inputContact.value) inputContact.value = data.phone;
        }
        if (data.tipo) {
          const selectTipo = document.getElementById("ref-tipo") as HTMLSelectElement;
          if (selectTipo && selectTipo.value === "refugio") selectTipo.value = data.tipo;
        }

        // Mostrar tarjeta con toda la info de Google Places
        mostrarInfoGoogle(data);

        if (data.aproximado) {
          if (gpsStatus) {
            gpsStatus.textContent = `⚠️ Ubicación aproximada: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)} — Ajusta el pin tocando el mapa.`;
            gpsStatus.className = "text-[11px] text-warning font-uber-text italic font-semibold";
          }
          initMap(data.lat, data.lng, 16);
        } else {
          if (gpsStatus) {
            gpsStatus.textContent = `Enlace resuelto: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
            gpsStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          initMap(data.lat, data.lng, 17);
        }
      } else {
        const err = await resp.json();
        if (gpsStatus) {
          gpsStatus.textContent = `Error: ${err.error || "No se pudieron extraer coordenadas."}`;
          gpsStatus.className = "text-[11px] text-error font-uber-text italic";
        }
      }
    } catch (err) {
      console.error(err);
      if (gpsStatus) {
        gpsStatus.textContent = "Error al conectar con la API de resolución.";
        gpsStatus.className = "text-[11px] text-error font-uber-text italic";
      }
    }
  });

  // Intentar geolocalizar de inmediato
  obtenerUbicacion();

  // Pestañas de inventario
  const tabBtns = document.querySelectorAll(".tab-btn");
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      tabBtns.forEach((b) => {
        b.classList.remove("tab-active");
      });
      btn.classList.add("tab-active");

      document.querySelectorAll(".tab-pane").forEach((pane) => pane.classList.add("hidden"));
      const targetId = btn.getAttribute("data-target");
      if (targetId) {
        document.getElementById(targetId)?.classList.remove("hidden");
      }
    });
  });

  // Lógica de fotos
  const fotosInput = document.getElementById("ref-fotos") as HTMLInputElement;
  const previewContainer = document.getElementById("preview-fotos");
  let selectedFiles: File[] = [];

  fotosInput?.addEventListener("change", () => {
    if (!fotosInput.files) return;
    const newFiles = Array.from(fotosInput.files);
    for (const file of newFiles) {
      if (selectedFiles.length < 3) {
        selectedFiles.push(file);
      }
    }
    fotosInput.value = "";
    renderPreviews();
  });

  function renderPreviews() {
    if (!previewContainer) return;
    previewContainer.innerHTML = "";
    selectedFiles.forEach((file, index) => {
      const url = URL.createObjectURL(file);
      const div = document.createElement("div");
      div.className = "relative aspect-square rounded-xl border border-base-300 bg-base-300";
      
      const img = document.createElement("img");
      img.src = url;
      img.className = "w-full h-full object-cover rounded-xl";
      
      const removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.innerHTML = "✕";
      removeBtn.className = "absolute top-1 right-1 bg-black/60 hover:bg-black text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center border-none cursor-pointer";
      removeBtn.addEventListener("click", () => {
        selectedFiles.splice(index, 1);
        URL.revokeObjectURL(url);
        renderPreviews();
      });
      
      div.appendChild(img);
      div.appendChild(removeBtn);
      previewContainer.appendChild(div);
    });
  }

  // Form submit
  const form = document.getElementById("form-nuevo-refugio") as HTMLFormElement;
  const errorDiv = document.getElementById("ref-error");
  const btnSubmit = document.getElementById("btn-submit-ref") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const tipo = (document.getElementById("ref-tipo") as HTMLSelectElement).value;
    const nombre = (document.getElementById("ref-nombre") as HTMLInputElement).value.trim();
    const encargado = (document.getElementById("ref-encargado") as HTMLInputElement).value.trim();
    const direccion = (document.getElementById("ref-direccion") as HTMLInputElement).value.trim();
    const capacidad = parseInt((document.getElementById("ref-capacidad") as HTMLInputElement).value) || 0;
    const ocupacion = parseInt((document.getElementById("ref-ocupacion") as HTMLInputElement).value) || 0;
    const necesidades = (document.getElementById("ref-necesidades") as HTMLTextAreaElement).value.trim();
    const contacto = (document.getElementById("ref-contacto") as HTMLInputElement).value.trim();
    const lat = latInput.value;
    const lon = lonInput.value;

    const ninos = parseInt((document.getElementById("ref-ninos") as HTMLInputElement).value) || 0;
    const bebes = parseInt((document.getElementById("ref-bebes-lactantes") as HTMLInputElement).value) || 0;
    const mayores = parseInt((document.getElementById("ref-adultos-mayores") as HTMLInputElement).value) || 0;
    const prof = parseInt((document.getElementById("ref-personal-profesional") as HTMLInputElement).value) || 0;
    const vols = parseInt((document.getElementById("ref-voluntarios") as HTMLInputElement).value) || 0;

    const sumaSubgrupos = ninos + bebes + mayores + prof + vols;
    const demografiaWarning = document.getElementById("demografia-warning");

    if (ocupacion < sumaSubgrupos) {
      if (demografiaWarning) demografiaWarning.classList.remove("hidden");
      if (errorDiv) {
        errorDiv.textContent = "Error: La Población Total no puede ser menor a la suma de niños, bebés, adultos mayores, profesionales y voluntarios.";
        errorDiv.classList.remove("hidden");
      }
      return;
    } else {
      if (demografiaWarning) demografiaWarning.classList.add("hidden");
    }

    if (!lat || !lon) {
      if (errorDiv) {
        errorDiv.textContent = "Debes marcar la ubicación del refugio en el mapa o usar detección GPS.";
        errorDiv.classList.remove("hidden");
      }
      return;
    }

    if (errorDiv) errorDiv.classList.add("hidden");
    
    if (btnSubmit) {
      btnSubmit.disabled = true;
      btnSubmit.textContent = "Subiendo imágenes...";
    }

    // Subir imágenes a R2
    const fotosKeys: string[] = [];
    if (selectedFiles.length > 0) {
      for (const file of selectedFiles) {
        const formData = new FormData();
        formData.append("foto", file);
        try {
          const uploadResp = await fetch("/api/upload", {
            method: "POST",
            body: formData,
          });
          if (uploadResp.ok) {
            const data = await uploadResp.json();
            if (data.key) {
              fotosKeys.push(data.key);
            }
          } else {
            console.error("Fallo al subir una de las imágenes");
          }
        } catch (uploadErr) {
          console.error("Error de red al subir imagen:", uploadErr);
        }
      }
    }

    if (btnSubmit) {
      btnSubmit.textContent = "Registrando...";
    }

    // Recopilar inventario
    const inventario: Record<string, string> = {};
    const radios = form.querySelectorAll('input[type="radio"]:checked');
    radios.forEach((radio: any) => {
      if (radio.name.startsWith("inv-")) {
        const itemId = radio.name.replace("inv-", "");
        inventario[itemId] = radio.value;
      }
    });

    try {
      const resp = await fetch("/api/refugios", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          nombre,
          direccion,
          capacidad_maxima: capacidad,
          ocupacion_actual: ocupacion,
          necesidades,
          contacto,
          latitud: lat,
          longitud: lon,
          tipo,
          encargado,
          ninos,
          bebes_lactantes: bebes,
          adultos_mayores: mayores,
          personal_profesional: prof,
          voluntarios: vols,
          inventario,
          fotos: fotosKeys
        })
      });

      if (resp.ok) {
        const data = await resp.json();
        if (data.id) {
          window.location.href = `/r/${data.id}`;
        } else {
          window.location.href = "/";
        }
      } else {
        const err = await resp.json();
        if (errorDiv) {
          errorDiv.textContent = `Error: ${err.error || "no se pudo registrar el centro."}`;
          errorDiv.classList.remove("hidden");
        }
        if (btnSubmit) {
          btnSubmit.disabled = false;
          btnSubmit.textContent = "Registrar Centro";
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = "Error de conexión con el servidor.";
        errorDiv.classList.remove("hidden");
      }
      if (btnSubmit) {
        btnSubmit.disabled = false;
        btnSubmit.textContent = "Registrar Centro";
      }
    }
  });
});
</script>
