---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";
import { CATEGORIAS_INVENTARIO } from "../../lib/items";
import { obtenerVoluntarioSesion } from "../../lib/auth-helpers";

export const prerender = false;

let refugiosIniciales: any[] = [];
let esVoluntario = false;

try {
  const { DB } = env;
  if (DB) {
    const res = await DB.prepare("SELECT * FROM refugios ORDER BY nombre ASC").all();
    refugiosIniciales = res.results || [];

    const sessionToken = Astro.cookies.get("session_token")?.value;
    const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    if (voluntario) {
      esVoluntario = true;
    }
  }
} catch (error) {
  console.error("Error al cargar refugios iniciales:", error);
}
---

<Layout title="Refugios y Centros de Acopio - dondeestan.org">
  <!-- Leaflet CSS y JS para mapas de emergencia -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-canvas max-w-4xl mx-auto w-full">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <div>
        <h1 class="font-uber-display text-2xl sm:text-3xl text-ink tracking-tight">
          Refugios y Centros de Acopio
        </h1>
        <p class="text-xs sm:text-sm text-body font-uber-text mt-1">
          Directorio en tiempo real de albergues activos y sus necesidades críticas.
        </p>
      </div>
      <a href="/refugios/nuevo" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong px-5 py-2.5 rounded-[36px] text-center shadow-sm shrink-0">
        ➕ Registrar Refugio
      </a>
    </div>

    <!-- Mapa Interactivo -->
    <div class="mb-6 relative">
      <div id="mapa-refugios" class="w-full h-80 sm:h-96 rounded-xl border border-canvas-soft shadow-sm z-0"></div>
      <button type="button" id="btn-geolocalizar" class="absolute bottom-4 right-4 z-[400] w-10 h-10 bg-white border border-canvas-soft rounded-full shadow-md hover:bg-canvas-soft active:scale-95 transition-transform flex items-center justify-center cursor-pointer text-lg" title="Encontrar mi ubicación">
        📍
      </button>
    </div>

    <!-- Filtros Rápidos y Buscador -->
    <div class="space-y-4 mb-6">
      <!-- Filtros por tipo -->
      <div class="flex flex-wrap gap-2 overflow-x-auto pb-1 scrollbar-none" id="tipo-filtros">
        <button type="button" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border border-canvas-soft bg-primary text-white cursor-pointer transition-all" data-tipo="todos">
          Todos
        </button>
        <button type="button" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border border-canvas-soft bg-canvas text-ink hover:bg-canvas-soft cursor-pointer transition-all" data-tipo="refugio">
          🏠 Refugios
        </button>
        <button type="button" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border border-canvas-soft bg-canvas text-ink hover:bg-canvas-soft cursor-pointer transition-all" data-tipo="centro_acopio">
          📦 Centros de Acopio
        </button>
        <button type="button" class="filter-btn px-4 py-1.5 rounded-full text-xs font-semibold font-uber-text border border-canvas-soft bg-canvas text-ink hover:bg-canvas-soft cursor-pointer transition-all" data-tipo="hospital">
          🏥 Hospitales / Salud
        </button>
      </div>

      <!-- Buscador por texto -->
      <input 
        type="text" 
        id="search-refugios" 
        placeholder="Buscar refugio por nombre, ubicación o insumos..." 
        class="input w-full font-uber-text uber-body-md border border-canvas-soft bg-canvas px-4 py-3 rounded-xl focus:outline-none focus:ring-1 focus:ring-primary shadow-sm"
      />
    </div>

    <!-- Lista de Refugios -->
    <div id="refugios-container" class="space-y-4">
      {refugiosIniciales.length === 0 ? (
        <div class="text-center py-12 bg-canvas-soft border border-canvas-soft rounded-xl">
          <p class="text-sm text-mute font-uber-text">No hay centros registrados en este momento.</p>
        </div>
      ) : (
        refugiosIniciales.map((r) => {
          const ocupacion = r.ocupacion_actual || 0;
          const capacidad = r.capacidad_maxima || 100;
          const pct = Math.min(Math.round((ocupacion / capacidad) * 100), 100);
          
          let colorBar = "bg-success"; // Verde
          if (pct >= 90) colorBar = "bg-error"; // Rojo
          else if (pct >= 70) colorBar = "bg-warning"; // Amarillo/Naranja

          let tipoLabel = "Refugio / Albergue";
          let tipoColor = "bg-blue-100 text-blue-800 border-blue-200";
          if (r.tipo === "hospital") {
            tipoLabel = "Hospital / Salud";
            tipoColor = "bg-red-100 text-red-800 border-red-200";
          } else if (r.tipo === "centro_acopio") {
            tipoLabel = "Centro de Acopio";
            tipoColor = "bg-yellow-100 text-yellow-800 border-yellow-200";
          }

          // Parsear inventario para extraer críticos y alertas
          let itemsCriticos: string[] = [];
          let itemsAlerta: string[] = [];
          if (r.inventario) {
            try {
              const inv = typeof r.inventario === 'string' ? JSON.parse(r.inventario) : r.inventario;
              for (const [itemId, estado] of Object.entries(inv)) {
                const itemObj = CATEGORIAS_INVENTARIO.flatMap(c => c.items).find(i => i.id === itemId);
                if (itemObj) {
                  if (estado === "Crítico") {
                    itemsCriticos.push(itemObj.nombre);
                  } else if (estado === "Alerta") {
                    itemsAlerta.push(itemObj.nombre);
                  }
                }
              }
            } catch (e) {
              console.error("Error al parsear inventario:", e);
            }
          }

          // Formatear fecha
          let fechaFormateada = "";
          if (r.fecha_registro) {
            try {
              fechaFormateada = new Date(r.fecha_registro).toLocaleString('es-VE', {
                dateStyle: 'short',
                timeStyle: 'short'
              });
            } catch {
              fechaFormateada = r.fecha_registro;
            }
          }

          return (
            <div 
              class="refugio-card bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm space-y-4 transition-all hover:shadow-md"
              data-id={r.id}
              data-nombre={r.nombre.toLowerCase()}
              data-direccion={(r.direccion || "").toLowerCase()}
              data-necesidades={(r.necesidades || "").toLowerCase()}
              data-tipo={r.tipo || "refugio"}
              data-lat={r.latitud || ""}
              data-lng={r.longitud || ""}
              data-ocupacion={ocupacion}
              data-capacidad={capacidad}
              data-contacto={r.contacto || ""}
              data-encargado={r.encargado || ""}
              data-semaforo={itemsCriticos.length > 0 ? "rojo" : itemsAlerta.length > 0 ? "amarillo" : "verde"}
            >
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full border ${tipoColor} font-uber-text`}>
                      {tipoLabel}
                    </span>
                    <h3 class="font-uber-display text-lg text-ink font-semibold">{r.nombre}</h3>
                  </div>
                  {r.direccion && <p class="text-xs text-body font-uber-text mt-1">📍 {r.direccion}</p>}
                </div>
                <div class="text-right shrink-0">
                  <span class="text-xs font-semibold text-ink font-uber-text bg-canvas-soft px-2.5 py-1 rounded-full border border-canvas-soft">
                    {ocupacion} / {capacidad} personas
                  </span>
                </div>
              </div>

              <!-- Encargado y Fecha -->
              {(r.encargado || fechaFormateada) && (
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-uber-text text-body border-t border-canvas-soft pt-2">
                  {r.encargado && <span>👤 Encargado: <strong>{r.encargado}</strong></span>}
                  {fechaFormateada && <span>📅 Reportado: <strong>{fechaFormateada}</strong></span>}
                </div>
              )}

              <!-- Barra de capacidad -->
              <div class="space-y-1">
                <div class="flex justify-between text-[11px] font-uber-text font-medium text-mute">
                  <span>Capacidad ocupada</span>
                  <span>{pct}%</span>
                </div>
                <div class="w-full bg-canvas-soft h-2.5 rounded-full overflow-hidden border border-canvas-soft">
                  <div class={`h-full ${colorBar}`} style={`width: ${pct}%`}></div>
                </div>
              </div>

              <!-- Demografía -->
              <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 text-xs font-uber-text bg-canvas-soft p-3 rounded-lg border border-canvas-soft">
                <div>👶 Niños: <strong class="text-ink">{r.ninos || 0}</strong></div>
                <div>🍼 Lactantes: <strong class="text-ink">{r.bebes_lactantes || 0}</strong></div>
                <div>👵 Mayores: <strong class="text-ink">{r.adultos_mayores || 0}</strong></div>
                <div>🩺 Personal: <strong class="text-ink">{r.personal_profesional || 0}</strong></div>
                <div>🤝 Vols: <strong class="text-ink">{r.voluntarios || 0}</strong></div>
              </div>

              <!-- Inventario Crítico/Alerta -->
              {(itemsCriticos.length > 0 || itemsAlerta.length > 0) && (
                <div class="space-y-1.5 bg-canvas-soft/50 border border-canvas-soft p-3 rounded-lg">
                  {itemsCriticos.length > 0 && (
                    <div class="flex flex-wrap gap-1 items-center">
                      <span class="text-[9px] font-bold text-red-700 uppercase tracking-wider font-uber-text mr-1">Crítico:</span>
                      {itemsCriticos.map(item => (
                        <span class="text-[9px] bg-red-500/10 text-red-700 font-semibold px-2 py-0.5 rounded-full border border-red-500/20">{item}</span>
                      ))}
                    </div>
                  )}
                  {itemsAlerta.length > 0 && (
                    <div class="flex flex-wrap gap-1 items-center">
                      <span class="text-[9px] font-bold text-amber-700 uppercase tracking-wider font-uber-text mr-1">Alerta:</span>
                      {itemsAlerta.map(item => (
                        <span class="text-[9px] bg-amber-500/10 text-amber-700 font-semibold px-2 py-0.5 rounded-full border border-amber-500/20">{item}</span>
                      ))}
                    </div>
                  )}
                </div>
              )}

              <!-- Necesidades (Texto Libre) -->
              {r.necesidades && (
                <div class="bg-yellow-500/5 border border-yellow-500/20 p-3 rounded-lg">
                  <div class="text-[10px] font-bold text-yellow-800 uppercase tracking-wider mb-1 font-uber-text">🚨 Notas de Necesidades</div>
                  <p class="text-xs text-body font-uber-text font-medium">{r.necesidades}</p>
                </div>
              )}

              <!-- Contacto y acciones -->
              <div class="flex flex-wrap items-center justify-between gap-3 pt-2 border-t border-canvas-soft">
                <div class="text-xs text-mute font-uber-text">
                  {r.contacto ? `📞 Contacto: ${r.contacto}` : "Sin información de contacto"}
                </div>
                {esVoluntario && (
                  <button 
                    class="btn-edit-refugio btn btn-xs bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text font-semibold px-3 py-1.5 rounded-lg border border-canvas-soft cursor-pointer"
                    data-id={r.id}
                    data-nombre={r.nombre}
                    data-ocupacion={ocupacion}
                    data-capacidad={capacidad}
                    data-necesidades={r.necesidades || ""}
                    data-contacto={r.contacto || ""}
                    data-direccion={r.direccion || ""}
                    data-tipo={r.tipo || "refugio"}
                    data-encargado={r.encargado || ""}
                    data-ninos={r.ninos || 0}
                    data-bebes={r.bebes_lactantes || 0}
                    data-mayores={r.adultos_mayores || 0}
                    data-prof={r.personal_profesional || 0}
                    data-vols={r.voluntarios || 0}
                    data-inventario={typeof r.inventario === 'string' ? r.inventario : JSON.stringify(r.inventario || {})}
                    data-fecha={r.fecha_registro || ""}
                  >
                    ✏️ Actualizar Estado
                  </button>
                )}
              </div>
            </div>
          );
        })
      )}
    </div>
  </main>

  <!-- Modal para actualizar refugio -->
  <div id="modal-edit-refugio" class="fixed inset-0 z-50 bg-black/60 hidden flex items-end sm:items-center justify-center animate-fade-in" style="backdrop-filter:blur(4px)">
    <div class="bg-canvas w-full sm:max-w-lg sm:rounded-2xl rounded-t-2xl p-6 space-y-4 max-h-[95vh] overflow-y-auto border border-canvas-soft shadow-xl">
      <div class="flex justify-between items-center">
        <h3 class="font-uber-display text-lg text-ink font-semibold" id="edit-refugio-titulo">Actualizar Centro</h3>
        <button id="btn-close-edit" class="w-8 h-8 rounded-full bg-canvas-soft flex items-center justify-center text-ink text-sm hover:bg-surface-pressed cursor-pointer">✕</button>
      </div>

      <form id="form-edit-refugio" class="space-y-4">
        <input type="hidden" id="edit-refugio-id" />
        
        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-tipo">Tipo de Centro *</label>
          <select id="edit-tipo" required class="select w-full font-uber-text uber-body-md">
            <option value="refugio">Refugio / Albergue</option>
            <option value="centro_acopio">Centro de Acopio</option>
            <option value="hospital">Hospital / Puesto de Salud</option>
          </select>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-encargado">Encargado *</label>
          <input 
            type="text" 
            id="edit-encargado" 
            required
            class="input w-full font-uber-text uber-body-md" 
          />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-direccion">Dirección / Sector *</label>
          <div class="flex gap-2 mb-3">
            <input 
              type="text" 
              id="edit-direccion" 
              required 
              class="input flex-grow font-uber-text uber-body-md" 
              placeholder="Ej: Sector La Lucha, Caracas"
            />
            <button type="button" id="btn-edit-buscar-direccion" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed border border-canvas-soft font-uber-text font-semibold px-3 py-2 rounded-xl text-xs shrink-0 cursor-pointer">
              📍 Ubicar
            </button>
          </div>

          <!-- Bloque de ubicación integrado para edicion -->
          <div class="p-3.5 bg-canvas-soft rounded-xl flex flex-col gap-3 border border-canvas-soft">
            <span class="text-[10px] font-bold text-mute uppercase tracking-wider font-uber-text">📍 Método de Ubicación GPS *</span>
            
            <!-- Tabs de selección de método -->
            <div class="flex gap-1 bg-canvas p-1 rounded-lg border border-canvas-soft">
              <button type="button" id="tab-edit-gps" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md bg-primary text-white border-none cursor-pointer">
                GPS Móvil
              </button>
              <button type="button" id="tab-edit-gmaps" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md bg-transparent text-ink border-none cursor-pointer">
                Pegar Enlace
              </button>
              <button type="button" id="tab-edit-map" class="flex-1 text-center py-1.5 px-2 text-[10px] font-bold font-uber-text rounded-md bg-transparent text-ink border-none cursor-pointer">
                Mapa Manual
              </button>
            </div>

            <!-- Inputs ocultos para lat/lng -->
            <input type="hidden" id="edit-latitud" />
            <input type="hidden" id="edit-longitud" />

            <!-- Panel 1: GPS Móvil -->
            <div id="panel-edit-gps" class="flex items-center justify-between gap-2">
              <span class="text-[10px] text-body font-uber-text">Obtén la ubicación actual del dispositivo.</span>
              <button id="btn-edit-ref-gps" type="button" class="btn btn-xs bg-primary text-white font-uber-text px-3 py-1.5 rounded-lg text-[10px] cursor-pointer shrink-0">
                Detectar GPS
              </button>
            </div>

            <!-- Panel 2: Pegar Enlace -->
            <div id="panel-edit-gmaps" class="space-y-2 hidden">
              <div class="flex gap-2">
                <input 
                  type="url" 
                  id="edit-gmaps-link" 
                  class="input flex-grow font-uber-text text-xs p-2.5 min-h-[36px]" 
                  placeholder="Pegar enlace de Google Maps..."
                />
                <button type="button" id="btn-edit-resolver-gmaps" class="btn bg-primary text-white font-uber-text font-semibold px-3 py-1.5 rounded-lg text-[10px] shrink-0 cursor-pointer">
                  Extraer
                </button>
              </div>
            </div>

            <!-- Panel 3: Mapa Manual -->
            <div id="panel-edit-map" class="text-[10px] text-mute font-uber-text italic hidden">
              Toca el mapa abajo para ajustar el marcador manualmente.
            </div>

            <!-- Contenedor del mapa (común) -->
            <div id="edit-gps-map" class="w-full h-40 rounded-lg overflow-hidden border border-canvas-soft bg-canvas"></div>
            
            <!-- Estatus de Ubicación -->
            <div id="edit-gps-status" class="text-[11px] text-mute font-uber-text italic">Ubicación cargada.</div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-capacidad">Capacidad Máxima *</label>
            <input 
              type="number" 
              id="edit-capacidad" 
              required 
              min="1"
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-ocupacion">Población Total *</label>
            <input 
              type="number" 
              id="edit-ocupacion" 
              required 
              min="0"
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
        </div>

        <div class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-2">
          <span class="text-xs font-semibold text-ink font-uber-text block">👥 Desglose de Población</span>
          <div class="grid grid-cols-3 gap-2">
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-ninos">Niños</label>
              <input type="number" id="edit-ninos" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-bebes">Bebés</label>
              <input type="number" id="edit-bebes" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-mayores">Adultos M.</label>
              <input type="number" id="edit-mayores" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-prof">Prof. Salud</label>
              <input type="number" id="edit-prof" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-vols">Voluntarios</label>
              <input type="number" id="edit-vols" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
          </div>
          <div id="edit-demografia-warning" class="hidden text-[10px] text-red-500 font-uber-text font-medium bg-red-500/5 p-2 rounded">
            ⚠️ La Población Total debe ser mayor o igual a la suma de los subgrupos.
          </div>
        </div>

        <div class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-3">
          <span class="text-xs font-semibold text-ink font-uber-text block">📋 Estado del Inventario (43 Ítems)</span>
          
          <div class="flex gap-1 overflow-x-auto pb-1.5 border-b border-canvas-soft scrollbar-none" id="edit-tabs-container">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <button 
                type="button" 
                class={`edit-tab-btn font-uber-text text-[11px] whitespace-nowrap px-2.5 py-1 rounded-lg border ${idx === 0 ? 'bg-primary text-white border-primary' : 'bg-canvas-soft text-ink border-transparent'} cursor-pointer`}
                data-target={`edit-tab-${idx}`}
              >
                {cat.nombre}
              </button>
            ))}
          </div>

          <div class="edit-tab-contents max-h-48 overflow-y-auto">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <div id={`edit-tab-${idx}`} class={`edit-tab-pane space-y-2 ${idx === 0 ? '' : 'hidden'}`}>
                {cat.items.map((item) => (
                  <div class="flex flex-col gap-1 py-1 border-b border-canvas-soft last:border-b-0">
                    <span class="text-[11px] font-uber-text text-ink font-medium">{item.nombre}</span>
                    <div class="flex gap-0.5 bg-canvas-soft p-0.5 rounded-lg w-full overflow-x-auto">
                      {["Crítico", "Alerta", "Estable", "Excedente"].map((est) => {
                        let activeClass = "";
                        if (est === "Crítico") activeClass = "has-[:checked]:bg-red-500 has-[:checked]:text-white";
                        else if (est === "Alerta") activeClass = "has-[:checked]:bg-amber-500 has-[:checked]:text-white";
                        else if (est === "Estable") activeClass = "has-[:checked]:bg-green-600 has-[:checked]:text-white";
                        else if (est === "Excedente") activeClass = "has-[:checked]:bg-blue-600 has-[:checked]:text-white";

                        return (
                          <label class={`flex-grow text-center py-1 text-[9px] rounded-md cursor-pointer transition-all font-semibold font-uber-text select-none border border-transparent hover:bg-surface-pressed ${activeClass}`}>
                            <input 
                              type="radio" 
                              name={`edit-inv-${item.id}`} 
                              value={est} 
                              class="hidden" 
                            />
                            {est}
                          </label>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-necesidades">Notas Adicionales de Necesidades (Texto Libre)</label>
          <textarea 
            id="edit-necesidades" 
            rows="2"
            class="textarea w-full font-uber-text uber-body-md" 
            placeholder="Ej: Agua mineral, mantas, leche de fórmula..."
          ></textarea>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-contacto">Teléfono o Datos de Contacto</label>
          <input 
            type="text" 
            id="edit-contacto" 
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: 0412-1234567"
          />
        </div>

        <div id="edit-refugio-error" class="hidden text-xs text-red-500 font-uber-text bg-red-500/5 border border-red-500/20 p-3 rounded-lg"></div>

        <button type="submit" class="btn bg-primary text-white w-full font-uber-text font-semibold py-2.5 rounded-xl">
          Guardar Cambios
        </button>
      </form>
    </div>
  </div>
</Layout>

<style is:global>
  /* Marcadores personalizados para el mapa de emergencia */
  .custom-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 2px solid white;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.15), 0 2px 4px -2px rgba(0, 0, 0, 0.15);
    width: 32px;
    height: 32px;
    position: relative;
    color: white;
    font-size: 14px;
  }
  
  .marker-refugio {
    background-color: #2563eb; /* Azul */
  }
  
  .marker-acopio {
    background-color: #d97706; /* Naranja/Amarillo */
  }
  
  .marker-hospital {
    background-color: #dc2626; /* Rojo */
  }

  .custom-marker-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    border: 1.5px solid white;
  }

  .badge-verde {
    background-color: #16a34a;
  }

  .badge-amarillo {
    background-color: #fbbf24;
  }

  .badge-rojo {
    background-color: #dc2626;
  }

  .custom-marker-pulse {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background-color: #dc2626;
    animation: marker-pulse-anim 1.5s infinite;
  }

  @keyframes marker-pulse-anim {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 6px rgba(220, 38, 38, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(220, 38, 38, 0);
    }
  }

  /* Indicador de posición del usuario */
  .user-location-marker {
    width: 16px;
    height: 16px;
    border-radius: 9999px;
    background-color: #3b82f6;
    border: 2px solid white;
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.6);
    position: relative;
  }

  .user-location-pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    background-color: rgba(59, 130, 246, 0.4);
    animation: user-pulse 2s infinite;
  }

  @keyframes user-pulse {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
    }
  }

  /* Ajustes del Popup de Leaflet */
  .leaflet-popup-content-wrapper {
    border-radius: 12px;
    padding: 2px;
    border: 1px solid var(--canvas-soft);
  }
  .leaflet-popup-content {
    margin: 8px 12px;
  }
</style>

<script>
  let esVoluntario = false;
  // Obtener estado de voluntario desde el botón del DOM
  const btnEdits = document.querySelectorAll(".btn-edit-refugio");
  if (btnEdits.length > 0) {
    esVoluntario = true;
  }

  // Elementos UI
  const searchInput = document.getElementById("search-refugios") as HTMLInputElement;
  const filterBtns = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll(".refugio-card");
  const btnGeolocalizar = document.getElementById("btn-geolocalizar");

  // Instancia de Mapa Leaflet
  let map: any = null;
  const marcadores = new Map<string, any>();
  let userMarker: any = null;

  // Inicializar Mapa
  function initMap() {
    const mapDiv = document.getElementById("mapa-refugios");
    if (!mapDiv) return;

    // Centrar en Venezuela por defecto
    // @ts-ignore
    map = L.map("mapa-refugios", {
      zoomControl: false // Desactivamos por defecto para colocar controles personalizados si se requiere
    }).setView([8.0, -66.0], 6);

    // Añadir control de Zoom abajo a la derecha
    // @ts-ignore
    L.control.zoom({ position: 'bottomleft' }).addTo(map);

    // Capa de mosaicos (Tiles)
    // @ts-ignore
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: '&copy; <a href="https://openstreetmap.org/copyright">OpenStreetMap</a>'
    }).addTo(map);

    // Crear marcadores desde los datos del DOM de las tarjetas
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const id = el.dataset.id || "";
      const latRaw = el.dataset.lat;
      const lngRaw = el.dataset.lng;
      const nombre = el.dataset.nombre || "";
      const direccion = el.dataset.direccion || "";
      const tipo = el.dataset.tipo || "refugio";
      const ocupacion = el.dataset.ocupacion || "0";
      const capacidad = el.dataset.capacidad || "100";
      const contacto = el.dataset.contacto || "";
      const semaforo = el.dataset.semaforo || "verde";

      if (!latRaw || !lngRaw) return;

      const lat = parseFloat(latRaw);
      const lng = parseFloat(lngRaw);

      if (isNaN(lat) || isNaN(lng)) return;

      // Definir emoji e icono del marcador según tipo y semáforo
      let emoji = "🏠";
      let classTipo = "marker-refugio";
      if (tipo === "hospital") {
        emoji = "🏥";
        classTipo = "marker-hospital";
      } else if (tipo === "centro_acopio") {
        emoji = "📦";
        classTipo = "marker-acopio";
      }

      // Badge indicador de inventario en marcador
      let badgeHTML = "";
      if (semaforo === "rojo") {
        badgeHTML = `<div class="custom-marker-pulse"></div><div class="custom-marker-badge badge-rojo"></div>`;
      } else if (semaforo === "amarillo") {
        badgeHTML = `<div class="custom-marker-badge badge-amarillo"></div>`;
      } else {
        badgeHTML = `<div class="custom-marker-badge badge-verde"></div>`;
      }

      // Crear el DivIcon personalizado
      // @ts-ignore
      const customIcon = L.divIcon({
        html: `<div class="custom-marker ${classTipo}">${emoji}${badgeHTML}</div>`,
        className: "", // Limpiar clase por defecto de Leaflet
        iconSize: [32, 32],
        iconAnchor: [16, 32],
        popupAnchor: [0, -32]
      });

      // Crear popup
      let semaforoText = "🟢 Estable";
      let semaforoColor = "text-green-600";
      if (semaforo === "rojo") {
        semaforoText = "🔴 Insumos Críticos";
        semaforoColor = "text-red-600 font-bold";
      } else if (semaforo === "amarillo") {
        semaforoText = "🟡 Alertas de Insumo";
        semaforoColor = "text-amber-600 font-semibold";
      }

      const popupHTML = `
        <div class="p-1.5 space-y-2 max-w-[240px] font-uber-text">
          <div class="flex items-center gap-1.5">
            <span class="text-base">${emoji}</span>
            <h4 class="font-bold text-ink text-sm leading-tight capitalize">${nombre}</h4>
          </div>
          <p class="text-[10px] text-body leading-normal">📍 ${direccion || 'Sin dirección registrada'}</p>
          <div class="flex flex-col gap-1 text-[11px] bg-canvas-soft p-2 rounded-lg border border-canvas-soft">
            <div>👥 Ocupación: <strong class="text-ink">${ocupacion} / ${capacidad} pers.</strong></div>
            <div>📦 Inventario: <span class="font-semibold ${semaforoColor}">${semaforoText}</span></div>
            ${contacto ? `<div>📞 Contacto: <strong class="text-ink">${contacto}</strong></div>` : ''}
          </div>
          <div class="flex flex-col gap-1.5 pt-1">
            <a href="https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}" target="_blank" rel="noopener noreferrer" class="btn btn-xs bg-primary text-white hover:bg-black-elevated text-center py-2 rounded-lg text-[10px] font-bold flex items-center justify-center gap-1 no-underline">
              🚗 Cómo llegar
            </a>
            ${esVoluntario ? `
              <button type="button" class="btn-mapa-edit btn btn-xs bg-canvas text-ink hover:bg-canvas-soft border border-canvas-soft text-center py-2 rounded-lg text-[10px] font-semibold cursor-pointer" data-id="${id}">
                ✏️ Actualizar Estado
              </button>
            ` : ''}
          </div>
        </div>
      `;

      // @ts-ignore
      const marker = L.marker([lat, lng], { icon: customIcon }).bindPopup(popupHTML);
      marker.addTo(map);
      marcadores.set(id, marker);
    });

    // Si hay marcadores, ajustar el mapa para que muestre todos (si es más de 0)
    if (marcadores.size > 0) {
      // @ts-ignore
      const group = new L.featureGroup(Array.from(marcadores.values()));
      map.fitBounds(group.getBounds().pad(0.15));
    }
  }

  // Filtro de Búsqueda y Tipo
  function filtrarCentros() {
    const term = searchInput.value.toLowerCase().trim();
    // Obtener tipo activo
    const activeBtn = document.querySelector(".filter-btn.bg-primary") as HTMLElement;
    const tipoActivo = activeBtn ? activeBtn.dataset.tipo : "todos";

    cards.forEach((card) => {
      const el = card as HTMLElement;
      const id = el.dataset.id || "";
      const nombre = el.dataset.nombre || "";
      const direccion = el.dataset.direccion || "";
      const necesidades = el.dataset.necesidades || "";
      const tipo = el.dataset.tipo || "";

      const coincideTexto = nombre.includes(term) || direccion.includes(term) || necesidades.includes(term);
      const coincideTipo = tipoActivo === "todos" || tipo === tipoActivo;

      const marker = marcadores.get(id);

      if (coincideTexto && coincideTipo) {
        el.classList.remove("hidden");
        if (marker && map) {
          marker.addTo(map);
        }
      } else {
        el.classList.add("hidden");
        if (marker && map) {
          map.removeLayer(marker);
        }
      }
    });
  }

  // Escuchar entrada de búsqueda
  searchInput?.addEventListener("input", filtrarCentros);

  // Escuchar filtros de tipo (botones de píldoras)
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => {
        b.classList.remove("bg-primary", "text-white");
        b.classList.add("bg-canvas", "text-ink", "hover:bg-canvas-soft");
      });
      btn.classList.add("bg-primary", "text-white");
      btn.classList.remove("bg-canvas", "text-ink", "hover:bg-canvas-soft");
      
      filtrarCentros();
    });
  });

  // Geolocalización
  btnGeolocalizar?.addEventListener("click", () => {
    if (!navigator.geolocation) {
      alert("Tu navegador no soporta geolocalización.");
      return;
    }

    btnGeolocalizar.classList.add("scale-90");
    navigator.geolocation.getCurrentPosition(
      (position) => {
        btnGeolocalizar.classList.remove("scale-90");
        const lat = position.coords.latitude;
        const lng = position.coords.longitude;

        if (map) {
          map.setView([lat, lng], 14);

          // Agregar o mover marcador de usuario
          if (userMarker) {
            userMarker.setLatLng([lat, lng]);
          } else {
            // @ts-ignore
            const userIcon = L.divIcon({
              html: `<div class="user-location-marker"><div class="user-location-pulse"></div></div>`,
              className: "",
              iconSize: [16, 16],
              iconAnchor: [8, 8]
            });
            // @ts-ignore
            userMarker = L.marker([lat, lng], { icon: userIcon }).addTo(map);
          }
        }
      },
      (error) => {
        btnGeolocalizar.classList.remove("scale-90");
        console.error("Error de geolocalización:", error);
        alert("No se pudo obtener tu ubicación. Verifica los permisos de tu navegador.");
      },
      { enableHighAccuracy: true, timeout: 5000 }
    );
  });

  // Delegar click del botón "Editar" del mapa para abrir el modal nativo
  document.getElementById("mapa-refugios")?.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target.classList.contains("btn-mapa-edit")) {
      const id = target.getAttribute("data-id");
      if (id) {
        // Encontrar botón correspondiente en el listado y disparar click
        const btnLista = document.querySelector(`.btn-edit-refugio[data-id="${id}"]`) as HTMLButtonElement;
        if (btnLista) {
          btnLista.click();
        }
      }
    }
  });

  // Inicializar Leaflet cuando cargue la página
  if (typeof window !== "undefined") {
    // Si Leaflet está cargado por el CDN in:inline
    // @ts-ignore
    if (typeof L !== "undefined") {
      initMap();
    } else {
      // Reintentar en un momento si carga asíncrona
      const interval = setInterval(() => {
        // @ts-ignore
        if (typeof L !== "undefined") {
          initMap();
          clearInterval(interval);
        }
      }, 100);
    }
  }

  // ================= MODAL DE EDICIÓN NATIVO =================
  const modal = document.getElementById("modal-edit-refugio");
  const closeBtn = document.getElementById("btn-close-edit");
  const form = document.getElementById("form-edit-refugio") as HTMLFormElement;
  const errorDiv = document.getElementById("edit-refugio-error");

  const inputId = document.getElementById("edit-refugio-id") as HTMLInputElement;
  const selectTipo = document.getElementById("edit-tipo") as HTMLSelectElement;
  const inputEncargado = document.getElementById("edit-encargado") as HTMLInputElement;
  const inputDireccion = document.getElementById("edit-direccion") as HTMLInputElement;
  const btnEditBuscarDireccion = document.getElementById("btn-edit-buscar-direccion");
  const inputOcupacion = document.getElementById("edit-ocupacion") as HTMLInputElement;
  const inputCapacidad = document.getElementById("edit-capacidad") as HTMLInputElement;
  const inputNecesidades = document.getElementById("edit-necesidades") as HTMLTextAreaElement;
  const inputContacto = document.getElementById("edit-contacto") as HTMLInputElement;
  const editTitulo = document.getElementById("edit-refugio-titulo");

  const inputNinos = document.getElementById("edit-ninos") as HTMLInputElement;
  const inputBebes = document.getElementById("edit-bebes") as HTMLInputElement;
  const inputMayores = document.getElementById("edit-mayores") as HTMLInputElement;
  const inputProf = document.getElementById("edit-prof") as HTMLInputElement;
  const inputVols = document.getElementById("edit-vols") as HTMLInputElement;

  // Ubicación del Modal
  const latEditInput = document.getElementById("edit-latitud") as HTMLInputElement;
  const lonEditInput = document.getElementById("edit-longitud") as HTMLInputElement;
  const gpsEditStatus = document.getElementById("edit-gps-status");
  const btnEditGps = document.getElementById("btn-edit-ref-gps");

  let editMap: any = null;
  let editMarker: any = null;

  function initEditMap(lat: number, lon: number, zoom = 15) {
    if (typeof (window as any).L === "undefined") return;
    const L = (window as any).L;

    if (!editMap) {
      editMap = L.map("edit-gps-map", {
        zoomControl: true,
        attributionControl: false
      }).setView([lat, lon], zoom);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 18,
      }).addTo(editMap);

      editMap.on("click", (e: any) => {
        const clat = e.latlng.lat;
        const clon = e.latlng.lng;
        latEditInput.value = clat.toFixed(6);
        lonEditInput.value = clon.toFixed(6);
        
        if (editMarker) {
          editMarker.setLatLng(e.latlng);
        } else {
          editMarker = L.marker(e.latlng).addTo(editMap);
        }

        if (gpsEditStatus) {
          gpsEditStatus.textContent = `Ubicación modificada: ${clat.toFixed(5)}, ${clon.toFixed(5)}`;
          gpsEditStatus.className = "text-[11px] text-blue-600 font-uber-text italic font-medium";
        }
      });
    }

    if (editMarker) {
      editMarker.setLatLng([lat, lon]);
    } else {
      editMarker = L.marker([lat, lon]).addTo(editMap);
    }
    editMap.setView([lat, lon], zoom);
    
    // Forzar a Leaflet a recalcular tamaño de contenedor para evitar bugs de visualización en modales
    setTimeout(() => {
      editMap.invalidateSize();
    }, 200);
  }

  // Lógica de pestañas del modal (Demografía/Inventario)
  const editTabBtns = document.querySelectorAll(".edit-tab-btn");
  editTabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      editTabBtns.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "border-primary");
        b.classList.add("bg-canvas-soft", "text-ink", "border-transparent");
      });
      btn.classList.add("bg-primary", "text-white", "border-primary");
      btn.classList.remove("bg-canvas-soft", "text-ink", "border-transparent");

      document.querySelectorAll(".edit-tab-pane").forEach((pane) => pane.classList.add("hidden"));
      const targetId = btn.getAttribute("data-target");
      if (targetId) {
        document.getElementById(targetId)?.classList.remove("hidden");
      }
    });
  });

  // Lógica de Tabs de Ubicación del Modal
  const tabEditGps = document.getElementById("tab-edit-gps");
  const tabEditGmaps = document.getElementById("tab-edit-gmaps");
  const tabEditMap = document.getElementById("tab-edit-map");

  const panelEditGps = document.getElementById("panel-edit-gps");
  const panelEditGmaps = document.getElementById("panel-edit-gmaps");
  const panelEditMap = document.getElementById("panel-edit-map");

  function deseleccionarEditTabs() {
    [tabEditGps, tabEditGmaps, tabEditMap].forEach(tab => {
      tab?.classList.remove("bg-primary", "text-white");
      tab?.classList.add("bg-transparent", "text-ink");
    });
    [panelEditGps, panelEditGmaps, panelEditMap].forEach(panel => panel?.classList.add("hidden"));
  }

  tabEditGps?.addEventListener("click", () => {
    deseleccionarEditTabs();
    tabEditGps.classList.add("bg-primary", "text-white");
    tabEditGps.classList.remove("bg-transparent", "text-ink");
    panelEditGps?.classList.remove("hidden");
  });

  tabEditGmaps?.addEventListener("click", () => {
    deseleccionarEditTabs();
    tabEditGmaps.classList.add("bg-primary", "text-white");
    tabEditGmaps.classList.remove("bg-transparent", "text-ink");
    panelEditGmaps?.classList.remove("hidden");
  });

  tabEditMap?.addEventListener("click", () => {
    deseleccionarEditTabs();
    tabEditMap.classList.add("bg-primary", "text-white");
    tabEditMap.classList.remove("bg-transparent", "text-ink");
    panelEditMap?.classList.remove("hidden");
  });

  // Geolocalización en Modal
  btnEditGps?.addEventListener("click", () => {
    if (!navigator.geolocation) {
      alert("Geolocalización no soportada.");
      return;
    }
    if (gpsEditStatus) {
      gpsEditStatus.textContent = "Detectando GPS...";
      gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        latEditInput.value = lat.toFixed(6);
        lonEditInput.value = lon.toFixed(6);
        if (gpsEditStatus) {
          gpsEditStatus.textContent = `Ubicación GPS: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
          gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
        }
        initEditMap(lat, lon, 15);
      },
      () => {
        if (gpsEditStatus) {
          gpsEditStatus.textContent = "No se pudo obtener ubicación.";
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    );
  });

  // Buscar dirección en Modal con Nominatim
  btnEditBuscarDireccion?.addEventListener("click", async () => {
    const dir = inputDireccion.value.trim();
    if (!dir) {
      alert("Introduce una dirección.");
      return;
    }
    if (gpsEditStatus) {
      gpsEditStatus.textContent = "Buscando coordenadas...";
      gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
    }

    try {
      const resp = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(dir + ", Venezuela")}&limit=1`);
      if (resp.ok) {
        const res = await resp.json();
        if (res && res.length > 0) {
          const lat = parseFloat(res[0].lat);
          const lon = parseFloat(res[0].lon);
          latEditInput.value = lat.toFixed(6);
          lonEditInput.value = lon.toFixed(6);
          if (gpsEditStatus) {
            gpsEditStatus.textContent = `Encontrado: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
            gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
          }
          initEditMap(lat, lon, 15);
        } else {
          if (gpsEditStatus) {
            gpsEditStatus.textContent = "No encontrado.";
            gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
          }
        }
      }
    } catch {
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Error al buscar dirección.";
        gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
      }
    }
  });

  // Resolver link de Google Maps en Modal
  const btnEditResolverGmaps = document.getElementById("btn-edit-resolver-gmaps");
  const inputEditGmaps = document.getElementById("edit-gmaps-link") as HTMLInputElement;

  btnEditResolverGmaps?.addEventListener("click", async () => {
    const url = inputEditGmaps.value.trim();
    if (!url) {
      alert("Pega un enlace de Google Maps.");
      return;
    }
    if (gpsEditStatus) {
      gpsEditStatus.textContent = "Resolviendo enlace...";
      gpsEditStatus.className = "text-[11px] text-yellow-600 font-uber-text italic font-medium";
    }

    try {
      const resp = await fetch("/api/maps/resolve", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url })
      });
      if (resp.ok) {
        const data = await resp.json();
        latEditInput.value = data.lat.toFixed(6);
        lonEditInput.value = data.lng.toFixed(6);
        if (gpsEditStatus) {
          gpsEditStatus.textContent = `Resuelto: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
          gpsEditStatus.className = "text-[11px] text-success font-uber-text italic font-semibold";
        }
        initEditMap(data.lat, data.lng, 15);
      } else {
        const err = await resp.json();
        if (gpsEditStatus) {
          gpsEditStatus.textContent = `Error: ${err.error}`;
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }
    } catch {
      if (gpsEditStatus) {
        gpsEditStatus.textContent = "Error de conexión.";
        gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
      }
    }
  });

  // Abrir Modal y llenar campos
  document.querySelectorAll(".btn-edit-refugio").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const el = btn as HTMLElement;
      
      if (inputId) inputId.value = el.dataset.id || "";
      if (selectTipo) selectTipo.value = el.dataset.tipo || "refugio";
      if (inputEncargado) inputEncargado.value = el.dataset.encargado || "";
      if (inputDireccion) inputDireccion.value = el.dataset.direccion || "";
      if (inputOcupacion) inputOcupacion.value = el.dataset.ocupacion || "0";
      if (inputCapacidad) inputCapacidad.value = el.dataset.capacidad || "100";
      if (inputNecesidades) inputNecesidades.value = el.dataset.necesidades || "";
      if (inputContacto) inputContacto.value = el.dataset.contacto || "";
      if (editTitulo) editTitulo.textContent = `Actualizar: ${el.dataset.nombre}`;

      if (inputNinos) inputNinos.value = el.dataset.ninos || "0";
      if (inputBebes) inputBebes.value = el.dataset.bebes || "0";
      if (inputMayores) inputMayores.value = el.dataset.mayores || "0";
      if (inputProf) inputProf.value = el.dataset.prof || "0";
      if (inputVols) inputVols.value = el.dataset.vols || "0";

      // Cargar coordenadas actuales
      const latRaw = el.dataset.lat || "";
      const lngRaw = el.dataset.lng || "";
      latEditInput.value = latRaw;
      lonEditInput.value = lngRaw;

      if (gpsEditStatus) {
        if (latRaw && lngRaw) {
          gpsEditStatus.textContent = `Coordenadas cargadas: ${parseFloat(latRaw).toFixed(5)}, ${parseFloat(lngRaw).toFixed(5)}`;
          gpsEditStatus.className = "text-[11px] text-mute font-uber-text italic";
        } else {
          gpsEditStatus.textContent = "Ubicación no establecida.";
          gpsEditStatus.className = "text-[11px] text-red-500 font-uber-text italic";
        }
      }

      // Reiniciar Tabs de ubicación
      deseleccionarEditTabs();
      tabEditGps?.classList.add("bg-primary", "text-white");
      panelEditGps?.classList.remove("hidden");
      if (inputEditGmaps) inputEditGmaps.value = "";

      // Dibujar Mapa
      const lat = latRaw ? parseFloat(latRaw) : 10.4806;
      const lon = lngRaw ? parseFloat(lngRaw) : -66.9036;
      const zoom = latRaw && lngRaw ? 15 : 12;
      initEditMap(lat, lon, zoom);

      // Inicializar los radio buttons del inventario
      let inventarioObj: Record<string, string> = {};
      try {
        if (el.dataset.inventario) {
          inventarioObj = JSON.parse(el.dataset.inventario);
        }
      } catch (err) {
        console.error("Error al parsear dataset de inventario:", err);
      }

      // Reiniciar y setear radios
      const radios = form.querySelectorAll('input[type="radio"]');
      radios.forEach((r: any) => {
        r.checked = false;
        if (r.name.startsWith("edit-inv-")) {
          const itemId = r.name.replace("edit-inv-", "");
          const valorEsperado = inventarioObj[itemId] || "Estable";
          if (r.value === valorEsperado) {
            r.checked = true;
          }
        }
      });

      if (errorDiv) {
        errorDiv.textContent = "";
        errorDiv.classList.add("hidden");
      }

      modal?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    });
  });

  function cerrarModal() {
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  closeBtn?.addEventListener("click", cerrarModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) cerrarModal();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = inputId.value;
    const tipo = selectTipo.value;
    const encargado = inputEncargado.value.trim();
    const direccion = inputDireccion.value.trim();
    const ocupacion = parseInt(inputOcupacion.value);
    const capacidad = parseInt(inputCapacidad.value);
    const necesidades = inputNecesidades.value.trim();
    const contacto = inputContacto.value.trim();
    const lat = latEditInput.value;
    const lon = lonEditInput.value;

    const ninos = parseInt(inputNinos.value) || 0;
    const bebes = parseInt(inputBebes.value) || 0;
    const mayores = parseInt(inputMayores.value) || 0;
    const prof = parseInt(inputProf.value) || 0;
    const vols = parseInt(inputVols.value) || 0;

    const sumaSubgrupos = ninos + bebes + mayores + prof + vols;
    const demografiaWarning = document.getElementById("edit-demografia-warning");

    if (ocupacion < sumaSubgrupos) {
      if (demografiaWarning) demografiaWarning.classList.remove("hidden");
      if (errorDiv) {
        errorDiv.textContent = "Error: La Población Total no puede ser menor a la suma de niños, bebés, adultos mayores, profesionales y voluntarios.";
        errorDiv.classList.remove("hidden");
      }
      return;
    } else {
      if (demografiaWarning) demografiaWarning.classList.add("hidden");
    }

    if (isNaN(ocupacion) || ocupacion < 0) {
      alert("Ocupación inválida");
      return;
    }
    if (isNaN(capacidad) || capacidad <= 0) {
      alert("Capacidad inválida");
      return;
    }

    if (errorDiv) errorDiv.classList.add("hidden");

    // Recopilar inventario
    const inventario: Record<string, string> = {};
    const radios = form.querySelectorAll('input[type="radio"]:checked');
    radios.forEach((radio: any) => {
      if (radio.name.startsWith("edit-inv-")) {
        const itemId = radio.name.replace("edit-inv-", "");
        inventario[itemId] = radio.value;
      }
    });

    try {
      const resp = await fetch(`/api/refugios/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ocupacion_actual: ocupacion,
          capacidad_maxima: capacidad,
          necesidades,
          contacto,
          tipo,
          encargado,
          direccion,
          latitud: lat,
          longitud: lon,
          ninos,
          bebes_lactantes: bebes,
          adultos_mayores: mayores,
          personal_profesional: prof,
          voluntarios: vols,
          inventario
        })
      });

      if (resp.ok) {
        cerrarModal();
        window.location.reload();
      } else {
        const err = await resp.json();
        if (errorDiv) {
          errorDiv.textContent = `Error: ${err.error || "no se pudo actualizar"}`;
          errorDiv.classList.remove("hidden");
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = "Error de conexión con el servidor.";
        errorDiv.classList.remove("hidden");
      }
    }
  });
</script>
