---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

let refugiosIniciales: any[] = [];
try {
  const { DB } = env;
  if (DB) {
    const res = await DB.prepare("SELECT * FROM refugios ORDER BY nombre ASC").all();
    refugiosIniciales = res.results || [];
  }
} catch (error) {
  console.error("Error al cargar refugios iniciales:", error);
}
---

<Layout title="Refugios y Centros de Acopio - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-canvas max-w-4xl mx-auto w-full">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="font-uber-display text-2xl sm:text-3xl text-ink tracking-tight">
          Refugios y Centros de Acopio
        </h1>
        <p class="text-xs sm:text-sm text-body font-uber-text mt-1">
          Directorio en tiempo real de albergues activos y sus necesidades críticas.
        </p>
      </div>
      <a href="/refugios/nuevo" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong px-5 py-2.5 rounded-[36px] text-center shadow-sm shrink-0">
        ➕ Registrar Refugio
      </a>
    </div>

    <!-- Buscador de Refugios -->
    <div class="mb-6">
      <input 
        type="text" 
        id="search-refugios" 
        placeholder="Buscar refugio por nombre, ubicación o insumos..." 
        class="input w-full font-uber-text uber-body-md border border-canvas-soft bg-canvas px-4 py-3 rounded-xl focus:outline-none focus:ring-1 focus:ring-primary shadow-sm"
      />
    </div>

    <!-- Lista de Refugios -->
    <div id="refugios-container" class="space-y-4">
      {refugiosIniciales.length === 0 ? (
        <div class="text-center py-12 bg-canvas-soft border border-canvas-soft rounded-xl">
          <p class="text-sm text-mute font-uber-text">No hay refugios registrados en este momento.</p>
        </div>
      ) : (
        refugiosIniciales.map((r) => {
          const ocupacion = r.ocupacion_actual || 0;
          const capacidad = r.capacidad_maxima || 100;
          const pct = Math.min(Math.round((ocupacion / capacidad) * 100), 100);
          
          let colorBar = "bg-success"; // Verde
          if (pct >= 90) colorBar = "bg-error"; // Rojo
          else if (pct >= 70) colorBar = "bg-warning"; // Amarillo/Naranja

          return (
            <div 
              class="refugio-card bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm space-y-4 transition-all hover:shadow-md"
              data-nombre={r.nombre.toLowerCase()}
              data-direccion={(r.direccion || "").toLowerCase()}
              data-necesidades={(r.necesidades || "").toLowerCase()}
            >
              <div class="flex justify-between items-start gap-4">
                <div>
                  <h3 class="font-uber-display text-lg text-ink font-semibold">{r.nombre}</h3>
                  {r.direccion && <p class="text-xs text-body font-uber-text mt-0.5">📍 {r.direccion}</p>}
                </div>
                <div class="text-right shrink-0">
                  <span class="text-xs font-semibold text-ink font-uber-text bg-canvas-soft px-2.5 py-1 rounded-full border border-canvas-soft">
                    {ocupacion} / {capacidad} personas
                  </span>
                </div>
              </div>

              <!-- Barra de capacidad -->
              <div class="space-y-1">
                <div class="flex justify-between text-[11px] font-uber-text font-medium text-mute">
                  <span>Capacidad ocupada</span>
                  <span>{pct}%</span>
                </div>
                <div class="w-full bg-canvas-soft h-2.5 rounded-full overflow-hidden border border-canvas-soft">
                  <div class={`h-full ${colorBar}`} style={`width: ${pct}%`}></div>
                </div>
              </div>

              <!-- Necesidades / Insumos -->
              {r.necesidades && (
                <div class="bg-yellow-500/5 border border-yellow-500/20 p-3 rounded-lg">
                  <div class="text-[10px] font-bold text-yellow-800 uppercase tracking-wider mb-1 font-uber-text">🚨 Insumos requeridos urgentemente</div>
                  <p class="text-xs text-body font-uber-text font-medium">{r.necesidades}</p>
                </div>
              )}

              <!-- Contacto y acciones -->
              <div class="flex flex-wrap items-center justify-between gap-3 pt-2 border-t border-canvas-soft">
                <div class="text-xs text-mute font-uber-text">
                  {r.contacto ? `📞 Contacto: ${r.contacto}` : "Sin información de contacto"}
                </div>
                <button 
                  class="btn-edit-refugio btn btn-xs bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text font-semibold px-3 py-1.5 rounded-lg border border-canvas-soft cursor-pointer"
                  data-id={r.id}
                  data-nombre={r.nombre}
                  data-ocupacion={ocupacion}
                  data-capacidad={capacidad}
                  data-necesidades={r.necesidades || ""}
                  data-contacto={r.contacto || ""}
                  data-direccion={r.direccion || ""}
                >
                  ✏️ Actualizar Estado
                </button>
              </div>
            </div>
          );
        })
      )}
    </div>
  </main>

  <!-- Modal para actualizar refugio -->
  <div id="modal-edit-refugio" class="fixed inset-0 z-50 bg-black/60 hidden flex items-end sm:items-center justify-center animate-fade-in" style="backdrop-filter:blur(4px)">
    <div class="bg-canvas w-full sm:max-w-md sm:rounded-2xl rounded-t-2xl p-6 space-y-4 max-h-[90vh] overflow-y-auto border border-canvas-soft shadow-xl">
      <div class="flex justify-between items-center">
        <h3 class="font-uber-display text-lg text-ink font-semibold" id="edit-refugio-titulo">Actualizar Refugio</h3>
        <button id="btn-close-edit" class="w-8 h-8 rounded-full bg-canvas-soft flex items-center justify-center text-ink text-sm hover:bg-surface-pressed cursor-pointer">✕</button>
      </div>

      <form id="form-edit-refugio" class="space-y-4">
        <input type="hidden" id="edit-refugio-id" />
        
        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-ocupacion">Ocupación Actual (Personas) *</label>
          <input 
            type="number" 
            id="edit-ocupacion" 
            required 
            min="0"
            class="input w-full font-uber-text uber-body-md" 
          />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-capacidad">Capacidad Máxima *</label>
          <input 
            type="number" 
            id="edit-capacidad" 
            required 
            min="1"
            class="input w-full font-uber-text uber-body-md" 
          />
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-necesidades">Necesidades de Insumos (ej. agua, medicinas)</label>
          <textarea 
            id="edit-necesidades" 
            rows="3"
            class="textarea w-full font-uber-text uber-body-md" 
            placeholder="Ej: Agua mineral, mantas, leche de fórmula..."
          ></textarea>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-contacto">Teléfono o Datos de Contacto</label>
          <input 
            type="text" 
            id="edit-contacto" 
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: 0412-1234567"
          />
        </div>

        <div id="edit-refugio-error" class="hidden text-xs text-red-500 font-uber-text bg-red-500/5 border border-red-500/20 p-3 rounded-lg"></div>

        <button type="submit" class="btn bg-primary text-white w-full font-uber-text font-semibold py-2.5 rounded-xl">
          Guardar Cambios
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById("search-refugios") as HTMLInputElement;
  const cards = document.querySelectorAll(".refugio-card");

  // Filtro en el cliente
  searchInput?.addEventListener("input", () => {
    const term = searchInput.value.toLowerCase().trim();
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const nombre = el.dataset.nombre || "";
      const direccion = el.dataset.direccion || "";
      const necesidades = el.dataset.necesidades || "";

      if (nombre.includes(term) || direccion.includes(term) || necesidades.includes(term)) {
        el.classList.remove("hidden");
      } else {
        el.classList.add("hidden");
      }
    });
  });

  // Modal de edición
  const modal = document.getElementById("modal-edit-refugio");
  const closeBtn = document.getElementById("btn-close-edit");
  const form = document.getElementById("form-edit-refugio") as HTMLFormElement;
  const errorDiv = document.getElementById("edit-refugio-error");

  const inputId = document.getElementById("edit-refugio-id") as HTMLInputElement;
  const inputOcupacion = document.getElementById("edit-ocupacion") as HTMLInputElement;
  const inputCapacidad = document.getElementById("edit-capacidad") as HTMLInputElement;
  const inputNecesidades = document.getElementById("edit-necesidades") as HTMLTextAreaElement;
  const inputContacto = document.getElementById("edit-contacto") as HTMLInputElement;
  const editTitulo = document.getElementById("edit-refugio-titulo");

  document.querySelectorAll(".btn-edit-refugio").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const el = btn as HTMLElement;
      
      if (inputId) inputId.value = el.dataset.id || "";
      if (inputOcupacion) inputOcupacion.value = el.dataset.ocupacion || "0";
      if (inputCapacidad) inputCapacidad.value = el.dataset.capacidad || "100";
      if (inputNecesidades) inputNecesidades.value = el.dataset.necesidades || "";
      if (inputContacto) inputContacto.value = el.dataset.contacto || "";
      if (editTitulo) editTitulo.textContent = `Actualizar: ${el.dataset.nombre}`;

      if (errorDiv) {
        errorDiv.textContent = "";
        errorDiv.classList.add("hidden");
      }

      modal?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    });
  });

  function cerrarModal() {
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  closeBtn?.addEventListener("click", cerrarModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) cerrarModal();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = inputId.value;
    const ocupacion = parseInt(inputOcupacion.value);
    const capacidad = parseInt(inputCapacidad.value);
    const necesidades = inputNecesidades.value.trim();
    const contacto = inputContacto.value.trim();

    if (isNaN(ocupacion) || ocupacion < 0) {
      alert("Ocupación inválida");
      return;
    }
    if (isNaN(capacidad) || capacidad <= 0) {
      alert("Capacidad inválida");
      return;
    }

    if (errorDiv) errorDiv.classList.add("hidden");

    try {
      const resp = await fetch(`/api/refugios/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ocupacion_actual: ocupacion,
          capacidad_maxima: capacidad,
          necesidades,
          contacto
        })
      });

      if (resp.ok) {
        cerrarModal();
        window.location.reload();
      } else {
        const err = await resp.json();
        if (errorDiv) {
          errorDiv.textContent = `Error: ${err.error || "no se pudo actualizar"}`;
          errorDiv.classList.remove("hidden");
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = "Error de conexión con el servidor.";
        errorDiv.classList.remove("hidden");
      }
    }
  });
</script>
