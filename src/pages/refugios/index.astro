---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";
import { CATEGORIAS_INVENTARIO } from "../../lib/items";
import { obtenerVoluntarioSesion } from "../../lib/auth-helpers";

export const prerender = false;

let refugiosIniciales: any[] = [];
let esVoluntario = false;

try {
  const { DB } = env;
  if (DB) {
    const res = await DB.prepare("SELECT * FROM refugios ORDER BY nombre ASC").all();
    refugiosIniciales = res.results || [];

    const sessionToken = Astro.cookies.get("session_token")?.value;
    const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    if (voluntario) {
      esVoluntario = true;
    }
  }
} catch (error) {
  console.error("Error al cargar refugios iniciales:", error);
}
---

<Layout title="Refugios y Centros de Acopio - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-6 sm:py-12 px-4 bg-canvas max-w-4xl mx-auto w-full">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="font-uber-display text-2xl sm:text-3xl text-ink tracking-tight">
          Refugios y Centros de Acopio
        </h1>
        <p class="text-xs sm:text-sm text-body font-uber-text mt-1">
          Directorio en tiempo real de albergues activos y sus necesidades críticas.
        </p>
      </div>
      <a href="/refugios/nuevo" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong px-5 py-2.5 rounded-[36px] text-center shadow-sm shrink-0">
        ➕ Registrar Refugio
      </a>
    </div>

    <!-- Buscador de Refugios -->
    <div class="mb-6">
      <input 
        type="text" 
        id="search-refugios" 
        placeholder="Buscar refugio por nombre, ubicación o insumos..." 
        class="input w-full font-uber-text uber-body-md border border-canvas-soft bg-canvas px-4 py-3 rounded-xl focus:outline-none focus:ring-1 focus:ring-primary shadow-sm"
      />
    </div>

    <!-- Lista de Refugios -->
    <div id="refugios-container" class="space-y-4">
      {refugiosIniciales.length === 0 ? (
        <div class="text-center py-12 bg-canvas-soft border border-canvas-soft rounded-xl">
          <p class="text-sm text-mute font-uber-text">No hay centros registrados en este momento.</p>
        </div>
      ) : (
        refugiosIniciales.map((r) => {
          const ocupacion = r.ocupacion_actual || 0;
          const capacidad = r.capacidad_maxima || 100;
          const pct = Math.min(Math.round((ocupacion / capacidad) * 100), 100);
          
          let colorBar = "bg-success"; // Verde
          if (pct >= 90) colorBar = "bg-error"; // Rojo
          else if (pct >= 70) colorBar = "bg-warning"; // Amarillo/Naranja

          let tipoLabel = "Refugio / Albergue";
          let tipoColor = "bg-blue-100 text-blue-800 border-blue-200";
          if (r.tipo === "hospital") {
            tipoLabel = "Hospital / Salud";
            tipoColor = "bg-red-100 text-red-800 border-red-200";
          } else if (r.tipo === "centro_acopio") {
            tipoLabel = "Centro de Acopio";
            tipoColor = "bg-yellow-100 text-yellow-800 border-yellow-200";
          }

          // Parsear inventario para extraer críticos y alertas
          let itemsCriticos: string[] = [];
          let itemsAlerta: string[] = [];
          if (r.inventario) {
            try {
              const inv = typeof r.inventario === 'string' ? JSON.parse(r.inventario) : r.inventario;
              for (const [itemId, estado] of Object.entries(inv)) {
                const itemObj = CATEGORIAS_INVENTARIO.flatMap(c => c.items).find(i => i.id === itemId);
                if (itemObj) {
                  if (estado === "Crítico") {
                    itemsCriticos.push(itemObj.nombre);
                  } else if (estado === "Alerta") {
                    itemsAlerta.push(itemObj.nombre);
                  }
                }
              }
            } catch (e) {
              console.error("Error al parsear inventario:", e);
            }
          }

          // Formatear fecha
          let fechaFormateada = "";
          if (r.fecha_registro) {
            try {
              fechaFormateada = new Date(r.fecha_registro).toLocaleString('es-VE', {
                dateStyle: 'short',
                timeStyle: 'short'
              });
            } catch {
              fechaFormateada = r.fecha_registro;
            }
          }

          return (
            <div 
              class="refugio-card bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm space-y-4 transition-all hover:shadow-md"
              data-nombre={r.nombre.toLowerCase()}
              data-direccion={(r.direccion || "").toLowerCase()}
              data-necesidades={(r.necesidades || "").toLowerCase()}
            >
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full border ${tipoColor} font-uber-text`}>
                      {tipoLabel}
                    </span>
                    <h3 class="font-uber-display text-lg text-ink font-semibold">{r.nombre}</h3>
                  </div>
                  {r.direccion && <p class="text-xs text-body font-uber-text mt-1">📍 {r.direccion}</p>}
                </div>
                <div class="text-right shrink-0">
                  <span class="text-xs font-semibold text-ink font-uber-text bg-canvas-soft px-2.5 py-1 rounded-full border border-canvas-soft">
                    {ocupacion} / {capacidad} personas
                  </span>
                </div>
              </div>

              <!-- Encargado y Fecha -->
              {(r.encargado || fechaFormateada) && (
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-uber-text text-body border-t border-canvas-soft pt-2">
                  {r.encargado && <span>👤 Encargado: <strong>{r.encargado}</strong></span>}
                  {fechaFormateada && <span>📅 Reportado: <strong>{fechaFormateada}</strong></span>}
                </div>
              )}

              <!-- Barra de capacidad -->
              <div class="space-y-1">
                <div class="flex justify-between text-[11px] font-uber-text font-medium text-mute">
                  <span>Capacidad ocupada</span>
                  <span>{pct}%</span>
                </div>
                <div class="w-full bg-canvas-soft h-2.5 rounded-full overflow-hidden border border-canvas-soft">
                  <div class={`h-full ${colorBar}`} style={`width: ${pct}%`}></div>
                </div>
              </div>

              <!-- Demografía -->
              <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 text-xs font-uber-text bg-canvas-soft p-3 rounded-lg border border-canvas-soft">
                <div>👶 Niños: <strong class="text-ink">{r.ninos || 0}</strong></div>
                <div>🍼 Lactantes: <strong class="text-ink">{r.bebes_lactantes || 0}</strong></div>
                <div>👵 Mayores: <strong class="text-ink">{r.adultos_mayores || 0}</strong></div>
                <div>🩺 Personal: <strong class="text-ink">{r.personal_profesional || 0}</strong></div>
                <div>🤝 Vols: <strong class="text-ink">{r.voluntarios || 0}</strong></div>
              </div>

              <!-- Inventario Crítico/Alerta -->
              {(itemsCriticos.length > 0 || itemsAlerta.length > 0) && (
                <div class="space-y-1.5 bg-canvas-soft/50 border border-canvas-soft p-3 rounded-lg">
                  {itemsCriticos.length > 0 && (
                    <div class="flex flex-wrap gap-1 items-center">
                      <span class="text-[9px] font-bold text-red-700 uppercase tracking-wider font-uber-text mr-1">Crítico:</span>
                      {itemsCriticos.map(item => (
                        <span class="text-[9px] bg-red-500/10 text-red-700 font-semibold px-2 py-0.5 rounded-full border border-red-500/20">{item}</span>
                      ))}
                    </div>
                  )}
                  {itemsAlerta.length > 0 && (
                    <div class="flex flex-wrap gap-1 items-center">
                      <span class="text-[9px] font-bold text-amber-700 uppercase tracking-wider font-uber-text mr-1">Alerta:</span>
                      {itemsAlerta.map(item => (
                        <span class="text-[9px] bg-amber-500/10 text-amber-700 font-semibold px-2 py-0.5 rounded-full border border-amber-500/20">{item}</span>
                      ))}
                    </div>
                  )}
                </div>
              )}

              <!-- Necesidades (Texto Libre) -->
              {r.necesidades && (
                <div class="bg-yellow-500/5 border border-yellow-500/20 p-3 rounded-lg">
                  <div class="text-[10px] font-bold text-yellow-800 uppercase tracking-wider mb-1 font-uber-text">🚨 Notas de Necesidades</div>
                  <p class="text-xs text-body font-uber-text font-medium">{r.necesidades}</p>
                </div>
              )}

              <!-- Contacto y acciones -->
              <div class="flex flex-wrap items-center justify-between gap-3 pt-2 border-t border-canvas-soft">
                <div class="text-xs text-mute font-uber-text">
                  {r.contacto ? `📞 Contacto: ${r.contacto}` : "Sin información de contacto"}
                </div>
                {esVoluntario && (
                  <button 
                    class="btn-edit-refugio btn btn-xs bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text font-semibold px-3 py-1.5 rounded-lg border border-canvas-soft cursor-pointer"
                    data-id={r.id}
                    data-nombre={r.nombre}
                    data-ocupacion={ocupacion}
                    data-capacidad={capacidad}
                    data-necesidades={r.necesidades || ""}
                    data-contacto={r.contacto || ""}
                    data-direccion={r.direccion || ""}
                    data-tipo={r.tipo || "refugio"}
                    data-encargado={r.encargado || ""}
                    data-ninos={r.ninos || 0}
                    data-bebes={r.bebes_lactantes || 0}
                    data-mayores={r.adultos_mayores || 0}
                    data-prof={r.personal_profesional || 0}
                    data-vols={r.voluntarios || 0}
                    data-inventario={typeof r.inventario === 'string' ? r.inventario : JSON.stringify(r.inventario || {})}
                    data-fecha={r.fecha_registro || ""}
                  >
                    ✏️ Actualizar Estado
                  </button>
                )}
              </div>
            </div>
          );
        })
      )}
    </div>
  </main>

  <!-- Modal para actualizar refugio -->
  <div id="modal-edit-refugio" class="fixed inset-0 z-50 bg-black/60 hidden flex items-end sm:items-center justify-center animate-fade-in" style="backdrop-filter:blur(4px)">
    <div class="bg-canvas w-full sm:max-w-lg sm:rounded-2xl rounded-t-2xl p-6 space-y-4 max-h-[95vh] overflow-y-auto border border-canvas-soft shadow-xl">
      <div class="flex justify-between items-center">
        <h3 class="font-uber-display text-lg text-ink font-semibold" id="edit-refugio-titulo">Actualizar Centro</h3>
        <button id="btn-close-edit" class="w-8 h-8 rounded-full bg-canvas-soft flex items-center justify-center text-ink text-sm hover:bg-surface-pressed cursor-pointer">✕</button>
      </div>

      <form id="form-edit-refugio" class="space-y-4">
        <input type="hidden" id="edit-refugio-id" />
        
        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-tipo">Tipo de Centro *</label>
          <select id="edit-tipo" required class="select w-full font-uber-text uber-body-md">
            <option value="refugio">Refugio / Albergue</option>
            <option value="centro_acopio">Centro de Acopio</option>
            <option value="hospital">Hospital / Puesto de Salud</option>
          </select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-encargado">Encargado *</label>
            <input 
              type="text" 
              id="edit-encargado" 
              required
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-fecha-registro">Fecha y Hora *</label>
            <input 
              type="datetime-local" 
              id="edit-fecha-registro" 
              required
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-capacidad">Capacidad Máxima *</label>
            <input 
              type="number" 
              id="edit-capacidad" 
              required 
              min="1"
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-ocupacion">Población Total *</label>
            <input 
              type="number" 
              id="edit-ocupacion" 
              required 
              min="0"
              class="input w-full font-uber-text uber-body-md" 
            />
          </div>
        </div>

        <div class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-2">
          <span class="text-xs font-semibold text-ink font-uber-text block">👥 Desglose de Población</span>
          <div class="grid grid-cols-3 gap-2">
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-ninos">Niños</label>
              <input type="number" id="edit-ninos" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-bebes">Bebés</label>
              <input type="number" id="edit-bebes" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-mayores">Adultos M.</label>
              <input type="number" id="edit-mayores" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-prof">Prof. Salud</label>
              <input type="number" id="edit-prof" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
            <div>
              <label class="block text-[9px] font-bold text-mute uppercase font-uber-text" for="edit-vols">Voluntarios</label>
              <input type="number" id="edit-vols" min="0" class="input w-full font-uber-text text-xs p-2 min-h-[36px]" />
            </div>
          </div>
          <div id="edit-demografia-warning" class="hidden text-[10px] text-red-500 font-uber-text font-medium bg-red-500/5 p-2 rounded">
            ⚠️ La Población Total debe ser mayor o igual a la suma de los subgrupos.
          </div>
        </div>

        <div class="bg-canvas border border-canvas-soft p-3 rounded-xl space-y-3">
          <span class="text-xs font-semibold text-ink font-uber-text block">📋 Estado del Inventario (43 Ítems)</span>
          
          <div class="flex gap-1 overflow-x-auto pb-1.5 border-b border-canvas-soft scrollbar-none" id="edit-tabs-container">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <button 
                type="button" 
                class={`edit-tab-btn font-uber-text text-[11px] whitespace-nowrap px-2.5 py-1 rounded-lg border ${idx === 0 ? 'bg-primary text-white border-primary' : 'bg-canvas-soft text-ink border-transparent'} cursor-pointer`}
                data-target={`edit-tab-${idx}`}
              >
                {cat.nombre}
              </button>
            ))}
          </div>

          <div class="edit-tab-contents max-h-48 overflow-y-auto">
            {CATEGORIAS_INVENTARIO.map((cat, idx) => (
              <div id={`edit-tab-${idx}`} class={`edit-tab-pane space-y-2 ${idx === 0 ? '' : 'hidden'}`}>
                {cat.items.map((item) => (
                  <div class="flex flex-col gap-1 py-1 border-b border-canvas-soft last:border-b-0">
                    <span class="text-[11px] font-uber-text text-ink font-medium">{item.nombre}</span>
                    <div class="flex gap-0.5 bg-canvas-soft p-0.5 rounded-lg w-full overflow-x-auto">
                      {["Crítico", "Alerta", "Estable", "Excedente"].map((est) => {
                        let activeClass = "";
                        if (est === "Crítico") activeClass = "has-[:checked]:bg-red-500 has-[:checked]:text-white";
                        else if (est === "Alerta") activeClass = "has-[:checked]:bg-amber-500 has-[:checked]:text-white";
                        else if (est === "Estable") activeClass = "has-[:checked]:bg-green-600 has-[:checked]:text-white";
                        else if (est === "Excedente") activeClass = "has-[:checked]:bg-blue-600 has-[:checked]:text-white";

                        return (
                          <label class={`flex-grow text-center py-1 text-[9px] rounded-md cursor-pointer transition-all font-semibold font-uber-text select-none border border-transparent hover:bg-surface-pressed ${activeClass}`}>
                            <input 
                              type="radio" 
                              name={`edit-inv-${item.id}`} 
                              value={est} 
                              class="hidden" 
                            />
                            {est}
                          </label>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-necesidades">Notas Adicionales de Necesidades (Texto Libre)</label>
          <textarea 
            id="edit-necesidades" 
            rows="2"
            class="textarea w-full font-uber-text uber-body-md" 
            placeholder="Ej: Agua mineral, mantas, leche de fórmula..."
          ></textarea>
        </div>

        <div>
          <label class="block text-[10px] font-bold text-mute uppercase tracking-wider mb-1 font-uber-text" for="edit-contacto">Teléfono o Datos de Contacto</label>
          <input 
            type="text" 
            id="edit-contacto" 
            class="input w-full font-uber-text uber-body-md" 
            placeholder="Ej: 0412-1234567"
          />
        </div>

        <div id="edit-refugio-error" class="hidden text-xs text-red-500 font-uber-text bg-red-500/5 border border-red-500/20 p-3 rounded-lg"></div>

        <button type="submit" class="btn bg-primary text-white w-full font-uber-text font-semibold py-2.5 rounded-xl">
          Guardar Cambios
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById("search-refugios") as HTMLInputElement;
  const cards = document.querySelectorAll(".refugio-card");

  // Filtro en el cliente
  searchInput?.addEventListener("input", () => {
    const term = searchInput.value.toLowerCase().trim();
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const nombre = el.dataset.nombre || "";
      const direccion = el.dataset.direccion || "";
      const necesidades = el.dataset.necesidades || "";

      if (nombre.includes(term) || direccion.includes(term) || necesidades.includes(term)) {
        el.classList.remove("hidden");
      } else {
        el.classList.add("hidden");
      }
    });
  });

  // Modal de edición
  const modal = document.getElementById("modal-edit-refugio");
  const closeBtn = document.getElementById("btn-close-edit");
  const form = document.getElementById("form-edit-refugio") as HTMLFormElement;
  const errorDiv = document.getElementById("edit-refugio-error");

  const inputId = document.getElementById("edit-refugio-id") as HTMLInputElement;
  const selectTipo = document.getElementById("edit-tipo") as HTMLSelectElement;
  const inputEncargado = document.getElementById("edit-encargado") as HTMLInputElement;
  const inputFecha = document.getElementById("edit-fecha-registro") as HTMLInputElement;
  const inputOcupacion = document.getElementById("edit-ocupacion") as HTMLInputElement;
  const inputCapacidad = document.getElementById("edit-capacidad") as HTMLInputElement;
  const inputNecesidades = document.getElementById("edit-necesidades") as HTMLTextAreaElement;
  const inputContacto = document.getElementById("edit-contacto") as HTMLInputElement;
  const editTitulo = document.getElementById("edit-refugio-titulo");

  const inputNinos = document.getElementById("edit-ninos") as HTMLInputElement;
  const inputBebes = document.getElementById("edit-bebes") as HTMLInputElement;
  const inputMayores = document.getElementById("edit-mayores") as HTMLInputElement;
  const inputProf = document.getElementById("edit-prof") as HTMLInputElement;
  const inputVols = document.getElementById("edit-vols") as HTMLInputElement;

  // Lógica de pestañas del modal
  const editTabBtns = document.querySelectorAll(".edit-tab-btn");
  editTabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      editTabBtns.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "border-primary");
        b.classList.add("bg-canvas-soft", "text-ink", "border-transparent");
      });
      btn.classList.add("bg-primary", "text-white", "border-primary");
      btn.classList.remove("bg-canvas-soft", "text-ink", "border-transparent");

      document.querySelectorAll(".edit-tab-pane").forEach((pane) => pane.classList.add("hidden"));
      const targetId = btn.getAttribute("data-target");
      if (targetId) {
        document.getElementById(targetId)?.classList.remove("hidden");
      }
    });
  });

  document.querySelectorAll(".btn-edit-refugio").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const el = btn as HTMLElement;
      
      if (inputId) inputId.value = el.dataset.id || "";
      if (selectTipo) selectTipo.value = el.dataset.tipo || "refugio";
      if (inputEncargado) inputEncargado.value = el.dataset.encargado || "";
      if (inputOcupacion) inputOcupacion.value = el.dataset.ocupacion || "0";
      if (inputCapacidad) inputCapacidad.value = el.dataset.capacidad || "100";
      if (inputNecesidades) inputNecesidades.value = el.dataset.necesidades || "";
      if (inputContacto) inputContacto.value = el.dataset.contacto || "";
      if (editTitulo) editTitulo.textContent = `Actualizar: ${el.dataset.nombre}`;

      if (inputNinos) inputNinos.value = el.dataset.ninos || "0";
      if (inputBebes) inputBebes.value = el.dataset.bebes || "0";
      if (inputMayores) inputMayores.value = el.dataset.mayores || "0";
      if (inputProf) inputProf.value = el.dataset.prof || "0";
      if (inputVols) inputVols.value = el.dataset.vols || "0";

      // Setear fecha y hora
      if (inputFecha) {
        if (el.dataset.fecha) {
          inputFecha.value = el.dataset.fecha.slice(0, 16);
        } else {
          const ahora = new Date();
          const tzOffset = ahora.getTimezoneOffset() * 60000;
          inputFecha.value = (new Date(ahora.getTime() - tzOffset)).toISOString().slice(0, 16);
        }
      }

      // Inicializar los radio buttons del inventario
      let inventarioObj: Record<string, string> = {};
      try {
        if (el.dataset.inventario) {
          inventarioObj = JSON.parse(el.dataset.inventario);
        }
      } catch (err) {
        console.error("Error al parsear dataset de inventario:", err);
      }

      // Reiniciar y setear radios
      const radios = form.querySelectorAll('input[type="radio"]');
      radios.forEach((r: any) => {
        r.checked = false;
        if (r.name.startsWith("edit-inv-")) {
          const itemId = r.name.replace("edit-inv-", "");
          const valorEsperado = inventarioObj[itemId] || "Estable"; // Por defecto Estable si no existe
          if (r.value === valorEsperado) {
            r.checked = true;
          }
        }
      });

      if (errorDiv) {
        errorDiv.textContent = "";
        errorDiv.classList.add("hidden");
      }

      modal?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    });
  });

  function cerrarModal() {
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  closeBtn?.addEventListener("click", cerrarModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) cerrarModal();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = inputId.value;
    const tipo = selectTipo.value;
    const encargado = inputEncargado.value.trim();
    const fecha_registro = inputFecha.value;
    const ocupacion = parseInt(inputOcupacion.value);
    const capacidad = parseInt(inputCapacidad.value);
    const necesidades = inputNecesidades.value.trim();
    const contacto = inputContacto.value.trim();

    const ninos = parseInt(inputNinos.value) || 0;
    const bebes = parseInt(inputBebes.value) || 0;
    const mayores = parseInt(inputMayores.value) || 0;
    const prof = parseInt(inputProf.value) || 0;
    const vols = parseInt(inputVols.value) || 0;

    const sumaSubgrupos = ninos + bebes + mayores + prof + vols;
    const demografiaWarning = document.getElementById("edit-demografia-warning");

    if (ocupacion < sumaSubgrupos) {
      if (demografiaWarning) demografiaWarning.classList.remove("hidden");
      if (errorDiv) {
        errorDiv.textContent = "Error: La Población Total no puede ser menor a la suma de niños, bebés, adultos mayores, profesionales y voluntarios.";
        errorDiv.classList.remove("hidden");
      }
      return;
    } else {
      if (demografiaWarning) demografiaWarning.classList.add("hidden");
    }

    if (isNaN(ocupacion) || ocupacion < 0) {
      alert("Ocupación inválida");
      return;
    }
    if (isNaN(capacidad) || capacidad <= 0) {
      alert("Capacidad inválida");
      return;
    }

    if (errorDiv) errorDiv.classList.add("hidden");

    // Recopilar inventario
    const inventario: Record<string, string> = {};
    const radios = form.querySelectorAll('input[type="radio"]:checked');
    radios.forEach((radio: any) => {
      if (radio.name.startsWith("edit-inv-")) {
        const itemId = radio.name.replace("edit-inv-", "");
        inventario[itemId] = radio.value;
      }
    });

    try {
      const resp = await fetch(`/api/refugios/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ocupacion_actual: ocupacion,
          capacidad_maxima: capacidad,
          necesidades,
          contacto,
          tipo,
          encargado,
          ninos,
          bebes_lactantes: bebes,
          adultos_mayores: mayores,
          personal_profesional: prof,
          voluntarios: vols,
          inventario,
          fecha_registro
        })
      });

      if (resp.ok) {
        cerrarModal();
        window.location.reload();
      } else {
        const err = await resp.json();
        if (errorDiv) {
          errorDiv.textContent = `Error: ${err.error || "no se pudo actualizar"}`;
          errorDiv.classList.remove("hidden");
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = "Error de conexión con el servidor.";
        errorDiv.classList.remove("hidden");
      }
    }
  });
</script>
