---
import Layout from "../layouts/Layout.astro";
import TelegramMenu from "../components/TelegramMenu.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";

export const prerender = false;

let esVoluntario = false;

try {
  const { DB } = env;
  if (DB) {
    const sessionToken = Astro.cookies.get("session_token")?.value;
    const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    esVoluntario = !!voluntario;
  }
} catch (e) {
  console.error("Error al cargar sesión en menú:", e);
}
---

<Layout title="Menú Principal">
  <main class="min-h-screen bg-[var(--tg-theme-bg-color,var(--color-canvas))]">
    <TelegramMenu isVoluntario={esVoluntario} />
  </main>
</Layout>
