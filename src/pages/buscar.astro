---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BuscadorRapido from "../components/BuscadorRapido.astro";
import { env } from "cloudflare:workers";
import { obtenerVoluntarioSesion } from "../lib/auth-helpers";

export const prerender = false;

let esVoluntario = false;
try {
  const { DB } = env;
  if (DB) {
    const sessionToken = Astro.cookies.get("session_token")?.value;
    const voluntario = await obtenerVoluntarioSesion(DB, sessionToken);
    if (voluntario) {
      esVoluntario = true;
    }
  }
} catch (error) {
  console.error("Error al obtener sesión en buscar:", error);
}
---
<Layout title="Buscar Personas - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 sm:py-12 px-4 bg-base-200 min-h-screen">
    <div class="text-center max-w-2xl mx-auto mb-10 pt-4">
      <h1 class="text-4xl md:text-5xl font-black text-base-content tracking-tight mb-3">
        Buscar Personas y Reportes
      </h1>
      <p class="text-base-content/70 leading-relaxed max-w-xl mx-auto px-2 mb-6">
        Consulta el censo de personas localizadas o reportadas como desaparecidas en nuestra plataforma.
      </p>
      
      <!-- BOTÓN ESTOY A SALVO TRASLADADO -->
      <div class="flex justify-center">
        <button id="btn-estoy-a-salvo" class="btn btn-outline btn-success rounded-full gap-2 hover:-translate-y-0.5 transition-transform shadow-sm">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-success animate-pulse"></span>
          Estoy a Salvo / Reportar Localizado
        </button>
      </div>
    </div>

    <BuscadorRapido />
  </main>

  <!-- Modal "Localizado" trasladado -->
  <div id="modal-salvo" class="fixed inset-0 z-[120] bg-black/60 hidden flex items-end sm:items-center justify-center animate-fade-in" style="backdrop-filter:blur(4px)">
    <div class="bg-base-100 w-full sm:max-w-md sm:rounded-2xl rounded-t-2xl p-6 space-y-4 max-h-[90vh] overflow-y-auto shadow-2xl border border-base-200">
      <div class="flex justify-between items-center">
        <h3 class="text-xl font-bold text-base-content">Localizado</h3>
        <button id="btn-close-salvo" class="btn btn-sm btn-circle btn-ghost">✕</button>
      </div>
      <p class="text-sm text-base-content/70">
        Si eres una persona reportada o deseas registrar que estás localizado, ingresa tu cédula o nombre completo para buscarte en el censo.
      </p>
      
      <form id="form-salvo-buscar" class="space-y-3">
        <div class="flex flex-col gap-3">
          <input 
            type="text" 
            id="input-salvo-query" 
            required
            class="input input-bordered w-full rounded-xl" 
            placeholder="Tu Cédula o Nombre completo..." 
          />
          <button type="submit" class="btn btn-primary w-full rounded-xl">
            Buscar registro
          </button>
        </div>
      </form>

      <!-- Resultados del auto-reporte -->
      <div id="salvo-results-loader" class="hidden flex justify-center py-4">
        <span class="loading loading-spinner text-primary"></span>
      </div>
      <div id="salvo-results" class="space-y-3 max-h-60 overflow-y-auto pr-1"></div>

      <div id="salvo-no-results" data-es-voluntario={esVoluntario ? "true" : "false"} class="hidden text-center py-4 space-y-3 border-t border-base-200">
        <p class="text-sm text-base-content/70">
          No encontramos un registro con tus datos en la base de datos.
        </p>
        {esVoluntario ? (
          <a id="btn-salvo-registrar" href="/registrar" class="btn btn-primary w-full rounded-xl">
            Registrar en el censo
          </a>
        ) : (
          <a id="btn-salvo-registrar" href="/reportar" class="btn btn-primary w-full rounded-xl">
            Emitir reporte de emergencia
          </a>
        )}
      </div>

      <!-- Contenedor secundario para confirmar datos, contacto y GPS -->
      <div id="salvo-confirmar-container" class="hidden space-y-4 border-t border-base-200 pt-4 animate-fade-in">
        <h4 class="text-base font-bold text-base-content">Completar datos de ubicación y contacto</h4>
        <p class="text-xs text-base-content/70">
          Ingresa información real para notificar y reconectar con tus familiares.
        </p>
        
        <div class="space-y-3">
          <div class="form-control">
            <label class="label" for="salvo-contacto">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Tu Teléfono / Contacto Actual *</span>
            </label>
            <input 
              type="text" 
              id="salvo-contacto" 
              required 
              class="input input-bordered w-full rounded-xl" 
              placeholder="Ej: 0412-1234567, telegram, email..."
            />
          </div>
          <div class="form-control">
            <label class="label" for="salvo-refugio">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">¿Dónde te encuentras? / Refugio</span>
            </label>
            <input 
              type="text" 
              id="salvo-refugio" 
              class="input input-bordered w-full rounded-xl" 
              placeholder="Ej: Albergue Polideportivo, casa de familiares..."
            />
          </div>
          <div class="form-control">
            <label class="label" for="salvo-estado-salud">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Tu Estado de Salud (Opcional)</span>
            </label>
            <select id="salvo-estado-salud" class="select select-bordered w-full rounded-xl">
              <option value="localizado">Localizado / Sin lesiones</option>
              <option value="herido">Herido / Requiere asistencia médica</option>
            </select>
          </div>
          <div class="form-control">
            <label class="label" for="salvo-notas">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Mensaje rápido o Necesidades</span>
            </label>
            <textarea 
              id="salvo-notas" 
              rows="2" 
              class="textarea textarea-bordered w-full rounded-xl" 
              placeholder="Ej: Estoy bien, necesito medicamentos para la tensión."
            ></textarea>
          </div>
          <div class="form-control">
            <label class="label">
              <span class="label-text font-bold uppercase tracking-wider text-[10px] text-base-content/50">Foto Evidencia (Opcional)</span>
            </label>
            <div class="flex items-center gap-3 bg-base-200 p-3 rounded-xl border border-base-300">
              <input 
                type="file" 
                id="salvo-foto-file" 
                accept="image/*" 
                class="file-input file-input-bordered file-input-xs w-full text-xs" 
              />
              <input type="hidden" id="salvo-foto-key" />
            </div>
            <div id="salvo-foto-status" class="text-[10px] text-base-content/50 mt-1 italic hidden">Cargando imagen...</div>
          </div>
          
          <!-- GPS Status Panel -->
          <div class="p-4 bg-base-200 rounded-xl flex flex-col gap-2 border border-base-300">
            <div class="flex justify-between items-center">
              <span class="text-xs font-bold text-base-content">Coordenadas de GPS</span>
              <button id="btn-salvo-gps" type="button" class="btn btn-xs btn-primary rounded-full">
                Recargar GPS
              </button>
            </div>
            <div id="salvo-gps-status" class="text-xs text-base-content/60 italic">Iniciando búsqueda...</div>
            <input type="hidden" id="salvo-latitud" />
            <input type="hidden" id="salvo-longitud" />
            <div id="salvo-gps-map" class="w-full h-36 rounded-xl overflow-hidden border border-base-300 mt-2 hidden"></div>
          </div>

          <!-- Checkbox de confirmación -->
          <div class="flex items-start gap-2.5 pt-1">
            <input 
              type="checkbox" 
              id="chk-salvo-confirmacion" 
              class="checkbox checkbox-primary mt-0.5" 
              required 
            />
            <label for="chk-salvo-confirmacion" class="text-xs text-base-content/70 select-none cursor-pointer">
              Confirmo que estos datos de contacto y ubicación son correctos para mis familiares.
            </label>
          </div>
        </div>

        <div class="flex gap-3 pt-2">
          <button id="btn-salvo-confirmar-enviar" class="btn btn-primary flex-grow">Confirmar "Localizado"</button>
          <button id="btn-salvo-confirmar-cancelar" type="button" class="btn btn-outline flex-grow">Atrás</button>
        </div>
      </div>

      <!-- Panel de Éxito y Compartir -->
      <div id="salvo-exito-container" class="hidden text-center space-y-4 border-t border-base-200 pt-4 animate-fade-in">
        <div class="text-4xl">🎉</div>
        <h4 class="text-xl font-bold text-base-content">¡Estado actualizado!</h4>
        <p class="text-xs text-base-content/70">
          Tu registro ha sido marcado como localizado. Puedes compartir este reporte con familiares y amigos.
        </p>
        
        <div class="space-y-2 pt-2">
          <button id="btn-salvo-compartir" class="btn bg-[#25D366] text-white hover:bg-[#20ba59] w-full flex items-center justify-center gap-2 border-0">
            Compartir por WhatsApp
          </button>
          <button id="btn-salvo-compartir-copiar" class="btn btn-primary w-full">
            Copiar enlace de reporte
          </button>
          <button id="btn-salvo-listo" class="btn btn-ghost w-full">
            Listo / Cerrar
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function initSalvo() {
    const btnEstoyASalvo = document.getElementById("btn-estoy-a-salvo");
    const modalSalvo = document.getElementById("modal-salvo");
    const btnCloseSalvo = document.getElementById("btn-close-salvo");
    const formSalvoBuscar = document.getElementById("form-salvo-buscar") as HTMLFormElement;
    const inputSalvoQuery = document.getElementById("input-salvo-query") as HTMLInputElement;
    const salvoLoader = document.getElementById("salvo-results-loader");
    const salvoResults = document.getElementById("salvo-results");
    const salvoNoResults = document.getElementById("salvo-no-results");
    const btnSalvoRegistrar = document.getElementById("btn-salvo-registrar") as HTMLAnchorElement;

    // Confirmar form elements
    const salvoConfirmarContainer = document.getElementById("salvo-confirmar-container");
    const salvoContacto = document.getElementById("salvo-contacto") as HTMLInputElement;
    const salvoRefugio = document.getElementById("salvo-refugio") as HTMLInputElement;
    const salvoEstadoSalud = document.getElementById("salvo-estado-salud") as HTMLSelectElement;
    const salvoNotas = document.getElementById("salvo-notas") as HTMLTextAreaElement;
    const salvoFotoFile = document.getElementById("salvo-foto-file") as HTMLInputElement;
    const salvoFotoKey = document.getElementById("salvo-foto-key") as HTMLInputElement;
    const salvoFotoStatus = document.getElementById("salvo-foto-status");

    const btnSalvoGps = document.getElementById("btn-salvo-gps");
    const salvoGpsStatus = document.getElementById("salvo-gps-status");
    const salvoLatitud = document.getElementById("salvo-latitud") as HTMLInputElement;
    const salvoLongitud = document.getElementById("salvo-longitud") as HTMLInputElement;
    const chkSalvoConfirmacion = document.getElementById("chk-salvo-confirmacion") as HTMLInputElement;
    const btnSalvoConfirmarEnviar = document.getElementById("btn-salvo-confirmar-enviar") as HTMLButtonElement;
    const btnSalvoConfirmarCancelar = document.getElementById("btn-salvo-confirmar-cancelar");

    // Panel de éxito
    const salvoExitoContainer = document.getElementById("salvo-exito-container");
    const btnSalvoCompartir = document.getElementById("btn-salvo-compartir");
    const btnSalvoCompartirCopiar = document.getElementById("btn-salvo-compartir-copiar");
    const btnSalvoListo = document.getElementById("btn-salvo-listo");

    let personaIdConfirmar: number | null = null;
    let reporteIdConfirmar: number | null = null;
    let personaNombreConfirmar: string = "";

    btnEstoyASalvo?.addEventListener("click", () => {
      modalSalvo?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      inputSalvoQuery?.focus();
    });

    function cerrarModalSalvo() {
      modalSalvo?.classList.add("hidden");
      document.body.style.overflow = "";
      if (formSalvoBuscar) {
        formSalvoBuscar.reset();
        formSalvoBuscar.classList.remove("hidden");
      }
      if (salvoResults) {
        salvoResults.innerHTML = "";
        salvoResults.classList.remove("hidden");
      }
      salvoNoResults?.classList.add("hidden");
      salvoConfirmarContainer?.classList.add("hidden");
      salvoExitoContainer?.classList.add("hidden");
      btnCloseSalvo?.classList.remove("hidden");
      personaIdConfirmar = null;
      reporteIdConfirmar = null;
      personaNombreConfirmar = "";
    }

    btnCloseSalvo?.addEventListener("click", cerrarModalSalvo);
    modalSalvo?.addEventListener("click", (e) => {
      if (e.target === modalSalvo) cerrarModalSalvo();
    });

    // Función para comprimir imagen en el cliente antes de la subida
    async function comprimirImagen(file: File): Promise<Blob> {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = (event) => {
          const img = new Image();
          img.src = event.target?.result as string;
          img.onload = () => {
            const canvas = document.createElement("canvas");
            const maxDim = 800;
            let width = img.width;
            let height = img.height;
            
            if (width > height) {
              if (width > maxDim) {
                height = Math.round((height * maxDim) / width);
                width = maxDim;
              }
            } else {
              if (height > maxDim) {
                width = Math.round((width * maxDim) / height);
                height = maxDim;
              }
            }
            
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext("2d");
            ctx?.drawImage(img, 0, 0, width, height);
            canvas.toBlob(
              (blob) => {
                if (blob) resolve(blob);
                else reject(new Error("Error al comprimir blob"));
              },
              "image/jpeg",
              0.75
            );
          };
          img.onerror = (err) => reject(err);
        };
        reader.onerror = (err) => reject(err);
      });
    }

    // Manejo de carga de foto con compresión
    salvoFotoFile?.addEventListener("change", async (ev) => {
      const input = ev.currentTarget as HTMLInputElement;
      if (!input.files || input.files.length === 0) return;

      const file = input.files[0];
      if (salvoFotoStatus) {
        salvoFotoStatus.textContent = "Comprimiendo foto...";
        salvoFotoStatus.className = "text-[10px] text-warning font-uber-text mt-1 italic font-medium";
        salvoFotoStatus.classList.remove("hidden");
      }

      try {
        const compressedBlob = await comprimirImagen(file);
        const formData = new FormData();
        formData.append("file", compressedBlob, "evidencia.jpg");

        if (salvoFotoStatus) {
          salvoFotoStatus.textContent = "Cargando foto de verificación...";
        }

        const resp = await fetch("/api/upload", {
          method: "POST",
          body: formData
        });

        if (resp.ok) {
          const res = await resp.json();
          if (salvoFotoKey) salvoFotoKey.value = res.key;
          if (salvoFotoStatus) {
            salvoFotoStatus.textContent = "✓ Foto cargada correctamente";
            salvoFotoStatus.className = "text-[10px] text-success font-uber-text mt-1 italic font-semibold";
          }
        } else {
          throw new Error();
        }
      } catch (err) {
        console.error(err);
        if (salvoFotoStatus) {
          salvoFotoStatus.textContent = "❌ Error al comprimir o cargar foto";
          salvoFotoStatus.className = "text-[10px] text-error font-uber-text mt-1 italic";
        }
      }
    });

    let salvoMiniMap: any = null;
    let salvoMarker: any = null;

    function initSalvoMiniMap(lat: number, lon: number) {
      const mapDiv = document.getElementById("salvo-gps-map");
      if (!mapDiv || typeof (window as any).L === "undefined") return;

      mapDiv.classList.remove("hidden");

      const L = (window as any).L;

      if (!salvoMiniMap) {
        salvoMiniMap = L.map("salvo-gps-map", {
          zoomControl: false,
          attributionControl: false,
          dragging: true,
          scrollWheelZoom: false,
        }).setView([lat, lon], 15);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 18,
        }).addTo(salvoMiniMap);

        salvoMiniMap.on("click", (e: any) => {
          if (salvoLatitud) salvoLatitud.value = e.latlng.lat.toFixed(6);
          if (salvoLongitud) salvoLongitud.value = e.latlng.lng.toFixed(6);
          updateSalvoMarker(e.latlng.lat, e.latlng.lng);
          if (salvoGpsStatus) {
            salvoGpsStatus.textContent = "Ubicación ajustada en mapa.";
            salvoGpsStatus.className = "text-xs text-info font-uber-text italic font-medium";
          }
        });
      }

      updateSalvoMarker(lat, lon);
      salvoMiniMap.setView([lat, lon], 15);
      setTimeout(() => { if (salvoMiniMap) salvoMiniMap.invalidateSize(); }, 150);
    }

    function updateSalvoMarker(lat: number, lon: number) {
      if (!salvoMiniMap) return;
      const L = (window as any).L;
      if (salvoMarker) {
        salvoMarker.setLatLng([lat, lon]);
      } else {
        salvoMarker = L.marker([lat, lon]).addTo(salvoMiniMap);
      }
    }

    async function obtenerUbicacionGps() {
      if (!salvoGpsStatus || !salvoLatitud || !salvoLongitud) return;
      salvoGpsStatus.textContent = "Buscando ubicación GPS...";
      salvoGpsStatus.className = "text-xs text-warning font-uber-text italic font-medium";
      
      if (!navigator.geolocation) {
        salvoGpsStatus.textContent = "GPS no compatible con tu navegador";
        salvoGpsStatus.className = "text-xs text-error font-uber-text italic";
        return;
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lon = position.coords.longitude;
          salvoLatitud.value = lat.toString();
          salvoLongitud.value = lon.toString();
          salvoGpsStatus.textContent = `Ubicación GPS obtenida: ${lat.toFixed(5)}, ${lon.toFixed(5)}`;
          salvoGpsStatus.className = "text-xs text-success font-uber-text italic font-semibold";
          initSalvoMiniMap(lat, lon);
        },
        (error) => {
          let msg = "No se pudo obtener la ubicación GPS";
          if (error.code === error.PERMISSION_DENIED) {
            msg = "Permiso de GPS denegado";
          }
          salvoGpsStatus.textContent = msg;
          salvoGpsStatus.className = "text-xs text-error font-uber-text italic";
        },
        { timeout: 8000, enableHighAccuracy: true }
      );
    }

    btnSalvoGps?.addEventListener("click", obtenerUbicacionGps);

    btnSalvoConfirmarCancelar?.addEventListener("click", () => {
      personaIdConfirmar = null;
      reporteIdConfirmar = null;
      personaNombreConfirmar = "";
      salvoConfirmarContainer?.classList.add("hidden");
      formSalvoBuscar?.classList.remove("hidden");
      if (salvoResults) salvoResults.classList.remove("hidden");
    });

    btnSalvoConfirmarEnviar?.addEventListener("click", async () => {
      if (!personaIdConfirmar && !reporteIdConfirmar) return;

      const contacto = salvoContacto?.value.trim();
      const refugio = salvoRefugio?.value.trim() || null;
      const estadoSalud = salvoEstadoSalud?.value || "localizado";
      const notas = salvoNotas?.value.trim() || null;
      const fotoKey = salvoFotoKey?.value || null;
      const lat = salvoLatitud?.value ? parseFloat(salvoLatitud.value) : null;
      const lon = salvoLongitud?.value ? parseFloat(salvoLongitud.value) : null;
      const confirmado = chkSalvoConfirmacion?.checked;

      if (!contacto) {
        alert("Contacto requerido para familiares.");
        salvoContacto?.focus();
        return;
      }

      if (!confirmado) {
        alert("Debes confirmar que los datos son correctos.");
        return;
      }

      btnSalvoConfirmarEnviar.disabled = true;
      btnSalvoConfirmarEnviar.textContent = "Guardando...";

      try {
        let patchResp;
        if (personaIdConfirmar) {
          patchResp = await fetch(`/api/personas/${personaIdConfirmar}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              accion: "reportar_localizado",
              estado: estadoSalud,
              contacto,
              refugio,
              notas,
              foto_key: fotoKey,
              latitud: lat,
              longitud: lon
            })
          });
        } else {
          patchResp = await fetch(`/api/reportes/${reporteIdConfirmar}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              accion: "reportar_localizado",
              estado_reporte: "resuelto",
              contacto,
              refugio,
              notas,
              foto_key: fotoKey,
              latitud: lat,
              longitud: lon
            })
          });
        }

        if (patchResp.ok) {
          btnSalvoConfirmarEnviar.textContent = "✓ Guardado";
          
          // Mostrar panel de éxito
          salvoConfirmarContainer?.classList.add("hidden");
          if (btnCloseSalvo) btnCloseSalvo.classList.add("hidden"); // Forzar cerrar por botón Listo
          salvoExitoContainer?.classList.remove("hidden");
        } else {
          const err = await patchResp.json();
          alert(`Error: ${err.error || "intente de nuevo"}`);
          btnSalvoConfirmarEnviar.disabled = false;
          btnSalvoConfirmarEnviar.textContent = 'Confirmar "Localizado"';
        }
      } catch {
        alert("Error de conexión");
        btnSalvoConfirmarEnviar.disabled = false;
        btnSalvoConfirmarEnviar.textContent = 'Confirmar "Localizado"';
      }
    });

    // Listeners de panel de éxito
    btnSalvoCompartir?.addEventListener("click", () => {
      const link = `${window.location.origin}/buscar?q=${encodeURIComponent(personaNombreConfirmar)}`;
      const texto = `¡Hola! He confirmado que estoy localizado en la plataforma dondeestan.org. Puedes ver mis detalles aquí: ${link}`;
      window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(texto)}`, "_blank");
    });

    btnSalvoCompartirCopiar?.addEventListener("click", () => {
      const link = `${window.location.origin}/buscar?q=${encodeURIComponent(personaNombreConfirmar)}`;
      navigator.clipboard.writeText(link);
      if (btnSalvoCompartirCopiar) btnSalvoCompartirCopiar.textContent = "✓ Enlace copiado";
      setTimeout(() => {
        if (btnSalvoCompartirCopiar) btnSalvoCompartirCopiar.textContent = "Copiar enlace de reporte";
      }, 2000);
    });

    btnSalvoListo?.addEventListener("click", () => {
      cerrarModalSalvo();
      window.location.reload();
    });

    formSalvoBuscar?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const query = inputSalvoQuery.value.trim();
      if (!query) return;

      if (salvoLoader) salvoLoader.classList.remove("hidden");
      if (salvoResults) salvoResults.innerHTML = "";
      salvoNoResults?.classList.add("hidden");

      try {
        const resp = await fetch("/api/buscar-unificado", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ q: query, limit: 20, offset: 0 })
        });
        if (resp.ok) {
          const data = await resp.json();
          const resultados = data.results || data;
          if (salvoLoader) salvoLoader.classList.add("hidden");
          
          if (!resultados || resultados.length === 0) {
            if (btnSalvoRegistrar) {
              const esVol = salvoNoResults ? salvoNoResults.getAttribute("data-es-voluntario") === "true" : false;
              if (esVol) {
                const esCedula = /^\d+$/.test(query.replace(/[^0-9]/g, ""));
                if (esCedula) {
                  btnSalvoRegistrar.href = `/registrar?cedula=${encodeURIComponent(query)}`;
                } else {
                  btnSalvoRegistrar.href = `/registrar?nombre=${encodeURIComponent(query)}`;
                }
              } else {
                btnSalvoRegistrar.href = `/reportar`;
              }
            }
            salvoNoResults?.classList.remove("hidden");
          } else {
            resultados.forEach((item: any) => {
              const isPersona = item._source === "persona";
              const nombre = isPersona ? `${item.nombre} ${item.apellido || ""}` : (item.nombre_buscado || "Persona");
              
              const card = document.createElement("div");
              card.className = "p-4 bg-base-200 border border-base-300 rounded-xl flex items-center justify-between gap-3 text-sm shadow-sm";
              
              let btnHtml = "";
              if (isPersona && item.estado === "desconocido") {
                btnHtml = `<button class="btn btn-xs btn-success text-success-content btn-salvo-marcar">
                             ✅ Localizado
                           </button>`;
              } else if (!isPersona && item.estado_reporte === "abierto") {
                btnHtml = `<button class="btn btn-xs btn-success text-success-content btn-salvo-reporte-marcar">
                             ✅ Encontrado
                           </button>`;
              } else {
                const displayState = isPersona 
                  ? (item.estado === "localizado" ? "Localizado" : item.estado)
                  : (item.estado_reporte === "resuelto" ? "Resuelto" : item.estado_reporte);
                btnHtml = `<span class="badge badge-sm badge-neutral font-semibold uppercase">${displayState}</span>`;
              }

              card.innerHTML = `
                <div class="min-w-0 flex-grow">
                  <div class="font-bold text-base-content truncate">${nombre}</div>
                  <div class="text-xs text-base-content/70 mt-0.5">${isPersona ? "Censo" : "Reporte"} ${item.cedula || item.cedula_buscado ? `· Doc: ${item.cedula || item.cedula_buscado}` : ""}</div>
                </div>
                <div class="shrink-0">${btnHtml}</div>
              `;
              
              // Eventos dinámicos
              card.querySelector(".btn-salvo-marcar")?.addEventListener("click", (ev) => {
                personaIdConfirmar = item.id;
                personaNombreConfirmar = nombre;
                formSalvoBuscar?.classList.add("hidden");
                if (salvoResults) salvoResults.classList.add("hidden");
                salvoNoResults?.classList.add("hidden");

                if (salvoContacto) salvoContacto.value = "";
                if (salvoRefugio) salvoRefugio.value = "";
                if (salvoNotas) salvoNotas.value = "";
                if (salvoFotoFile) salvoFotoFile.value = "";
                if (salvoFotoKey) salvoFotoKey.value = "";
                if (salvoFotoStatus) {
                  salvoFotoStatus.textContent = "";
                  salvoFotoStatus.classList.add("hidden");
                }
                if (chkSalvoConfirmacion) chkSalvoConfirmacion.checked = false;
                if (salvoLatitud) salvoLatitud.value = "";
                if (salvoLongitud) salvoLongitud.value = "";

                salvoConfirmarContainer?.classList.remove("hidden");
                obtenerUbicacionGps();
              });

              card.querySelector(".btn-salvo-reporte-marcar")?.addEventListener("click", (ev) => {
                reporteIdConfirmar = item.id;
                personaNombreConfirmar = nombre;
                formSalvoBuscar?.classList.add("hidden");
                if (salvoResults) salvoResults.classList.add("hidden");
                salvoNoResults?.classList.add("hidden");

                if (salvoContacto) salvoContacto.value = "";
                if (salvoRefugio) salvoRefugio.value = "";
                if (salvoNotas) salvoNotas.value = "";
                if (salvoFotoFile) salvoFotoFile.value = "";
                if (salvoFotoKey) salvoFotoKey.value = "";
                if (salvoFotoStatus) {
                  salvoFotoStatus.textContent = "";
                  salvoFotoStatus.classList.add("hidden");
                }
                if (chkSalvoConfirmacion) chkSalvoConfirmacion.checked = false;
                if (salvoLatitud) salvoLatitud.value = "";
                if (salvoLongitud) salvoLongitud.value = "";

                salvoConfirmarContainer?.classList.remove("hidden");
                obtenerUbicacionGps();
              });

              salvoResults?.appendChild(card);
            });
          }
        } else {
          throw new Error();
        }
      } catch {
        if (salvoLoader) salvoLoader.classList.add("hidden");
        alert("Error al buscar");
      }
    });
  }

  // Escuchar evento de carga de página de Astro ClientRouter
  document.addEventListener("astro:page-load", initSalvo);
</script>
