---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import ShareButton from "../../components/ShareButton.astro";
import { env } from "cloudflare:workers";
import { CATEGORIAS_INVENTARIO } from "../../lib/items";

export const prerender = false;

const { id } = Astro.params;

let notFound = false;
let r: any = {};

try {
  const { DB } = env;
  if (DB && id) {
    let query = await DB.prepare("SELECT *, 'refugio' as tipo FROM refugios WHERE id = ?").bind(id).first();
    if (!query) {
      query = await DB.prepare("SELECT *, 'centro_acopio' as tipo FROM centros_acopio WHERE id = ?").bind(id).first();
    }
    if (!query) {
      query = await DB.prepare("SELECT *, 'hospital' as tipo FROM hospitales WHERE id = ?").bind(id).first();
    }

    if (query) {
      r = query;
    } else {
      notFound = true;
    }
  }
} catch (error) {
  console.error("Error al buscar refugio para la ficha:", error);
}

if (notFound) {
  return Astro.redirect("/404");
}

const ocupacion = r.ocupacion_actual || 0;
const capacidad = r.capacidad_maxima || 100;
const pct = Math.min(Math.round((ocupacion / capacidad) * 100), 100);

let colorBar = "bg-success"; // Verde
if (pct >= 90) colorBar = "bg-error"; // Rojo
else if (pct >= 70) colorBar = "bg-warning"; // Amarillo/Naranja

let tipoLabel = "Refugio / Albergue";
let tipoColor = "bg-blue-100 text-blue-800 border-blue-200";
if (r.tipo === "hospital") {
  tipoLabel = "Hospital / Salud";
  tipoColor = "bg-red-100 text-red-800 border-red-200";
} else if (r.tipo === "centro_acopio") {
  tipoLabel = "Centro de Acopio";
  tipoColor = "bg-yellow-100 text-yellow-800 border-yellow-200";
}

let itemsCriticos: string[] = [];
let itemsAlerta: string[] = [];
if (r.inventario) {
  try {
    const inv = typeof r.inventario === 'string' ? JSON.parse(r.inventario) : r.inventario;
    for (const [itemId, estado] of Object.entries(inv)) {
      const itemObj = CATEGORIAS_INVENTARIO.flatMap(c => c.items).find(i => i.id === itemId);
      if (itemObj) {
        if (estado === "Crítico") {
          itemsCriticos.push(itemObj.nombre);
        } else if (estado === "Alerta") {
          itemsAlerta.push(itemObj.nombre);
        }
      }
    }
  } catch (e) {
    console.error("Error al parsear inventario:", e);
  }
}

const formatFechaStr = (fstr: string) => {
  if (!fstr) return "";
  try {
    return new Date(fstr).toLocaleString('es-VE', {
      dateStyle: 'short',
      timeStyle: 'short'
    });
  } catch {
    return fstr;
  }
};

let fechaFormateada = formatFechaStr(r.fecha_registro || r.created_at);
let fechaActualizada = formatFechaStr(r.updated_at);

let fotosArray: string[] = [];
if (r.fotos) {
  try {
    fotosArray = typeof r.fotos === 'string' ? JSON.parse(r.fotos) : r.fotos;
  } catch (e) {
    console.error("Error al parsear fotos:", e);
  }
}

const siteUrl = Astro.url ? Astro.url.origin : "https://dondeestan.org";
const flyerUrl = `${siteUrl}/refugios/flyer/${id}.png`;
const flyerRelativeUrl = `/refugios/flyer/${id}.png`;
const descripcion = `${tipoLabel} en ${r.direccion || "Venezuela"}. Ayuda a difundir y organizar la ayuda.`;
---

<Layout 
  title={`Ficha: ${r.nombre} - dondeestan.org`}
  description={descripcion}
  ogImage={flyerUrl}
>
  <Navbar />
  
  <main class="flex-grow flex justify-center py-8 px-4 bg-base-200 min-h-[80vh]">
    <div class="max-w-2xl w-full">
      <div class="mb-4">
        <a href="/" class="link link-primary text-sm font-semibold inline-flex items-center gap-2">
          ← Volver al mapa general
        </a>
      </div>
      
      <div class="card bg-base-100 border border-base-200 p-5 sm:p-8 rounded-3xl shadow-sm space-y-6">
        
        <div class="w-full bg-base-200 border border-base-300 rounded-2xl overflow-hidden flex justify-center p-2 mb-4">
          <img 
            src={flyerRelativeUrl} 
            alt={`Ficha de ${r.nombre}`} 
            class="max-w-full h-auto rounded-xl border border-base-300 shadow-sm"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
          <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class={`badge ${tipoColor} font-bold`}>
                {tipoLabel}
              </span>
            </div>
            <h1 class="text-3xl font-black text-base-content leading-tight">{r.nombre}</h1>
            {r.direccion && <p class="text-sm text-base-content/75 mt-2">📍 {r.direccion}</p>}
          </div>
          {r.tipo === "refugio" && (
            <div class="text-right shrink-0">
              <span class="badge badge-neutral gap-1.5 py-3.5 px-4 font-bold shadow-sm">
                {ocupacion} / {capacidad} personas
              </span>
            </div>
          )}
        </div>

        <!-- Encargado y Fechas -->
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 border-t border-base-200 pt-4 mt-2">
          {r.encargado && (
            <div class="text-sm text-base-content/80 flex items-center gap-1.5">
              <span class="text-base-content/50">👤 Encargado:</span>
              <strong class="font-semibold text-base-content">{r.encargado}</strong>
            </div>
          )}
          <div class="flex flex-wrap gap-2">
            {fechaActualizada && (
              <div class="inline-flex items-center gap-1.5 bg-info/10 text-info border border-info/20 px-3 py-1 rounded-full text-xs font-semibold" title="Última actualización de la información">
                ⏱️ Actualizado: {fechaActualizada}
              </div>
            )}
            {(!fechaActualizada && fechaFormateada) && (
              <div class="inline-flex items-center gap-1.5 bg-base-300 text-base-content/80 border border-base-300 px-3 py-1 rounded-full text-xs font-semibold" title="Fecha de reporte original">
                📅 Reportado: {fechaFormateada}
              </div>
            )}
          </div>
        </div>

        {r.tipo === "refugio" && (
          <div class="space-y-2 pt-2">
            <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-base-content/50">
              <span>Capacidad ocupada</span>
              <span class="text-base-content font-bold">{pct}%</span>
            </div>
            <div class="w-full bg-base-200 h-2.5 rounded-full overflow-hidden border border-base-300">
              <div class={`h-full ${colorBar} transition-all duration-500`} style={`width: ${pct}%`}></div>
            </div>
          </div>
        )}

        {r.tipo === "refugio" && (
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mt-4">
            <div class="bg-base-100 border border-base-200 p-3 rounded-2xl text-center shadow-xs">
              <span class="text-xs text-base-content/60 block">👶 Niños</span>
              <strong class="text-base-content text-2xl font-black block mt-1">{r.ninos || 0}</strong>
            </div>
            <div class="bg-base-100 border border-base-200 p-3 rounded-2xl text-center shadow-xs">
              <span class="text-xs text-base-content/60 block">🍼 Lactantes</span>
              <strong class="text-base-content text-2xl font-black block mt-1">{r.bebes_lactantes || 0}</strong>
            </div>
            <div class="bg-base-100 border border-base-200 p-3 rounded-2xl text-center shadow-xs">
              <span class="text-xs text-base-content/60 block">👵 Mayores</span>
              <strong class="text-base-content text-2xl font-black block mt-1">{r.adultos_mayores || 0}</strong>
            </div>
            <div class="bg-base-100 border border-base-200 p-3 rounded-2xl text-center shadow-xs">
              <span class="text-xs text-base-content/60 block">🩺 Personal</span>
              <strong class="text-base-content text-2xl font-black block mt-1">{r.personal_profesional || 0}</strong>
            </div>
            <div class="bg-base-100 border border-base-200 p-3 rounded-2xl text-center shadow-xs">
              <span class="text-xs text-base-content/60 block">🤝 Vols</span>
              <strong class="text-base-content text-2xl font-black block mt-1">{r.voluntarios || 0}</strong>
            </div>
          </div>
        )}

        {(itemsCriticos.length > 0 || itemsAlerta.length > 0) && (
          <div class="space-y-3 bg-base-100 border border-base-200 p-5 rounded-2xl mt-4 shadow-xs">
            {itemsCriticos.length > 0 && (
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs font-bold text-error uppercase tracking-wider mr-1">Crítico:</span>
                {itemsCriticos.map(item => (
                  <span class="badge badge-error badge-outline py-2.5 px-3 font-semibold rounded-lg">{item}</span>
                ))}
              </div>
            )}
            {itemsAlerta.length > 0 && (
              <div class="flex flex-wrap gap-2 items-center mt-3">
                <span class="text-xs font-bold text-warning uppercase tracking-wider mr-1">Alerta:</span>
                {itemsAlerta.map(item => (
                  <span class="badge badge-warning badge-outline py-2.5 px-3 font-semibold rounded-lg">{item}</span>
                ))}
              </div>
            )}
          </div>
        )}
        
        {r.necesidades && (
          <div class="pt-5 border-t border-base-200 mt-4">
            <h4 class="font-bold text-base text-base-content mb-2 flex items-center gap-1.5">
              📝 Notas y Necesidades Adicionales
            </h4>
            <div class="bg-base-200/50 border border-base-200 p-4 rounded-2xl text-sm text-base-content/90 whitespace-pre-wrap leading-relaxed shadow-inner">
              {r.necesidades}
            </div>
          </div>
        )}

        <!-- Galería de fotos reales si existen -->
        {fotosArray.length > 0 && (
          <div class="pt-5 border-t border-base-200 mt-4">
            <h4 class="font-bold text-base text-base-content mb-3 flex items-center gap-1.5">
              📸 Fotos del Recurso
            </h4>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {fotosArray.map(foto => (
                <div class="aspect-video rounded-xl overflow-hidden border border-base-200 shadow-xs hover:border-base-300 transition-colors bg-base-200">
                  <img 
                    src={`/api/upload?key=${foto}`} 
                    alt="Foto del recurso" 
                    class="w-full h-full object-cover" 
                    loading="lazy" 
                  />
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="grid grid-cols-2 gap-3 pt-5 border-t border-base-200 mt-4">
          <a 
            href={r.latitud && r.longitud ? `https://www.google.com/maps/dir/?api=1&destination=${r.latitud},${r.longitud}` : "/"}
            target="_blank"
            class="btn btn-outline flex items-center justify-center w-full h-[3rem] text-sm font-semibold rounded-full cursor-pointer"
          >
            🗺️ Cómo llegar
          </a>
          {r.contacto ? (
            <a 
              href={`tel:${r.contacto}`} 
              class="btn btn-outline flex items-center justify-center w-full h-[3rem] text-sm font-semibold rounded-full cursor-pointer"
            >
              📞 Llamar
            </a>
          ) : (
            <div class="btn btn-outline flex items-center justify-center w-full cursor-not-allowed opacity-50 h-[3rem] text-sm font-semibold rounded-full">
              📞 Sin número
            </div>
          )}
          <div class="w-full">
            <ShareButton 
              class="btn-outline w-full h-[3rem] text-sm font-semibold rounded-full cursor-pointer"
              buttonText="Compartir"
              url={`/r/${r.id}`}
              text={`📍 Ayuda en ${r.nombre}:`}
            />
          </div>
          <a 
            href={`/refugios/flyer/${r.id}.png`} 
            target="_blank" 
            download 
            class="btn btn-primary flex items-center justify-center gap-2 w-full h-[3rem] text-sm font-bold rounded-full cursor-pointer"
          >
            ⬇️ Flyer
          </a>
        </div>
      </div>
      
    </div>
  </main>
</Layout>
