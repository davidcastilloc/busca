---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";

export const prerender = false;
---

<Layout title="Escáner de Listas con IA - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 sm:py-12 bg-canvas">
    <div class="max-w-xl mx-auto px-4">
      <div class="text-center mb-8">
        <h1 class="font-uber-display text-3xl text-ink tracking-tight">Escáner de Listas con IA</h1>
        <p class="text-sm text-body font-uber-text mt-2">
          Sube una foto de una lista manuscrita. La IA extraerá los nombres y podrás corregirlos antes de guardarlos.
        </p>
      </div>

      <div class="bg-canvas border border-canvas-soft p-6 rounded-2xl shadow-sm space-y-6">
        
        <!-- Paso 1: Subida de Foto -->
        <form id="form-upload" class="space-y-4">
          <!-- Campo Refugio -->
          <div>
            <label class="block text-xs font-bold text-mute uppercase tracking-wider mb-2 font-uber-text" for="escaner-refugio">
              Nombre del Refugio / Ubicación actual *
            </label>
            <input 
              type="text" 
              id="escaner-refugio" 
              required 
              class="input input-bordered w-full font-uber-text" 
              placeholder="Ej: Estadio Olímpico, Gimnasio Municipal..."
            />
          </div>

          <!-- Campo Notas/Contacto del Refugio -->
          <div>
            <label class="block text-xs font-bold text-mute uppercase tracking-wider mb-2 font-uber-text" for="escaner-contacto">
              Contacto de referencia de este refugio (Opcional)
            </label>
            <input 
              type="text" 
              id="escaner-contacto" 
              class="input input-bordered w-full font-uber-text" 
              placeholder="Ej: 0424-5551234 (Voluntario Pedro)"
            />
          </div>

          <!-- Selector de Imagen -->
          <div>
            <label class="block text-xs font-bold text-mute uppercase tracking-wider mb-2 font-uber-text">
              Foto de la lista de papel *
            </label>
            
            <div id="dropzone" class="border-2 border-dashed border-canvas-soft rounded-2xl p-8 text-center cursor-pointer hover:border-primary hover:bg-canvas-soft transition-all flex flex-col items-center justify-center min-h-[180px]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-mute mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-sm font-semibold text-ink">Haz clic para tomar foto o seleccionar</span>
              <span class="text-xs text-mute mt-1">Soporta JPG, PNG (Max 5MB)</span>
              
              <input 
                type="file" 
                id="file-input" 
                accept="image/*" 
                class="hidden" 
                required
              />
            </div>
            
            <!-- Vista Previa de Imagen -->
            <div id="preview-container" class="hidden mt-4 relative rounded-xl overflow-hidden border border-canvas-soft">
              <img id="image-preview" class="w-full h-48 object-cover" />
              <button type="button" id="btn-remove-photo" class="absolute top-2 right-2 w-8 h-8 rounded-full bg-black/60 text-white flex items-center justify-center text-sm hover:bg-black/80 transition-colors">✕</button>
            </div>
          </div>

          <!-- Botón de Envío Paso 1 -->
          <button 
            type="submit" 
            id="btn-analizar" 
            class="btn bg-primary text-white hover:bg-black-elevated w-full py-3 rounded-full font-uber-text font-semibold flex items-center justify-center gap-2"
          >
            Analizar con IA (Demora ~10s)
          </button>
        </form>

        <!-- Paso 2: Edición de Nombres -->
        <form id="form-edit" class="hidden space-y-4">
          <div class="border-b border-canvas-soft pb-2 mb-4">
            <h2 class="text-lg font-bold text-ink">Revisa los nombres extraídos</h2>
            <p class="text-xs text-body">Borra los incorrectos o añade filas nuevas.</p>
          </div>

          <div id="names-container" class="space-y-2 max-h-64 overflow-y-auto pr-2">
            <!-- Nombres inyectados acá -->
          </div>

          <button type="button" id="btn-add-name" class="btn btn-outline btn-sm w-full font-uber-text border-dashed">
            + Añadir otra persona
          </button>

          <button 
            type="submit" 
            id="btn-confirmar" 
            class="btn bg-primary text-white hover:bg-black-elevated w-full py-3 mt-4 rounded-full font-uber-text font-semibold flex items-center justify-center gap-2"
          >
            Confirmar y Subir Lista Definitiva
          </button>
          
          <button type="button" id="btn-cancel" class="btn btn-ghost w-full font-uber-text mt-2 text-mute hover:text-ink">
            Cancelar y subir otra foto
          </button>
        </form>

        <!-- Indicador de Estado -->
        <div id="status-panel" class="hidden p-4 rounded-xl border space-y-2">
          <div class="flex items-center gap-3">
            <span id="status-spinner" class="loading loading-spinner text-primary hidden"></span>
            <span id="status-icon" class="text-lg"></span>
            <span id="status-text" class="text-sm font-semibold"></span>
          </div>
          <p id="status-desc" class="text-xs text-body font-uber-text"></p>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const formUpload = document.getElementById("form-upload") as HTMLFormElement;
      const formEdit = document.getElementById("form-edit") as HTMLFormElement;
      
      const dropzone = document.getElementById("dropzone");
      const fileInput = document.getElementById("file-input") as HTMLInputElement;
      const previewContainer = document.getElementById("preview-container");
      const imagePreview = document.getElementById("image-preview") as HTMLImageElement;
      const btnRemovePhoto = document.getElementById("btn-remove-photo");
      const btnAnalizar = document.getElementById("btn-analizar") as HTMLButtonElement;
      
      const namesContainer = document.getElementById("names-container") as HTMLDivElement;
      const btnAddName = document.getElementById("btn-add-name");
      const btnConfirmar = document.getElementById("btn-confirmar") as HTMLButtonElement;
      const btnCancel = document.getElementById("btn-cancel");
      
      const statusPanel = document.getElementById("status-panel");
      const statusSpinner = document.getElementById("status-spinner");
      const statusIcon = document.getElementById("status-icon");
      const statusText = document.getElementById("status-text");
      const statusDesc = document.getElementById("status-desc");

      let compressedBlob: Blob | null = null;
      let nameCount = 0;

      // --- MANEJO DE FOTO ---
      if (dropzone) {
        const newDropzone = dropzone.cloneNode(true);
        dropzone.parentNode?.replaceChild(newDropzone, dropzone);
        newDropzone.addEventListener("click", () => document.getElementById("file-input")?.click());
      }
      
      const currentFileInput = document.getElementById("file-input") as HTMLInputElement;
      if (currentFileInput) {
        const newFileInput = currentFileInput.cloneNode(true) as HTMLInputElement;
        currentFileInput.parentNode?.replaceChild(newFileInput, currentFileInput);
        newFileInput.addEventListener("change", async (e) => {
          const target = e.target as HTMLInputElement;
          if (target.files && target.files.length > 0) {
            await procesarFoto(target.files[0]);
          }
        });
      }

      async function comprimirImagen(file: File): Promise<Blob> {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.readAsDataURL(file);
          reader.onload = (event) => {
            const img = new Image();
            img.src = event.target?.result as string;
            img.onload = () => {
              const canvas = document.createElement("canvas");
              const maxDim = 1200;
              let width = img.width;
              let height = img.height;
              
              if (width > height) {
                if (width > maxDim) {
                  height = Math.round((height * maxDim) / width);
                  width = maxDim;
                }
              } else {
                if (height > maxDim) {
                  width = Math.round((width * maxDim) / height);
                  height = maxDim;
                }
              }
              
              canvas.width = width;
              canvas.height = height;
              const ctx = canvas.getContext("2d");
              ctx?.drawImage(img, 0, 0, width, height);
              canvas.toBlob(
                (blob) => {
                  if (blob) resolve(blob);
                  else reject(new Error("Error al comprimir blob"));
                },
                "image/jpeg",
                0.80
              );
            };
            img.onerror = (err) => reject(err);
          };
          reader.onerror = (err) => reject(err);
        });
      }

      async function procesarFoto(file: File) {
        try {
          mostrarStatus("info", "Comprimiendo...", "Preparando imagen...");
          compressedBlob = await comprimirImagen(file);
          
          const reader = new FileReader();
          reader.onload = (e) => {
            const imgEl = document.getElementById("image-preview") as HTMLImageElement;
            const previewEl = document.getElementById("preview-container");
            const dropEl = document.getElementById("dropzone");
            if (imgEl && e.target?.result) {
              imgEl.src = e.target.result as string;
              previewEl?.classList.remove("hidden");
              dropEl?.classList.add("hidden");
            }
          };
          reader.readAsDataURL(compressedBlob);
          
          ocultarStatus();
        } catch (err) {
          mostrarStatus("error", "Error", "Intente con otra imagen.");
          clearPhoto();
        }
      }

      function clearPhoto() {
        const fi = document.getElementById("file-input") as HTMLInputElement;
        if (fi) fi.value = "";
        compressedBlob = null;
        document.getElementById("preview-container")?.classList.add("hidden");
        document.getElementById("dropzone")?.classList.remove("hidden");
      }

      const currentBtnRemovePhoto = document.getElementById("btn-remove-photo");
      if (currentBtnRemovePhoto) {
        const newBtnRemovePhoto = currentBtnRemovePhoto.cloneNode(true);
        currentBtnRemovePhoto.parentNode?.replaceChild(newBtnRemovePhoto, currentBtnRemovePhoto);
        newBtnRemovePhoto.addEventListener("click", (e) => {
          e.stopPropagation();
          clearPhoto();
        });
      }

      // --- UTILIDADES STATUS ---
      function mostrarStatus(tipo: "info" | "success" | "error", titulo: string, descripcion: string) {
        const sp = document.getElementById("status-panel");
        const sspinner = document.getElementById("status-spinner");
        const sicon = document.getElementById("status-icon");
        const stext = document.getElementById("status-text");
        const sdesc = document.getElementById("status-desc");
        
        if (!sp || !sspinner || !sicon || !stext || !sdesc) return;
        sp.classList.remove("hidden");
        
        sp.className = "p-4 rounded-xl border space-y-2 " + 
          (tipo === "success" ? "bg-green-50 border-green-200 text-green-800" :
           tipo === "error" ? "bg-red-50 border-red-200 text-red-800" :
           "bg-blue-50 border-blue-200 text-blue-800");

        if (tipo === "info") {
          sspinner.classList.remove("hidden");
          sicon.classList.add("hidden");
        } else {
          sspinner.classList.add("hidden");
          sicon.classList.remove("hidden");
          sicon.textContent = tipo === "success" ? "✓" : "✕";
        }

        stext.textContent = titulo;
        sdesc.textContent = descripcion;
      }

      function ocultarStatus() {
        document.getElementById("status-panel")?.classList.add("hidden");
      }

      // --- FORMULARIO EDICIÓN ---
      function renderNames(personas: any[]) {
        const nc = document.getElementById("names-container") as HTMLDivElement;
        if (nc) {
          nc.innerHTML = "";
          nameCount = 0;
          personas.forEach(p => addNameRow(p.nombre, p.cedula, p.telefono, p.edad, p.raw_context));
          if (personas.length === 0) {
            addNameRow("");
          }
        }
      }

      // Exponer al scope global para que el botón "Eliminar" inline funcione
      (window as any).eliminarFila = (id: string) => {
        const el = document.getElementById(id);
        if (el) el.remove();
      };

      function addNameRow(nameValue: string = "", cedula: number|string|null = "", telefono: string|null = "", edad: number|string|null = "", raw_context: string = "") {
        const nc = document.getElementById("names-container") as HTMLDivElement;
        if (!nc) return;
        
        const id = `name-row-${nameCount++}`;
        const row = document.createElement("div");
        row.id = id;
        row.className = "flex flex-col items-start gap-3 mb-4 bg-canvas p-4 rounded-xl border border-canvas-soft shadow-sm w-full";
        
        const cedulaStr = cedula !== null ? cedula : "";
        const telStr = telefono !== null ? telefono : "";
        const edadStr = edad !== null ? edad : "";

        row.innerHTML = `
          <div class="flex justify-between items-center w-full pb-2 border-b border-canvas-soft">
            <span class="text-xs font-bold text-body-soft uppercase tracking-wider">Registro</span>
            <button type="button" class="btn btn-ghost btn-xs text-error hover:bg-error/10 px-2" onclick="window.eliminarFila('${id}')" title="Eliminar registro">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              <span class="hidden sm:inline ml-1 text-xs">Eliminar</span>
            </button>
          </div>
          
          <div class="w-full flex flex-col gap-3">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 w-full">
              <div class="w-full">
                <label class="text-xs text-body-soft mb-1 block font-medium">Nombre Completo</label>
                <input type="text" class="input input-bordered w-full font-uber-text extracted-name text-sm" value="${nameValue}" placeholder="Nombre completo" required />
              </div>
              <div class="w-full">
                <label class="text-xs text-body-soft mb-1 block font-medium">Cédula</label>
                <input type="number" class="input input-bordered w-full font-uber-text extracted-cedula text-sm" value="${cedulaStr}" placeholder="Ej: 15370185" />
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-3 w-full">
              <div class="w-full">
                <label class="text-xs text-body-soft mb-1 block font-medium">Teléfono</label>
                <input type="text" class="input input-bordered w-full font-uber-text extracted-telefono text-sm" value="${telStr}" placeholder="Ej: 04141234567" />
              </div>
              <div class="w-full">
                <label class="text-xs text-body-soft mb-1 block font-medium">Edad</label>
                <input type="number" class="input input-bordered w-full font-uber-text extracted-edad text-sm" value="${edadStr}" placeholder="Años" />
              </div>
            </div>

            <div class="text-xs text-body-soft mt-1 bg-canvas-soft p-2 rounded font-mono truncate w-full" title="${raw_context}">
              <span class="font-bold">Raw:</span> ${raw_context || "Carga Manual"}
            </div>
          </div>
        `;
        nc.appendChild(row);
      }

      const currentBtnAddName = document.getElementById("btn-add-name");
      if (currentBtnAddName) {
        const newBtnAddName = currentBtnAddName.cloneNode(true);
        currentBtnAddName.parentNode?.replaceChild(newBtnAddName, currentBtnAddName);
        newBtnAddName.addEventListener("click", () => addNameRow("", ""));
      }

      // --- EVENTOS ---
      const currentFormUpload = document.getElementById("form-upload") as HTMLFormElement;
      if (currentFormUpload) {
        const newFormUpload = currentFormUpload.cloneNode(true) as HTMLFormElement;
        currentFormUpload.parentNode?.replaceChild(newFormUpload, currentFormUpload);
        newFormUpload.addEventListener("submit", async (e) => {
          e.preventDefault();
          if (!compressedBlob) {
            alert("Sube una foto primero.");
            return;
          }

          const btnAnalizarEl = document.getElementById("btn-analizar") as HTMLButtonElement;
          if (btnAnalizarEl) {
            btnAnalizarEl.disabled = true;
            btnAnalizarEl.innerHTML = `<span class="loading loading-spinner"></span> Analizando con IA...`;
          }
          mostrarStatus("info", "Leyendo manuscrito...", "La IA está procesando la imagen. Esto tardará unos 10 segundos.");

          try {
            const formData = new FormData();
            formData.append("file", compressedBlob, "lista.jpg");

            const resp = await fetch("/api/analizar-lista", {
              method: "POST",
              body: formData
            });

            if (resp.ok) {
              const res = await resp.json();
              renderNames(res.personas || []);
              document.getElementById("form-upload")?.classList.add("hidden");
              document.getElementById("form-edit")?.classList.remove("hidden");
              ocultarStatus();
            } else {
              const err = await resp.json();
              mostrarStatus("error", "Fallo al analizar", err.error || "Error de la IA.");
            }
          } catch (err) {
            mostrarStatus("error", "Error de conexión", "Fallo de red.");
          } finally {
            const btnAnalizarElFinal = document.getElementById("btn-analizar") as HTMLButtonElement;
            if (btnAnalizarElFinal) {
              btnAnalizarElFinal.disabled = false;
              btnAnalizarElFinal.textContent = "Analizar con IA (Demora ~10s)";
            }
          }
        });
      }

      const currentBtnCancel = document.getElementById("btn-cancel");
      if (currentBtnCancel) {
        const newBtnCancel = currentBtnCancel.cloneNode(true);
        currentBtnCancel.parentNode?.replaceChild(newBtnCancel, currentBtnCancel);
        newBtnCancel.addEventListener("click", () => {
          document.getElementById("form-edit")?.classList.add("hidden");
          document.getElementById("form-upload")?.classList.remove("hidden");
          clearPhoto();
          ocultarStatus();
        });
      }

      const currentFormEdit = document.getElementById("form-edit") as HTMLFormElement;
      if (currentFormEdit) {
        const newFormEdit = currentFormEdit.cloneNode(true) as HTMLFormElement;
        currentFormEdit.parentNode?.replaceChild(newFormEdit, currentFormEdit);
        newFormEdit.addEventListener("submit", async (e) => {
          e.preventDefault();
          
          const refugio = (document.getElementById("escaner-refugio") as HTMLInputElement).value.trim();
          const contacto = (document.getElementById("escaner-contacto") as HTMLInputElement).value.trim();
          
          // Recolectar nombres de inputs
          const nc = document.getElementById("names-container");
          if (!nc) return;
          const rowDivs = nc.querySelectorAll("[id^='name-row-']");
          const finalPersonas: any[] = [];
          
          rowDivs.forEach(row => {
            const nameInput = row.querySelector(".extracted-name") as HTMLInputElement;
            const cedulaInput = row.querySelector(".extracted-cedula") as HTMLInputElement;
            const telInput = row.querySelector(".extracted-telefono") as HTMLInputElement;
            const edadInput = row.querySelector(".extracted-edad") as HTMLInputElement;
            
            if (nameInput && nameInput.value.trim().length > 2) {
              finalPersonas.push({
                nombre: nameInput.value.trim(),
                cedula: cedulaInput.value ? parseInt(cedulaInput.value, 10) : null,
                telefono: telInput.value ? telInput.value.trim() : null,
                edad: edadInput.value ? parseInt(edadInput.value, 10) : null
              });
            }
          });

          if (finalPersonas.length === 0) {
            alert("La lista debe tener al menos un nombre válido.");
            return;
          }

          const btnConfirmarEl = document.getElementById("btn-confirmar") as HTMLButtonElement;
          if (btnConfirmarEl) {
            btnConfirmarEl.disabled = true;
            btnConfirmarEl.textContent = "Guardando...";
          }
          mostrarStatus("info", "Encolando procesamientos...", "Guardando registros y cruzando con base de datos.");

          try {
            const resp = await fetch("/api/procesar-censo", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ personas: finalPersonas, refugio, contacto })
            });

            if (resp.ok) {
              mostrarStatus("success", "¡Censo cargado con éxito!", `Se registraron ${finalPersonas.length} personas en el sistema y se enviaron a cruzar.`);
              setTimeout(() => {
                const fe = document.getElementById("form-edit") as HTMLFormElement;
                const fu = document.getElementById("form-upload") as HTMLFormElement;
                if (fe) fe.classList.add("hidden");
                if (fu) {
                  fu.classList.remove("hidden");
                  fu.reset();
                }
                clearPhoto();
                ocultarStatus();
              }, 4000);
            } else {
              const err = await resp.json();
              mostrarStatus("error", "Fallo al guardar", err.error || "Intente de nuevo.");
              const bc = document.getElementById("btn-confirmar") as HTMLButtonElement;
              if (bc) {
                bc.disabled = false;
                bc.textContent = "Confirmar y Subir Lista Definitiva";
              }
            }
          } catch (err) {
            mostrarStatus("error", "Error de red", "Verifique su conexión.");
            const bc = document.getElementById("btn-confirmar") as HTMLButtonElement;
            if (bc) {
              bc.disabled = false;
              bc.textContent = "Confirmar y Subir Lista Definitiva";
            }
          }
        });
      }
    });
  </script>
</Layout>
