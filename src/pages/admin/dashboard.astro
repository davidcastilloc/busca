---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const url = new URL(Astro.request.url);
const filterEstado = url.searchParams.get("estado") || "";
const filterRefugio = url.searchParams.get("refugio") || "";

let stats = {
  total: 0,
  vivo: 0,
  herido: 0,
  fallecido: 0,
  desconocido: 0
};

let refugios: { refugio: string; count: number }[] = [];
let personas: any[] = [];

try {
  const { DB } = env;

  if (DB) {
    // 1. Estadísticas globales
    const countQuery = await DB.prepare("SELECT COUNT(*) as count FROM personas").first<{ count: number }>();
    stats.total = countQuery?.count || 0;

    const estadosQuery = await DB.prepare(`
      SELECT estado, COUNT(*) as count FROM personas GROUP BY estado
    `).all<{ estado: string; count: number }>();

    estadosQuery.results.forEach(row => {
      if (row.estado in stats) {
        // @ts-ignore
        stats[row.estado] = row.count;
      }
    });

    // 2. Lista de albergues / refugios
    const refugiosQuery = await DB.prepare(`
      SELECT refugio, COUNT(*) as count FROM personas WHERE refugio IS NOT NULL AND refugio != '' GROUP BY refugio ORDER BY count DESC
    `).all<{ refugio: string; count: number }>();
    refugios = refugiosQuery.results;

    // 3. Consulta de personas censadas con filtros
    let queryStr = "SELECT * FROM personas WHERE 1=1";
    const bindings: any[] = [];

    if (filterEstado) {
      queryStr += " AND estado = ?";
      bindings.push(filterEstado);
    }

    if (filterRefugio) {
      queryStr += " AND refugio = ?";
      bindings.push(filterRefugio);
    }

    queryStr += " ORDER BY updated_at DESC LIMIT 100";

    const personasQuery = await DB.prepare(queryStr).bind(...bindings).all();
    personas = personasQuery.results;
  }
} catch (error) {
  console.error("Error al cargar dashboard de administración:", error);
}

const formatFecha = (fechaStr: string) => {
  try {
    const d = new Date(fechaStr + " UTC");
    return d.toLocaleString("es-ES", { timeZone: "America/Caracas" });
  } catch (e) {
    return fechaStr;
  }
};
---

<Layout title="Dashboard de Rescatistas - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-7xl mx-auto w-full">
    <!-- Encabezado de Administración -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
      <div>
        <h1 class="font-uber-display text-3xl text-ink tracking-tight flex items-center gap-2">
          Panel de Triage y Censo
        </h1>
        <p class="text-sm text-body font-uber-text mt-1">
          Visualización y gestión de sobrevivientes. Acceso exclusivo para personal de rescate.
        </p>
      </div>
      <div class="flex gap-2">
        <a href="/registrar" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong">
          Registrar en Censo
        </a>
      </div>
    </div>

    <!-- Indicadores de Estado (cards minimalistas) -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
      <div class="bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm text-center">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Registros Totales</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.total}</div>
      </div>
      <div class="bg-canvas border border-green-500/20 p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Vivo / A Salvo</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.vivo}</div>
      </div>
      <div class="bg-canvas border border-yellow-500/20 p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Heridos</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.herido}</div>
      </div>
      <div class="bg-canvas border border-red-500/20 p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Fallecidos</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.fallecido}</div>
      </div>
      <div class="bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Desconocido</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.desconocido}</div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Columna Izquierda: Filtros y Albergues -->
      <div class="space-y-6 lg:col-span-1">
        <!-- Filtros (card-content) -->
        <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm">
          <h3 class="font-uber-display text-sm text-ink mb-4 uppercase tracking-wider">Filtrar Censo</h3>
          
          <form method="GET" class="space-y-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Estado Médico</label>
              <select name="estado" class="select select-sm w-full font-uber-text">
                <option value="">Todos</option>
                <option value="vivo" selected={filterEstado === "vivo"}>Vivo / A Salvo</option>
                <option value="herido" selected={filterEstado === "herido"}>Herido</option>
                <option value="fallecido" selected={filterEstado === "fallecido"}>Fallecido</option>
                <option value="desconocido" selected={filterEstado === "desconocido"}>Desconocido</option>
              </select>
            </div>

            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Refugio / Albergue</label>
              <select name="refugio" class="select select-sm w-full font-uber-text">
                <option value="">Todos</option>
                {refugios.map(r => (
                  <option value={r.refugio} selected={filterRefugio === r.refugio}>
                    {r.refugio} ({r.count})
                  </option>
                ))}
              </select>
            </div>

            <div class="flex flex-col gap-2 pt-2">
              <button type="submit" class="btn bg-primary text-white hover:bg-black-elevated w-full font-uber-text uber-body-md-strong">
                Filtrar
              </button>
              <a href="/admin/dashboard" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed w-full font-uber-text uber-body-md-strong text-center">
                Limpiar
              </a>
            </div>
          </form>
        </div>

        <!-- Lista de albergues con recuento (card-content) -->
        <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm">
          <h3 class="font-uber-display text-sm text-ink mb-4 uppercase tracking-wider">Albergues Activos</h3>
          <div class="divide-y divide-canvas-soft">
            {refugios.length === 0 ? (
              <p class="text-xs text-mute py-2 font-uber-text">No hay albergues registrados.</p>
            ) : (
              refugios.map(r => (
                <div class="flex justify-between items-center py-2.5 text-sm">
                  <a href={`?refugio=${encodeURIComponent(r.refugio)}`} class="font-uber-text uber-body-sm-strong text-link hover:opacity-80 truncate mr-2">
                    {r.refugio}
                  </a>
                  <span class="px-2 py-0.5 rounded bg-canvas-soft text-xs text-ink font-semibold">{r.count}</span>
                </div>
              ))
            )}
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Tabla de registros (ex-data-table-cell) -->
      <div class="lg:col-span-3">
        <div class="bg-canvas border border-canvas-soft rounded-xl shadow-sm overflow-hidden">
          <div class="p-6 border-b border-canvas-soft flex justify-between items-center bg-canvas">
            <h3 class="font-uber-display text-lg text-ink">Sobrevivientes y Registros Recientes</h3>
            <span class="text-xs font-uber-text font-medium text-body">Mostrando {personas.length} registros</span>
          </div>

          <div class="overflow-x-auto">
            <table class="table w-full text-left">
              <thead>
                <tr class="font-uber-text font-medium text-xs uppercase text-body">
                  <th>Foto</th>
                  <th>Nombre</th>
                  <th>Cédula</th>
                  <th>Estado</th>
                  <th>Ubicación / Refugio</th>
                  <th>Fecha</th>
                </tr>
              </thead>
              <tbody>
                {personas.length === 0 ? (
                  <tr>
                    <td colspan="6" class="text-center py-10 font-uber-text font-medium text-body">
                      No se encontraron personas con los filtros seleccionados.
                    </td>
                  </tr>
                ) : (
                  personas.map(p => {
                    const statusMap = {
                      vivo: { badge: "border border-green-500/30 text-ink bg-canvas", dot: "bg-green-500" },
                      herido: { badge: "border border-yellow-500/30 text-ink bg-canvas", dot: "bg-yellow-500" },
                      fallecido: { badge: "border border-red-500/30 text-ink bg-canvas", dot: "bg-red-500" },
                      desconocido: { badge: "border border-canvas-soft text-ink bg-canvas", dot: "bg-mute" }
                    }[p.estado as string] || { badge: "border border-canvas-soft text-ink bg-canvas", dot: "bg-mute" };

                    return (
                      <tr class="transition-colors hover:bg-canvas-soft">
                        <td>
                          {p.foto_key ? (
                            <div class="w-10 h-10 rounded-xl overflow-hidden bg-canvas-soft">
                              <img src={`/api/upload?key=${encodeURIComponent(p.foto_key)}`} alt="Foto" class="w-full h-full object-cover" />
                            </div>
                          ) : (
                            <div class="w-10 h-10 bg-canvas-soft rounded-xl flex items-center justify-center text-lg text-mute">
                              👤
                            </div>
                          )}
                        </td>
                        <td class="font-uber-text uber-body-md-strong text-ink">
                          {p.nombre} {p.apellido || ""}
                        </td>
                        <td class="font-mono text-sm text-body">{p.cedula || "-"}</td>
                        <td>
                          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-uber-text font-medium ${statusMap.badge}`}>
                            <span class={`w-1.5 h-1.5 rounded-full ${statusMap.dot}`}></span>
                            <span>{p.estado}</span>
                          </span>
                        </td>
                        <td>
                          <div class="font-uber-text uber-body-sm-strong text-ink">{p.refugio || "Sin albergue"}</div>
                          <div class="text-xs text-body font-uber-text truncate max-w-xs">{p.ubicacion_nombre || "-"}</div>
                        </td>
                        <td class="text-xs text-body font-uber-text">
                          {formatFecha(p.updated_at)}
                        </td>
                      </tr>
                    );
                  })
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
