---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const url = new URL(Astro.request.url);
const filterEstado = url.searchParams.get("estado") || "";
const filterRefugio = url.searchParams.get("refugio") || "";

let stats = {
  total: 0,
  vivo: 0,
  herido: 0,
  fallecido: 0,
  desconocido: 0
};

let refugios: { refugio: string; count: number }[] = [];
let personas: any[] = [];

try {
  const { DB } = env;

  if (DB) {
    // 1. Estadísticas globales
    const countQuery = await DB.prepare("SELECT COUNT(*) as count FROM personas").first<{ count: number }>();
    stats.total = countQuery?.count || 0;

    const estadosQuery = await DB.prepare(`
      SELECT estado, COUNT(*) as count FROM personas GROUP BY estado
    `).all<{ estado: string; count: number }>();

    estadosQuery.results.forEach(row => {
      if (row.estado in stats) {
        // @ts-ignore
        stats[row.estado] = row.count;
      }
    });

    // 2. Lista de albergues / refugios
    const refugiosQuery = await DB.prepare(`
      SELECT refugio, COUNT(*) as count FROM personas WHERE refugio IS NOT NULL AND refugio != '' GROUP BY refugio ORDER BY count DESC
    `).all<{ refugio: string; count: number }>();
    refugios = refugiosQuery.results;

    // 3. Consulta de personas censadas con filtros
    let queryStr = "SELECT * FROM personas WHERE 1=1";
    const bindings: any[] = [];

    if (filterEstado) {
      queryStr += " AND estado = ?";
      bindings.push(filterEstado);
    }

    if (filterRefugio) {
      queryStr += " AND refugio = ?";
      bindings.push(filterRefugio);
    }

    queryStr += " ORDER BY updated_at DESC LIMIT 100";

    const personasQuery = await DB.prepare(queryStr).bind(...bindings).all();
    personas = personasQuery.results;
  }
} catch (error) {
  console.error("Error al cargar dashboard de administración:", error);
}

const formatFecha = (fechaStr: string) => {
  try {
    const d = new Date(fechaStr + " UTC");
    return d.toLocaleString("es-ES", { timeZone: "America/Caracas" });
  } catch (e) {
    return fechaStr;
  }
};
---

<Layout title="Dashboard de Rescatistas - BUSCA">
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-7xl mx-auto w-full">
    <!-- Encabezado de Administración -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-black text-base-content flex items-center gap-2">
          📊 Panel de Triage y Censo
        </h1>
        <p class="text-sm text-base-content/70 mt-1">
          Visualización y gestión de sobrevivientes. Acceso exclusivo para personal de rescate.
        </p>
      </div>
      <div class="flex gap-2">
        <a href="/registrar" class="btn btn-error text-white font-bold btn-sm">
          ➕ Censo Rápido
        </a>
      </div>
    </div>

    <!-- Indicadores de Estado -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
      <div class="card bg-base-100 border border-base-300 p-4 shadow-sm text-center">
        <div class="text-xs text-base-content/60 font-bold uppercase">Registros Totales</div>
        <div class="text-3xl font-black text-base-content mt-1">{stats.total}</div>
      </div>
      <div class="card bg-base-100 border border-base-300 p-4 shadow-sm text-center border-l-4 border-success">
        <div class="text-xs text-base-content/60 font-bold uppercase text-success">Vivo / A Salvo</div>
        <div class="text-3xl font-black text-success mt-1">{stats.vivo}</div>
      </div>
      <div class="card bg-base-100 border border-base-300 p-4 shadow-sm text-center border-l-4 border-warning">
        <div class="text-xs text-base-content/60 font-bold uppercase text-warning">Heridos</div>
        <div class="text-3xl font-black text-warning mt-1">{stats.herido}</div>
      </div>
      <div class="card bg-base-100 border border-base-300 p-4 shadow-sm text-center border-l-4 border-error">
        <div class="text-xs text-base-content/60 font-bold uppercase text-error">Fallecidos</div>
        <div class="text-3xl font-black text-error mt-1">{stats.fallecido}</div>
      </div>
      <div class="card bg-base-100 border border-base-300 p-4 shadow-sm text-center border-l-4 border-neutral">
        <div class="text-xs text-base-content/60 font-bold uppercase">Desconocido</div>
        <div class="text-3xl font-black text-neutral mt-1">{stats.desconocido}</div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Columna Izquierda: Filtros y Albergues -->
      <div class="space-y-6 lg:col-span-1">
        <!-- Filtros -->
        <div class="card bg-base-100 border border-base-300 p-5 shadow-sm">
          <h3 class="font-black text-sm text-base-content/80 mb-4 uppercase">Filtrar Censo</h3>
          
          <form method="GET" class="space-y-4">
            <div>
              <label class="label font-bold text-xs p-0 mb-1">Estado Médico</label>
              <select name="estado" class="select select-bordered select-sm w-full">
                <option value="">Todos</option>
                <option value="vivo" selected={filterEstado === "vivo"}>Vivo / A Salvo</option>
                <option value="herido" selected={filterEstado === "herido"}>Herido</option>
                <option value="fallecido" selected={filterEstado === "fallecido"}>Fallecido</option>
                <option value="desconocido" selected={filterEstado === "desconocido"}>Desconocido</option>
              </select>
            </div>

            <div>
              <label class="label font-bold text-xs p-0 mb-1">Refugio / Albergue</label>
              <select name="refugio" class="select select-bordered select-sm w-full">
                <option value="">Todos</option>
                {refugios.map(r => (
                  <option value={r.refugio} selected={filterRefugio === r.refugio}>
                    {r.refugio} ({r.count})
                  </option>
                ))}
              </select>
            </div>

            <div class="flex gap-2 pt-2">
              <button type="submit" class="btn btn-error text-white btn-sm flex-1 font-bold">
                Filtrar
              </button>
              <a href="/admin/dashboard" class="btn btn-outline border-base-300 btn-sm font-bold">
                Limpiar
              </a>
            </div>
          </form>
        </div>

        <!-- Lista de albergues con recuento -->
        <div class="card bg-base-100 border border-base-300 p-5 shadow-sm">
          <h3 class="font-black text-sm text-base-content/80 mb-3 uppercase">Albergues Activos</h3>
          <div class="divide-y divide-base-200">
            {refugios.length === 0 ? (
              <p class="text-xs text-base-content/50 py-2">No hay albergues registrados.</p>
            ) : (
              refugios.map(r => (
                <div class="flex justify-between items-center py-2 text-sm">
                  <a href={`?refugio=${encodeURIComponent(r.refugio)}`} class="font-semibold text-error hover:underline truncate mr-2">
                    {r.refugio}
                  </a>
                  <span class="badge badge-sm font-bold bg-base-200">{r.count}</span>
                </div>
              ))
            )}
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Tabla de registros -->
      <div class="lg:col-span-3">
        <div class="card bg-base-100 border border-base-300 shadow-sm overflow-hidden">
          <div class="p-5 border-b border-base-200 flex justify-between items-center">
            <h3 class="font-black text-lg text-base-content">Sobrevivientes y Registros Recientes</h3>
            <span class="text-xs font-semibold text-base-content/60">Mostrando {personas.length} registros</span>
          </div>

          <div class="overflow-x-auto">
            <table class="table table-zebra w-full text-left">
              <thead>
                <tr class="font-bold text-xs uppercase text-base-content/60">
                  <th class="bg-base-200">Foto</th>
                  <th class="bg-base-200">Nombre</th>
                  <th class="bg-base-200">Cédula</th>
                  <th class="bg-base-200">Estado</th>
                  <th class="bg-base-200">Ubicación / Refugio</th>
                  <th class="bg-base-200">Fecha</th>
                </tr>
              </thead>
              <tbody>
                {personas.length === 0 ? (
                  <tr>
                    <td colspan="6" class="text-center py-10 font-bold text-base-content/50">
                      No se encontraron personas con los filtros seleccionados.
                    </td>
                  </tr>
                ) : (
                  personas.map(p => {
                    const statusClass = {
                      vivo: "badge-success text-white",
                      herido: "badge-warning text-black",
                      fallecido: "badge-error text-white",
                      desconocido: "badge-neutral text-white"
                    }[p.estado as string] || "badge-neutral text-white";

                    return (
                      <tr class="hover:bg-base-200/50">
                        <td>
                          {p.foto_key ? (
                            <div class="avatar">
                              <div class="w-10 h-10 rounded-lg">
                                <img src={`/api/upload?key=${encodeURIComponent(p.foto_key)}`} alt="Foto" />
                              </div>
                            </div>
                          ) : (
                            <div class="w-10 h-10 bg-base-300 rounded-lg flex items-center justify-center text-lg">
                              👤
                            </div>
                          )}
                        </td>
                        <td class="font-bold text-base-content">
                          {p.nombre} {p.apellido || ""}
                        </td>
                        <td class="font-mono text-sm font-semibold">{p.cedula || "-"}</td>
                        <td>
                          <span class={`badge badge-sm font-black uppercase text-[10px] ${statusClass}`}>
                            {p.estado}
                          </span>
                        </td>
                        <td>
                          <div class="font-bold text-sm">{p.refugio || "Sin albergue"}</div>
                          <div class="text-xs text-base-content/50 truncate max-w-xs">{p.ubicacion_nombre || "-"}</div>
                        </td>
                        <td class="text-xs font-semibold text-base-content/60">
                          {formatFecha(p.updated_at)}
                        </td>
                      </tr>
                    );
                  })
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
