---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout title="Dashboard - BUSCA">
  <Navbar />
  <main class="flex-grow py-8 px-4 max-w-7xl mx-auto w-full">
    <h1 class="text-3xl font-black text-base-content mb-8">📊 Dashboard</h1>

    <div id="stats-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="card bg-base-100 border p-4 shadow-sm text-center"><div class="text-xs font-bold uppercase">Total</div><div id="d-total" class="text-3xl font-black mt-1">...</div></div>
      <div class="card bg-base-100 border p-4 shadow-sm text-center border-l-4 border-error"><div class="text-xs font-bold uppercase text-error">Por Localizar</div><div id="d-missing" class="text-3xl font-black text-error mt-1">...</div></div>
      <div class="card bg-base-100 border p-4 shadow-sm text-center border-l-4 border-success"><div class="text-xs font-bold uppercase text-success">Localizadas</div><div id="d-found" class="text-3xl font-black text-success mt-1">...</div></div>
      <div class="card bg-base-100 border p-4 shadow-sm text-center border-l-4 border-info"><div class="text-xs font-bold uppercase text-info">Con Foto</div><div id="d-photos" class="text-3xl font-black text-info mt-1">...</div></div>
    </div>
  </main>
</Layout>

<script>
  const API = "http://localhost:3001";
  fetch(`${API}/api/stats`).then(r=>r.json()).then(s=>{
    document.getElementById("d-total").textContent = s.total.toLocaleString("es");
    document.getElementById("d-missing").textContent = s.missing.toLocaleString("es");
    document.getElementById("d-found").textContent = s.found.toLocaleString("es");
  });
</script>
