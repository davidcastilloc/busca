---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const url = new URL(Astro.request.url);
const filterEstado = url.searchParams.get("estado") || "";
const filterRefugio = url.searchParams.get("refugio") || "";

let stats = {
  total: 0,
  localizado: 0,
  herido: 0,
  fallecido: 0,
  desconocido: 0
};

let refugios: { refugio: string; count: number }[] = [];
let personas: any[] = [];
let pendientes: any[] = [];
let totalSuscriptoresPush = 0;

try {
  const { DB } = env;

  if (DB) {
    // 1. Estadísticas globales
    const countQuery = await DB.prepare("SELECT COUNT(*) as count FROM personas").first<{ count: number }>();
    stats.total = countQuery?.count || 0;

    const estadosQuery = await DB.prepare(`
      SELECT estado, COUNT(*) as count FROM personas GROUP BY estado
    `).all<{ estado: string; count: number }>();

    estadosQuery.results.forEach(row => {
      if (row.estado in stats) {
        // @ts-ignore
        stats[row.estado] = row.count;
      }
    });

    // 2. Lista de albergues / refugios
    const refugiosQuery = await DB.prepare(`
      SELECT refugio, COUNT(*) as count FROM personas WHERE refugio IS NOT NULL AND refugio != '' GROUP BY refugio ORDER BY count DESC
    `).all<{ refugio: string; count: number }>();
    refugios = refugiosQuery.results;

    // 3. Consulta de personas censadas con filtros
    let queryStr = "SELECT * FROM personas WHERE 1=1";
    const bindings: any[] = [];

    if (filterEstado) {
      queryStr += " AND estado = ?";
      bindings.push(filterEstado);
    }

    if (filterRefugio) {
      queryStr += " AND refugio = ?";
      bindings.push(filterRefugio);
    }

    queryStr += " ORDER BY updated_at DESC LIMIT 100";

    const personasQuery = await DB.prepare(queryStr).bind(...bindings).all();
    personas = personasQuery.results;

    // 4. Consulta de pendientes de verificación
    const personasPendientes = await DB.prepare("SELECT *, 'persona' as _tipo_origen FROM personas WHERE verificacion = 'pendiente'").all();
    const reportesPendientes = await DB.prepare("SELECT *, 'reporte' as _tipo_origen FROM reportes WHERE verificacion = 'pendiente'").all();
    pendientes = [...(personasPendientes.results || []), ...(reportesPendientes.results || [])];

    // 5. Contar suscriptores push activos
    try {
      const pushCount = await DB.prepare("SELECT COUNT(*) as count FROM push_subscriptions").first<{ count: number }>();
      totalSuscriptoresPush = pushCount?.count || 0;
    } catch {
      // La tabla puede no existir aún si no se ha corrido la migración
      totalSuscriptoresPush = 0;
    }
  }
} catch (error) {
  console.error("Error al cargar dashboard de administración:", error);
}

const formatFecha = (fechaStr: string) => {
  try {
    const d = new Date(fechaStr + " UTC");
    return d.toLocaleString("es-ES", { timeZone: "America/Caracas" });
  } catch (e) {
    return fechaStr;
  }
};
---

<Layout title="Dashboard de Rescatistas - dondeestan.org">
  <Navbar />
  
  <main class="flex-grow py-8 px-4 max-w-7xl mx-auto w-full">
    <!-- Encabezado de Administración -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
      <div>
        <h1 class="font-uber-display text-3xl text-ink tracking-tight flex items-center gap-2">
          Panel de Triage y Censo
        </h1>
        <p class="text-sm text-body font-uber-text mt-1">
          Visualización y gestión de sobrevivientes. Acceso exclusivo para personal de rescate.
        </p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/escaner" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text uber-body-md-strong border border-canvas-soft flex items-center gap-2">
          📷 Escáner IA
        </a>
        <a href="/registrar" class="btn bg-primary text-white hover:bg-black-elevated font-uber-text uber-body-md-strong">
          Registrar en Censo
        </a>
      </div>
    </div>

    <!-- Indicadores de Estado (cards minimalistas) -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
      <div class="bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm text-center">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Registros Totales</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.total}</div>
      </div>
      <div class="bg-canvas border border-green-500/20 p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Localizado</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.localizado}</div>
      </div>
      <div class="bg-canvas border border-yellow-500/20 p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Heridos</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.herido}</div>
      </div>
      <div class="bg-canvas border border-red-500/20 p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Fallecidos</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.fallecido}</div>
      </div>
      <div class="bg-canvas border border-canvas-soft p-5 rounded-xl shadow-sm text-center border-l-4">
        <div class="text-xs text-body font-uber-text font-medium uppercase tracking-wider">Desconocido</div>
        <div class="font-uber-display text-3xl text-ink mt-2">{stats.desconocido}</div>
      </div>
    </div>

    <!-- Mapa de Calor GPS con Leaflet -->
    <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm mb-8">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-uber-display text-lg text-ink flex items-center gap-2">
          🗺️ Mapa de Concentración
        </h2>
        <button id="btn-refrescar-mapa" class="btn btn-sm bg-canvas-soft text-ink hover:bg-surface-pressed font-uber-text cursor-pointer">
          🔄 Refrescar
        </button>
      </div>
      <div id="heatmap" class="w-full h-[400px] rounded-xl overflow-hidden border border-canvas-soft bg-canvas-soft"></div>
      <p id="heatmap-status" class="text-xs text-body font-uber-text mt-2 italic"></p>
    </div>

    <!-- Sección de Alertas de Emergencia Push -->
    <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm mb-8">
      <h2 class="font-uber-display text-lg text-ink mb-4 flex items-center gap-2">
        🚨 Enviar Alerta de Emergencia
      </h2>
      <p class="text-sm text-body font-uber-text mb-4">
        Envía una notificación push silenciosa a todos los voluntarios suscritos.
        <span class="font-medium text-ink">Suscriptores activos: {totalSuscriptoresPush}</span>
      </p>
      
      <form id="form-alerta" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Tipo de Alerta *</label>
          <select name="tipo_alerta" id="tipo-alerta" class="select w-full font-uber-text">
            <option value="evacuacion">🏃 Evacuación (2 vibraciones cortas)</option>
            <option value="replica">⚠️ Réplica / Peligro (3 vibraciones largas)</option>
            <option value="info">ℹ️ Información General (1 vibración)</option>
          </select>
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Título *</label>
          <input type="text" name="titulo_alerta" id="titulo-alerta" class="input w-full font-uber-text" placeholder="Ej: Nueva zona de evacuación" maxlength="100" required />
        </div>
        <div class="md:col-span-2">
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Mensaje *</label>
          <textarea name="mensaje_alerta" id="mensaje-alerta" class="textarea w-full h-20 font-uber-text" placeholder="Descripción de la alerta..." maxlength="500" required></textarea>
        </div>
        <div>
          <label class="block font-uber-text uber-body-sm-strong text-body mb-1">URL destino (opcional)</label>
          <input type="text" name="url_alerta" id="url-alerta" class="input w-full font-uber-text" placeholder="/" value="/" />
        </div>
        <div class="flex items-end">
          <button type="submit" id="btn-enviar-alerta" class="btn bg-red-600 text-white hover:bg-red-700 w-full font-uber-text uber-body-md-strong cursor-pointer">
            Enviar Alerta a {totalSuscriptoresPush} Dispositivos
          </button>
        </div>
      </form>
      <p id="alerta-status" class="text-sm font-uber-text mt-3 hidden"></p>
    </div>

    <!-- Sección de Moderación Destacada: Pendientes de Validación -->
    {pendientes.length > 0 && (
      <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm mb-8 animate-fade-in">
        <h2 class="font-uber-display text-lg text-ink mb-4 flex items-center gap-2">
          ⚠️ Pendientes de Validación ({pendientes.length})
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {pendientes.map((item: any) => {
            const esPersona = item._tipo_origen === "persona";
            const id = item.id;
            const nombre = esPersona 
              ? `${item.nombre} ${item.apellido || ""}`
              : (item.nombre_buscado || "Persona no identificada");
            
            const fotoOriginal = item.foto_key;
            const fotoEvidencia = item.foto_evidencia_key;
            const contacto = item.contacto_evidencia || item.contacto || "-";
            const notas = item.notas_evidencia || item.notas || "-";

            return (
              <div class="border border-canvas-soft bg-canvas rounded-xl p-4 flex flex-col justify-between shadow-sm hover:shadow transition-shadow">
                <div>
                  <div class="flex justify-between items-center mb-3">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-body">
                      {esPersona ? "👤 Censo de Persona" : "📢 Reporte de Desaparición"}
                    </span>
                    <span class="text-xs text-yellow-600 font-semibold bg-yellow-100 px-2.5 py-0.5 rounded-full">
                      Esperando Validación
                    </span>
                  </div>
                  <h3 class="font-uber-display text-base text-ink mb-3 truncate">{nombre}</h3>
                  
                  <!-- Fotos comparativas -->
                  <div class="grid grid-cols-2 gap-3 mb-4">
                    <div class="text-center">
                      <span class="text-[9px] font-semibold text-mute uppercase block mb-1">Foto Original</span>
                      <div class="aspect-square rounded-lg bg-canvas-soft overflow-hidden flex items-center justify-center border border-canvas-soft">
                        {fotoOriginal ? (
                          <img src={`/api/upload?key=${encodeURIComponent(fotoOriginal)}`} alt="Foto original" class="w-full h-full object-contain" />
                        ) : (
                          <span class="text-3xl text-mute">👤</span>
                        )}
                      </div>
                    </div>
                    <div class="text-center">
                      <span class="text-[9px] font-semibold text-mute uppercase block mb-1">Evidencia</span>
                      <div class="aspect-square rounded-lg bg-canvas-soft overflow-hidden flex items-center justify-center border border-yellow-500/30">
                        {fotoEvidencia ? (
                          <img src={`/api/upload?key=${encodeURIComponent(fotoEvidencia)}`} alt="Foto evidencia" class="w-full h-full object-contain" />
                        ) : (
                          <span class="text-3xl text-mute">📷</span>
                        )}
                      </div>
                    </div>
                  </div>

                  <!-- Detalles de evidencia -->
                  <div class="text-xs space-y-1 text-body font-uber-text mb-4 bg-canvas-soft p-3 rounded-lg">
                    <div><strong>📞 Contacto:</strong> {contacto}</div>
                    {item.refugio && <div><strong>📍 Refugio:</strong> {item.refugio}</div>}
                    <div class="line-clamp-3"><strong>📝 Mensaje:</strong> <span class="italic">"{notas}"</span></div>
                  </div>
                </div>

                <!-- Acciones -->
                <div class="flex gap-2 border-t border-canvas-soft pt-3 mt-auto">
                  <button 
                    class="btn-aprobar btn bg-success text-white hover:bg-green-700 flex-1 font-uber-text text-xs py-1 min-h-0 h-9 flex items-center justify-center gap-1 cursor-pointer"
                    data-id={id}
                    data-tipo={item._tipo_origen}
                  >
                    Aprobar
                  </button>
                  <button 
                    class="btn-rechazar btn bg-red-600 text-white hover:bg-red-800 flex-1 font-uber-text text-xs py-1 min-h-0 h-9 flex items-center justify-center gap-1 cursor-pointer"
                    data-id={id}
                    data-tipo={item._tipo_origen}
                  >
                    Rechazar
                  </button>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Columna Izquierda: Filtros y Albergues -->
      <div class="space-y-6 lg:col-span-1">
        <!-- Filtros (card-content) -->
        <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm">
          <h3 class="font-uber-display text-sm text-ink mb-4 uppercase tracking-wider">Filtrar Censo</h3>
          
          <form method="GET" class="space-y-4">
            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Estado Médico</label>
              <select name="estado" class="select select-sm w-full font-uber-text">
                <option value="">Todos</option>
                <option value="localizado" selected={filterEstado === "localizado"}>Localizado</option>
                <option value="herido" selected={filterEstado === "herido"}>Herido</option>
                <option value="fallecido" selected={filterEstado === "fallecido"}>Fallecido</option>
                <option value="desconocido" selected={filterEstado === "desconocido"}>Desconocido</option>
              </select>
            </div>

            <div>
              <label class="block font-uber-text uber-body-sm-strong text-body mb-1">Refugio / Albergue</label>
              <select name="refugio" class="select select-sm w-full font-uber-text">
                <option value="">Todos</option>
                {refugios.map(r => (
                  <option value={r.refugio} selected={filterRefugio === r.refugio}>
                    {r.refugio} ({r.count})
                  </option>
                ))}
              </select>
            </div>

            <div class="flex flex-col gap-2 pt-2">
              <button type="submit" class="btn bg-primary text-white hover:bg-black-elevated w-full font-uber-text uber-body-md-strong">
                Filtrar
              </button>
              <a href="/admin/dashboard" class="btn bg-canvas-soft text-ink hover:bg-surface-pressed w-full font-uber-text uber-body-md-strong text-center">
                Limpiar
              </a>
            </div>
          </form>
        </div>

        <!-- Lista de albergues con recuento (card-content) -->
        <div class="bg-canvas border border-canvas-soft p-6 rounded-xl shadow-sm">
          <h3 class="font-uber-display text-sm text-ink mb-4 uppercase tracking-wider">Albergues Activos</h3>
          <div class="divide-y divide-canvas-soft">
            {refugios.length === 0 ? (
              <p class="text-xs text-mute py-2 font-uber-text">No hay albergues registrados.</p>
            ) : (
              refugios.map(r => (
                <div class="flex justify-between items-center py-2.5 text-sm">
                  <a href={`?refugio=${encodeURIComponent(r.refugio)}`} class="font-uber-text uber-body-sm-strong text-link hover:opacity-80 truncate mr-2">
                    {r.refugio}
                  </a>
                  <span class="px-2 py-0.5 rounded bg-canvas-soft text-xs text-ink font-semibold">{r.count}</span>
                </div>
              ))
            )}
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Tabla de registros (ex-data-table-cell) -->
      <div class="lg:col-span-3">
        <div class="bg-canvas border border-canvas-soft rounded-xl shadow-sm overflow-hidden">
          <div class="p-6 border-b border-canvas-soft flex justify-between items-center bg-canvas">
            <h3 class="font-uber-display text-lg text-ink">Sobrevivientes y Registros Recientes</h3>
            <span class="text-xs font-uber-text font-medium text-body">Mostrando {personas.length} registros</span>
          </div>

          <div class="overflow-x-auto">
            <table class="table w-full text-left">
              <thead>
                <tr class="font-uber-text font-medium text-xs uppercase text-body">
                  <th>Foto</th>
                  <th>Nombre</th>
                  <th>Cédula</th>
                  <th>Estado</th>
                  <th>Ubicación / Refugio</th>
                  <th>Fecha</th>
                </tr>
              </thead>
              <tbody>
                {personas.length === 0 ? (
                  <tr>
                    <td colspan="6" class="text-center py-10 font-uber-text font-medium text-body">
                      No se encontraron personas con los filtros seleccionados.
                    </td>
                  </tr>
                ) : (
                  personas.map(p => {
                    const statusMap = {
                      localizado: { badge: "border border-green-500/30 text-ink bg-canvas", dot: "bg-green-500" },
                      herido: { badge: "border border-yellow-500/30 text-ink bg-canvas", dot: "bg-yellow-500" },
                      fallecido: { badge: "border border-red-500/30 text-ink bg-canvas", dot: "bg-red-500" },
                      desconocido: { badge: "border border-canvas-soft text-ink bg-canvas", dot: "bg-mute" }
                    }[p.estado as string] || { badge: "border border-canvas-soft text-ink bg-canvas", dot: "bg-mute" };

                    return (
                      <tr class="transition-colors hover:bg-canvas-soft">
                        <td>
                          {p.foto_key ? (
                            <div class="w-10 h-10 rounded-xl overflow-hidden bg-canvas-soft">
                              <img src={`/api/upload?key=${encodeURIComponent(p.foto_key)}`} alt="Foto" class="w-full h-full object-cover" />
                            </div>
                          ) : (
                            <div class="w-10 h-10 bg-canvas-soft rounded-xl flex items-center justify-center text-lg text-mute">
                              👤
                            </div>
                          )}
                        </td>
                        <td class="font-uber-text uber-body-md-strong text-ink">
                          {p.nombre} {p.apellido || ""}
                        </td>
                        <td class="font-mono text-sm text-body">{p.cedula || "-"}</td>
                        <td>
                          <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-uber-text font-medium ${statusMap.badge}`}>
                            <span class={`w-1.5 h-1.5 rounded-full ${statusMap.dot}`}></span>
                            <span>{p.estado}</span>
                          </span>
                        </td>
                        <td>
                          <div class="font-uber-text uber-body-sm-strong text-ink">{p.refugio || "Sin albergue"}</div>
                          <div class="text-xs text-body font-uber-text truncate max-w-xs">{p.ubicacion_nombre || "-"}</div>
                        </td>
                        <td class="text-xs text-body font-uber-text">
                          {formatFecha(p.updated_at)}
                        </td>
                      </tr>
                    );
                  })
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<!-- Script de acciones del administrador para moderar reportes de localizado -->
<script>
  const botonesAprobar = document.querySelectorAll(".btn-aprobar");
  const botonesRechazar = document.querySelectorAll(".btn-rechazar");

  botonesAprobar.forEach(btn => {
    btn.addEventListener("click", async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute("data-id");
      const tipo = target.getAttribute("data-tipo");
      if (!id || !tipo) return;

      if (!confirm("¿Confirmar y marcar esta persona/reporte como verificado localizado?")) return;

      target.disabled = true;
      target.textContent = "Aprobando...";

      try {
        const endpoint = tipo === "persona" ? `/api/personas/${id}` : `/api/reportes/${id}`;
        const resp = await fetch(endpoint, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ accion: "aprobar_localizado" })
        });

        if (resp.ok) {
          window.location.reload();
        } else {
          const err = await resp.json();
          alert(`Error: ${err.error}`);
          target.disabled = false;
          target.textContent = "Aprobar";
        }
      } catch {
        alert("Error de conexión");
        target.disabled = false;
        target.textContent = "Aprobar";
      }
    });
  });

  botonesRechazar.forEach(btn => {
    btn.addEventListener("click", async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute("data-id");
      const tipo = target.getAttribute("data-tipo");
      if (!id || !tipo) return;

      if (!confirm("¿Rechazar este reporte de localizado? La persona/reporte volverá a su estado anterior.")) return;

      target.disabled = true;
      target.textContent = "Rechazando...";

      try {
        const endpoint = tipo === "persona" ? `/api/personas/${id}` : `/api/reportes/${id}`;
        const resp = await fetch(endpoint, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ accion: "rechazar_localizado" })
        });

        if (resp.ok) {
          window.location.reload();
        } else {
          const err = await resp.json();
          alert(`Error: ${err.error}`);
          target.disabled = false;
          target.textContent = "Rechazar";
        }
      } catch {
        alert("Error de conexión");
        target.disabled = false;
        target.textContent = "Rechazar";
      }
    });
  });
</script>

<!-- Leaflet CSS + JS desde CDN -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

<!-- Script del Mapa de Calor -->
<script is:inline>
  (function() {
    const mapContainer = document.getElementById('heatmap');
    const statusText = document.getElementById('heatmap-status');
    const refrescarBtn = document.getElementById('btn-refrescar-mapa');
    
    if (!mapContainer || typeof L === 'undefined') return;

    // Inicializar mapa centrado en Venezuela
    const map = L.map('heatmap').setView([10.4806, -66.9036], 7);

    // Tiles de OpenStreetMap
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap',
      maxZoom: 18,
    }).addTo(map);

    let heatLayer = null;

    async function cargarHeatmap() {
      if (statusText) statusText.textContent = 'Cargando datos de coordenadas...';
      try {
        const resp = await fetch('/api/heatmap');
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();

        if (heatLayer) map.removeLayer(heatLayer);

        if (data.puntos && data.puntos.length > 0) {
          const heatPoints = data.puntos.map(function(p) { return [p.lat, p.lon, p.peso || 1]; });
          heatLayer = L.heatLayer(heatPoints, {
            radius: 25,
            blur: 15,
            maxZoom: 15,
            gradient: {
              0.2: '#2196F3',
              0.4: '#4CAF50',
              0.6: '#FFC107',
              0.8: '#FF5722',
              1.0: '#F44336'
            }
          }).addTo(map);

          if (statusText) statusText.textContent = data.total + ' puntos con coordenadas GPS cargados.';

          // Auto-centrar en los datos (Weighted Center para enfocar zonas con más centros y problemas)
          let sumLat = 0, sumLon = 0, totalWeight = 0;
          data.puntos.forEach(function(p) {
            const w = p.peso || 1;
            sumLat += p.lat * w;
            sumLon += p.lon * w;
            totalWeight += w;
          });
          
          if (totalWeight > 0) {
            const centerLat = sumLat / totalWeight;
            const centerLon = sumLon / totalWeight;
            map.flyTo([centerLat, centerLon], 12, { duration: 1.5 });
          }
        } else {
          if (statusText) statusText.textContent = 'No hay registros con coordenadas GPS aún.';
        }
      } catch (err) {
        if (statusText) statusText.textContent = 'Error al cargar datos: ' + err.message;
      }
    }

    cargarHeatmap();

    if (refrescarBtn) {
      refrescarBtn.addEventListener('click', function() {
        cargarHeatmap();
      });
    }
  })();
</script>

<!-- Script de Alertas Push -->
<script is:inline>
  (function() {
    var formAlerta = document.getElementById('form-alerta');
    var alertaStatus = document.getElementById('alerta-status');
    var btnEnviar = document.getElementById('btn-enviar-alerta');

    if (!formAlerta) return;

    formAlerta.addEventListener('submit', function(e) {
      e.preventDefault();

      var titulo = document.getElementById('titulo-alerta').value.trim();
      var mensaje = document.getElementById('mensaje-alerta').value.trim();
      var tipo = document.getElementById('tipo-alerta').value;
      var url = document.getElementById('url-alerta').value.trim() || '/';

      if (!titulo || !mensaje) {
        mostrarEstado('❌ Título y mensaje son obligatorios.', 'text-red-600');
        return;
      }

      // Confirmación doble
      var tipoLabel = { evacuacion: 'EVACUACIÓN', replica: 'RÉPLICA / PELIGRO', info: 'INFORMACIÓN' };
      if (!confirm('¿Enviar alerta de ' + (tipoLabel[tipo] || tipo) + ' a TODOS los voluntarios suscritos?\n\nTítulo: ' + titulo + '\nMensaje: ' + mensaje)) {
        return;
      }

      btnEnviar.disabled = true;
      btnEnviar.textContent = 'Enviando...';
      mostrarEstado('Encolando alerta...', 'text-blue-600');

      fetch('/api/push-send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          titulo: titulo,
          mensaje: mensaje,
          tipo: tipo,
          url_destino: url
        })
      })
      .then(function(resp) { return resp.json().then(function(data) { return { ok: resp.ok, data: data }; }); })
      .then(function(result) {
        if (result.ok) {
          mostrarEstado('✓ ' + result.data.mensaje, 'text-green-600');
          formAlerta.reset();
          document.getElementById('url-alerta').value = '/';
        } else {
          mostrarEstado('❌ ' + (result.data.error || 'Error desconocido'), 'text-red-600');
        }
      })
      .catch(function(err) {
        mostrarEstado('❌ Error de conexión: ' + err.message, 'text-red-600');
      })
      .finally(function() {
        btnEnviar.disabled = false;
        btnEnviar.textContent = 'Enviar Alerta';
      });
    });

    function mostrarEstado(text, colorClass) {
      if (!alertaStatus) return;
      alertaStatus.textContent = text;
      alertaStatus.className = 'text-sm font-uber-text mt-3 font-medium ' + colorClass;
      alertaStatus.classList.remove('hidden');
    }
  })();
</script>
